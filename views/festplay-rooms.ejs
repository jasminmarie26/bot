<%- include("partials/start", { hideTopbar: true, pageClass: "page-roomlist" }) %>

<section class="rp-shell">
  <% const festplayRoomDisplayName = currentUserDisplayName || (currentUser ? currentUser.display_name || currentUser.username : character.name); %>
  <% const festplayRoomAccountDisplayName = currentUserAccountName || (currentUser ? currentUser.username : character.name); %>
  <% const festplayRoomIdentityRoleStyle = currentUser && currentUser.is_admin && Number(currentUser.admin_character_id) === Number(character.id)
    ? "admin"
    : currentUser && currentUser.is_moderator && Number(currentUser.moderator_character_id) === Number(character.id)
      ? "moderator"
      : (currentUserDisplayRoleStyle || ""); %>
  <% const festplayRoomIdentityName = character.name || festplayRoomDisplayName; %>
  <% const festplayRoomIdentityColor = character.chat_text_color || currentUser?.display_chat_text_color || ""; %>
  <% const festplayRoomLiveUpdatesInitialRevision = String(latestSiteUpdateRevisionToken || "").trim(); %>
  <% const festplayRoomLiveUpdatesInitialRevisions = Array.isArray(recentSiteUpdateRevisions) ? recentSiteUpdateRevisions : []; %>
  <% const festplayRoomHeaderIdentityHref = currentUser?.is_admin
    ? "/admin"
    : currentUser?.is_moderator
      ? "/staff"
      : ""; %>
  <% const festplayRoomHeaderIdentityTitle = currentUser?.is_admin
    ? "Adminbereich im neuen Tab &ouml;ffnen"
    : currentUser?.is_moderator
      ? "Moderatorenbereich im neuen Tab &ouml;ffnen"
      : festplayRoomIdentityName; %>
  <% const festplayRoomIsOwner = Number(currentUser?.id) === Number(festplay?.created_by_user_id); %>

  <header class="rp-topline">
    <a class="rp-logo" href="/">Heldenhafte Reisen</a>
    <nav class="rp-menu" aria-label="Festspiel-Raumliste Navigation">
      <a href="/dashboard/areas/<%= character.server_id %>">Bereich</a>
      <% if (festplayRoomIsOwner) { %>
        <a href="/characters/<%= character.id %>/festplays?selected_festplay=<%= festplay.id %>#festplay-selected-editor" target="_blank" rel="noopener noreferrer">Festspiel</a>
      <% } %>
      <a href="/members" target="_blank" rel="noopener noreferrer">Mitgliederliste</a>
      <a
        class="live-updates-nav-link"
        href="/live-updates"
        target="site-live-updates"
        data-live-updates-link-root
        data-live-updates-target="site-live-updates"
        data-live-updates-initial-revision="<%= festplayRoomLiveUpdatesInitialRevision %>"
        data-live-updates-initial-revisions="<%= festplayRoomLiveUpdatesInitialRevisions.join('|') %>"
      >
        <span>Live Updates</span>
        <span class="live-updates-nav-badge" data-live-updates-badge hidden>1</span>
      </a>
    </nav>
    <% if (festplayRoomHeaderIdentityHref) { %>
      <a
        class="rp-header-identity rp-header-identity-link"
        data-header-identity
        href="<%= festplayRoomHeaderIdentityHref %>"
        target="_blank"
        rel="noopener noreferrer"
        title="<%- festplayRoomHeaderIdentityTitle %>"
        style="<%= festplayRoomIdentityColor ? `color:${festplayRoomIdentityColor};` : '' %>"
      ><%= festplayRoomIdentityName %></a>
    <% } else { %>
      <span
        class="rp-header-identity"
        data-header-identity
        title="<%= festplayRoomIdentityName %>"
        style="<%= festplayRoomIdentityColor ? `color:${festplayRoomIdentityColor};` : '' %>"
      ><%= festplayRoomIdentityName %></span>
    <% } %>
    <form method="POST" action="/settings/theme" class="inline-form theme-form">
      <label for="rp-theme-select-festplay-rooms">Design</label>
      <input type="hidden" name="return_to" value="<%= currentPath || '/' %>" />
      <select
        id="rp-theme-select-festplay-rooms"
        name="theme"
        class="theme-select"
      >
        <% availableThemes.forEach((theme) => { %>
          <option value="<%= theme.id %>" <%= activeTheme === theme.id ? "selected" : "" %>>
            <%= theme.label %>
          </option>
        <% }) %>
      </select>
    </form>
    <%- include("partials/guestbook-notification-link") %>
    <details class="rp-user-menu">
      <summary
        class="rp-user-menu-toggle"
        aria-label="Benutzermen&uuml; &ouml;ffnen"
        title="Benutzermen&uuml;"
      >
        <span class="rp-user-menu-toggle-icon" aria-hidden="true">&#128100;</span>
      </summary>
      <div class="rp-user-menu-panel">
        <div class="rp-user-menu-meta">
          <strong
            class="<%= festplayRoomIdentityRoleStyle ? `role-name-${festplayRoomIdentityRoleStyle}` : '' %>"
            style="<%= festplayRoomIdentityColor ? `color:${festplayRoomIdentityColor};` : '' %>"
          ><%= festplayRoomIdentityName %></strong>
          <% if (festplayRoomAccountDisplayName && festplayRoomAccountDisplayName !== festplayRoomIdentityName) { %>
            <span>Konto: <%= festplayRoomAccountDisplayName %></span>
          <% } %>
          <span>Festspiel: <%= festplay.name %></span>
          <span>Server: <%= character.server_id === "erp" ? "ERP" : "FREE-RP" %></span>
        </div>

        <nav class="rp-user-menu-links" aria-label="Benutzermen&uuml;">
          <a href="/account">Account</a>
          <a href="/dashboard">Dashboard</a>
          <a href="/characters/<%= character.id %>">Charakter</a>
          <a href="/characters/<%= character.id %>/edit" target="_blank" rel="noopener noreferrer">Charakter editieren</a>
          <a href="/characters/<%= character.id %>/guestbook" target="_blank" rel="noopener noreferrer">G&auml;stebuch</a>
          <a href="/characters/<%= character.id %>/festplays?selected_festplay=<%= festplay.id %>#festplay-selected-editor" target="_blank" rel="noopener noreferrer">Meine Festplays</a>
          <a href="/help" target="_blank" rel="noopener noreferrer">Hilfe</a>
        </nav>

        <form method="POST" action="/logout" class="inline-form rp-user-menu-form">
          <button type="submit" class="rp-user-menu-logout">Logout</button>
        </form>
      </div>
    </details>
  </header>

  <section class="rp-room-panel rp-room-panel-create">
    <div class="rp-room-create-header">
      <div>
        <h1><%= festplay.name %></h1>
        <p class="muted">Eigene R&auml;ume nur f&uuml;r dieses Festspiel, ohne vorgefertigte Treffpunkte.</p>
      </div>
    </div>

    <section class="rp-room-section rp-room-section-standard">
      <h2 class="rp-room-form-title">Raum erstellen</h2>
      <form
        method="POST"
        action="/characters/<%= character.id %>/festplays/<%= festplay.id %>/rooms"
        class="rp-room-form rp-room-form-inline"
      >
        <div class="rp-room-input">
          <span class="rp-room-icon" aria-hidden="true">&#128172;</span>
          <input
            name="room_name"
            maxlength="80"
            placeholder="Raumname"
            required
          />
        </div>
        <input
          name="room_description"
          maxlength="160"
          placeholder="Raumbeschreibung"
        />
        <button type="submit" class="rp-enter-btn">Raum erstellen</button>
      </form>
    </section>

    <details class="rp-room-section rp-room-section-standard rp-room-accordion" open>
      <summary class="rp-room-section-summary">
        <span>Festspiel-R&auml;ume</span>
      </summary>
      <div class="rp-room-section-divider" aria-hidden="true"></div>
      <% if (!festplayRooms || !festplayRooms.length) { %>
        <p class="muted">Noch keine Festspiel-R&auml;ume vorhanden.</p>
      <% } else { %>
        <div class="rp-room-list rp-room-list-owned">
          <% festplayRooms.forEach((room) => { %>
            <% const activeUsers = Array.isArray(festplayRoomUsers?.[room.id]) ? festplayRoomUsers[room.id] : []; %>
            <div class="rp-room-standard-card rp-room-custom-card">
              <div class="rp-room-custom-titleline">
                <span
                  class="rp-room-lock-indicator<%= room.is_locked ? ' is-visible' : '' %>"
                  data-room-lock-target
                  data-room-lock-room="<%= room.id %>"
                  data-room-lock-server="<%= character.server_id %>"
                  aria-hidden="<%= room.is_locked ? 'false' : 'true' %>"
                  title="Raum ist abgeschlossen"
                ><svg class="room-lock-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path class="room-lock-fill" d="M12 3.7a4.45 4.45 0 0 0-4.45 4.45v1.92c0 .18-.06.35-.16.5l-1.31 2a1.08 1.08 0 0 0 .91 1.67h10.02a1.08 1.08 0 0 0 .91-1.67l-1.31-2c-.1-.15-.16-.32-.16-.5V8.15A4.45 4.45 0 0 0 12 3.7Z"/>
                  <path d="M8.1 10.02V8.35a3.9 3.9 0 1 1 7.8 0v1.67"/>
                  <rect x="6.35" y="10.02" width="11.3" height="9.28" rx="2.15" ry="2.15"/>
                  <path d="M12 13.15v2.8"/>
                </svg></span>
                <a
                  class="rp-room-custom-link<%= room.can_enter ? '' : ' is-disabled' %>"
                  href="<%= room.can_enter ? `/chat?room_id=${room.id}&character_id=${character.id}` : '#' %>"
                  title="<%= room.can_enter ? 'Raum betreten' : 'Raum ist abgeschlossen' %>"
                  data-room-link-target
                  data-room-link-room="<%= room.id %>"
                  data-room-link-server="<%= character.server_id %>"
                  data-room-link-url="/chat?room_id=<%= room.id %>&character_id=<%= character.id %>"
                  aria-disabled="<%= room.can_enter ? 'false' : 'true' %>"
                ><%= room.name %></a>
              </div>
              <% if (room.description) { %>
                <div class="rp-room-custom-description">
                  <%= room.description %>
                </div>
              <% } %>
              <div
                class="rp-room-occupants"
                data-room-watch-target
                data-room-watch-room="<%= room.id %>"
                data-room-watch-server="<%= character.server_id %>"
              >
                <% if (activeUsers.length) { %>
                  <% activeUsers.forEach((entry, index) => { %>
                    <% if (entry.character_id) { %>
                      <a
                        class="rp-room-occupant <%= entry.has_room_rights ? 'has-room-rights ' : '' %><%= entry.role_style ? `role-name-${entry.role_style}` : '' %>"
                        href="/characters/<%= entry.character_id %>/guestbook"
                        style="<%= entry.chat_text_color ? `color:${entry.chat_text_color};` : '' %>"
                      ><%= entry.name %></a>
                    <% } else { %>
                      <span
                        class="rp-room-occupant <%= entry.has_room_rights ? 'has-room-rights ' : '' %><%= entry.role_style ? `role-name-${entry.role_style}` : '' %>"
                        style="<%= entry.chat_text_color ? `color:${entry.chat_text_color};` : '' %>"
                      ><%= entry.name %></span>
                    <% } %>
                    <% if (index < activeUsers.length - 1) { %>
                      <span class="rp-room-occupant-separator">, </span>
                    <% } %>
                  <% }) %>
                <% } else { %>
                  <span class="muted">Gerade niemand dort.</span>
                <% } %>
              </div>
              <div class="rp-room-custom-owner">
                <%= room.is_owned_room
                  ? "Dein Festspiel-Raum."
                  : `Von ${room.creator_character_name || "Festspiel-Mitglied"}.` %>
                <% if (room.is_owned_room) { %>
                  <a href="/characters/<%= character.id %>/festplays/<%= festplay.id %>/rooms?selected_room=<%= room.id %>#festplay-room-editor">Bearbeiten</a>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </details>

    <% if (selectedRoom) { %>
      <section class="rp-room-editor" id="festplay-room-editor" aria-label="Festspiel-Raumdetails">
        <div class="rp-room-editor-bar">
          <div class="rp-room-editor-title-wrap">
            <strong class="rp-room-editor-title"><%= selectedRoom.name %></strong>
            <% if (selectedRoom.description) { %>
              <span class="rp-room-inline-teaser"> - [<%= selectedRoom.description %>]</span>
            <% } %>
          </div>
          <a
            class="rp-room-editor-enter"
            href="/chat?room_id=<%= selectedRoom.id %>&character_id=<%= character.id %>"
          >Raum betreten</a>
        </div>

        <nav class="rp-room-editor-tabs" aria-label="Festspiel-Raum bearbeiten">
          <a
            class="rp-room-editor-tab is-active"
            href="/characters/<%= character.id %>/festplays/<%= festplay.id %>/rooms?selected_room=<%= selectedRoom.id %>#festplay-room-editor"
          >&Uuml;bersicht</a>
        </nav>

        <form
          id="room-editor-form-<%= selectedRoom.id %>"
          method="POST"
          action="/characters/<%= character.id %>/festplays/<%= festplay.id %>/rooms/<%= selectedRoom.id %>/update"
          class="rp-room-editor-body"
        >
          <div class="rp-room-editor-checks">
            <label class="rp-room-editor-check">
              <input
                type="checkbox"
                name="is_locked"
                value="1"
                <%= selectedRoom.is_locked ? "checked" : "" %>
              />
              Raum abschlie&szlig;en
            </label>
            <label class="rp-room-editor-check">
              <input
                type="checkbox"
                name="email_log_enabled"
                value="1"
                <%= selectedRoom.email_log_enabled ? "checked" : "" %>
              />
              E-Mail-Log
            </label>
          </div>

          <label class="rp-room-editor-field">
            <span class="rp-room-editor-field-label">Raumname</span>
            <input
              type="text"
              name="room_name"
              maxlength="80"
              placeholder="Raumname"
              value="<%= selectedRoom.name || '' %>"
              required
            />
          </label>

          <label class="rp-room-editor-field">
            <span class="rp-room-editor-field-label">Raumbeschreibung</span>
            <input
              type="text"
              name="room_description"
              maxlength="160"
              placeholder="Kurzer Text f&uuml;r die Raumliste"
              value="<%= selectedRoom.description || '' %>"
            />
          </label>

          <label class="rp-room-editor-field">
            <span class="rp-room-editor-field-label">
              Beschreibung im Raum
              <a
                class="rp-room-editor-help-link"
                href="/help/gaestebuch-design-bbcode"
                target="_blank"
                rel="noopener noreferrer"
              >BBCode-Hilfe</a>
            </span>
            <textarea
              name="room_teaser"
              rows="9"
              maxlength="160"
              placeholder="Dieser Text erscheint direkt im Raum"
            ><%= selectedRoom.teaser || '' %></textarea>
          </label>

          <div class="rp-room-editor-actions">
            <button type="submit">Speichern</button>
          </div>
        </form>
      </section>
    <% } else if (ownedFestplayRooms && ownedFestplayRooms.length) { %>
      <section class="rp-room-editor rp-room-editor-placeholder" id="festplay-room-editor" aria-label="Festspiel-Raumdetails">
        <div class="rp-room-editor-body">
          <p class="rp-room-editor-note">Klicke oben bei den Festspiel-R&auml;umen auf <code>Bearbeiten</code>, dann wird der Raum hier ge&ouml;ffnet.</p>
        </div>
      </section>
    <% } %>
  </section>
</section>

<div
  data-server-presence="<%= character.server_id %>"
  data-active-character-id="<%= character.id %>"
  hidden
></div>
<script src="/server-presence.js?v=<%= staticAssetVersion %>"></script>

<%- include("partials/end") %>
