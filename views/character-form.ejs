<%- include("partials/start", { enableRealtime: false }) %>

<section class="panel character-form-panel">
  <div class="header-line">
    <div>
      <h1><%= mode === "create" ? "Neuer Charakter" : "Charakter bearbeiten" %></h1>
    </div>
  </div>

  <% if (error) { %>
    <div class="inline-error"><%= error %></div>
  <% } %>

  <form
    method="POST"
    action="<%= mode === "create" ? "/characters" : `/characters/${character.id}/update` %>"
    class="form"
  >
    <input type="hidden" name="server_id" value="<%= character.server_id || 'free-rp' %>" />
    <input type="hidden" name="festplay_id" value="<%= character.festplay_id || '' %>" />

    <% const isNameLocked = mode === "edit" && typeof renameAvailability !== "undefined" && renameAvailability && !renameAvailability.can_change; %>

    <label>
      Name
      <% if (isNameLocked) { %>
        <span class="gb-editor-helptext">
          Umbenennen ist nur alle 3 Monate m&ouml;glich. N&auml;chste &Auml;nderung ab <%= renameAvailability.available_at_text %>.
        </span>
      <% } %>
      <input
        name="name"
        required
        maxlength="80"
        value="<%= character.name %>"
        <%= isNameLocked ? "readonly" : "" %>
      />
    </label>

    <label>
      Chat-Farbe
      <span class="gb-editor-helptext">
        Diese Farbe wird f&uuml;r Namen und Schrift deines Charakters im Chat und in Bereichen verwendet.
      </span>

      <div class="character-color-row" data-character-color-root>
        <div class="character-color-input-wrap">
          <input
            id="character-chat-color-text"
            name="chat_text_color"
            value="<%= character.chat_text_color || '#AEE7B7' %>"
            maxlength="7"
            spellcheck="false"
            autocomplete="off"
          />
          <button
            id="character-chat-color-trigger"
            class="character-color-trigger"
            type="button"
            aria-haspopup="dialog"
            aria-expanded="false"
            aria-controls="character-chat-color-panel"
            aria-label="Chat-Farbe ausw&auml;hlen"
          >
            <span id="character-chat-color-swatch" class="character-color-trigger-swatch" aria-hidden="true"></span>
          </button>
          <span id="character-chat-color-preview" class="gb-color-preview" aria-hidden="true">Aa</span>
        </div>

        <div
          id="character-chat-color-panel"
          class="character-color-panel"
          role="dialog"
          aria-label="Chat-Farbe ausw&auml;hlen"
          hidden
        >
          <div class="character-color-panel-grid">
            <div
              id="character-chat-color-surface"
              class="character-color-surface"
              tabindex="0"
              role="slider"
              aria-label="S&auml;ttigung und Helligkeit"
              aria-valuemin="0"
              aria-valuemax="100"
            >
              <span
                id="character-chat-color-surface-handle"
                class="character-color-surface-handle"
                aria-hidden="true"
              ></span>
            </div>

            <div
              id="character-chat-color-hue"
              class="character-color-hue"
              tabindex="0"
              role="slider"
              aria-label="Farbton"
              aria-valuemin="0"
              aria-valuemax="360"
            >
              <span
                id="character-chat-color-hue-handle"
                class="character-color-hue-handle"
                aria-hidden="true"
              ></span>
            </div>
          </div>

          <div class="character-color-panel-footer">
            <span class="character-color-panel-label">Ausgew&auml;hlte Farbe</span>
            <div class="character-color-panel-current">
              <span id="character-chat-color-panel-swatch" class="character-color-panel-swatch" aria-hidden="true"></span>
              <strong id="character-chat-color-panel-value">#AEE7B7</strong>
            </div>
          </div>
        </div>
      </div>
    </label>

    <div class="character-form-actions">
      <button type="submit" class="btn">Speichern</button>
    </div>

    <% if (mode !== "create" && guestbookEditorUrl) { %>
      <div class="character-form-meta-link-row">
        <a class="character-form-meta-link" href="<%= guestbookEditorUrl %>" target="_blank" rel="noopener noreferrer">
          G&auml;stebuch-Design
        </a>
      </div>
    <% } %>
  </form>
</section>

<script>
  (() => {
    const colorRoot = document.querySelector("[data-character-color-root]");
    const colorText = document.getElementById("character-chat-color-text");
    const colorTrigger = document.getElementById("character-chat-color-trigger");
    const colorSwatch = document.getElementById("character-chat-color-swatch");
    const colorPreview = document.getElementById("character-chat-color-preview");
    const colorPanel = document.getElementById("character-chat-color-panel");
    const colorSurface = document.getElementById("character-chat-color-surface");
    const colorSurfaceHandle = document.getElementById("character-chat-color-surface-handle");
    const colorHue = document.getElementById("character-chat-color-hue");
    const colorHueHandle = document.getElementById("character-chat-color-hue-handle");
    const colorPanelSwatch = document.getElementById("character-chat-color-panel-swatch");
    const colorPanelValue = document.getElementById("character-chat-color-panel-value");

    if (
      !colorRoot ||
      !colorText ||
      !colorTrigger ||
      !colorSwatch ||
      !colorPreview ||
      !colorPanel ||
      !colorSurface ||
      !colorSurfaceHandle ||
      !colorHue ||
      !colorHueHandle ||
      !colorPanelSwatch ||
      !colorPanelValue
    ) {
      return;
    }

    let colorState = {
      h: 120,
      s: 0.24,
      v: 0.91
    };

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

    const normalizeHexColor = (value) => {
      const normalized = String(value || "").trim().toUpperCase();
      return /^#[0-9A-F]{6}$/.test(normalized) ? normalized : "";
    };

    const rgbToHex = (rgb) =>
      `#${[rgb.r, rgb.g, rgb.b]
        .map((channel) => clamp(Math.round(channel), 0, 255).toString(16).padStart(2, "0"))
        .join("")
        .toUpperCase()}`;

    const hexToRgb = (hex) => {
      const normalized = normalizeHexColor(hex) || "#AEE7B7";
      return {
        r: Number.parseInt(normalized.slice(1, 3), 16),
        g: Number.parseInt(normalized.slice(3, 5), 16),
        b: Number.parseInt(normalized.slice(5, 7), 16)
      };
    };

    const rgbToHsv = ({ r, g, b }) => {
      const red = r / 255;
      const green = g / 255;
      const blue = b / 255;
      const max = Math.max(red, green, blue);
      const min = Math.min(red, green, blue);
      const delta = max - min;

      let hue = 0;
      if (delta > 0) {
        if (max === red) {
          hue = ((green - blue) / delta) % 6;
        } else if (max === green) {
          hue = (blue - red) / delta + 2;
        } else {
          hue = (red - green) / delta + 4;
        }
      }

      hue = Math.round(hue * 60);
      if (hue < 0) hue += 360;

      return {
        h: hue,
        s: max === 0 ? 0 : delta / max,
        v: max
      };
    };

    const hsvToRgb = ({ h, s, v }) => {
      const hue = ((h % 360) + 360) % 360;
      const chroma = v * s;
      const section = hue / 60;
      const x = chroma * (1 - Math.abs((section % 2) - 1));
      let red = 0;
      let green = 0;
      let blue = 0;

      if (section >= 0 && section < 1) {
        red = chroma;
        green = x;
      } else if (section < 2) {
        red = x;
        green = chroma;
      } else if (section < 3) {
        green = chroma;
        blue = x;
      } else if (section < 4) {
        green = x;
        blue = chroma;
      } else if (section < 5) {
        red = x;
        blue = chroma;
      } else {
        red = chroma;
        blue = x;
      }

      const match = v - chroma;
      return {
        r: (red + match) * 255,
        g: (green + match) * 255,
        b: (blue + match) * 255
      };
    };

    const getHexFromState = () => rgbToHex(hsvToRgb(colorState));

    const renderColorState = ({ forceText = true } = {}) => {
      const nextColor = getHexFromState();

      if (forceText) {
        colorText.value = nextColor;
      }

      colorSwatch.style.backgroundColor = nextColor;
      colorPreview.style.color = nextColor;
      colorPanelSwatch.style.backgroundColor = nextColor;
      colorPanelValue.textContent = nextColor;

      colorSurface.style.setProperty("--character-picker-hue", String(Math.round(colorState.h)));
      colorSurface.setAttribute(
        "aria-valuetext",
        `Sättigung ${Math.round(colorState.s * 100)} Prozent, Helligkeit ${Math.round(colorState.v * 100)} Prozent`
      );
      colorSurface.setAttribute(
        "aria-valuetext",
        `Saettigung ${Math.round(colorState.s * 100)} Prozent, Helligkeit ${Math.round(colorState.v * 100)} Prozent`
      );
      colorHue.setAttribute("aria-valuenow", String(Math.round(colorState.h)));

      colorSurfaceHandle.style.left = `${colorState.s * 100}%`;
      colorSurfaceHandle.style.top = `${(1 - colorState.v) * 100}%`;
      colorHueHandle.style.top = `${(colorState.h / 360) * 100}%`;
    };

    const setStateFromHex = (value, { force = false } = {}) => {
      const normalized = normalizeHexColor(value);
      if (!normalized && !force) {
        return;
      }

      colorState = rgbToHsv(hexToRgb(normalized || "#AEE7B7"));
      renderColorState({ forceText: true });
    };

    const openColorPanel = () => {
      colorPanel.hidden = false;
      colorTrigger.setAttribute("aria-expanded", "true");
    };

    const closeColorPanel = () => {
      if (colorPanel.hidden) return;
      colorPanel.hidden = true;
      colorTrigger.setAttribute("aria-expanded", "false");
    };

    const updateSurfaceFromPointer = (event) => {
      const rect = colorSurface.getBoundingClientRect();
      colorState.s = clamp((event.clientX - rect.left) / rect.width, 0, 1);
      colorState.v = clamp(1 - (event.clientY - rect.top) / rect.height, 0, 1);
      renderColorState({ forceText: true });
    };

    const updateHueFromPointer = (event) => {
      const rect = colorHue.getBoundingClientRect();
      const nextHue = clamp((event.clientY - rect.top) / rect.height, 0, 1) * 360;
      colorState.h = nextHue >= 360 ? 359.999 : nextHue;
      renderColorState({ forceText: true });
    };

    const bindPointerDrag = (element, updateFn) => {
      element.addEventListener("pointerdown", (event) => {
        if (event.button !== 0) return;
        event.preventDefault();
        openColorPanel();
        updateFn(event);
        element.setPointerCapture(event.pointerId);

        const handlePointerMove = (moveEvent) => {
          updateFn(moveEvent);
        };

        const handlePointerEnd = () => {
          element.removeEventListener("pointermove", handlePointerMove);
          element.removeEventListener("pointerup", handlePointerEnd);
          element.removeEventListener("pointercancel", handlePointerEnd);
        };

        element.addEventListener("pointermove", handlePointerMove);
        element.addEventListener("pointerup", handlePointerEnd);
        element.addEventListener("pointercancel", handlePointerEnd);
      });
    };

    bindPointerDrag(colorSurface, updateSurfaceFromPointer);
    bindPointerDrag(colorHue, updateHueFromPointer);

    colorSurface.addEventListener("keydown", (event) => {
      const step = event.shiftKey ? 0.1 : 0.02;
      let handled = true;

      if (event.key === "ArrowLeft") {
        colorState.s = clamp(colorState.s - step, 0, 1);
      } else if (event.key === "ArrowRight") {
        colorState.s = clamp(colorState.s + step, 0, 1);
      } else if (event.key === "ArrowUp") {
        colorState.v = clamp(colorState.v + step, 0, 1);
      } else if (event.key === "ArrowDown") {
        colorState.v = clamp(colorState.v - step, 0, 1);
      } else {
        handled = false;
      }

      if (handled) {
        event.preventDefault();
        renderColorState({ forceText: true });
      }
    });

    colorHue.addEventListener("keydown", (event) => {
      const step = event.shiftKey ? 18 : 6;
      if (event.key !== "ArrowUp" && event.key !== "ArrowDown") return;
      event.preventDefault();
      colorState.h = clamp(colorState.h + (event.key === "ArrowDown" ? step : -step), 0, 359.999);
      renderColorState({ forceText: true });
    });

    setStateFromHex(colorText.value, { force: true });

    colorText.addEventListener("focus", openColorPanel);
    colorText.addEventListener("input", () => setStateFromHex(colorText.value));
    colorText.addEventListener("blur", () => setStateFromHex(colorText.value, { force: true }));

    colorTrigger.addEventListener("click", () => {
      if (colorPanel.hidden) {
        openColorPanel();
      } else {
        closeColorPanel();
      }
    });

    document.addEventListener("pointerdown", (event) => {
      if (colorRoot.contains(event.target)) {
        return;
      }
      closeColorPanel();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeColorPanel();
      }
    });
  })();
</script>

<%- include("partials/end") %>
