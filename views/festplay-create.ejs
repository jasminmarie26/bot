<%- include("partials/start", { hideTopbar: true, pageClass: "page-roomlist" }) %>

<section class="rp-shell">
  <% const festplayDisplayName = currentUserDisplayName || (currentUser ? currentUser.display_name || currentUser.username : character.name); %>
  <% const festplayAccountDisplayName = currentUserAccountName || (currentUser ? currentUser.username : character.name); %>
  <% const festplayIdentityRoleStyle = currentUser && currentUser.is_admin && Number(currentUser.admin_character_id) === Number(character.id)
    ? "admin"
    : currentUser && currentUser.is_moderator && Number(currentUser.moderator_character_id) === Number(character.id)
      ? "moderator"
      : (currentUserDisplayRoleStyle || ""); %>
  <% const festplayIdentityName = character.name || festplayDisplayName; %>
  <% const festplayIdentityColor = character.chat_text_color || currentUser?.display_chat_text_color || ""; %>
  <% const festplayLiveUpdatesInitialRevision = String(latestSiteUpdateRevisionToken || "").trim(); %>
  <% const festplayLiveUpdatesInitialRevisions = Array.isArray(recentSiteUpdateRevisions) ? recentSiteUpdateRevisions : []; %>
  <% const festplayHeaderIdentityHref = currentUser?.is_admin
    ? "/admin"
    : currentUser?.is_moderator
      ? "/staff"
      : ""; %>
  <% const festplayHeaderIdentityTitle = currentUser?.is_admin
    ? "Adminbereich im neuen Tab &ouml;ffnen"
    : currentUser?.is_moderator
      ? "Moderatorenbereich im neuen Tab &ouml;ffnen"
      : festplayIdentityName; %>

  <header class="rp-topline">
    <a class="rp-logo" href="/">Heldenhafte Reisen</a>
    <nav class="rp-menu" aria-label="Festspiel Navigation">
      <a href="<%= character.server_id === 'free-rp' || character.server_id === 'erp' ? `/dashboard/areas/${character.server_id}` : `/characters/${character.id}#roomlist` %>"><%= character.server_id === "free-rp" || character.server_id === "erp" ? "Bereich" : "Raumliste" %></a>
      <a href="/members" target="_blank" rel="noopener noreferrer">Mitglieder</a>
      <a href="/characters/<%= character.id %>/festplays/public" target="_blank" rel="noopener noreferrer">Festspiele</a>
      <a
        class="live-updates-nav-link"
        href="/live-updates"
        target="site-live-updates"
        data-live-updates-link-root
        data-live-updates-target="site-live-updates"
        data-live-updates-initial-revision="<%= festplayLiveUpdatesInitialRevision %>"
        data-live-updates-initial-revisions="<%= festplayLiveUpdatesInitialRevisions.join('|') %>"
      >
        <span>Live Updates</span>
        <span class="live-updates-nav-badge" data-live-updates-badge hidden>1</span>
      </a>
    </nav>
    <div class="rp-topline-actions">
      <% if (festplayHeaderIdentityHref) { %>
        <a
          class="rp-header-identity rp-header-identity-link"
          data-header-identity
          href="<%= festplayHeaderIdentityHref %>"
          target="_blank"
          rel="noopener noreferrer"
          title="<%- festplayHeaderIdentityTitle %>"
          style="<%= festplayIdentityColor ? `color:${festplayIdentityColor};` : '' %>"
        ><%= festplayIdentityName %></a>
      <% } else { %>
        <span
          class="rp-header-identity"
          data-header-identity
          title="<%= festplayIdentityName %>"
          style="<%= festplayIdentityColor ? `color:${festplayIdentityColor};` : '' %>"
        ><%= festplayIdentityName %></span>
      <% } %>
      <form method="POST" action="/settings/theme" class="inline-form theme-form">
        <label for="rp-theme-select-festplay-create">Design</label>
        <input type="hidden" name="return_to" value="<%= currentPath || '/' %>" />
        <select
          id="rp-theme-select-festplay-create"
          name="theme"
          class="theme-select"
        >
          <% availableThemes.forEach((theme) => { %>
            <option value="<%= theme.id %>" <%= activeTheme === theme.id ? "selected" : "" %>>
              <%= theme.label %>
            </option>
          <% }) %>
        </select>
      </form>
      <div class="rp-topline-quick-actions">
        <%- include("partials/guestbook-notification-link") %>
        <details class="rp-user-menu">
          <summary
            class="rp-user-menu-toggle"
            aria-label="Benutzermen&uuml; &ouml;ffnen"
            title="Benutzermen&uuml;"
          >
            <span class="rp-user-menu-toggle-icon" aria-hidden="true">&#128100;</span>
          </summary>
          <div class="rp-user-menu-panel">
        <div class="rp-user-menu-meta">
          <strong
            class="<%= festplayIdentityRoleStyle ? `role-name-${festplayIdentityRoleStyle}` : '' %>"
            style="<%= festplayIdentityColor ? `color:${festplayIdentityColor};` : '' %>"
          ><%= festplayIdentityName %></strong>
          <% if (festplayAccountDisplayName && festplayAccountDisplayName !== festplayIdentityName) { %>
            <span>Konto: <%= festplayAccountDisplayName %></span>
          <% } %>
          <span>Server: <%= character.server_id === "erp" ? "ERP" : "FREE-RP" %></span>
        </div>

        <nav class="rp-user-menu-links" aria-label="Benutzermen&uuml;">
          <a href="/account">Account</a>
          <a href="/dashboard">Dashboard</a>
          <a href="/characters/<%= character.id %>/edit" target="_blank" rel="noopener noreferrer">Charakter editieren</a>
          <a href="/characters/<%= character.id %>/guestbook" target="_blank" rel="noopener noreferrer">G&auml;stebuch</a>
          <a href="/help" target="_blank" rel="noopener noreferrer">Hilfe</a>
        </nav>

        <form method="POST" action="/logout" class="inline-form rp-user-menu-form">
          <button type="submit" class="rp-user-menu-logout">Logout</button>
        </form>
          </div>
        </details>
      </div>
    </div>
  </header>

  <section class="rp-room-panel rp-room-panel-create" id="festplay-create">
    <div class="rp-room-create-header">
      <% if ((!selectedFestplay && activeFestplayOverviewTab !== "andere") || (selectedFestplayMode === "owned" && activeFestplayTab === "allgemein")) { %>
        <button
          class="rp-room-create-save"
          type="submit"
          form="<%= selectedFestplay ? `festplay-editor-form-${selectedFestplay.id}` : 'festplay-create-form' %>"
        >Speichern</button>
      <% } %>
    </div>

    <nav class="rp-room-editor-tabs rp-festplay-overview-tabs" aria-label="Festspiel&uuml;bersicht">
      <a
        class="rp-room-editor-tab<%= activeFestplayOverviewTab === 'eigene' ? ' is-active' : '' %>"
        href="/characters/<%= character.id %>/festplays"
      >Eigene Festplays</a>
      <a
        class="rp-room-editor-tab<%= activeFestplayOverviewTab === 'andere' ? ' is-active' : '' %>"
        href="/characters/<%= character.id %>/festplays?overview=andere"
      >Andere Festplays</a>
    </nav>

    <section class="rp-room-editor rp-room-editor-placeholder rp-festplay-overview-panel" aria-label="Festspiel&uuml;bersicht">
      <div class="rp-room-editor-body">
        <% const visibleFestplays = activeFestplayOverviewTab === "andere" ? (otherFestplays || []) : (ownedFestplays || []); %>
        <% if (visibleFestplays.length) { %>
          <div class="rp-room-inline-list rp-festplay-overview-list">
            <% visibleFestplays.forEach((festplay) => { %>
              <a
                class="rp-room-inline-item rp-room-manage-link<%= selectedFestplay && Number(selectedFestplay.id) === Number(festplay.id) ? ' is-active' : '' %>"
                href="/characters/<%= character.id %>/festplays?overview=<%= activeFestplayOverviewTab %>&selected_festplay=<%= festplay.id %>#festplay-selected-editor"
                title="Festspiel &ouml;ffnen"
              >
                <span class="rp-room-inline-name"><%= festplay.name %></span>
                <% if (activeFestplayOverviewTab === "andere" && festplay.creator_display_name) { %>
                  <span class="rp-room-inline-teaser">von <%= festplay.creator_display_name %></span>
                <% } %>
              </a>
            <% }) %>
          </div>
        <% } else { %>
          <p class="rp-room-editor-note">
            <%= activeFestplayOverviewTab === "andere"
              ? "Du bist auf diesem Server noch in keinen Festspielen anderer Spieler eingetragen."
              : "Du hast noch keine eigenen Festspiele erstellt." %>
          </p>
        <% } %>
      </div>
    </section>

    <% if (selectedFestplayMode === "owned") { %>
      <section class="rp-room-editor" id="festplay-selected-editor" aria-label="Festspieldetails">
        <div class="rp-room-editor-bar">
          <div class="rp-room-editor-title-wrap">
            <strong class="rp-room-editor-title"><%= selectedFestplay.name %></strong>
          </div>
        </div>

        <nav class="rp-room-editor-tabs" aria-label="Festspiel bearbeiten">
          <a
            class="rp-room-editor-tab<%= activeFestplayTab === 'allgemein' ? ' is-active' : '' %>"
            href="/characters/<%= character.id %>/festplays?selected_festplay=<%= selectedFestplay.id %>#festplay-selected-editor"
          >Allgemein</a>
          <a
            class="rp-room-editor-tab<%= activeFestplayTab === 'raeume' ? ' is-active' : '' %>"
            href="/characters/<%= character.id %>/festplays?selected_festplay=<%= selectedFestplay.id %>&tab=raeume#festplay-selected-editor"
          >R&auml;ume</a>
          <a
            class="rp-room-editor-tab<%= activeFestplayTab === 'bewerbungen' ? ' is-active' : '' %>"
            href="/characters/<%= character.id %>/festplays?selected_festplay=<%= selectedFestplay.id %>&tab=bewerbungen#festplay-selected-editor"
          >Bewerbungen &amp; Spieler</a>
        </nav>

        <% if (activeFestplayTab === "bewerbungen") { %>
          <div class="rp-room-editor-body">
            <section class="rp-room-editor-section">
              <h3 class="rp-room-editor-subheading">Bewerbungen</h3>

              <% if (festplayApplications && festplayApplications.length) { %>
                <div class="rp-festplay-player-list">
                  <% festplayApplications.forEach((application) => { %>
                    <div class="rp-festplay-player-row rp-festplay-application-row">
                      <div class="rp-festplay-application-meta">
                        <strong><%= application.character_name %></strong>
                        <span>Beworben mit diesem Charakter.</span>
                      </div>
                      <form
                        method="POST"
                        action="/characters/<%= character.id %>/festplays/<%= selectedFestplay.id %>/applications/<%= application.id %>/approve"
                        class="inline-form"
                      >
                        <button type="submit">Freischalten</button>
                      </form>
                    </div>
                  <% }) %>
                </div>
              <% } else { %>
                <p class="rp-room-editor-note">Noch keine offenen Bewerbungen vorhanden.</p>
              <% } %>
            </section>

            <section class="rp-room-editor-section">
              <h3 class="rp-room-editor-subheading">Rechte</h3>
              <form
                method="POST"
                action="/characters/<%= character.id %>/festplays/<%= selectedFestplay.id %>/permissions"
                class="rp-room-editor-inline-form"
              >
                <input
                  type="text"
                  name="character_name"
                  maxlength="80"
                  placeholder="Charaktername"
                  required
                />
                <button type="submit">Hinzuf&uuml;gen</button>
              </form>

              <% if (festplayPermissionEntries && festplayPermissionEntries.length) { %>
                <div class="rp-room-editor-chip-list">
                  <% festplayPermissionEntries.forEach((entry) => { %>
                    <div class="rp-room-editor-chip-row">
                      <span class="rp-room-editor-chip-name"><%= entry.character_name %></span>
                      <form
                        method="POST"
                        action="/characters/<%= character.id %>/festplays/<%= selectedFestplay.id %>/permissions/<%= entry.id %>/delete"
                        class="inline-form rp-room-delete-form"
                      >
                        <button
                          class="rp-room-delete-btn"
                          type="submit"
                          aria-label="Recht f&uuml;r <%= entry.character_name %> entfernen"
                          title="Recht entfernen"
                        >X</button>
                      </form>
                    </div>
                  <% }) %>
                </div>
              <% } else { %>
                <p class="rp-room-editor-note">Noch keine zus&auml;tzlichen Rechte vergeben.</p>
              <% } %>
            </section>

            <section class="rp-room-editor-section">
              <h3 class="rp-room-editor-subheading">Spieler</h3>
              <div class="rp-festplay-stats">
                <div class="rp-festplay-stat">
                  <strong><%= festplayPlayerOverview?.activePlayerCount || 0 %></strong>
                  <span>Spieler gerade aktiv</span>
                </div>
                <div class="rp-festplay-stat">
                  <strong><%= festplayPlayerOverview?.activeCharacterCount || 0 %></strong>
                  <span>Charaktere gerade aktiv</span>
                </div>
                <div class="rp-festplay-stat">
                  <strong><%= festplayPlayerOverview?.playerCount || 0 %></strong>
                  <span>Mitspieler gesamt</span>
                </div>
                <div class="rp-festplay-stat">
                  <strong><%= festplayPlayerOverview?.characterCount || 0 %></strong>
                  <span>Charaktere gesamt</span>
                </div>
              </div>

              <% if (festplayPlayerOverview?.characters?.length) { %>
                <div class="rp-festplay-player-list">
                  <% festplayPlayerOverview.characters.forEach((entry) => { %>
                    <div class="rp-festplay-player-row">
                      <strong><%= entry.name %></strong>
                    </div>
                  <% }) %>
                </div>
              <% } else { %>
                <p class="rp-room-editor-note">Noch keine Charaktere diesem Festspiel zugeordnet.</p>
              <% } %>
            </section>
          </div>
        <% } else if (activeFestplayTab === "raeume") { %>
          <% const festplayRoomsBaseTarget = `/characters/${character.id}/festplays?selected_festplay=${selectedFestplay.id}&tab=raeume#festplay-selected-editor`; %>
          <% const selectedFestplayRoomTarget = selectedFestplayRoom
            ? `/characters/${character.id}/festplays?selected_festplay=${selectedFestplay.id}&tab=raeume&selected_room=${selectedFestplayRoom.id}#festplay-selected-editor`
            : festplayRoomsBaseTarget; %>
          <% const festplayRoomFormId = selectedFestplayRoom
            ? `festplay-room-editor-form-${selectedFestplayRoom.id}`
            : `festplay-room-create-form-${selectedFestplay.id}`; %>

          <div class="rp-room-editor-body">
            <section class="rp-room-editor-section">
              <h3 class="rp-room-editor-subheading">Festspiel-R&auml;ume</h3>

              <% if (festplayRooms && festplayRooms.length) { %>
                <div class="rp-room-inline-list">
                  <% festplayRooms.forEach((room) => { %>
                    <a
                      class="rp-room-inline-item rp-room-manage-link<%= selectedFestplayRoom && Number(selectedFestplayRoom.id) === Number(room.id) ? ' is-active' : '' %>"
                      href="/characters/<%= character.id %>/festplays?selected_festplay=<%= selectedFestplay.id %>&tab=raeume&selected_room=<%= room.id %>#festplay-selected-editor"
                      title="Raum &ouml;ffnen"
                    >
                      <span class="rp-room-inline-name"><%= room.name %></span>
                      <% if (room.description) { %>
                        <span class="rp-room-inline-teaser"><%= room.description %></span>
                      <% } %>
                    </a>
                  <% }) %>
                </div>
              <% } else { %>
                <p class="rp-room-editor-note">Noch keine Festspiel-R&auml;ume vorhanden.</p>
              <% } %>
            </section>

            <section class="rp-room-editor-section">
              <h3 class="rp-room-editor-subheading"><%= selectedFestplayRoom ? 'Raum bearbeiten' : 'Raum anlegen' %></h3>

              <form
                id="<%= festplayRoomFormId %>"
                method="POST"
                action="<%= selectedFestplayRoom
                  ? `/characters/${character.id}/festplays/${selectedFestplay.id}/rooms/${selectedFestplayRoom.id}/update`
                  : `/characters/${character.id}/festplays/${selectedFestplay.id}/rooms` %>"
                class="rp-room-editor-section"
              >
                <input type="hidden" name="return_to" value="<%= selectedFestplayRoomTarget %>" />

                <div class="rp-room-editor-checks">
                  <label class="rp-room-editor-check">
                    <input
                      type="checkbox"
                      name="email_log_enabled"
                      value="1"
                      <%= selectedFestplayRoom?.email_log_enabled ? "checked" : "" %>
                    />
                    Log
                  </label>
                </div>

                <label class="rp-room-editor-field">
                  <span class="rp-room-editor-field-label">Raumname</span>
                  <input
                    type="text"
                    name="room_name"
                    maxlength="80"
                    placeholder="Raumname"
                    value="<%= selectedFestplayRoom?.name || '' %>"
                    required
                  />
                </label>

                <label class="rp-room-editor-field">
                  <span class="rp-room-editor-field-label">Raumbeschreibung</span>
                  <input
                    type="text"
                    name="room_description"
                    maxlength="160"
                    placeholder="Kurzer Text für die Raumliste"
                    value="<%= selectedFestplayRoom?.description || '' %>"
                  />
                </label>

                <label class="rp-room-editor-field">
                  <span class="rp-room-editor-field-label">
                    Raum
                    <a class="rp-room-editor-help-link" href="/help/gaestebuch-design-bbcode" target="_blank" rel="noopener noreferrer">BBCode-Hilfe</a>
                  </span>
                  <textarea
                    name="room_teaser"
                    rows="10"
                    maxlength="4000"
                    placeholder="Text, der direkt im Raum angezeigt wird"
                  ><%= selectedFestplayRoom?.teaser || '' %></textarea>
                </label>
              </form>

              <div class="rp-room-editor-actions">
                <button type="submit" form="<%= festplayRoomFormId %>"><%= selectedFestplayRoom ? 'Speichern' : 'Raum anlegen' %></button>
                <% if (selectedFestplayRoom) { %>
                  <a
                    class="rp-room-editor-enter"
                    href="/chat?room_id=<%= selectedFestplayRoom.id %>&character_id=<%= character.id %>"
                  >Raum betreten</a>
                  <form
                    method="POST"
                    action="/characters/<%= character.id %>/festplays/<%= selectedFestplay.id %>/rooms/<%= selectedFestplayRoom.id %>/delete"
                    class="inline-form rp-room-delete-form"
                  >
                    <input type="hidden" name="return_to" value="<%= festplayRoomsBaseTarget %>" />
                    <button
                      class="rp-room-delete-btn"
                      type="submit"
                      aria-label="Raum <%= selectedFestplayRoom.name %> l&ouml;schen"
                      title="Raum l&ouml;schen"
                    >X</button>
                  </form>
                <% } %>
              </div>

              <% if (selectedFestplayRoomPreviewHtml) { %>
                <div class="rp-room-editor-field">
                  <span class="rp-room-editor-field-label">Vorschau</span>
                  <div class="rp-room-editor-static rp-room-editor-static-long">
                    <div class="guestbook-entry-body"><%- selectedFestplayRoomPreviewHtml %></div>
                  </div>
                </div>
              <% } %>
            </section>
          </div>
        <% } else { %>
          <form
            id="festplay-editor-form-<%= selectedFestplay.id %>"
            method="POST"
            action="/characters/<%= character.id %>/festplays/<%= selectedFestplay.id %>/update"
            class="rp-room-editor-body"
          >
            <label class="rp-room-editor-field">
              <span class="rp-room-editor-field-label">Festspielname</span>
              <input
                type="text"
                name="festplay_name"
                maxlength="80"
                placeholder="Festspielname"
                value="<%= selectedFestplay.name || '' %>"
                required
              />
            </label>

            <label class="rp-room-editor-field">
              <span class="rp-room-editor-field-label">
                Festplay Beschreibung
                <a class="rp-room-editor-help-link" href="/help/gaestebuch-design-bbcode" target="_blank" rel="noopener noreferrer">BBCode-Hilfe</a>
              </span>
              <textarea
                name="long_description"
                rows="10"
                maxlength="8000"
                placeholder="Beschreibung f&uuml;r Inhalt, Ablauf oder wichtige Hinweise"
              ><%= selectedFestplay.long_description || '' %></textarea>
            </label>

            <div class="rp-room-editor-actions">
              <button type="submit">Speichern</button>
            </div>
          </form>
        <% } %>
      </section>
    <% } else if (selectedFestplayMode === "other") { %>
      <section class="rp-room-editor" id="festplay-selected-editor" aria-label="Festspiel&uuml;bersicht">
        <div class="rp-room-editor-bar">
          <div class="rp-room-editor-title-wrap">
            <strong class="rp-room-editor-title"><%= selectedFestplay.name %></strong>
          </div>
        </div>

        <nav class="rp-room-editor-tabs" aria-label="Festspiel anzeigen">
          <span class="rp-room-editor-tab is-active">Allgemein</span>
        </nav>

        <div class="rp-room-editor-body">
          <% if (selectedFestplay.creator_display_name) { %>
            <p class="rp-room-editor-note">Erstellt mit <strong><%= selectedFestplay.creator_display_name %></strong>.</p>
          <% } %>

          <div class="rp-room-editor-field">
            <span class="rp-room-editor-field-label">Festplay Beschreibung</span>
            <div class="rp-room-editor-static rp-room-editor-static-long">
              <% if (selectedFestplay.long_description_html) { %>
                <div class="guestbook-entry-body"><%- selectedFestplay.long_description_html %></div>
              <% } else { %>
                Keine Festplay Beschreibung hinterlegt.
              <% } %>
            </div>
          </div>
        </div>
      </section>
    <% } else if (activeFestplayOverviewTab === "eigene" && ownedFestplays && ownedFestplays.length) { %>
      <section class="rp-room-editor rp-room-editor-placeholder" id="festplay-selected-editor" aria-label="Festspieldetails">
        <div class="rp-room-editor-body">
          <p class="rp-room-editor-note">Klicke oben auf ein Festspiel, dann wird es hervorgehoben und hier ge&ouml;ffnet.</p>
        </div>
      </section>
    <% } %>

    <% if (!selectedFestplay && activeFestplayOverviewTab === "eigene") { %>
      <form
        id="festplay-create-form"
        method="POST"
        action="/characters/<%= character.id %>/festplays"
        class="rp-room-form"
      >
        <div class="rp-room-input">
          <span class="rp-room-icon" aria-hidden="true">&#128172;</span>
          <input
            id="festplay_name"
            name="festplay_name"
            maxlength="80"
            placeholder="Festspielname (neu anlegen)"
            required
          />
        </div>
      </form>
    <% } %>
  </section>
</section>

<%- include("partials/end") %>
