<%- include("../../partials/start") %>

<% const isLarpView = Boolean(typeof isLarpBackupView !== "undefined" && isLarpBackupView); %>
<% const resolvedBackupReturnTarget = typeof backupReturnTarget !== "undefined" && backupReturnTarget
  ? backupReturnTarget
  : "/character-backups"; %>
<% const visibleCharacterBackups = Array.isArray(characterBackups) ? characterBackups : []; %>
<% const backupServerFilterId = isLarpView ? "larp" : ""; %>

<section class="header-line dashboard-page-header">
  <div>
    <h1>Gelöschte Charaktere</h1>
    <p class="muted">Hier kannst du gelöschte Charaktere mit Gästebuch, Farbe und Gästebucheinträgen wiederherstellen.</p>
  </div>
</section>

<% if (!isLarpView) { %>
  <nav class="rp-room-editor-tabs backup-view-tabs" aria-label="Backup Navigation">
    <a
      class="rp-room-editor-tab<%= activeTab === 'characters' ? ' is-active' : '' %>"
      href="/character-backups"
    >Charaktere</a>
    <a
      class="rp-room-editor-tab<%= activeTab === 'logs' ? ' is-active' : '' %>"
      href="/character-backups/logs"
    >Logs</a>
  </nav>
<% } %>

<section class="dashboard-block" data-character-backups-root>
  <details class="dashboard-festplay-overview dashboard-character-overview" data-character-backup-panel open>
    <summary class="dashboard-festplay-overview-header">
      <div class="dashboard-festplay-overview-title">
        <h3>Gelöschte Charaktere</h3>
        <span class="dashboard-festplay-count">(<%= visibleCharacterBackups.length %>)</span>
      </div>
      <% if (visibleCharacterBackups.length) { %>
        <div class="dashboard-character-overview-actions" data-backup-character-actions>
          <form
            method="POST"
            action="/character-backups/delete-selected"
            class="backup-bulk-delete-form"
            data-backup-delete-selected-form
          >
            <input type="hidden" name="return_to" value="<%= resolvedBackupReturnTarget %>">
            <input type="hidden" name="server_id" value="<%= backupServerFilterId %>">
            <button
              type="button"
              class="backup-character-action-btn backup-delete-selected-toggle"
              data-backup-delete-selected-toggle
              aria-label="Gel&ouml;schte Charaktere zum L&ouml;schen ausw&auml;hlen"
              aria-pressed="false"
              title="Gel&ouml;schte Charaktere zum L&ouml;schen ausw&auml;hlen"
            >
              <span class="backup-character-action-mark" aria-hidden="true"></span>
            </button>
          </form>
          <form
            method="POST"
            action="/character-backups/delete-all"
            class="backup-delete-all-form"
            data-backup-delete-all-form
            onsubmit="return confirm('Alle gel&ouml;schten Charaktere endg&uuml;ltig l&ouml;schen? Danach k&ouml;nnen sie nie wieder wiederhergestellt werden.')"
          >
            <input type="hidden" name="return_to" value="<%= resolvedBackupReturnTarget %>">
            <input type="hidden" name="server_id" value="<%= backupServerFilterId %>">
            <button
              type="submit"
              class="backup-character-action-btn backup-delete-all-btn"
              data-backup-delete-all-toggle
              data-backup-count="<%= visibleCharacterBackups.length %>"
              aria-label="Alle gel&ouml;schten Charaktere endg&uuml;ltig l&ouml;schen"
              title="Alle gel&ouml;schten Charaktere endg&uuml;ltig l&ouml;schen"
            >
              &#10003;
            </button>
          </form>
        </div>
      <% } %>
      <span class="dashboard-festplay-toggle-icon" aria-hidden="true"></span>
    </summary>

    <div class="dashboard-server-panel dashboard-character-overview-body">
      <% if (!visibleCharacterBackups.length) { %>
        <p class="muted">Noch keine gelöschten Charaktere vorhanden.</p>
      <% } else { %>
        <div class="character-mini-grid">
          <% visibleCharacterBackups.forEach((backup) => { %>
            <article class="character-mini-card" data-backup-character-card data-backup-id="<%= backup.id %>" data-backup-name="<%= backup.character_name %>">
              <label class="backup-character-select" title="<%= backup.character_name %> ausw&auml;hlen">
                <input
                  type="checkbox"
                  value="<%= backup.id %>"
                  data-backup-character-select
                  aria-label="<%= backup.character_name %> zum endg&uuml;ltigen L&ouml;schen ausw&auml;hlen"
                >
                <span class="backup-character-select-box" aria-hidden="true"></span>
              </label>
              <div class="character-mini-item">
                <span class="character-mini-name"><%= backup.character_name %></span>
              </div>
              <div class="character-mini-actions">
                <form
                  method="POST"
                  action="/character-backups/<%= backup.id %>/restore"
                  class="character-mini-move-form"
                  onsubmit="return confirm('Charakter wirklich wiederherstellen?')"
                >
                  <input type="hidden" name="return_to" value="<%= resolvedBackupReturnTarget %>">
                  <button
                    type="submit"
                    class="character-mini-move-btn"
                    aria-label="Charakter wiederherstellen"
                    title="Charakter wiederherstellen"
                  >
                    &olarr;
                  </button>
                </form>
                <form
                  method="POST"
                  action="/character-backups/<%= backup.id %>/delete"
                  class="character-mini-delete-form"
                  onsubmit="return confirm('Backup endgültig löschen? Danach kann der Charakter nie wieder wiederhergestellt werden.')"
                >
                  <input type="hidden" name="return_to" value="<%= resolvedBackupReturnTarget %>">
                  <button
                    type="submit"
                    class="character-mini-delete-btn"
                    aria-label="Backup endgültig löschen"
                    title="Backup endgültig löschen"
                  >
                    X
                  </button>
                </form>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  </details>

  <% if (isLarpView) { %>
    <details class="dashboard-festplay-overview dashboard-character-overview" open>
      <summary class="dashboard-festplay-overview-header">
        <div class="dashboard-festplay-overview-title">
          <h3>Gelöschter Account</h3>
        </div>
        <span class="dashboard-festplay-toggle-icon" aria-hidden="true"></span>
      </summary>

      <div class="dashboard-server-panel dashboard-character-overview-body">
        <p class="muted">Hier kannst du deinen gelöschten Account widerherstellen.</p>
      </div>
    </details>
  <% } %>
</section>

<%- include("../../partials/end") %>
