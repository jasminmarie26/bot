<%- include("../partials/start", { pageClass: "page-larp-profile", topbarCharacter }) %>

<%
  const hasAvatar = Boolean(String(character.avatar_url || "").trim());
  const hasCoverImage = Boolean(String(profileCoverUrl || "").trim());
  const profileInitial = String(character.name || "L").trim().charAt(0).toUpperCase() || "L";
  const normalizePercentValue = (value, fallback = 50) => {
    const numericValue = Number(value);
    if (!Number.isFinite(numericValue)) {
      return fallback;
    }

    return Math.min(100, Math.max(0, numericValue));
  };
  const avatarFocusX = normalizePercentValue(character.avatar_focus_x, 50);
  const avatarFocusY = normalizePercentValue(character.avatar_focus_y, 50);
  const avatarObjectPosition = `${avatarFocusX}% ${avatarFocusY}%`;
  const coverFocusX = normalizePercentValue(character.larp_profile_title_image_focus_x, 50);
  const coverFocusY = normalizePercentValue(character.larp_profile_title_image_focus_y, 50);
  const coverBackgroundPosition = `${coverFocusX}% ${coverFocusY}%`;
  const buildProfileLinkHref = (value) => {
    const normalizedValue = String(value || "").trim();
    if (!normalizedValue) {
      return "";
    }

    if (/^https?:\/\//i.test(normalizedValue)) {
      return normalizedValue;
    }

    if (/^[^\s]+\.[^\s]+$/i.test(normalizedValue)) {
      return `https://${normalizedValue}`;
    }

    return "";
  };
  const visibleBirthdayRows = Array.isArray(publicBirthdayRows) ? publicBirthdayRows.filter((entry) => entry && entry.label && entry.value) : [];
  const infoRows = [
    { label: "Spezies", value: character.species },
    { label: "Alter", value: character.age },
    { label: "Faceclaim", value: character.faceclaim }
  ].filter((entry) => String(entry.value || "").trim());
  const renderedProfileDescription = String(profileDescriptionHtml || "").trim();
  const selectedStarWarsLarpValues = String(character.larp_profile_star_wars_larp || "")
    .split(",")
    .map((value) => String(value || "").trim())
    .filter(Boolean);
  const personalInfoRows = [
    ...(Array.isArray(visibleBirthdayRows) ? visibleBirthdayRows : []),
    { label: "Geschlecht", value: character.larp_profile_gender },
    { label: "Wohnort", value: character.larp_profile_location },
    { label: "Beruf", value: character.larp_profile_occupation },
    { label: "Hobbys", value: character.larp_profile_hobbies }
  ].filter((entry) => String(entry?.label || "").trim() && String(entry?.value || "").trim());
  const contactRows = [
    { label: "Discord", value: character.larp_profile_discord },
    { label: "YouTube", value: character.larp_profile_youtube },
    { label: "Website", value: character.larp_profile_website, href: buildProfileLinkHref(character.larp_profile_website) },
    { label: "Instagram", value: character.larp_profile_instagram }
  ].filter((entry) => String(entry.value || "").trim());
  const larpSectionRows = [
    { label: "Charaktere", value: character.larp_profile_characters },
    { label: "Star Wars LARP", value: selectedStarWarsLarpValues.join(", ") },
    { label: "Gilde", value: character.larp_profile_guild },
    { label: "Gildenwebsite", value: character.larp_profile_guild_website, href: buildProfileLinkHref(character.larp_profile_guild_website) }
  ].filter((entry) => String(entry.value || "").trim());
  const showStats = Number(guestbookStats?.entryCount || 0) > 0 || Number(larpGuildCount || 0) > 0;
  const lastActivityLabel = lastActivity?.relativeLabel || lastActivity?.absoluteLabel || "";
  const larpCoverUploadHref = `/characters/${character.id}/larp-profile/cover-upload`;
  const larpAvatarUploadHref = `/characters/${character.id}/avatar-upload`;
  const aboutViewHref = `/characters/${character.id}#larp-profile-about`;
  const showProfileAboutPreview = !(isOwner && isEditingProfileAbout);
%>

