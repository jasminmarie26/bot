<% if (isOwner) { %>
  <div
    class="larp-profile-cover-modal"
    hidden
    data-larp-cover-modal
    data-upload-url="<%= larpCoverUploadHref %>"
    data-current-cover-url="<%= profileCoverUrl || "" %>"
  >
    <button type="button" class="larp-profile-cover-modal-backdrop" data-larp-cover-close aria-label="Fenster schließen"></button>

    <div class="larp-profile-cover-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="larp-cover-upload-title">
      <div class="larp-profile-cover-modal-header">
        <div>
          <p class="larp-profile-cover-modal-kicker">LARP Profil</p>
          <h2 id="larp-cover-upload-title">Titelbild hochladen</h2>
        </div>

        <button type="button" class="larp-profile-cover-modal-close" data-larp-cover-close aria-label="Fenster schließen">
          &times;
        </button>
      </div>

      <div class="larp-profile-cover-modal-body">
        <section class="larp-profile-cover-preview-panel">
          <div class="larp-profile-cover-preview-frame" data-larp-cover-preview>
            <span class="larp-profile-cover-preview-tag" data-larp-cover-preview-tag>Aktuelles Titelbild</span>
            <strong class="larp-profile-cover-preview-empty" data-larp-cover-preview-empty>
              Wähle ein Bild vom PC aus, damit es hier direkt als Vorschau erscheint.
            </strong>
          </div>

          <p class="larp-profile-cover-file-meta" data-larp-cover-file-meta>
            Der obere Profilbereich übernimmt dein Titelbild sofort nach dem Speichern.
          </p>
        </section>

        <section class="larp-profile-cover-upload-panel">
          <p class="larp-profile-cover-upload-copy">
            Lade dein Titelbild direkt vom PC hoch. Das Bild wird im Profil gespeichert und erscheint danach sofort oben auf deiner LARP-Seite.
          </p>

          <div class="larp-profile-cover-rule-grid">
            <div class="larp-profile-cover-rule">
              <strong>Bildgröße</strong>
              <p>Mindestens 500 x 200 Pixel</p>
            </div>
            <div class="larp-profile-cover-rule">
              <strong>Maximal</strong>
              <p>2000 x 800 Pixel</p>
            </div>
            <div class="larp-profile-cover-rule">
              <strong>Dateien</strong>
              <p>gif, jpg, jpeg, png, webp</p>
            </div>
            <div class="larp-profile-cover-rule">
              <strong>Dateigröße</strong>
              <p>Maximal 2 MB</p>
            </div>
          </div>

          <input
            type="file"
            hidden
            accept=".gif,.jpg,.jpeg,.png,.webp,image/gif,image/jpeg,image/png,image/webp"
            data-larp-cover-file-input
          />

          <div class="larp-profile-cover-upload-actions">
            <button type="button" class="larp-profile-cover-upload-button is-primary" data-larp-cover-select>
              Bild vom PC wählen
            </button>
            <button type="button" class="larp-profile-cover-upload-button is-accent" data-larp-cover-upload disabled>
              Jetzt hochladen
            </button>
          </div>

          <p class="larp-profile-cover-status" data-larp-cover-status role="status" aria-live="polite"></p>
        </section>
      </div>
    </div>
  </div>

  <script>
    (() => {
      const coverArt = document.querySelector("[data-larp-cover-art]");
      const coverTrigger = document.querySelector("[data-larp-cover-trigger]");
      const coverPrompt = document.querySelector("[data-larp-cover-prompt]");
      const modal = document.querySelector("[data-larp-cover-modal]");
      const fileInput = modal?.querySelector("[data-larp-cover-file-input]");
      const selectButton = modal?.querySelector("[data-larp-cover-select]");
      const uploadButton = modal?.querySelector("[data-larp-cover-upload]");
      const previewFrame = modal?.querySelector("[data-larp-cover-preview]");
      const previewTag = modal?.querySelector("[data-larp-cover-preview-tag]");
      const previewEmpty = modal?.querySelector("[data-larp-cover-preview-empty]");
      const fileMeta = modal?.querySelector("[data-larp-cover-file-meta]");
      const statusField = modal?.querySelector("[data-larp-cover-status]");
      const openUploadButtons = Array.from(document.querySelectorAll("[data-larp-open-upload]"));
      const closeButtons = Array.from(document.querySelectorAll("[data-larp-cover-close]"));

      if (
        !(coverArt instanceof HTMLElement) ||
        !(coverTrigger instanceof HTMLButtonElement) ||
        !(coverPrompt instanceof HTMLElement) ||
        !(modal instanceof HTMLElement) ||
        !(fileInput instanceof HTMLInputElement) ||
        !(selectButton instanceof HTMLButtonElement) ||
        !(uploadButton instanceof HTMLButtonElement) ||
        !(previewFrame instanceof HTMLElement) ||
        !(previewTag instanceof HTMLElement) ||
        !(previewEmpty instanceof HTMLElement) ||
        !(fileMeta instanceof HTMLElement) ||
        !(statusField instanceof HTMLElement)
      ) {
        return;
      }

      const allowedMimeTypes = new Set(["image/gif", "image/jpeg", "image/png", "image/webp"]);
      const maxBytes = 2 * 1024 * 1024;
      const minWidth = 500;
      const minHeight = 200;
      const maxWidth = 2000;
      const maxHeight = 800;
      const uploadUrl = String(modal.getAttribute("data-upload-url") || "").trim();
      const defaultCoverBackground = "linear-gradient(135deg, rgba(15, 60, 79, 0.9), rgba(42, 131, 170, 0.72) 48%, rgba(192, 224, 232, 0.52)), radial-gradient(circle at top right, rgba(255, 255, 255, 0.26), transparent 42%), linear-gradient(120deg, rgba(255, 255, 255, 0.08), rgba(0, 0, 0, 0.18))";
      const defaultPreviewBackground = "linear-gradient(145deg, rgba(57, 122, 152, 0.9), rgba(144, 201, 213, 0.82) 54%, rgba(244, 222, 184, 0.76)), linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0))";
      const previewOverlay = "linear-gradient(145deg, rgba(12, 31, 42, 0.22), rgba(255, 255, 255, 0.06))";
      let currentCoverUrl = String(modal.getAttribute("data-current-cover-url") || "").trim();
      let selectedFile = null;
      let selectedPreviewUrl = "";
      let selectedWidth = 0;
      let selectedHeight = 0;
      let isUploading = false;
      let lastFocusedElement = null;

      const escapeCssUrl = (value) => String(value || "").replace(/\\/g, "\\\\").replace(/"/g, "\\\"");

      const buildCoverBackground = (imageUrl) =>
        imageUrl ? `url("${escapeCssUrl(imageUrl)}")` : defaultCoverBackground;

      const buildPreviewBackground = (imageUrl) =>
        imageUrl ? `${previewOverlay}, url("${escapeCssUrl(imageUrl)}")` : defaultPreviewBackground;

      const updateMainCover = (imageUrl) => {
        coverArt.style.backgroundImage = buildCoverBackground(imageUrl);
      };

      const setStatus = (message, state = "") => {
        statusField.textContent = String(message || "");
        if (state) {
          statusField.setAttribute("data-state", state);
        } else {
          statusField.removeAttribute("data-state");
        }
      };

      const syncPreview = () => {
        const previewUrl = selectedPreviewUrl || currentCoverUrl;
        const hasPreviewImage = Boolean(previewUrl);

        previewFrame.style.backgroundImage = buildPreviewBackground(previewUrl);
        previewFrame.classList.toggle("has-image", hasPreviewImage);

        if (selectedPreviewUrl && selectedFile) {
          previewTag.textContent = "Neues Titelbild";
          previewEmpty.textContent = "Deine Auswahl ist bereit und kann jetzt hochgeladen werden.";
          fileMeta.textContent = `${selectedFile.name} • ${selectedWidth} x ${selectedHeight} Pixel`;
          uploadButton.disabled = false;
          return;
        }

        uploadButton.disabled = true;
        previewTag.textContent = hasPreviewImage ? "Aktuelles Titelbild" : "Vorschau";
        previewEmpty.textContent = hasPreviewImage
          ? "So sieht dein aktuelles Titelbild im Profil gerade aus."
          : "Wähle ein Bild vom PC aus, damit es hier direkt als Vorschau erscheint.";
        fileMeta.textContent = hasPreviewImage
          ? "Der obere Profilbereich übernimmt dein Titelbild sofort nach dem Speichern."
          : "Noch kein Titelbild gespeichert. Du kannst hier direkt eins hochladen.";
      };

      const closePrompt = () => {
        coverPrompt.hidden = true;
      };

      const openPrompt = () => {
        if (modal.hidden === false) {
          return;
        }
        coverPrompt.hidden = false;
      };

      const resetSelection = () => {
        if (selectedPreviewUrl) {
          URL.revokeObjectURL(selectedPreviewUrl);
        }
        selectedFile = null;
        selectedPreviewUrl = "";
        selectedWidth = 0;
        selectedHeight = 0;
        fileInput.value = "";
        syncPreview();
      };

      const openModal = (originElement) => {
        lastFocusedElement = originElement instanceof HTMLElement ? originElement : document.activeElement;
        closePrompt();
        modal.hidden = false;
        document.body.classList.add("larp-cover-modal-open");
        syncPreview();
        setStatus("");
        selectButton.focus();
      };

      const closeModal = () => {
        modal.hidden = true;
        document.body.classList.remove("larp-cover-modal-open");
        setStatus("");
        if (lastFocusedElement instanceof HTMLElement) {
          lastFocusedElement.focus();
        }
      };

      const readFileAsDataUrl = (file) =>
        new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve(String(reader.result || ""));
          reader.onerror = () => reject(new Error("Die Datei konnte nicht gelesen werden."));
          reader.readAsDataURL(file);
        });

      const readImageDimensions = (file) =>
        new Promise((resolve, reject) => {
          const objectUrl = URL.createObjectURL(file);
          const image = new Image();

          image.onload = () => {
            resolve({
              objectUrl,
              width: image.naturalWidth,
              height: image.naturalHeight
            });
          };

          image.onerror = () => {
            URL.revokeObjectURL(objectUrl);
            reject(new Error("Das Bild konnte nicht geöffnet werden."));
          };

          image.src = objectUrl;
        });

      const applySelectedFile = async (file) => {
        if (!file) {
          return;
        }

        if (!allowedMimeTypes.has(String(file.type || "").toLowerCase())) {
          resetSelection();
          setStatus("Erlaubt sind gif, jpg, jpeg, png und webp.", "error");
          return;
        }

        if (Number(file.size || 0) > maxBytes) {
          resetSelection();
          setStatus("Die Datei darf maximal 2 MB groß sein.", "error");
          return;
        }

        let previewData = null;
        try {
          previewData = await readImageDimensions(file);
        } catch (error) {
          resetSelection();
          setStatus(error.message || "Das Bild konnte nicht gelesen werden.", "error");
          return;
        }

        if (previewData.width < minWidth || previewData.height < minHeight) {
          URL.revokeObjectURL(previewData.objectUrl);
          resetSelection();
          setStatus(`Das Titelbild muss mindestens ${minWidth} x ${minHeight} Pixel haben.`, "error");
          return;
        }

        if (previewData.width > maxWidth || previewData.height > maxHeight) {
          URL.revokeObjectURL(previewData.objectUrl);
          resetSelection();
          setStatus(`Das Titelbild darf höchstens ${maxWidth} x ${maxHeight} Pixel haben.`, "error");
          return;
        }

        if (selectedPreviewUrl) {
          URL.revokeObjectURL(selectedPreviewUrl);
        }

        selectedFile = file;
        selectedPreviewUrl = previewData.objectUrl;
        selectedWidth = previewData.width;
        selectedHeight = previewData.height;
        syncPreview();
        setStatus(`${file.name} ist ausgewählt und bereit zum Hochladen.`, "success");
      };

      const uploadSelectedFile = async () => {
        if (isUploading || !selectedFile || !uploadUrl) {
          return;
        }

        isUploading = true;
        selectButton.disabled = true;
        uploadButton.disabled = true;
        setStatus("Titelbild wird hochgeladen...", "success");

        try {
          const dataUrl = await readFileAsDataUrl(selectedFile);
          const response = await fetch(uploadUrl, {
            method: "POST",
            credentials: "same-origin",
            headers: {
              "Content-Type": "application/json",
              "X-Requested-With": "XMLHttpRequest"
            },
            body: JSON.stringify({
              filename: selectedFile.name,
              mimeType: selectedFile.type,
              dataUrl,
              width: selectedWidth,
              height: selectedHeight
            })
          });

          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload?.ok || !payload.imageUrl) {
            throw new Error(payload?.error || "Das Titelbild konnte nicht hochgeladen werden.");
          }

          currentCoverUrl = String(payload.imageUrl || "").trim();
          modal.setAttribute("data-current-cover-url", currentCoverUrl);
          updateMainCover(currentCoverUrl);
          resetSelection();
          syncPreview();
          setStatus("Titelbild gespeichert.", "success");
          window.setTimeout(() => {
            closeModal();
          }, 220);
        } catch (error) {
          setStatus(error?.message || "Das Titelbild konnte nicht hochgeladen werden.", "error");
        } finally {
          isUploading = false;
          selectButton.disabled = false;
          syncPreview();
        }
      };

      coverTrigger.addEventListener("click", (event) => {
        event.preventDefault();
        if (coverPrompt.hidden) {
          openPrompt();
        } else {
          closePrompt();
        }
      });

      openUploadButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) {
          return;
        }

        button.addEventListener("click", (event) => {
          event.preventDefault();
          openModal(button);
        });
      });

      closeButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) {
          return;
        }

        button.addEventListener("click", (event) => {
          event.preventDefault();
          closeModal();
        });
      });

      selectButton.addEventListener("click", () => {
        fileInput.click();
      });

      fileInput.addEventListener("change", () => {
        const nextFile = fileInput.files && fileInput.files[0] ? fileInput.files[0] : null;
        void applySelectedFile(nextFile);
      });

      uploadButton.addEventListener("click", () => {
        void uploadSelectedFile();
      });

      document.addEventListener("pointerdown", (event) => {
        const target = event.target;
        if (!(target instanceof Node)) {
          return;
        }

        if (!coverPrompt.hidden && !coverPrompt.contains(target) && !coverTrigger.contains(target)) {
          closePrompt();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key !== "Escape") {
          return;
        }

        if (modal.hidden === false) {
          event.preventDefault();
          closeModal();
          return;
        }

        if (!coverPrompt.hidden) {
          event.preventDefault();
          closePrompt();
        }
      });

      updateMainCover(currentCoverUrl);
      syncPreview();
    })();
  </script>

  <script>
    (() => {
      const avatarTrigger = document.querySelector("[data-larp-avatar-trigger]");
      const avatarFileInput = document.querySelector("[data-larp-avatar-file-input]");
      const avatarImage = document.querySelector("[data-larp-avatar-image]");
      const avatarFallback = document.querySelector("[data-larp-avatar-fallback]");

      if (
        !(avatarTrigger instanceof HTMLButtonElement) ||
        !(avatarFileInput instanceof HTMLInputElement) ||
        !(avatarFallback instanceof HTMLElement)
      ) {
        return;
      }

      const uploadUrl = String(avatarFileInput.getAttribute("data-upload-url") || "").trim();
      if (!uploadUrl) {
        return;
      }

      const allowedMimeTypes = new Set(["image/gif", "image/jpeg", "image/png", "image/webp"]);
      const maxBytes = 2 * 1024 * 1024;
      const minSide = 120;
      const maxSide = 2000;
      let isUploading = false;
      let currentAvatarUrl =
        avatarImage instanceof HTMLImageElement ? String(avatarImage.getAttribute("src") || "").trim() : "";

      const setButtonState = (label, disabled) => {
        avatarTrigger.textContent = label;
        avatarTrigger.disabled = Boolean(disabled);
      };

      const readFileAsDataUrl = (file) =>
        new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve(String(reader.result || ""));
          reader.onerror = () => reject(new Error("Die Datei konnte nicht gelesen werden."));
          reader.readAsDataURL(file);
        });

      const readImageDimensions = (file) =>
        new Promise((resolve, reject) => {
          const objectUrl = URL.createObjectURL(file);
          const image = new Image();

          image.onload = () => {
            resolve({
              objectUrl,
              width: image.naturalWidth,
              height: image.naturalHeight
            });
          };

          image.onerror = () => {
            URL.revokeObjectURL(objectUrl);
            reject(new Error("Das Bild konnte nicht geöffnet werden."));
          };

          image.src = objectUrl;
        });

      const applyAvatarImage = (imageUrl) => {
        const normalizedImageUrl = String(imageUrl || "").trim();
        if (avatarImage instanceof HTMLImageElement) {
          avatarImage.hidden = !normalizedImageUrl;
          if (normalizedImageUrl) {
            avatarImage.src = normalizedImageUrl;
          }
        }

        avatarFallback.hidden = Boolean(normalizedImageUrl);
      };

      const uploadSelectedAvatar = async (file) => {
        if (!file || isUploading) {
          return;
        }

        if (!allowedMimeTypes.has(String(file.type || "").toLowerCase())) {
          window.alert("Erlaubt sind gif, jpg, jpeg, png und webp.");
          return;
        }

        if (Number(file.size || 0) > maxBytes) {
          window.alert("Die Datei darf maximal 2 MB groß sein.");
          return;
        }

        let previewData = null;
        try {
          previewData = await readImageDimensions(file);
        } catch (error) {
          window.alert(error?.message || "Das Bild konnte nicht gelesen werden.");
          return;
        }

        if (previewData.width < minSide || previewData.height < minSide) {
          URL.revokeObjectURL(previewData.objectUrl);
          window.alert(`Das Bild muss mindestens ${minSide} x ${minSide} Pixel haben.`);
          return;
        }

        if (previewData.width > maxSide || previewData.height > maxSide) {
          URL.revokeObjectURL(previewData.objectUrl);
          window.alert(`Das Bild darf höchstens ${maxSide} x ${maxSide} Pixel haben.`);
          return;
        }

        isUploading = true;
        setButtonState("Lädt...", true);

        try {
          const dataUrl = await readFileAsDataUrl(file);
          const response = await fetch(uploadUrl, {
            method: "POST",
            credentials: "same-origin",
            headers: {
              "Content-Type": "application/json",
              "X-Requested-With": "XMLHttpRequest"
            },
            body: JSON.stringify({
              filename: file.name,
              mimeType: file.type,
              dataUrl,
              width: previewData.width,
              height: previewData.height
            })
          });

          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload?.ok || !payload.imageUrl) {
            throw new Error(payload?.error || "Das Bild konnte nicht hochgeladen werden.");
          }

          const previousAvatarUrl = currentAvatarUrl;
          currentAvatarUrl = String(payload.imageUrl || "").trim();
          applyAvatarImage(currentAvatarUrl);

          if (previousAvatarUrl) {
            document.querySelectorAll("img").forEach((imageElement) => {
              if (!(imageElement instanceof HTMLImageElement)) {
                return;
              }

              if (String(imageElement.getAttribute("src") || "").trim() === previousAvatarUrl) {
                imageElement.src = currentAvatarUrl;
              }
            });
          }
        } catch (error) {
          window.alert(error?.message || "Das Bild konnte nicht hochgeladen werden.");
        } finally {
          URL.revokeObjectURL(previewData.objectUrl);
          avatarFileInput.value = "";
          isUploading = false;
          setButtonState("Bild", false);
        }
      };

      avatarTrigger.addEventListener("click", () => {
        if (!isUploading) {
          avatarFileInput.click();
        }
      });

      avatarFileInput.addEventListener("change", () => {
        const nextFile = avatarFileInput.files && avatarFileInput.files[0] ? avatarFileInput.files[0] : null;
        void uploadSelectedAvatar(nextFile);
      });
    })();
  </script>
<% } %>

<script>
  (() => {
    const backToTopButton = document.querySelector("[data-larp-back-to-top]");
    if (!(backToTopButton instanceof HTMLButtonElement)) {
      return;
    }

    const toggleBackToTopButton = () => {
      backToTopButton.classList.toggle("is-visible", window.scrollY > 320);
    };

    backToTopButton.addEventListener("click", () => {
      window.scrollTo({
        top: 0,
        behavior: "smooth"
      });
    });

    window.addEventListener("scroll", toggleBackToTopButton, { passive: true });
    toggleBackToTopButton();
  })();
</script>

<%- include("../partials/end") %>
