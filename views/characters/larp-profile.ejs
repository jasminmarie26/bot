      const loadCurrentAvatarPreview = async () => {
        resetDraftState();
        if (!currentAvatarUrl) {
          setStatus("");
          return;
        }

        isLoadingPreview = true;
        syncActionState();

        try {
          const dimensions = await loadImageDimensionsFromUrl(currentAvatarUrl);
          previewSource = {
            src: currentAvatarUrl,
            width: dimensions.width,
            height: dimensions.height,
            isObjectUrl: false
          };
          draftFocusX = currentFocusX;
          draftFocusY = currentFocusY;
          renderPreview();
        } catch (error) {
          releasePreviewSource();
          setStatus(error?.message || "Das Bild konnte nicht geladen werden.", "error");
          renderPreview();
        } finally {
          isLoadingPreview = false;
          syncActionState();
        }
      };

      const applySelectedFile = async (file) => {
        if (!file || isUploading) {
          return;
        }

        if (!allowedMimeTypes.has(String(file.type || "").toLowerCase())) {
          setStatus("Erlaubt sind gif, jpg, jpeg, png und webp.", "error");
          return;
        }

        if (Number(file.size || 0) > maxBytes) {
          setStatus("Die Datei darf maximal 2 MB groß sein.", "error");
          return;
        }

        let previewData = null;
        try {
          previewData = await readImageDimensions(file);
        } catch (error) {
          setStatus(error?.message || "Das Bild konnte nicht gelesen werden.", "error");
          return;
        }

        if (previewData.width < minSide || previewData.height < minSide) {
          URL.revokeObjectURL(previewData.objectUrl);
          setStatus(`Das Bild muss mindestens ${minSide} x ${minSide} Pixel haben.`, "error");
          return;
        }

        if (previewData.width > maxSide || previewData.height > maxSide) {
          URL.revokeObjectURL(previewData.objectUrl);
          setStatus(`Das Bild darf höchstens ${maxSide} x ${maxSide} Pixel haben.`, "error");
          return;
        }

        releasePreviewSource();
        selectedFile = file;
        previewSource = {
          src: previewData.objectUrl,
          width: previewData.width,
          height: previewData.height,
          isObjectUrl: true
        };
        draftFocusX = 50;
        draftFocusY = 50;
        setStatus(`${file.name} ist ausgewählt und kann jetzt angepasst werden.`, "success");
        renderPreview();
      };

      const openModal = (originElement) => {
        lastFocusedElement = originElement instanceof HTMLElement ? originElement : document.activeElement;
        modal.hidden = false;
        document.body.classList.add("larp-cover-modal-open");
        avatarFileInput.value = "";
        setStatus("");
        void loadCurrentAvatarPreview();
        selectButton.focus();
      };

      const closeModal = () => {
        modal.hidden = true;
        document.body.classList.remove("larp-cover-modal-open");
        avatarFileInput.value = "";
        setStatus("");
        resetDraftState();
        if (lastFocusedElement instanceof HTMLElement) {
          lastFocusedElement.focus();
        }
      };

      const saveAvatar = async () => {
        if (isUploading || isLoadingPreview) {
          return;
        }

        if (!currentAvatarUrl && !selectedFile) {
          setStatus("Bitte ein Bild vom PC auswählen.", "error");
          return;
        }

        isUploading = true;
        syncActionState();
        setStatus("Profilbild wird gespeichert...", "success");

        try {
          const requestBody = {
            focusX: draftFocusX,
            focusY: draftFocusY
          };

          if (selectedFile && previewSource.src) {
            requestBody.filename = selectedFile.name;
            requestBody.mimeType = selectedFile.type;
            requestBody.dataUrl = await readFileAsDataUrl(selectedFile);
            requestBody.width = previewSource.width;
            requestBody.height = previewSource.height;
          }

          const response = await fetch(uploadUrl, {
            method: "POST",
            credentials: "same-origin",
            headers: {
              "Content-Type": "application/json",
              "X-Requested-With": "XMLHttpRequest"
            },
            body: JSON.stringify(requestBody)
          });

          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload?.ok || !payload.imageUrl) {
            throw new Error(payload?.error || "Das Bild konnte nicht gespeichert werden.");
          }

          currentAvatarUrl = String(payload.imageUrl || "").trim();
          currentFocusX = clampPercent(payload.focusX, draftFocusX);
          currentFocusY = clampPercent(payload.focusY, draftFocusY);
          modal.setAttribute("data-current-avatar-url", currentAvatarUrl);
          modal.setAttribute("data-current-focus-x", String(currentFocusX));
          modal.setAttribute("data-current-focus-y", String(currentFocusY));
