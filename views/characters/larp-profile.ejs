          setStatus("Profilbild gespeichert.", "success");
          window.setTimeout(() => {
            closeModal();
          }, 220);
        } catch (error) {
          setStatus(error?.message || "Das Bild konnte nicht gespeichert werden.", "error");
        } finally {
          isUploading = false;
          syncActionState();
        }
      };

      avatarTrigger.addEventListener("click", () => {
        if (!isUploading) {
          openModal(avatarTrigger);
        }
      });

      selectButton.addEventListener("click", () => {
        avatarFileInput.click();
      });

      avatarFileInput.addEventListener("change", () => {
        const nextFile = avatarFileInput.files && avatarFileInput.files[0] ? avatarFileInput.files[0] : null;
        void applySelectedFile(nextFile);
      });

      saveButton.addEventListener("click", () => {
        void saveAvatar();
      });

      closeButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) {
          return;
        }

        button.addEventListener("click", (event) => {
          event.preventDefault();
          closeModal();
        });
      });

      previewStage.addEventListener("pointerdown", (event) => {
        const metrics = getPreviewMetrics();
        if (!metrics) {
          return;
        }

        const offsets = getOffsetsFromFocus(draftFocusX, draftFocusY, metrics);
        dragState = {
          pointerId: event.pointerId,
          startClientX: event.clientX,
          startClientY: event.clientY,
          startOffsetX: offsets.offsetX,
          startOffsetY: offsets.offsetY
        };
        previewStage.setPointerCapture(event.pointerId);
        previewStage.classList.add("is-dragging");
        event.preventDefault();
      });

      previewStage.addEventListener("pointermove", (event) => {
        if (!dragState || event.pointerId !== dragState.pointerId) {
          return;
        }

        const metrics = getPreviewMetrics();
        if (!metrics) {
          return;
        }

        const nextOffsetX = clampNumber(
          dragState.startOffsetX + (event.clientX - dragState.startClientX),
          metrics.minOffsetX,
          0
        );
        const nextOffsetY = clampNumber(
          dragState.startOffsetY + (event.clientY - dragState.startClientY),
          metrics.minOffsetY,
          0
        );
        const nextFocus = getFocusFromOffsets(nextOffsetX, nextOffsetY, metrics);
        draftFocusX = nextFocus.focusX;
        draftFocusY = nextFocus.focusY;
        renderPreview();
        event.preventDefault();
      });

      const stopDragging = (event) => {
        if (!dragState) {
          return;
        }

        if (event && "pointerId" in event && event.pointerId !== dragState.pointerId) {
          return;
        }

        try {
          previewStage.releasePointerCapture(dragState.pointerId);
        } catch (_error) {
          // ignore capture cleanup errors
        }

        dragState = null;
        previewStage.classList.remove("is-dragging");
        renderPreview();
      };

      previewStage.addEventListener("pointerup", stopDragging);
      previewStage.addEventListener("pointercancel", stopDragging);
      previewStage.addEventListener("lostpointercapture", () => {
        dragState = null;
        previewStage.classList.remove("is-dragging");
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && modal.hidden === false) {
          event.preventDefault();
          closeModal();
        }
      });

      window.addEventListener("resize", () => {
        if (modal.hidden === false) {
          renderPreview();
        }
      });

      applyAvatarImage(currentAvatarUrl, currentFocusX, currentFocusY);
      renderPreview();
      syncActionState();
    })();
  </script>
<% } %>

<script>
  (() => {
    const backToTopButton = document.querySelector("[data-larp-back-to-top]");
    if (!(backToTopButton instanceof HTMLButtonElement)) {
      return;
    }

    const toggleBackToTopButton = () => {
      backToTopButton.classList.toggle("is-visible", window.scrollY > 320);
    };

    backToTopButton.addEventListener("click", () => {
      window.scrollTo({
        top: 0,
        behavior: "smooth"
      });
    });

    window.addEventListener("scroll", toggleBackToTopButton, { passive: true });
    toggleBackToTopButton();
  })();
</script>

<%- include("../partials/end") %>
