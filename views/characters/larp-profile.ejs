<%- include("../partials/start", { pageClass: "page-larp-profile", topbarCharacter }) %>

<%
  const hasAvatar = Boolean(String(character.avatar_url || "").trim());
  const hasCoverImage = Boolean(String(profileCoverUrl || "").trim());
  const profileInitial = String(character.name || "L").trim().charAt(0).toUpperCase() || "L";
  const visibleBirthdayRows = Array.isArray(publicBirthdayRows) ? publicBirthdayRows.filter((entry) => entry && entry.label && entry.value) : [];
  const infoRows = [
    { label: "Spezies", value: character.species },
    { label: "Alter", value: character.age },
    { label: "Faceclaim", value: character.faceclaim }
  ].filter((entry) => String(entry.value || "").trim());
  const renderedProfileDescription = String(profileDescriptionHtml || "").trim();
  const selectedStarWarsLarpValues = String(character.larp_profile_star_wars_larp || "")
    .split(",")
    .map((value) => String(value || "").trim())
    .filter(Boolean);
  const personalInfoRows = [
    ...(Array.isArray(visibleBirthdayRows) ? visibleBirthdayRows : []),
    { label: "Geschlecht", value: character.larp_profile_gender },
    { label: "Wohnort", value: character.larp_profile_location },
    { label: "Beruf", value: character.larp_profile_occupation },
    { label: "Hobbys", value: character.larp_profile_hobbies }
  ].filter((entry) => String(entry?.label || "").trim() && String(entry?.value || "").trim());
  const contactRows = [
    { label: "Discord", value: character.larp_profile_discord },
    { label: "YouTube", value: character.larp_profile_youtube },
    { label: "Website", value: character.larp_profile_website },
    { label: "Instagram", value: character.larp_profile_instagram }
  ].filter((entry) => String(entry.value || "").trim());
  const larpSectionRows = [
    { label: "Charaktere", value: character.larp_profile_characters },
    { label: "Star Wars LARP", value: selectedStarWarsLarpValues.join(", ") },
    { label: "Gilde", value: character.larp_profile_guild },
    { label: "Gildenwebsite", value: character.larp_profile_guild_website }
  ].filter((entry) => String(entry.value || "").trim());
  const showStats = Number(guestbookStats?.entryCount || 0) > 0 || Number(larpGuildCount || 0) > 0;
  const lastActivityLabel = lastActivity?.relativeLabel || lastActivity?.absoluteLabel || "";
  const larpCoverUploadHref = `/characters/${character.id}/larp-profile/cover-upload`;
  const larpAvatarUploadHref = `/characters/${character.id}/avatar-upload`;
%>

<style>
  body.larp-cover-modal-open {
    overflow: hidden;
  }

  .larp-profile-page {
    --larp-cover-shell: color-mix(in srgb, var(--panel-bg) 84%, white 16%);
    --larp-cover-shell-edge: color-mix(in srgb, var(--panel-edge) 66%, white 34%);
    --larp-cover-ink-soft: color-mix(in srgb, var(--muted) 74%, white 26%);
    display: grid;
    gap: 1.15rem;
  }

  .larp-profile-hero {
    position: relative;
    overflow: hidden;
    padding: 0;
  }

  .larp-profile-cover-stage {
    position: relative;
    border-radius: inherit;
  }

  .larp-profile-cover-art {
    min-height: 290px;
    background:
      linear-gradient(135deg, rgba(15, 60, 79, 0.9), rgba(42, 131, 170, 0.72) 48%, rgba(192, 224, 232, 0.52)),
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.26), transparent 42%),
      linear-gradient(120deg, rgba(255, 255, 255, 0.08), rgba(0, 0, 0, 0.18));
    background-size: cover;
    background-position: center;
    border-radius: inherit;
  }

  .larp-profile-cover-art.is-editable {
    cursor: pointer;
    transition: filter 180ms ease, transform 180ms ease;
  }

  .larp-profile-cover-art.is-editable:hover,
  .larp-profile-cover-art.is-editable:focus-visible {
    filter: brightness(1.05);
  }

  .larp-profile-cover-hit-area {
    position: absolute;
    inset: 0;
    z-index: 1;
    border: 0;
    padding: 0;
    background: transparent;
    border-radius: inherit;
    cursor: pointer;
  }

  .larp-profile-cover-hit-area:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.9);
    outline-offset: -8px;
  }

  .larp-profile-cover-edit {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 1rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--panel-edge) 54%, white 46%);
    background: color-mix(in srgb, var(--panel-bg) 72%, white 28%);
    color: var(--text);
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 16px 28px -24px rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .larp-profile-cover-edit:hover,
  .larp-profile-cover-edit:focus-visible {
    background: color-mix(in srgb, var(--panel-bg) 58%, white 42%);
    text-decoration: none;
  }

  .larp-profile-cover-prompt {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    z-index: 2;
    width: min(360px, calc(100% - 2rem));
    padding: 1rem 1.05rem 1.05rem;
    border-radius: 24px;
    border: 1px solid color-mix(in srgb, #9cc8b5 42%, white 58%);
    background:
      linear-gradient(135deg, rgba(248, 239, 219, 0.92), rgba(176, 214, 188, 0.85) 56%, rgba(119, 177, 191, 0.76)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0));
    color: #1f2f30;
    box-shadow: 0 24px 44px -28px rgba(3, 22, 29, 0.72);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .larp-profile-cover-prompt-title {
    display: inline-block;
    margin-bottom: 0.35rem;
    color: rgba(31, 47, 48, 0.68);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .larp-profile-cover-prompt p {
    margin: 0 0 0.9rem;
    line-height: 1.55;
  }

  .larp-profile-cover-prompt-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 1.05rem;
    border: 0;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(45, 107, 143, 0.96), rgba(22, 63, 110, 0.96));
    color: #f7fbff;
    font-weight: 700;
    box-shadow: 0 18px 32px -26px rgba(12, 37, 54, 0.9);
  }

  .larp-profile-cover-prompt-action:hover,
  .larp-profile-cover-prompt-action:focus-visible {
    filter: brightness(1.06);
  }

  .larp-profile-identity {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1.2rem;
    align-items: end;
    margin-top: -76px;
    padding: 0 1.4rem 1.4rem;
  }

  .larp-profile-avatar-wrap {
    position: relative;
    width: 150px;
    min-width: 150px;
    height: 150px;
  }

  .larp-profile-avatar-upload {
    position: absolute;
    top: 6px;
    right: -8px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 34px;
    padding: 0 0.75rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--panel-edge) 54%, white 46%);
    background: color-mix(in srgb, var(--panel-bg) 74%, white 26%);
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 700;
    box-shadow: 0 14px 26px -20px rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .larp-profile-avatar-upload:hover,
  .larp-profile-avatar-upload:focus-visible {
    background: color-mix(in srgb, var(--panel-bg) 58%, white 42%);
  }

  .larp-profile-avatar,
  .larp-profile-avatar-fallback {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 4px solid rgba(255, 255, 255, 0.88);
    box-shadow: 0 20px 40px -28px rgba(0, 0, 0, 0.6);
    background: linear-gradient(145deg, rgba(250, 252, 255, 0.95), rgba(196, 214, 225, 0.9));
  }

  .larp-profile-avatar {
    object-fit: cover;
    display: block;
  }

  .larp-profile-avatar-fallback {
    display: grid;
    place-items: center;
    color: color-mix(in srgb, var(--text) 70%, white 30%);
    font-size: 3.2rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .larp-profile-status {
    position: absolute;
    left: 8px;
    bottom: 8px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 3px solid rgba(255, 255, 255, 0.92);
    background: color-mix(in srgb, var(--muted) 78%, white 22%);
    box-shadow: 0 10px 18px -14px rgba(0, 0, 0, 0.8);
  }

  .larp-profile-status.is-online {
    background: #51cf66;
  }

  .larp-profile-copy {
    display: grid;
    gap: 0.55rem;
    padding-top: 1.2rem;
  }

  .larp-profile-name-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem;
  }

  .larp-profile-name-row h1 {
    margin: 0;
    font-size: clamp(2rem, 3vw, 2.7rem);
    line-height: 1.02;
  }

  .larp-profile-meta {
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.5;
  }

  .larp-profile-meta strong {
    color: var(--text);
  }

  .larp-profile-meta-location {
    color: var(--text);
  }

  .larp-profile-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    padding-top: 0.25rem;
  }

  .larp-profile-stat {
    display: inline-flex;
    gap: 0.35rem;
    align-items: baseline;
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--panel-bg) 84%, white 16%);
    border: 1px solid color-mix(in srgb, var(--panel-edge) 72%, white 28%);
    color: var(--muted);
    font-size: 0.95rem;
  }

  .larp-profile-stat strong {
    color: var(--text);
  }

  .larp-profile-content {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.92fr);
    gap: 1rem;
    align-items: start;
  }

  .larp-profile-card {
    display: grid;
    gap: 1rem;
  }

  .larp-profile-card h2 {
    margin: 0;
  }

  .larp-profile-tab-card {
    align-content: start;
  }

  .larp-profile-tab-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1.1rem;
  }

  .larp-profile-tab-item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
    padding: 0.15rem 0;
    border: 0;
    background: transparent;
    color: var(--text);
    font-size: 0.95rem;
    font-weight: 650;
    line-height: 1.25;
    text-decoration: none;
    white-space: nowrap;
  }

  .larp-profile-tab-item:hover,
  .larp-profile-tab-item:focus-visible,
  .larp-profile-tab-item.is-active {
    color: color-mix(in srgb, var(--text) 82%, var(--accent) 18%);
    text-decoration: underline;
    text-underline-offset: 0.22em;
  }

  .larp-profile-description {
    margin: 0;
    line-height: 1.65;
    font-size: 1rem;
  }

  .larp-profile-description > :first-child {
    margin-top: 0;
  }

  .larp-profile-description > :last-child {
    margin-bottom: 0;
  }

  .larp-profile-detail-grid,
  .larp-profile-note-list,
  .larp-profile-cover-rule-grid {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }

  .larp-profile-detail-grid {
    grid-template-columns: minmax(0, 1fr);
  }

  .larp-profile-detail-item,
  .larp-profile-note,
  .larp-profile-cover-rule {
    padding: 0.95rem 1rem;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--panel-edge) 78%, transparent 22%);
    background: color-mix(in srgb, var(--panel-bg) 88%, white 12%);
  }

  .larp-profile-detail-item span,
  .larp-profile-note strong,
  .larp-profile-cover-rule strong {
    display: block;
    margin-bottom: 0.25rem;
  }

  .larp-profile-detail-item span {
    color: var(--muted);
    font-size: 0.88rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .larp-profile-detail-item strong,
  .larp-profile-note p,
  .larp-profile-cover-rule p {
    margin: 0;
    overflow-wrap: anywhere;
  }

  .larp-profile-note p,
  .larp-profile-cover-rule p {
    color: var(--muted);
    line-height: 1.55;
  }

  .larp-profile-section-stack,
  .larp-profile-edit-stack {
    display: grid;
    gap: 1rem;
  }

  .larp-profile-section-block,
  .larp-profile-edit-section {
    display: grid;
    gap: 0.85rem;
    padding: 1rem;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--panel-edge) 78%, transparent 22%);
    background: color-mix(in srgb, var(--panel-bg) 88%, white 12%);
  }

  .larp-profile-section-block h3,
  .larp-profile-edit-section h3 {
    margin: 0;
    font-size: 1rem;
  }

  .larp-profile-edit-grid {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: minmax(0, 1fr);
  }

  .larp-profile-edit-field {
    display: grid;
    gap: 0.35rem;
    align-content: start;
  }

  .larp-profile-edit-wide {
    grid-column: 1 / -1;
  }

  .larp-profile-edit-grid select[multiple] {
    min-height: 5.5rem;
  }

  .larp-profile-choice-list,
  .larp-profile-edit-field .account-birthday-visibility-options {
    display: grid;
    gap: 0.55rem;
    justify-items: start;
  }

  .larp-profile-cover-modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: grid;
    place-items: center;
    height: 100dvh;
    padding: 0.8rem;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .larp-profile-cover-modal[hidden] {
    display: none;
  }

  .larp-profile-cover-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(7, 17, 22, 0.58);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .larp-profile-cover-modal-dialog {
    position: relative;
    z-index: 1;
    width: min(760px, 100%);
    max-height: min(680px, calc(100dvh - 1.6rem));
    border-radius: 24px;
    overflow: auto;
    overscroll-behavior: contain;
    border: 1px solid color-mix(in srgb, var(--panel-edge) 54%, white 46%);
    background:
      linear-gradient(155deg, rgba(238, 228, 208, 0.96), rgba(186, 220, 215, 0.88) 42%, rgba(153, 206, 224, 0.86) 100%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0));
    box-shadow: 0 40px 90px -52px rgba(0, 0, 0, 0.72);
  }

  .larp-profile-cover-modal-header {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: flex-start;
    padding: 0.9rem 1rem 0.7rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.32);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0.08));
    position: sticky;
    top: 0;
    z-index: 2;
  }

  .larp-profile-cover-modal-kicker {
    margin: 0 0 0.28rem;
    color: rgba(33, 49, 54, 0.62);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .larp-profile-cover-modal-header h2 {
    margin: 0;
    font-size: clamp(1.25rem, 2.2vw, 1.7rem);
    line-height: 1.1;
  }

  .larp-profile-cover-modal-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    min-width: 36px;
    height: 36px;
    border: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.34);
    color: #2b4651;
    font-size: 1.5rem;
    font-weight: 700;
  }

  .larp-profile-cover-modal-close:hover,
  .larp-profile-cover-modal-close:focus-visible {
    background: rgba(255, 255, 255, 0.48);
  }

  .larp-profile-cover-modal-body {
    display: grid;
    grid-template-columns: minmax(0, 0.98fr) minmax(270px, 1.02fr);
    gap: 0.75rem;
    padding: 0.85rem 1rem 1rem;
  }

  .larp-profile-cover-preview-panel,
  .larp-profile-cover-upload-panel {
    display: grid;
    gap: 0.65rem;
    align-content: start;
    padding: 0.75rem;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.34);
    background: rgba(255, 255, 255, 0.22);
  }

  .larp-profile-cover-preview-panel {
    background:
      linear-gradient(160deg, rgba(22, 45, 59, 0.14), rgba(255, 255, 255, 0.12)),
      rgba(255, 255, 255, 0.18);
  }

  .larp-profile-cover-preview-frame {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 185px;
    padding: 0.85rem;
    border-radius: 18px;
    background:
      linear-gradient(145deg, rgba(57, 122, 152, 0.9), rgba(144, 201, 213, 0.82) 54%, rgba(244, 222, 184, 0.76)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0));
    background-size: cover;
    background-position: center;
    overflow: hidden;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.12);
  }

  .larp-profile-cover-preview-frame.has-image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(6, 18, 25, 0.12), rgba(6, 18, 25, 0.54));
  }

  .larp-profile-cover-preview-tag,
  .larp-profile-cover-preview-empty {
    position: relative;
    z-index: 1;
  }

  .larp-profile-cover-preview-tag {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0.1rem 0.65rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    color: #21404b;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .larp-profile-cover-preview-empty {
    margin-top: auto;
    color: rgba(248, 252, 255, 0.96);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.4;
    text-shadow: 0 6px 18px rgba(7, 17, 24, 0.42);
  }

  .larp-profile-cover-file-meta {
    margin: 0;
    color: var(--larp-cover-ink-soft);
    line-height: 1.4;
  }

  .larp-profile-cover-upload-panel p {
    margin: 0;
  }

  .larp-profile-cover-upload-copy {
    line-height: 1.45;
    color: rgba(31, 47, 48, 0.84);
  }

  .larp-profile-cover-upload-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .larp-profile-cover-upload-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 0.85rem;
    border: 0;
    border-radius: 999px;
    font-weight: 700;
    box-shadow: 0 16px 28px -24px rgba(13, 27, 34, 0.78);
  }

  .larp-profile-cover-upload-button.is-primary {
    background: linear-gradient(135deg, rgba(54, 113, 180, 0.96), rgba(25, 68, 125, 0.96));
    color: #f8fbff;
  }

  .larp-profile-cover-upload-button.is-accent {
    background: linear-gradient(135deg, rgba(182, 216, 123, 0.96), rgba(242, 208, 163, 0.94));
    color: #213126;
  }

  .larp-profile-cover-upload-button:hover,
  .larp-profile-cover-upload-button:focus-visible {
    filter: brightness(1.04);
  }

  .larp-profile-cover-upload-button[disabled] {
    opacity: 0.56;
    cursor: not-allowed;
    filter: saturate(0.45);
    box-shadow: none;
  }

  .larp-profile-cover-status {
    min-height: 1.2rem;
    font-weight: 600;
  }

  .larp-profile-cover-rule-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .larp-profile-cover-rule {
    padding: 0.7rem 0.75rem;
    border-radius: 14px;
  }

  .larp-profile-cover-rule p {
    line-height: 1.35;
  }

  .larp-profile-cover-status[data-state="error"] {
    color: #b6453b;
  }

  .larp-profile-cover-status[data-state="success"] {
    color: #247f58;
  }

  .larp-profile-back-to-top {
    position: fixed;
    right: clamp(0.85rem, 1.5vw, 1.2rem);
    bottom: clamp(0.85rem, 2vw, 1.25rem);
    z-index: 120;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    min-width: 44px;
    height: 44px;
    border: 1px solid color-mix(in srgb, var(--panel-edge) 66%, white 34%);
    border-radius: 8px;
    background: color-mix(in srgb, var(--panel-bg) 88%, white 12%);
    color: color-mix(in srgb, var(--text) 88%, white 12%);
    box-shadow: 0 18px 36px -24px rgba(0, 0, 0, 0.72);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(10px);
    transition:
      opacity 160ms ease,
      visibility 160ms ease,
      transform 160ms ease,
      background 160ms ease,
      border-color 160ms ease;
  }

  .larp-profile-back-to-top.is-visible {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .larp-profile-back-to-top:hover,
  .larp-profile-back-to-top:focus-visible {
    background: color-mix(in srgb, var(--field-bg) 76%, white 24%);
    border-color: color-mix(in srgb, var(--accent) 48%, var(--panel-edge) 52%);
  }

  .larp-profile-back-to-top svg {
    width: 1.2rem;
    height: 1.2rem;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 980px) {
    .larp-profile-identity,
    .larp-profile-content,
    .larp-profile-cover-modal-body {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .larp-profile-cover-art {
      min-height: 220px;
    }

    .larp-profile-identity {
      margin-top: -52px;
      padding: 0 1rem 1rem;
      gap: 0.9rem;
    }

    .larp-profile-avatar-wrap {
      width: 112px;
      min-width: 112px;
      height: 112px;
    }

    .larp-profile-avatar-fallback {
      font-size: 2.2rem;
    }

    .larp-profile-cover-edit {
      top: 0.8rem;
      right: 0.8rem;
      min-height: 38px;
      padding: 0 0.85rem;
      font-size: 0.92rem;
    }

    .larp-profile-cover-prompt {
      left: 0.8rem;
      right: 0.8rem;
      bottom: 0.8rem;
      width: auto;
    }

    .larp-profile-cover-modal {
      padding: 0.8rem;
    }

    .larp-profile-cover-modal-header,
    .larp-profile-cover-modal-body {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
</style>

<%- include("../partials/larp-navigation", {
  activeLarpNavLabel: "Home",
  larpNavCompact: true,
  larpNavCharacter: character
}) %>

<section class="larp-profile-page" id="larp-profile-top">
  <section class="panel larp-profile-hero">
    <div class="larp-profile-cover-stage">
      <div
        class="larp-profile-cover-art<%= isOwner ? " is-editable" : "" %>"
        data-larp-cover-art
        <% if (hasCoverImage) { %>
          style="background-image: url('<%= profileCoverUrl %>');"
        <% } %>
      ></div>

      <% if (isOwner) { %>
        <button type="button" class="larp-profile-cover-hit-area" data-larp-cover-trigger aria-label="Titelbild bearbeiten"></button>

        <button type="button" class="larp-profile-cover-edit" data-larp-open-upload>
