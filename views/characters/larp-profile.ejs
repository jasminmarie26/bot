<%- include("../partials/start", { pageClass: "page-larp-profile", topbarCharacter }) %>

<%
  const hasAvatar = Boolean(String(character.avatar_url || "").trim());
  const hasCoverImage = Boolean(String(profileCoverUrl || "").trim());
  const profileInitial = String(character.name || "L").trim().charAt(0).toUpperCase() || "L";
  const visibleBirthdayRows = Array.isArray(publicBirthdayRows) ? publicBirthdayRows.filter((entry) => entry && entry.label && entry.value) : [];
  const infoRows = [
    { label: "Spezies", value: character.species },
    { label: "Alter", value: character.age },
    { label: "Faceclaim", value: character.faceclaim }
  ].filter((entry) => String(entry.value || "").trim());
  const showStats = Number(guestbookStats?.entryCount || 0) > 0 || Number(larpGuildCount || 0) > 0;
  const lastActivityLabel = lastActivity?.relativeLabel || lastActivity?.absoluteLabel || "";
%>

<style>
  .larp-profile-page {
    display: grid;
    gap: 1.15rem;
  }

  .larp-profile-hero {
    position: relative;
    overflow: hidden;
    padding: 0;
  }

  .larp-profile-cover-art {
    min-height: 290px;
    background:
      linear-gradient(135deg, rgba(15, 60, 79, 0.9), rgba(42, 131, 170, 0.72) 48%, rgba(192, 224, 232, 0.52)),
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.26), transparent 42%),
      linear-gradient(120deg, rgba(255, 255, 255, 0.08), rgba(0, 0, 0, 0.18));
    background-size: cover;
    background-position: center;
    border-radius: inherit;
  }

  .larp-profile-cover-edit {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 1rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--panel-edge) 54%, white 46%);
    background: color-mix(in srgb, var(--panel-bg) 72%, white 28%);
    color: var(--text);
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 16px 28px -24px rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .larp-profile-cover-edit:hover,
  .larp-profile-cover-edit:focus-visible {
    background: color-mix(in srgb, var(--panel-bg) 58%, white 42%);
    text-decoration: none;
  }

  .larp-profile-identity {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1.2rem;
    align-items: end;
    margin-top: -76px;
    padding: 0 1.4rem 1.4rem;
  }

  .larp-profile-avatar-wrap {
    position: relative;
    width: 150px;
    min-width: 150px;
    height: 150px;
  }

  .larp-profile-avatar,
  .larp-profile-avatar-fallback {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 4px solid rgba(255, 255, 255, 0.88);
    box-shadow: 0 20px 40px -28px rgba(0, 0, 0, 0.6);
    background: linear-gradient(145deg, rgba(250, 252, 255, 0.95), rgba(196, 214, 225, 0.9));
  }

  .larp-profile-avatar {
    object-fit: cover;
    display: block;
  }

  .larp-profile-avatar-fallback {
    display: grid;
    place-items: center;
    color: color-mix(in srgb, var(--text) 70%, white 30%);
    font-size: 3.2rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .larp-profile-status {
    position: absolute;
    left: 8px;
    bottom: 8px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 3px solid rgba(255, 255, 255, 0.92);
    background: color-mix(in srgb, var(--muted) 78%, white 22%);
    box-shadow: 0 10px 18px -14px rgba(0, 0, 0, 0.8);
  }

  .larp-profile-status.is-online {
    background: #51cf66;
  }

  .larp-profile-copy {
    display: grid;
    gap: 0.55rem;
    padding-top: 1.2rem;
  }

  .larp-profile-name-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem;
  }

  .larp-profile-name-row h1 {
    margin: 0;
    font-size: clamp(2rem, 3vw, 2.7rem);
    line-height: 1.02;
  }

  .larp-profile-meta {
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.5;
  }

  .larp-profile-meta strong {
    color: var(--text);
  }

  .larp-profile-meta-location {
    color: var(--text);
  }

  .larp-profile-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    padding-top: 0.25rem;
  }

  .larp-profile-stat {
    display: inline-flex;
    gap: 0.35rem;
    align-items: baseline;
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--panel-bg) 84%, white 16%);
    border: 1px solid color-mix(in srgb, var(--panel-edge) 72%, white 28%);
    color: var(--muted);
    font-size: 0.95rem;
  }

  .larp-profile-stat strong {
    color: var(--text);
  }

  .larp-profile-content {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.92fr);
    gap: 1rem;
  }

  .larp-profile-card {
    display: grid;
    gap: 1rem;
  }

  .larp-profile-card h2 {
    margin: 0;
  }

  .larp-profile-description {
    margin: 0;
    line-height: 1.65;
    font-size: 1rem;
  }

  .larp-profile-detail-grid,
  .larp-profile-note-list {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }

  .larp-profile-detail-item,
  .larp-profile-note {
    padding: 0.95rem 1rem;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--panel-edge) 78%, transparent 22%);
    background: color-mix(in srgb, var(--panel-bg) 88%, white 12%);
  }

  .larp-profile-detail-item span,
  .larp-profile-note strong {
    display: block;
    margin-bottom: 0.25rem;
  }

  .larp-profile-detail-item span {
    color: var(--muted);
    font-size: 0.88rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .larp-profile-detail-item strong,
  .larp-profile-note p {
    margin: 0;
  }

  .larp-profile-note p {
    color: var(--muted);
    line-height: 1.55;
  }

  @media (max-width: 980px) {
    .larp-profile-identity,
    .larp-profile-content {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .larp-profile-cover-art {
      min-height: 220px;
    }

    .larp-profile-identity {
      margin-top: -52px;
      padding: 0 1rem 1rem;
      gap: 0.9rem;
    }

    .larp-profile-avatar-wrap {
      width: 112px;
      min-width: 112px;
      height: 112px;
    }

    .larp-profile-avatar-fallback {
      font-size: 2.2rem;
    }

    .larp-profile-cover-edit {
      top: 0.8rem;
      right: 0.8rem;
      min-height: 38px;
      padding: 0 0.85rem;
      font-size: 0.92rem;
    }
  }
</style>

<section class="larp-profile-page">
  <section class="panel larp-profile-hero">
    <div
      class="larp-profile-cover-art"
      <% if (hasCoverImage) { %>
        style="background-image: linear-gradient(135deg, rgba(15, 60, 79, 0.9), rgba(42, 131, 170, 0.58) 48%, rgba(192, 224, 232, 0.35)), url('<%= profileCoverUrl %>');"
      <% } %>
    ></div>

    <% if (isOwner) { %>
      <a class="larp-profile-cover-edit" href="<%= profileEditHref %>#larp-profile-banner-url">
        Titelbild bearbeiten
      </a>
    <% } %>

    <div class="larp-profile-identity">
      <div class="larp-profile-avatar-wrap" aria-hidden="true">
        <% if (hasAvatar) { %>
          <img class="larp-profile-avatar" src="<%= character.avatar_url %>" alt="" />
        <% } else { %>
          <div class="larp-profile-avatar-fallback"><%= profileInitial %></div>
        <% } %>
        <span class="larp-profile-status<%= isCharacterOnline ? " is-online" : "" %>"></span>
      </div>

      <div class="larp-profile-copy">
        <div class="larp-profile-name-row">
          <h1><%= character.name %></h1>
        </div>

        <p class="larp-profile-meta">
          Mitglied seit <strong><%= memberSinceLabel || "-" %></strong>
        </p>

        <p class="larp-profile-meta">
          Letzte Aktivit&auml;t:
          <% if (lastActivity?.hasValue) { %>
            <strong><%= lastActivityLabel %></strong>
            <% if (lastActivity?.absoluteLabel && lastActivity?.relativeLabel && lastActivity.absoluteLabel !== lastActivity.relativeLabel) { %>
              <span>(<%= lastActivity.absoluteLabel %>)</span>
            <% } %>
            <% if (lastActivity?.locationLabel) { %>
              <span class="larp-profile-meta-location">
                <%= lastActivity.isLive ? "gerade in" : "zuletzt in" %>
                <strong><%= lastActivity.locationLabel %></strong>
              </span>
            <% } %>
          <% } else { %>
            <span>Noch keine LARP-Aktivit&auml;t gespeichert.</span>
          <% } %>
        </p>

        <% if (showStats) { %>
          <div class="larp-profile-stats" aria-label="Profilstatistik">
            <% if (Number(guestbookStats?.entryCount || 0) > 0) { %>
              <span class="larp-profile-stat">Eintr&auml;ge <strong><%= guestbookStats.entryCount %></strong></span>
            <% } %>
            <% if (Number(larpGuildCount || 0) > 0) { %>
              <span class="larp-profile-stat">Gilden <strong><%= larpGuildCount %></strong></span>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </section>

  <div class="larp-profile-content">
    <section class="panel larp-profile-card">
      <div class="header-line">
        <div>
          <h2>&Uuml;ber mich</h2>
          <p class="muted">Hier landen die Angaben, die direkt zu deinem LARP-Profil geh&ouml;ren.</p>
        </div>
      </div>

      <% if (String(character.description || "").trim()) { %>
        <p class="larp-profile-description pre-line"><%= character.description %></p>
      <% } else { %>
        <p class="muted">Noch keine Beschreibung hinterlegt.</p>
      <% } %>

      <% if (infoRows.length || visibleBirthdayRows.length) { %>
        <div class="larp-profile-detail-grid">
          <% infoRows.forEach((entry) => { %>
            <div class="larp-profile-detail-item">
              <span><%= entry.label %></span>
              <strong><%= entry.value %></strong>
            </div>
          <% }) %>
          <% visibleBirthdayRows.forEach((entry) => { %>
            <div class="larp-profile-detail-item">
              <span><%= entry.label %></span>
              <strong><%= entry.value %></strong>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>

    <section class="panel larp-profile-card">
      <div class="header-line">
        <div>
          <h2>Bereich</h2>
          <p class="muted">Die Profilseite bleibt bewusst sauber, bis weitere LARP-Module fertig sind.</p>
        </div>
      </div>

      <div class="larp-profile-note-list">
        <div class="larp-profile-note">
          <strong>Titelbild</strong>
          <p>Das Titelbild l&auml;sst sich direkt &uuml;ber die Profilbearbeitung setzen oder austauschen.</p>
        </div>
        <div class="larp-profile-note">
          <strong>Letzte Aktivit&auml;t</strong>
          <p>Hier siehst du, wann zuletzt etwas im LARP-Bereich passiert ist und wo du zuletzt unterwegs warst.</p>
        </div>
        <div class="larp-profile-note">
          <strong>Beitr&auml;ge, Termine und mehr</strong>
          <p>Diese Bereiche blenden wir erst ein, sobald sie im LARP wirklich aktiv sind. So bleibt die Seite ohne graue Platzhalter.</p>
        </div>
      </div>
    </section>
  </div>
</section>

<%- include("../partials/end") %>
