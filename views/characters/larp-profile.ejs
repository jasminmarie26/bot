        </button>

        <div class="larp-profile-cover-prompt" hidden data-larp-cover-prompt>
          <span class="larp-profile-cover-prompt-title">Titelbild</span>
          <p>Klick hier, um dein Titelbild direkt vom PC auszuwählen und oben im Profil zu speichern.</p>
          <button type="button" class="larp-profile-cover-prompt-action" data-larp-open-upload>
            Titelbild bearbeiten
          </button>
        </div>
      <% } %>
    </div>

    <div class="larp-profile-identity">
      <div class="larp-profile-avatar-wrap">
        <img
          class="larp-profile-avatar"
          src="<%= hasAvatar ? character.avatar_url : "" %>"
          alt=""
          <%= hasAvatar ? "" : "hidden" %>
          data-larp-avatar-image
        />
        <div class="larp-profile-avatar-fallback" <%= hasAvatar ? "hidden" : "" %> data-larp-avatar-fallback><%= profileInitial %></div>
        <% if (isOwner) { %>
          <button type="button" class="larp-profile-avatar-upload" data-larp-avatar-trigger>Bild</button>
          <input
            type="file"
            hidden
            accept=".gif,.jpg,.jpeg,.png,.webp,image/gif,image/jpeg,image/png,image/webp"
            data-larp-avatar-file-input
            data-upload-url="<%= larpAvatarUploadHref %>"
          />
