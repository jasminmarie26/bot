    overflow: hidden;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.12);
    touch-action: none;
    user-select: none;
  }

  .larp-profile-cover-editor-stage.is-draggable {
    cursor: grab;
  }

  .larp-profile-cover-editor-stage.is-dragging {
    cursor: grabbing;
  }

  .larp-profile-cover-editor-image {
    position: absolute;
    top: 0;
    left: 0;
    display: block;
    max-width: none;
    max-height: none;
    pointer-events: none;
    user-select: none;
    will-change: transform;
  }

  .larp-profile-cover-editor-fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 1rem;
    text-align: center;
    color: rgba(248, 252, 255, 0.96);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.45;
    text-shadow: 0 6px 18px rgba(7, 17, 24, 0.42);
  }

  .larp-profile-cover-upload-panel p {
    margin: 0;
  }

  .larp-profile-cover-upload-copy {
    line-height: 1.45;
    color: #31474f;
    font-weight: 600;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.24);
  }

  .larp-profile-cover-upload-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .larp-profile-cover-upload-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 0.85rem;
    border: 0;
    border-radius: 999px;
    font-weight: 700;
    box-shadow: 0 16px 28px -24px rgba(13, 27, 34, 0.78);
  }

  .larp-profile-cover-upload-button.is-primary {
    background: linear-gradient(135deg, rgba(54, 113, 180, 0.96), rgba(25, 68, 125, 0.96));
    color: #f8fbff;
  }

  .larp-profile-cover-upload-button.is-accent {
    background: linear-gradient(135deg, rgba(182, 216, 123, 0.96), rgba(242, 208, 163, 0.94));
    color: #213126;
  }

  .larp-profile-cover-upload-button.is-secondary {
    border: 1px solid rgba(255, 255, 255, 0.42);
    background: rgba(255, 255, 255, 0.38);
    color: #27414b;
  }

  .larp-profile-cover-upload-button:hover,
  .larp-profile-cover-upload-button:focus-visible {
    filter: brightness(1.04);
  }

  .larp-profile-cover-upload-button[disabled] {
    opacity: 0.56;
    cursor: not-allowed;
    filter: saturate(0.45);
    box-shadow: none;
  }

  .larp-profile-cover-status {
    min-height: 1.2rem;
    font-weight: 600;
  }

  .larp-profile-cover-status[data-state="error"] {
    color: #b6453b;
  }

  .larp-profile-cover-status[data-state="success"] {
    color: #247f58;
  }

  .larp-profile-cover-file-meta {
    margin: 0;
    color: #31474f;
    font-weight: 600;
    line-height: 1.4;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.24);
  }

  .larp-profile-back-to-top {
    position: fixed;
    right: clamp(0.85rem, 1.5vw, 1.2rem);
    bottom: clamp(0.85rem, 2vw, 1.25rem);
    z-index: 120;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    min-width: 44px;
    height: 44px;
    border: 1px solid color-mix(in srgb, var(--panel-edge) 66%, white 34%);
    border-radius: 8px;
    background: color-mix(in srgb, var(--panel-bg) 88%, white 12%);
    color: color-mix(in srgb, var(--text) 88%, white 12%);
    box-shadow: 0 18px 36px -24px rgba(0, 0, 0, 0.72);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(10px);
    transition:
      opacity 160ms ease,
      visibility 160ms ease,
      transform 160ms ease,
      background 160ms ease,
      border-color 160ms ease;
  }

  .larp-profile-back-to-top.is-visible {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .larp-profile-back-to-top:hover,
  .larp-profile-back-to-top:focus-visible {
    background: color-mix(in srgb, var(--field-bg) 76%, white 24%);
    border-color: color-mix(in srgb, var(--accent) 48%, var(--panel-edge) 52%);
  }

  .larp-profile-back-to-top svg {
    width: 1.2rem;
    height: 1.2rem;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 980px) {
    .larp-profile-identity,
    .larp-profile-content,
    .larp-profile-cover-modal-body {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .larp-profile-cover-art {
      min-height: 220px;
    }

    .larp-profile-identity {
      margin-top: -52px;
      padding: 0 1rem 1rem;
      gap: 0.9rem;
    }

    .larp-profile-avatar-wrap {
      width: 112px;
      min-width: 112px;
      height: 112px;
    }

    .larp-profile-avatar-fallback {
      font-size: 2.2rem;
    }

    .larp-profile-cover-edit {
      top: 0.8rem;
      right: 0.8rem;
      min-height: 38px;
      padding: 0 0.85rem;
      font-size: 0.92rem;
    }

    .larp-profile-cover-prompt {
      left: 0.8rem;
      right: 0.8rem;
      bottom: 0.8rem;
      width: auto;
    }

    .larp-profile-cover-modal {
      padding: calc(var(--topbar-bottom-offset, 72px) + 0.6rem) 0.6rem 0.6rem;
    }

    .larp-profile-cover-modal-header,
    .larp-profile-cover-modal-body {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
</style>

<%- include("../partials/larp-navigation", {
  activeLarpNavLabel: "Home",
  larpNavCompact: true,
  larpNavCharacter: typeof larpNavCharacter !== "undefined" && larpNavCharacter ? larpNavCharacter : character
}) %>

<section class="larp-profile-page" id="larp-profile-top">
  <section class="panel larp-profile-hero">
    <div class="larp-profile-cover-stage">
      <div
        class="larp-profile-cover-art<%= isOwner ? " is-editable" : "" %>"
        data-larp-cover-art
        <% if (hasCoverImage) { %>
          style="background-image: url('<%= profileCoverUrl %>'); background-position: <%= coverBackgroundPosition %>;"
        <% } %>
      ></div>

      <% if (isOwner) { %>
        <button type="button" class="larp-profile-cover-hit-area" data-larp-cover-trigger aria-label="Titelbild bearbeiten"></button>

        <button type="button" class="larp-profile-cover-edit" data-larp-open-upload aria-label="Titelbild bearbeiten">
          <span aria-hidden="true">&#9998;</span>
        </button>

        <div class="larp-profile-cover-prompt" hidden data-larp-cover-prompt>
          <span class="larp-profile-cover-prompt-title">Titelbild</span>
          <p>Klick hier, um dein Titelbild direkt vom PC auszuwählen und oben im Profil zu speichern.</p>
          <button type="button" class="larp-profile-cover-prompt-action" data-larp-open-upload aria-label="Titelbild bearbeiten">
            <span aria-hidden="true">&#9998;</span>
          </button>
        </div>
      <% } %>
    </div>

    <div class="larp-profile-identity">
      <div class="larp-profile-avatar-wrap">
        <img
          class="larp-profile-avatar"
          src="<%= hasAvatar ? character.avatar_url : "" %>"
          alt=""
          style="object-position: <%= avatarObjectPosition %>;"
          <%= hasAvatar ? "" : "hidden" %>
          data-larp-avatar-image
          data-character-avatar-image
          data-avatar-focus-x="<%= avatarFocusX %>"
          data-avatar-focus-y="<%= avatarFocusY %>"
        />
        <div class="larp-profile-avatar-fallback" <%= hasAvatar ? "hidden" : "" %> data-larp-avatar-fallback><%= profileInitial %></div>
        <% if (isOwner) { %>
          <button type="button" class="larp-profile-avatar-upload" data-larp-avatar-trigger aria-label="Profilbild bearbeiten">
            <span aria-hidden="true">&#9998;</span>
          </button>
        <% } %>
      </div>

      <div class="larp-profile-copy">
        <div class="larp-profile-name-row">
          <h1><%= character.name %></h1>
        </div>

        <p class="larp-profile-meta">
          Mitglied seit <strong><%= memberSinceLabel || "-" %></strong>
        </p>

        <p class="larp-profile-meta">
          Letzte Aktivität:
          <% if (lastActivity?.hasValue) { %>
            <strong><%= lastActivityLabel %></strong>
            <% if (lastActivity?.absoluteLabel && lastActivity?.relativeLabel && lastActivity.absoluteLabel !== lastActivity.relativeLabel) { %>
              <span>(<%= lastActivity.absoluteLabel %>)</span>
            <% } %>
            <% if (lastActivity?.locationLabel) { %>
              <span class="larp-profile-meta-location">
                <%= lastActivity.isLive ? "gerade in" : "zuletzt in" %>
                <strong><%= lastActivity.locationLabel %></strong>
              </span>
            <% } %>
          <% } else { %>
            <span>Noch keine LARP-Aktivität gespeichert.</span>
          <% } %>
        </p>

        <% if (showStats) { %>
          <div class="larp-profile-stats" aria-label="Profilstatistik">
            <% if (Number(guestbookStats?.entryCount || 0) > 0) { %>
              <span class="larp-profile-stat">Einträge <strong><%= guestbookStats.entryCount %></strong></span>
            <% } %>
            <% if (Number(larpGuildCount || 0) > 0) { %>
              <span class="larp-profile-stat">Gilden <strong><%= larpGuildCount %></strong></span>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </section>

  <div class="larp-profile-content">
    <section class="panel larp-profile-card" id="larp-profile-about">
      <div class="header-line">
        <div>
          <h2>Über mich</h2>
        </div>
      </div>

      <% if (isOwner && isEditingProfileAbout) { %>
        <form method="POST" action="<%= profileAboutSaveHref %>" class="form">
          <div class="larp-profile-edit-stack">
            <%- include("../partials/bbcode-editor", {
              bbcodeEditorWrapperClass: "gb-editor-row-content",
              bbcodeEditorFieldId: "larp-profile-description-editor",
              bbcodeEditorFieldName: "description",
              bbcodeEditorFieldValue: character.description || "",
              bbcodeEditorFieldLabel: "&Uuml;ber mich",
              bbcodeEditorRows: 12,
              bbcodeEditorMaxLength: 12000
            }) %>

            <section class="larp-profile-edit-section" aria-labelledby="larp-profile-personal-heading">
              <h3 id="larp-profile-personal-heading">Pers&ouml;nliche Informationen</h3>

              <div class="larp-profile-edit-grid">
                <label class="larp-profile-edit-field">
                  <span>Geburtstag</span>
                  <input
                    name="birth_date"
                    type="date"
                    value="<%= accountBirthDate || "" %>"
                  />
                </label>

                <div class="larp-profile-edit-field">
                  <span>Geburtstag im Profil anzeigen</span>
                  <div class="account-birthday-visibility-options">
                    <label class="checkbox account-table-checkbox">
                      <input
                        name="public_birth_show_day_month"
                        type="checkbox"
                        value="1"
                        <%= Number(character.public_birth_show_day_month) === 1 || Number(character.public_birth_show_year) === 1 ? "checked" : "" %>
                      />
                      <span>Tag und Monat</span>
                    </label>
                  </div>
                </div>

                <div class="larp-profile-edit-field">
                  <span>Jahr dazu anzeigen</span>
                  <label class="checkbox account-table-checkbox">
                    <input
                      name="public_birth_show_year"
                      type="checkbox"
                      value="1"
                      <%= Number(character.public_birth_show_year) === 1 ? "checked" : "" %>
                    />
                    <span>Ja</span>
                  </label>
                </div>

                <label class="larp-profile-edit-field larp-profile-edit-wide">
                  <span>Geschlecht</span>
                  <select name="larp_profile_gender">
                    <option value="">Keine Angabe</option>
                    <% (larpProfileGenderOptions || []).forEach((option) => { %>
                      <option value="<%= option %>" <%= String(character.larp_profile_gender || "") === option ? "selected" : "" %>><%= option %></option>
                    <% }) %>
                  </select>
                </label>

                <label class="larp-profile-edit-field larp-profile-edit-wide">
                  <span>Wohnort</span>
                  <input
                    name="larp_profile_location"
                    maxlength="120"
                    value="<%= character.larp_profile_location || "" %>"
                  />
                </label>

                <label class="larp-profile-edit-field larp-profile-edit-wide">
                  <span>Beruf</span>
                  <input
                    name="larp_profile_occupation"
                    maxlength="120"
                    value="<%= character.larp_profile_occupation || "" %>"
                  />
                </label>

                <label class="larp-profile-edit-field larp-profile-edit-wide">
                  <span>Hobbys</span>
                  <input
                    name="larp_profile_hobbies"
                    maxlength="240"
                    value="<%= character.larp_profile_hobbies || "" %>"
                  />
                </label>
              </div>
            </section>

            <section class="larp-profile-edit-section" aria-labelledby="larp-profile-contact-heading">
              <h3 id="larp-profile-contact-heading">Kontaktm&ouml;glichkeiten</h3>

              <div class="larp-profile-edit-grid">
                <label class="larp-profile-edit-field larp-profile-edit-wide">
                  <span>Discord</span>
                  <input
                    name="larp_profile_discord"
                    maxlength="120"
                    value="<%= character.larp_profile_discord || "" %>"
                  />
                </label>

                <label class="larp-profile-edit-field larp-profile-edit-wide">
                  <span>YouTube</span>
                  <input
                    name="larp_profile_youtube"
                    type="text"
                    inputmode="url"
                    maxlength="500"
                    value="<%= character.larp_profile_youtube || "" %>"
                  />
                </label>

                <label class="larp-profile-edit-field larp-profile-edit-wide">
                  <span>Website</span>
                  <input
                    name="larp_profile_website"
                    type="text"
                    inputmode="url"
                    maxlength="500"
                    value="<%= character.larp_profile_website || "" %>"
                  />
                </label>

                <label class="larp-profile-edit-field larp-profile-edit-wide">
                  <span>Instagram</span>
                  <input
                    name="larp_profile_instagram"
                    maxlength="120"
                    value="<%= character.larp_profile_instagram || "" %>"
                  />
                </label>
              </div>
            </section>

            <section class="larp-profile-edit-section" aria-labelledby="larp-profile-own-larp-heading">
              <h3 id="larp-profile-own-larp-heading">DEIN LARP</h3>

              <div class="larp-profile-edit-grid">
                <label class="larp-profile-edit-field larp-profile-edit-wide">
                  <span>Charaktere</span>
                  <input
                    name="larp_profile_characters"
                    maxlength="500"
                    value="<%= character.larp_profile_characters || "" %>"
                  />
                  <span class="gb-editor-helptext">Eine Liste der Charaktere. Charakterdatenbl&auml;tter bitte in der Datenbank speichern.</span>
                </label>

                <label class="larp-profile-edit-field larp-profile-edit-wide">
                  <span>Star Wars LARP</span>
                  <div class="larp-profile-choice-list">
                    <% (larpProfileStarWarsLarpOptions || []).forEach((option) => { %>
                      <label class="checkbox account-table-checkbox">
                        <input
                          name="larp_profile_star_wars_larp"
                          type="checkbox"
                          value="<%= option %>"
                          <%= selectedStarWarsLarpValues.includes(option) ? "checked" : "" %>
                        />
                        <span><%= option %></span>
                      </label>
                    <% }) %>
                  </div>
                  <span class="gb-editor-helptext">Wenn nichts angehakt ist, wird dort auch nichts angezeigt.</span>
                </label>

                <label class="larp-profile-edit-field larp-profile-edit-wide">
                  <span>Gilde</span>
                  <input
                    name="larp_profile_guild"
                    maxlength="120"
                    value="<%= character.larp_profile_guild || "" %>"
                  />
                </label>

                <label class="larp-profile-edit-field larp-profile-edit-wide">
                  <span>Gildenwebsite</span>
                  <input
                    name="larp_profile_guild_website"
                    type="text"
                    inputmode="url"
                    maxlength="500"
                    value="<%= character.larp_profile_guild_website || "" %>"
                  />
                </label>
              </div>
            </section>
          </div>

          <div class="character-form-actions">
            <button type="submit" class="btn">Speichern</button>
            <a class="btn btn-secondary" href="/characters/<%= character.id %>#larp-profile-about">Zur&uuml;ck</a>
          </div>
        </form>
      <% } else if (renderedProfileDescription) { %>
        <div class="larp-profile-description"><%- renderedProfileDescription %></div>
      <% } else { %>
        <p class="muted">Noch keine Beschreibung hinterlegt.</p>
      <% } %>

      <% if (showProfileAboutPreview && infoRows.length) { %>
        <div class="larp-profile-detail-grid">
          <% infoRows.forEach((entry) => { %>
            <div class="larp-profile-detail-item">
              <span><%= entry.label %></span>
              <strong><%= entry.value %></strong>
            </div>
          <% }) %>
        </div>
      <% } %>

      <% if (showProfileAboutPreview && (personalInfoRows.length || contactRows.length || larpSectionRows.length)) { %>
        <div class="larp-profile-section-stack">
          <% if (personalInfoRows.length) { %>
            <section class="larp-profile-section-block" aria-labelledby="larp-profile-personal-view-heading">
              <h3 id="larp-profile-personal-view-heading">Pers&ouml;nliche Informationen</h3>
              <div class="larp-profile-detail-grid">
                <% personalInfoRows.forEach((entry) => { %>
                  <div class="larp-profile-detail-item">
                    <span><%= entry.label %></span>
                    <strong><%= entry.value %></strong>
                  </div>
                <% }) %>
              </div>
            </section>
          <% } %>

          <% if (contactRows.length) { %>
            <section class="larp-profile-section-block" aria-labelledby="larp-profile-contact-view-heading">
              <h3 id="larp-profile-contact-view-heading">Kontaktm&ouml;glichkeiten</h3>
              <div class="larp-profile-detail-grid">
                <% contactRows.forEach((entry) => { %>
                  <div class="larp-profile-detail-item">
                    <span><%= entry.label %></span>
                    <strong>
                      <% if (entry.href) { %>
                        <a href="<%= entry.href %>" rel="noopener noreferrer"><%= entry.value %></a>
                      <% } else { %>
                        <%= entry.value %>
                      <% } %>
                    </strong>
                  </div>
                <% }) %>
              </div>
            </section>
          <% } %>

          <% if (larpSectionRows.length) { %>
            <section class="larp-profile-section-block" aria-labelledby="larp-profile-own-larp-view-heading">
              <h3 id="larp-profile-own-larp-view-heading">DEIN LARP</h3>
              <div class="larp-profile-detail-grid">
                <% larpSectionRows.forEach((entry) => { %>
                  <div class="larp-profile-detail-item">
                    <span><%= entry.label %></span>
                    <strong>
                      <% if (entry.href) { %>
                        <a href="<%= entry.href %>" rel="noopener noreferrer"><%= entry.value %></a>
                      <% } else { %>
                        <%= entry.value %>
                      <% } %>
                    </strong>
                  </div>
                <% }) %>
              </div>
            </section>
          <% } %>
        </div>
      <% } %>
    </section>

    <section class="panel larp-profile-card larp-profile-tab-card" id="larp-profile-tabs" aria-label="Profilbereiche">
      <div class="larp-profile-tab-row">
        <a class="larp-profile-tab-item is-active" href="<%= isEditingProfileAbout ? aboutViewHref : "#larp-profile-about" %>">Über mich</a>
        <a class="larp-profile-tab-item" href="#larp-profile-tabs">Letzte Aktivitäten</a>
        <a class="larp-profile-tab-item" href="#larp-profile-tabs">Pinnwand</a>
        <a class="larp-profile-tab-item" href="#larp-profile-tabs">Reaktionen</a>
      </div>
    </section>
  </div>
</section>

<button type="button" class="larp-profile-back-to-top" data-larp-back-to-top aria-label="Ganz nach oben">
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <path d="M12 18V6"></path>
    <path d="m6.5 11.5 5.5-5.5 5.5 5.5"></path>
  </svg>
</button>

<% if (isOwner) { %>
  <div
    class="larp-profile-cover-modal"
    hidden
    data-larp-avatar-modal
    data-upload-url="<%= larpAvatarUploadHref %>"
    data-current-avatar-url="<%= hasAvatar ? character.avatar_url : "" %>"
    data-current-focus-x="<%= avatarFocusX %>"
    data-current-focus-y="<%= avatarFocusY %>"
  >
    <button type="button" class="larp-profile-cover-modal-backdrop" data-larp-avatar-close aria-label="Fenster schließen"></button>

    <div class="larp-profile-cover-modal-dialog larp-profile-avatar-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="larp-avatar-upload-title">
      <div class="larp-profile-cover-modal-header">
        <div>
          <p class="larp-profile-cover-modal-kicker">LARP Profil</p>
          <h2 id="larp-avatar-upload-title">Profilbild anpassen</h2>
        </div>

        <button type="button" class="larp-profile-cover-modal-close" data-larp-avatar-close aria-label="Fenster schließen">
          X
        </button>
      </div>

      <div class="larp-profile-avatar-modal-body">
        <section class="larp-profile-avatar-preview-panel">
          <div class="larp-profile-avatar-preview-stage" data-larp-avatar-preview-stage>
            <img class="larp-profile-avatar-preview-image" alt="" hidden data-larp-avatar-preview-image />
            <div class="larp-profile-avatar-preview-fallback" data-larp-avatar-preview-fallback><%= profileInitial %></div>
          </div>

          <p class="larp-profile-avatar-preview-help">Zieh dein Bild im Kreis, damit der Ausschnitt genau so sitzt, wie du ihn haben willst.</p>
          <p class="larp-profile-avatar-file-meta" data-larp-avatar-file-meta>Dein gespeicherter Ausschnitt wird danach überall für das runde Profilbild benutzt.</p>
        </section>

        <input
          type="file"
          hidden
          accept=".gif,.jpg,.jpeg,.png,.webp,image/gif,image/jpeg,image/png,image/webp"
          data-larp-avatar-source-input
        />

        <div class="larp-profile-avatar-upload-actions">
          <button type="button" class="larp-profile-cover-upload-button is-primary" data-larp-avatar-select>Bild vom PC wählen</button>
          <button type="button" class="larp-profile-cover-upload-button is-accent" data-larp-avatar-save>Speichern</button>
          <button type="button" class="larp-profile-cover-upload-button is-secondary" data-larp-avatar-close>Abbrechen</button>
        </div>

        <p class="larp-profile-avatar-status" data-larp-avatar-status role="status" aria-live="polite"></p>
      </div>
    </div>
  </div>

  <div
    class="larp-profile-cover-modal"
    hidden
    data-larp-cover-modal
    data-upload-url="<%= larpCoverUploadHref %>"
    data-current-cover-url="<%= profileCoverUrl || "" %>"
    data-current-focus-x="<%= coverFocusX %>"
    data-current-focus-y="<%= coverFocusY %>"
  >
    <button type="button" class="larp-profile-cover-modal-backdrop" data-larp-cover-close aria-label="Fenster schließen"></button>

    <div class="larp-profile-cover-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="larp-cover-upload-title">
      <div class="larp-profile-cover-modal-header">
        <div>
          <p class="larp-profile-cover-modal-kicker">LARP Profil</p>
          <h2 id="larp-cover-upload-title">Titelbild hochladen</h2>
        </div>

        <button type="button" class="larp-profile-cover-modal-close" data-larp-cover-close aria-label="Fenster schließen">
          X
        </button>
      </div>

      <div class="larp-profile-cover-modal-body">
        <section class="larp-profile-cover-preview-panel">
          <div class="larp-profile-cover-preview-frame" data-larp-cover-preview>
            <span class="larp-profile-cover-preview-tag" data-larp-cover-preview-tag>Aktuelles Titelbild</span>
            <strong class="larp-profile-cover-preview-empty" data-larp-cover-preview-empty>
              Wähle ein Bild vom PC aus, damit es hier direkt als Vorschau erscheint.
            </strong>
          </div>

          <p class="larp-profile-cover-file-meta" data-larp-cover-file-meta>
            Der obere Profilbereich übernimmt dein Titelbild sofort nach dem Speichern.
          </p>
        </section>

        <section class="larp-profile-cover-upload-panel">
          <div class="larp-profile-cover-editor-stage" data-larp-cover-editor-stage>
            <img class="larp-profile-cover-editor-image" alt="" hidden data-larp-cover-editor-image />
            <div class="larp-profile-cover-editor-fallback" data-larp-cover-editor-fallback>
              WÃ¤hle ein Bild vom PC aus und zieh es danach direkt passend im Titelbereich zurecht.
            </div>
          </div>

          <p class="larp-profile-cover-upload-copy">
            Die Bildgröße wird automatisch passend eingepasst. Zieh dein Titelbild danach im Ausschnitt so hin, wie es oben im Profil sitzen soll.
          </p>

          <p class="larp-profile-cover-file-meta" data-larp-cover-file-meta-visible>
            Dein gespeicherter Ausschnitt erscheint danach direkt oben auf deiner LARP-Seite.
          </p>

          <div class="larp-profile-cover-rule-grid">
            <div class="larp-profile-cover-rule">
              <strong>Bildgröße</strong>
              <p>Wird automatisch passend eingepasst</p>
            </div>
            <div class="larp-profile-cover-rule">
              <strong>Dateigröße</strong>
              <p>Maximal 2 MB</p>
            </div>
            <div class="larp-profile-cover-rule">
              <strong>Dateien</strong>
              <p>gif, jpg, jpeg, png, webp</p>
            </div>
            <div class="larp-profile-cover-rule">
              <strong>Dateigröße</strong>
              <p>Maximal 2 MB</p>
            </div>
          </div>

          <input
            type="file"
            hidden
            accept=".gif,.jpg,.jpeg,.png,.webp,image/gif,image/jpeg,image/png,image/webp"
            data-larp-cover-file-input
          />

          <div class="larp-profile-cover-upload-actions">
            <button type="button" class="larp-profile-cover-upload-button is-primary" data-larp-cover-select>
              Bild vom PC wählen
            </button>
            <button type="button" class="larp-profile-cover-upload-button is-accent" data-larp-cover-upload>
              Speichern
            </button>
          </div>

          <p class="larp-profile-cover-status" data-larp-cover-status role="status" aria-live="polite"></p>
        </section>
      </div>
    </div>
  </div>

  <script>
    (() => {
      const coverArt = document.querySelector("[data-larp-cover-art]");
      const coverTrigger = document.querySelector("[data-larp-cover-trigger]");
      const coverPrompt = document.querySelector("[data-larp-cover-prompt]");
      const modal = document.querySelector("[data-larp-cover-modal]");
      const fileInput = modal?.querySelector("[data-larp-cover-file-input]");
      const selectButton = modal?.querySelector("[data-larp-cover-select]");
      const uploadButton = modal?.querySelector("[data-larp-cover-upload]");
      const previewFrame = modal?.querySelector("[data-larp-cover-preview]");
      const previewTag = modal?.querySelector("[data-larp-cover-preview-tag]");
      const previewEmpty = modal?.querySelector("[data-larp-cover-preview-empty]");
      const fileMeta = modal?.querySelector("[data-larp-cover-file-meta]");
      const statusField = modal?.querySelector("[data-larp-cover-status]");
      const openUploadButtons = Array.from(document.querySelectorAll("[data-larp-open-upload]"));
      const closeButtons = Array.from(document.querySelectorAll("[data-larp-cover-close]"));

      if (
        !(coverArt instanceof HTMLElement) ||
        !(coverTrigger instanceof HTMLButtonElement) ||
        !(coverPrompt instanceof HTMLElement) ||
        !(modal instanceof HTMLElement) ||
        !(fileInput instanceof HTMLInputElement) ||
        !(selectButton instanceof HTMLButtonElement) ||
        !(uploadButton instanceof HTMLButtonElement) ||
        !(previewFrame instanceof HTMLElement) ||
        !(previewTag instanceof HTMLElement) ||
        !(previewEmpty instanceof HTMLElement) ||
        !(fileMeta instanceof HTMLElement) ||
        !(statusField instanceof HTMLElement)
      ) {
        return;
      }

      const allowedMimeTypes = new Set(["image/gif", "image/jpeg", "image/png", "image/webp"]);
      const maxBytes = 2 * 1024 * 1024;
      const uploadUrl = String(modal.getAttribute("data-upload-url") || "").trim();
      const defaultCoverBackground = "linear-gradient(135deg, rgba(15, 60, 79, 0.9), rgba(42, 131, 170, 0.72) 48%, rgba(192, 224, 232, 0.52)), radial-gradient(circle at top right, rgba(255, 255, 255, 0.26), transparent 42%), linear-gradient(120deg, rgba(255, 255, 255, 0.08), rgba(0, 0, 0, 0.18))";
      const defaultPreviewBackground = "linear-gradient(145deg, rgba(57, 122, 152, 0.9), rgba(144, 201, 213, 0.82) 54%, rgba(244, 222, 184, 0.76)), linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0))";
      const previewOverlay = "linear-gradient(145deg, rgba(12, 31, 42, 0.22), rgba(255, 255, 255, 0.06))";
      let currentCoverUrl = String(modal.getAttribute("data-current-cover-url") || "").trim();
      let selectedFile = null;
      let selectedPreviewUrl = "";
      let selectedWidth = 0;
      let selectedHeight = 0;
      let isUploading = false;
      let lastFocusedElement = null;

      const escapeCssUrl = (value) => String(value || "").replace(/\\/g, "\\\\").replace(/"/g, "\\\"");

      const buildCoverBackground = (imageUrl) =>
        imageUrl ? `url("${escapeCssUrl(imageUrl)}")` : defaultCoverBackground;

      const buildPreviewBackground = (imageUrl) =>
        imageUrl ? `${previewOverlay}, url("${escapeCssUrl(imageUrl)}")` : defaultPreviewBackground;

      const updateMainCover = (imageUrl) => {
        coverArt.style.backgroundImage = buildCoverBackground(imageUrl);
      };

      const setStatus = (message, state = "") => {
        statusField.textContent = String(message || "");
        if (state) {
          statusField.setAttribute("data-state", state);
        } else {
          statusField.removeAttribute("data-state");
        }
      };

      const syncPreview = () => {
        const previewUrl = selectedPreviewUrl || currentCoverUrl;
        const hasPreviewImage = Boolean(previewUrl);

        previewFrame.style.backgroundImage = buildPreviewBackground(previewUrl);
        previewFrame.classList.toggle("has-image", hasPreviewImage);

        if (selectedPreviewUrl && selectedFile) {
          previewTag.textContent = "Neues Titelbild";
          previewEmpty.textContent = "Deine Auswahl ist bereit und kann jetzt hochgeladen werden.";
          fileMeta.textContent = `${selectedFile.name} • ${selectedWidth} x ${selectedHeight} Pixel`;
          uploadButton.disabled = false;
          return;
        }

        uploadButton.disabled = true;
        previewTag.textContent = hasPreviewImage ? "Aktuelles Titelbild" : "Vorschau";
        previewEmpty.textContent = hasPreviewImage
          ? "So sieht dein aktuelles Titelbild im Profil gerade aus."
          : "Wähle ein Bild vom PC aus, damit es hier direkt als Vorschau erscheint.";
        fileMeta.textContent = hasPreviewImage
          ? "Der obere Profilbereich übernimmt dein Titelbild sofort nach dem Speichern."
          : "Noch kein Titelbild gespeichert. Du kannst hier direkt eins hochladen.";
      };

      const closePrompt = () => {
        coverPrompt.hidden = true;
      };

      const openPrompt = () => {
        if (modal.hidden === false) {
          return;
        }
        coverPrompt.hidden = false;
      };

      const resetSelection = () => {
        if (selectedPreviewUrl) {
          URL.revokeObjectURL(selectedPreviewUrl);
        }
        selectedFile = null;
        selectedPreviewUrl = "";
        selectedWidth = 0;
        selectedHeight = 0;
        fileInput.value = "";
        syncPreview();
      };

      const openModal = (originElement) => {
        lastFocusedElement = originElement instanceof HTMLElement ? originElement : document.activeElement;
        closePrompt();
        modal.hidden = false;
        document.body.classList.add("larp-cover-modal-open");
        syncPreview();
        setStatus("");
        selectButton.focus();
      };

      const closeModal = () => {
        modal.hidden = true;
        document.body.classList.remove("larp-cover-modal-open");
        setStatus("");
        if (lastFocusedElement instanceof HTMLElement) {
          lastFocusedElement.focus();
        }
      };

      const readFileAsDataUrl = (file) =>
        new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve(String(reader.result || ""));
          reader.onerror = () => reject(new Error("Die Datei konnte nicht gelesen werden."));
          reader.readAsDataURL(file);
        });

      const readImageDimensions = (file) =>
        new Promise((resolve, reject) => {
          const objectUrl = URL.createObjectURL(file);
          const image = new Image();

          image.onload = () => {
            resolve({
              objectUrl,
              width: image.naturalWidth,
              height: image.naturalHeight
            });
          };

          image.onerror = () => {
            URL.revokeObjectURL(objectUrl);
            reject(new Error("Das Bild konnte nicht geöffnet werden."));
          };

          image.src = objectUrl;
        });

      const applySelectedFile = async (file) => {
        if (!file) {
          return;
        }

        if (!allowedMimeTypes.has(String(file.type || "").toLowerCase())) {
          resetSelection();
          setStatus("Erlaubt sind gif, jpg, jpeg, png und webp.", "error");
          return;
        }

        if (Number(file.size || 0) > maxBytes) {
          resetSelection();
          setStatus("Die Datei darf maximal 2 MB groß sein.", "error");
          return;
        }

        let previewData = null;
        try {
          previewData = await readImageDimensions(file);
        } catch (error) {
          resetSelection();
          setStatus(error.message || "Das Bild konnte nicht gelesen werden.", "error");
          return;
        }

        if (selectedPreviewUrl) {
          URL.revokeObjectURL(selectedPreviewUrl);
        }

        selectedFile = file;
        selectedPreviewUrl = previewData.objectUrl;
        selectedWidth = previewData.width;
        selectedHeight = previewData.height;
        syncPreview();
        setStatus(`${file.name} ist ausgewählt und bereit zum Hochladen.`, "success");
      };

      const uploadSelectedFile = async () => {
        if (isUploading || !selectedFile || !uploadUrl) {
          return;
        }

        isUploading = true;
        selectButton.disabled = true;
        uploadButton.disabled = true;
        setStatus("Titelbild wird hochgeladen...", "success");

        try {
          const dataUrl = await readFileAsDataUrl(selectedFile);
          const response = await fetch(uploadUrl, {
            method: "POST",
            credentials: "same-origin",
            headers: {
              "Content-Type": "application/json",
              "X-Requested-With": "XMLHttpRequest"
            },
            body: JSON.stringify({
              filename: selectedFile.name,
              mimeType: selectedFile.type,
              dataUrl,
              width: selectedWidth,
              height: selectedHeight
            })
          });

          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload?.ok || !payload.imageUrl) {
            throw new Error(payload?.error || "Das Titelbild konnte nicht hochgeladen werden.");
          }

          currentCoverUrl = String(payload.imageUrl || "").trim();
          modal.setAttribute("data-current-cover-url", currentCoverUrl);
          updateMainCover(currentCoverUrl);
          resetSelection();
          syncPreview();
          setStatus("Titelbild gespeichert.", "success");
          window.setTimeout(() => {
            closeModal();
          }, 220);
        } catch (error) {
          setStatus(error?.message || "Das Titelbild konnte nicht hochgeladen werden.", "error");
        } finally {
          isUploading = false;
          selectButton.disabled = false;
          syncPreview();
        }
      };

      coverTrigger.addEventListener("click", (event) => {
        event.preventDefault();
        if (coverPrompt.hidden) {
          openPrompt();
        } else {
          closePrompt();
        }
      });

      openUploadButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) {
          return;
        }

        button.addEventListener("click", (event) => {
          event.preventDefault();
          openModal(button);
        });
      });

      closeButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) {
          return;
        }

        button.addEventListener("click", (event) => {
          event.preventDefault();
          closeModal();
        });
      });

      selectButton.addEventListener("click", () => {
        fileInput.click();
      });

      fileInput.addEventListener("change", () => {
        const nextFile = fileInput.files && fileInput.files[0] ? fileInput.files[0] : null;
        void applySelectedFile(nextFile);
      });

      uploadButton.addEventListener("click", () => {
        void uploadSelectedFile();
      });

      document.addEventListener("pointerdown", (event) => {
        const target = event.target;
        if (!(target instanceof Node)) {
          return;
        }

        if (!coverPrompt.hidden && !coverPrompt.contains(target) && !coverTrigger.contains(target)) {
          closePrompt();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key !== "Escape") {
          return;
        }

        if (modal.hidden === false) {
          event.preventDefault();
          closeModal();
          return;
        }

        if (!coverPrompt.hidden) {
          event.preventDefault();
          closePrompt();
        }
      });

      updateMainCover(currentCoverUrl);
      syncPreview();
    })();
  </script>

  <script>
    (() => {
      const modal = document.querySelector("[data-larp-cover-modal]");
      const coverArt = document.querySelector("[data-larp-cover-art]");
      const coverTrigger = document.querySelector("[data-larp-cover-trigger]");
      const editorStage = modal?.querySelector("[data-larp-cover-editor-stage]");
      const editorImage = modal?.querySelector("[data-larp-cover-editor-image]");
      const editorFallback = modal?.querySelector("[data-larp-cover-editor-fallback]");
      const statusField = modal?.querySelector("[data-larp-cover-status]");
      const fileMetaNodes = modal ? Array.from(modal.querySelectorAll("[data-larp-cover-file-meta], [data-larp-cover-file-meta-visible]")) : [];

      let fileInput = modal?.querySelector("[data-larp-cover-file-input]");
      let selectButton = modal?.querySelector("[data-larp-cover-select]");
      let uploadButton = modal?.querySelector("[data-larp-cover-upload]");

      if (
        !(modal instanceof HTMLElement) ||
        !(coverArt instanceof HTMLElement) ||
        !(editorStage instanceof HTMLElement) ||
        !(editorImage instanceof HTMLImageElement) ||
        !(editorFallback instanceof HTMLElement) ||
        !(statusField instanceof HTMLElement) ||
        !fileMetaNodes.length ||
        !(fileInput instanceof HTMLInputElement) ||
        !(selectButton instanceof HTMLButtonElement) ||
        !(uploadButton instanceof HTMLButtonElement)
      ) {
        return;
      }

      const replaceControl = (element) => {
        const clone = element.cloneNode(true);
        element.replaceWith(clone);
        return clone;
      };

      fileInput = replaceControl(fileInput);
      selectButton = replaceControl(selectButton);
      uploadButton = replaceControl(uploadButton);

      if (
        !(fileInput instanceof HTMLInputElement) ||
        !(selectButton instanceof HTMLButtonElement) ||
        !(uploadButton instanceof HTMLButtonElement)
      ) {
        return;
      }

      const allowedMimeTypes = new Set(["image/gif", "image/jpeg", "image/png", "image/webp"]);
      const maxBytes = 2 * 1024 * 1024;
      const uploadUrl = String(modal.getAttribute("data-upload-url") || "").trim();
      const defaultCoverBackground = "linear-gradient(135deg, rgba(15, 60, 79, 0.9), rgba(42, 131, 170, 0.72) 48%, rgba(192, 224, 232, 0.52)), radial-gradient(circle at top right, rgba(255, 255, 255, 0.26), transparent 42%), linear-gradient(120deg, rgba(255, 255, 255, 0.08), rgba(0, 0, 0, 0.18))";
      const clampPercent = (value, fallback = 50) => {
        const numericValue = Number(value);
        if (!Number.isFinite(numericValue)) {
          return Math.min(100, Math.max(0, Number(fallback) || 50));
        }

        return Math.min(100, Math.max(0, numericValue));
      };
      const clampNumber = (value, minValue, maxValue) => Math.min(maxValue, Math.max(minValue, value));
      const escapeCssUrl = (value) => String(value || "").replace(/\\/g, "\\\\").replace(/"/g, "\\\"");
      const emptyPreviewSource = () => ({
        src: "",
        width: 0,
        height: 0,
        isObjectUrl: false
      });
      let currentCoverUrl = String(modal.getAttribute("data-current-cover-url") || "").trim();
      let currentFocusX = clampPercent(modal.getAttribute("data-current-focus-x"), 50);
      let currentFocusY = clampPercent(modal.getAttribute("data-current-focus-y"), 50);
      let draftFocusX = currentFocusX;
      let draftFocusY = currentFocusY;
      let selectedFile = null;
      let previewSource = emptyPreviewSource();
      let isUploading = false;
      let isLoadingPreview = false;
      let dragState = null;
      let wasHidden = modal.hidden;

      const buildCoverBackground = (imageUrl) =>
        imageUrl ? `url("${escapeCssUrl(imageUrl)}")` : defaultCoverBackground;

      const updateMainCover = (imageUrl, focusX, focusY) => {
        coverArt.style.backgroundImage = buildCoverBackground(imageUrl);
        coverArt.style.backgroundPosition = `${clampPercent(focusX, 50)}% ${clampPercent(focusY, 50)}%`;
      };

      const setStatus = (message, state = "") => {
        statusField.textContent = String(message || "");
        if (state) {
          statusField.setAttribute("data-state", state);
        } else {
          statusField.removeAttribute("data-state");
        }
      };

      const setFileMetaText = (message) => {
        fileMetaNodes.forEach((node) => {
          if (node instanceof HTMLElement) {
            node.textContent = message;
          }
        });
      };

      const syncActionState = () => {
        selectButton.disabled = isUploading;
        if (coverTrigger instanceof HTMLButtonElement) {
          coverTrigger.disabled = isUploading;
        }
        uploadButton.disabled = isUploading || isLoadingPreview || (!selectedFile && !currentCoverUrl);
      };

      const readFileAsDataUrl = (file) =>
        new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve(String(reader.result || ""));
          reader.onerror = () => reject(new Error("Die Datei konnte nicht gelesen werden."));
          reader.readAsDataURL(file);
        });

      const readImageDimensions = (file) =>
        new Promise((resolve, reject) => {
          const objectUrl = URL.createObjectURL(file);
          const image = new Image();

          image.onload = () => {
            resolve({
              objectUrl,
              width: image.naturalWidth,
              height: image.naturalHeight
            });
          };

          image.onerror = () => {
            URL.revokeObjectURL(objectUrl);
            reject(new Error("Das Bild konnte nicht geoeffnet werden."));
          };

          image.src = objectUrl;
        });

      const loadImageDimensionsFromUrl = (imageUrl) =>
        new Promise((resolve, reject) => {
          const image = new Image();

          image.onload = () => {
            resolve({
              width: image.naturalWidth,
              height: image.naturalHeight
            });
          };

          image.onerror = () => {
            reject(new Error("Das Bild konnte nicht geladen werden."));
          };

          image.src = imageUrl;
        });

      const releasePreviewSource = () => {
        if (previewSource.isObjectUrl && previewSource.src) {
          URL.revokeObjectURL(previewSource.src);
        }
        previewSource = emptyPreviewSource();
      };

      const updateFileMeta = () => {
        if (selectedFile && previewSource.src) {
          setFileMetaText(`${selectedFile.name} - ${previewSource.width} x ${previewSource.height} Pixel`);
          return;
        }

        if (currentCoverUrl && previewSource.src) {
          setFileMetaText("Dein gespeicherter Ausschnitt erscheint danach direkt oben auf deiner LARP-Seite.");
          return;
        }

        setFileMetaText("Waehle ein Bild vom PC aus, dann kannst du es hier direkt passend verschieben.");
      };

      const getEditorMetrics = () => {
        if (!previewSource.src || !previewSource.width || !previewSource.height) {
          return null;
        }

        const stageRect = editorStage.getBoundingClientRect();
        const stageWidth = Math.max(1, stageRect.width);
        const stageHeight = Math.max(1, stageRect.height);
        const scale = Math.max(stageWidth / previewSource.width, stageHeight / previewSource.height);
        const displayWidth = previewSource.width * scale;
        const displayHeight = previewSource.height * scale;

        return {
          stageWidth,
          stageHeight,
          displayWidth,
          displayHeight,
          minOffsetX: Math.min(0, stageWidth - displayWidth),
          minOffsetY: Math.min(0, stageHeight - displayHeight)
        };
      };

      const getOffsetsFromFocus = (focusX, focusY, metrics) => ({
        offsetX: metrics.displayWidth > metrics.stageWidth
          ? (metrics.stageWidth - metrics.displayWidth) * (clampPercent(focusX, 50) / 100)
          : (metrics.stageWidth - metrics.displayWidth) / 2,
        offsetY: metrics.displayHeight > metrics.stageHeight
          ? (metrics.stageHeight - metrics.displayHeight) * (clampPercent(focusY, 50) / 100)
          : (metrics.stageHeight - metrics.displayHeight) / 2
      });

      const getFocusFromOffsets = (offsetX, offsetY, metrics) => ({
        focusX: metrics.displayWidth > metrics.stageWidth
          ? clampPercent((offsetX / (metrics.stageWidth - metrics.displayWidth)) * 100, 50)
          : 50,
        focusY: metrics.displayHeight > metrics.stageHeight
          ? clampPercent((offsetY / (metrics.stageHeight - metrics.displayHeight)) * 100, 50)
          : 50
      });

      const renderEditor = (metricsOverride = null) => {
        const metrics = metricsOverride || getEditorMetrics();
        const hasImage = Boolean(metrics && previewSource.src);

        editorStage.classList.toggle("is-draggable", hasImage);
        editorStage.classList.toggle("is-dragging", Boolean(dragState));
        editorImage.hidden = !hasImage;
        editorFallback.hidden = hasImage;

        if (!hasImage) {
          editorImage.removeAttribute("src");
          editorImage.style.width = "";
          editorImage.style.height = "";
          editorImage.style.left = "0";
          editorImage.style.top = "0";
          editorImage.style.transform = "";
          updateFileMeta();
          syncActionState();
          return;
        }

        const offsets = getOffsetsFromFocus(draftFocusX, draftFocusY, metrics);
        editorImage.src = previewSource.src;
        editorImage.style.width = `${metrics.displayWidth}px`;
        editorImage.style.height = `${metrics.displayHeight}px`;
        editorImage.style.left = "0";
        editorImage.style.top = "0";
        editorImage.style.transform = `translate3d(${offsets.offsetX}px, ${offsets.offsetY}px, 0)`;
        updateFileMeta();
        syncActionState();
      };

      const resetDraftState = () => {
        releasePreviewSource();
        selectedFile = null;
        draftFocusX = currentFocusX;
        draftFocusY = currentFocusY;
        dragState = null;
        editorStage.classList.remove("is-dragging");
        renderEditor();
      };

      const loadCurrentCoverPreview = async () => {
        resetDraftState();
        if (!currentCoverUrl) {
          setStatus("");
          return;
        }

        isLoadingPreview = true;
        syncActionState();

        try {
          const dimensions = await loadImageDimensionsFromUrl(currentCoverUrl);
          previewSource = {
            src: currentCoverUrl,
            width: dimensions.width,
            height: dimensions.height,
            isObjectUrl: false
          };
          draftFocusX = currentFocusX;
          draftFocusY = currentFocusY;
          renderEditor();
        } catch (error) {
          releasePreviewSource();
          setStatus(error?.message || "Das Bild konnte nicht geladen werden.", "error");
          renderEditor();
        } finally {
          isLoadingPreview = false;
          syncActionState();
        }
      };

      const applySelectedFile = async (file) => {
        if (!file || isUploading) {
          return;
        }

        if (!allowedMimeTypes.has(String(file.type || "").toLowerCase())) {
          resetDraftState();
          setStatus("Erlaubt sind gif, jpg, jpeg, png und webp.", "error");
          return;
        }

        if (Number(file.size || 0) > maxBytes) {
          resetDraftState();
          setStatus("Die Datei darf maximal 2 MB gross sein.", "error");
          return;
        }

        let previewData = null;
        try {
          previewData = await readImageDimensions(file);
        } catch (error) {
          resetDraftState();
          setStatus(error?.message || "Das Bild konnte nicht gelesen werden.", "error");
          return;
        }

        releasePreviewSource();
        selectedFile = file;
        previewSource = {
          src: previewData.objectUrl,
          width: previewData.width,
          height: previewData.height,
          isObjectUrl: true
        };
        draftFocusX = 50;
        draftFocusY = 50;
        renderEditor();
        setStatus(`${file.name} ist ausgewaehlt und kann jetzt angepasst werden.`, "success");
      };

      const saveCover = async () => {
        if (isUploading || isLoadingPreview || (!selectedFile && !currentCoverUrl)) {
          return;
        }

        isUploading = true;
        syncActionState();
        setStatus("Titelbild wird gespeichert...", "success");

        try {
          const requestBody = {
            focusX: draftFocusX,
            focusY: draftFocusY
          };

          if (selectedFile && previewSource.src) {
            requestBody.filename = selectedFile.name;
            requestBody.mimeType = selectedFile.type;
            requestBody.dataUrl = await readFileAsDataUrl(selectedFile);
            requestBody.width = previewSource.width;
            requestBody.height = previewSource.height;
          }

          const response = await fetch(uploadUrl, {
            method: "POST",
            credentials: "same-origin",
            headers: {
              "Content-Type": "application/json",
              "X-Requested-With": "XMLHttpRequest"
            },
            body: JSON.stringify(requestBody)
          });

          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload?.ok || !payload.imageUrl) {
            throw new Error(payload?.error || "Das Titelbild konnte nicht gespeichert werden.");
          }

          currentCoverUrl = String(payload.imageUrl || "").trim();
          currentFocusX = clampPercent(payload.focusX, draftFocusX);
          currentFocusY = clampPercent(payload.focusY, draftFocusY);
          modal.setAttribute("data-current-cover-url", currentCoverUrl);
          modal.setAttribute("data-current-focus-x", String(currentFocusX));
          modal.setAttribute("data-current-focus-y", String(currentFocusY));
          updateMainCover(currentCoverUrl, currentFocusX, currentFocusY);
          resetDraftState();
          setStatus("Titelbild gespeichert.", "success");
          window.setTimeout(() => {
            modal.hidden = true;
          }, 220);
        } catch (error) {
          setStatus(error?.message || "Das Titelbild konnte nicht gespeichert werden.", "error");
        } finally {
          isUploading = false;
          syncActionState();
        }
      };

      selectButton.addEventListener("click", () => {
        if (!isUploading) {
          fileInput.click();
        }
      });

      fileInput.addEventListener("change", () => {
        const nextFile = fileInput.files && fileInput.files[0] ? fileInput.files[0] : null;
        void applySelectedFile(nextFile);
      });

      uploadButton.addEventListener("click", () => {
        void saveCover();
      });

      editorStage.addEventListener("pointerdown", (event) => {
        const metrics = getEditorMetrics();
        if (!metrics) {
          return;
        }

        const offsets = getOffsetsFromFocus(draftFocusX, draftFocusY, metrics);
        dragState = {
          metrics,
          pointerId: event.pointerId,
          startClientX: event.clientX,
          startClientY: event.clientY,
          startOffsetX: offsets.offsetX,
          startOffsetY: offsets.offsetY
        };
        editorStage.setPointerCapture(event.pointerId);
        editorStage.classList.add("is-dragging");
        event.preventDefault();
      });

      editorStage.addEventListener("pointermove", (event) => {
        if (!dragState || event.pointerId !== dragState.pointerId) {
          return;
        }

        const metrics = dragState.metrics || getEditorMetrics();
        if (!metrics) {
          return;
        }

        const nextOffsetX = clampNumber(
          dragState.startOffsetX + (event.clientX - dragState.startClientX),
          metrics.minOffsetX,
          0
        );
        const nextOffsetY = clampNumber(
          dragState.startOffsetY + (event.clientY - dragState.startClientY),
          metrics.minOffsetY,
          0
        );
        const nextFocus = getFocusFromOffsets(nextOffsetX, nextOffsetY, metrics);
        draftFocusX = nextFocus.focusX;
        draftFocusY = nextFocus.focusY;
        renderEditor(metrics);
        event.preventDefault();
      });

      const stopDragging = (event) => {
        if (!dragState) {
          return;
        }

        if (event && "pointerId" in event && event.pointerId !== dragState.pointerId) {
          return;
        }

        try {
          editorStage.releasePointerCapture(dragState.pointerId);
        } catch (_error) {
          // ignore capture cleanup errors
        }

        dragState = null;
        editorStage.classList.remove("is-dragging");
        renderEditor();
      };

      editorStage.addEventListener("pointerup", stopDragging);
      editorStage.addEventListener("pointercancel", stopDragging);
      editorStage.addEventListener("lostpointercapture", () => {
        dragState = null;
        editorStage.classList.remove("is-dragging");
      });

      const handleModalVisibility = () => {
        if (modal.hidden === wasHidden) {
          return;
        }

        wasHidden = modal.hidden;
        if (modal.hidden) {
          fileInput.value = "";
          setStatus("");
          resetDraftState();
          return;
        }

        setStatus("");
        void loadCurrentCoverPreview();
      };

      const observer = new MutationObserver(handleModalVisibility);
      observer.observe(modal, {
        attributes: true,
        attributeFilter: ["hidden"]
      });

      window.addEventListener("resize", () => {
        if (modal.hidden === false) {
          renderEditor();
        }
      });

      updateMainCover(currentCoverUrl, currentFocusX, currentFocusY);
      renderEditor();
      syncActionState();
    })();
  </script>

  <script>
    (() => {
      const avatarTrigger = document.querySelector("[data-larp-avatar-trigger]");
      const avatarFileInput = document.querySelector("[data-larp-avatar-file-input]");
      const avatarImage = document.querySelector("[data-larp-avatar-image]");
      const avatarFallback = document.querySelector("[data-larp-avatar-fallback]");

      if (
        !(avatarTrigger instanceof HTMLButtonElement) ||
        !(avatarFileInput instanceof HTMLInputElement) ||
        !(avatarFallback instanceof HTMLElement)
      ) {
        return;
      }

      const uploadUrl = String(avatarFileInput.getAttribute("data-upload-url") || "").trim();
      if (!uploadUrl) {
        return;
      }

      const allowedMimeTypes = new Set(["image/gif", "image/jpeg", "image/png", "image/webp"]);
      const maxBytes = 2 * 1024 * 1024;
      const minSide = 120;
      const maxSide = 2000;
      let isUploading = false;
      let currentAvatarUrl =
        avatarImage instanceof HTMLImageElement ? String(avatarImage.getAttribute("src") || "").trim() : "";

      const setButtonState = (label, disabled) => {
        avatarTrigger.textContent = label;
        avatarTrigger.disabled = Boolean(disabled);
      };

      const readFileAsDataUrl = (file) =>
        new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve(String(reader.result || ""));
          reader.onerror = () => reject(new Error("Die Datei konnte nicht gelesen werden."));
          reader.readAsDataURL(file);
        });

      const readImageDimensions = (file) =>
        new Promise((resolve, reject) => {
          const objectUrl = URL.createObjectURL(file);
          const image = new Image();

          image.onload = () => {
            resolve({
              objectUrl,
              width: image.naturalWidth,
              height: image.naturalHeight
            });
          };

          image.onerror = () => {
            URL.revokeObjectURL(objectUrl);
            reject(new Error("Das Bild konnte nicht geöffnet werden."));
          };

          image.src = objectUrl;
        });

      const applyAvatarImage = (imageUrl) => {
        const normalizedImageUrl = String(imageUrl || "").trim();
        if (avatarImage instanceof HTMLImageElement) {
          avatarImage.hidden = !normalizedImageUrl;
          if (normalizedImageUrl) {
            avatarImage.src = normalizedImageUrl;
          }
        }

        avatarFallback.hidden = Boolean(normalizedImageUrl);
      };

      const uploadSelectedAvatar = async (file) => {
        if (!file || isUploading) {
          return;
        }

        if (!allowedMimeTypes.has(String(file.type || "").toLowerCase())) {
          window.alert("Erlaubt sind gif, jpg, jpeg, png und webp.");
          return;
        }

        if (Number(file.size || 0) > maxBytes) {
          window.alert("Die Datei darf maximal 2 MB groß sein.");
          return;
        }

        let previewData = null;
        try {
          previewData = await readImageDimensions(file);
        } catch (error) {
          window.alert(error?.message || "Das Bild konnte nicht gelesen werden.");
          return;
        }

        if (previewData.width < minSide || previewData.height < minSide) {
          URL.revokeObjectURL(previewData.objectUrl);
          window.alert(`Das Bild muss mindestens ${minSide} x ${minSide} Pixel haben.`);
          return;
        }

        if (previewData.width > maxSide || previewData.height > maxSide) {
          URL.revokeObjectURL(previewData.objectUrl);
          window.alert(`Das Bild darf höchstens ${maxSide} x ${maxSide} Pixel haben.`);
          return;
        }

        isUploading = true;
        setButtonState("Lädt...", true);

        try {
          const dataUrl = await readFileAsDataUrl(file);
          const response = await fetch(uploadUrl, {
            method: "POST",
            credentials: "same-origin",
            headers: {
              "Content-Type": "application/json",
              "X-Requested-With": "XMLHttpRequest"
            },
            body: JSON.stringify({
              filename: file.name,
              mimeType: file.type,
              dataUrl,
              width: previewData.width,
              height: previewData.height
            })
          });

          const payload = await response.json().catch(() => null);
          if (!response.ok || !payload?.ok || !payload.imageUrl) {
            throw new Error(payload?.error || "Das Bild konnte nicht hochgeladen werden.");
          }

          const previousAvatarUrl = currentAvatarUrl;
          currentAvatarUrl = String(payload.imageUrl || "").trim();
          applyAvatarImage(currentAvatarUrl);

          if (previousAvatarUrl) {
            document.querySelectorAll("img").forEach((imageElement) => {
              if (!(imageElement instanceof HTMLImageElement)) {
                return;
              }

              if (String(imageElement.getAttribute("src") || "").trim() === previousAvatarUrl) {
                imageElement.src = currentAvatarUrl;
              }
            });
          }
        } catch (error) {
          window.alert(error?.message || "Das Bild konnte nicht hochgeladen werden.");
        } finally {
          URL.revokeObjectURL(previewData.objectUrl);
          avatarFileInput.value = "";
          isUploading = false;
          setButtonState("Bild", false);
        }
      };

      avatarTrigger.addEventListener("click", () => {
        if (!isUploading) {
          avatarFileInput.click();
        }
      });

      avatarFileInput.addEventListener("change", () => {
        const nextFile = avatarFileInput.files && avatarFileInput.files[0] ? avatarFileInput.files[0] : null;
        void uploadSelectedAvatar(nextFile);
      });
    })();
  </script>

  <script>
    (() => {
      const avatarTrigger = document.querySelector("[data-larp-avatar-trigger]");
      const avatarImage = document.querySelector("[data-larp-avatar-image]");
      const avatarFallback = document.querySelector("[data-larp-avatar-fallback]");
      const modal = document.querySelector("[data-larp-avatar-modal]");
      const avatarFileInput = modal?.querySelector("[data-larp-avatar-source-input]");
      const selectButton = modal?.querySelector("[data-larp-avatar-select]");
      const saveButton = modal?.querySelector("[data-larp-avatar-save]");
      const statusField = modal?.querySelector("[data-larp-avatar-status]");
      const fileMeta = modal?.querySelector("[data-larp-avatar-file-meta]");
      const previewStage = modal?.querySelector("[data-larp-avatar-preview-stage]");
      const previewImage = modal?.querySelector("[data-larp-avatar-preview-image]");
      const previewFallback = modal?.querySelector("[data-larp-avatar-preview-fallback]");
      const closeButtons = Array.from(document.querySelectorAll("[data-larp-avatar-close]"));

      if (
        !(avatarTrigger instanceof HTMLButtonElement) ||
        !(avatarImage instanceof HTMLImageElement) ||
        !(avatarFallback instanceof HTMLElement) ||
        !(modal instanceof HTMLElement) ||
        !(avatarFileInput instanceof HTMLInputElement) ||
        !(selectButton instanceof HTMLButtonElement) ||
        !(saveButton instanceof HTMLButtonElement) ||
        !(statusField instanceof HTMLElement) ||
        !(fileMeta instanceof HTMLElement) ||
        !(previewStage instanceof HTMLElement) ||
        !(previewImage instanceof HTMLImageElement) ||
        !(previewFallback instanceof HTMLElement)
      ) {
        return;
      }

      const uploadUrl = String(modal.getAttribute("data-upload-url") || "").trim();
      if (!uploadUrl) {
        return;
      }

      const allowedMimeTypes = new Set(["image/gif", "image/jpeg", "image/png", "image/webp"]);
      const maxBytes = 2 * 1024 * 1024;
      const minSide = 120;
      const maxSide = 2000;
      const clampPercent = (value, fallback = 50) => {
        const numericValue = Number(value);
        if (!Number.isFinite(numericValue)) {
          return Math.min(100, Math.max(0, Number(fallback) || 50));
        }

        return Math.min(100, Math.max(0, numericValue));
      };
      const clampNumber = (value, minValue, maxValue) => Math.min(maxValue, Math.max(minValue, value));
      const buildObjectPosition = (focusX, focusY) =>
        `${clampPercent(focusX, 50)}% ${clampPercent(focusY, 50)}%`;
      const emptyPreviewSource = () => ({
        src: "",
        width: 0,
        height: 0,
        isObjectUrl: false
      });
      let isUploading = false;
      let isLoadingPreview = false;
      let lastFocusedElement = null;
      let currentAvatarUrl = String(modal.getAttribute("data-current-avatar-url") || "").trim();
      let currentFocusX = clampPercent(
        modal.getAttribute("data-current-focus-x"),
        avatarImage.getAttribute("data-avatar-focus-x")
      );
      let currentFocusY = clampPercent(
        modal.getAttribute("data-current-focus-y"),
        avatarImage.getAttribute("data-avatar-focus-y")
      );
      let draftFocusX = currentFocusX;
      let draftFocusY = currentFocusY;
      let selectedFile = null;
      let previewSource = emptyPreviewSource();
      let dragState = null;

      const setStatus = (message, state = "") => {
        statusField.textContent = String(message || "");
        if (state) {
          statusField.setAttribute("data-state", state);
        } else {
          statusField.removeAttribute("data-state");
        }
      };

      const readFileAsDataUrl = (file) =>
        new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve(String(reader.result || ""));
          reader.onerror = () => reject(new Error("Die Datei konnte nicht gelesen werden."));
          reader.readAsDataURL(file);
        });

      const readImageDimensions = (file) =>
        new Promise((resolve, reject) => {
          const objectUrl = URL.createObjectURL(file);
          const image = new Image();

          image.onload = () => {
            resolve({
              objectUrl,
              width: image.naturalWidth,
              height: image.naturalHeight
            });
          };

          image.onerror = () => {
            URL.revokeObjectURL(objectUrl);
            reject(new Error("Das Bild konnte nicht geöffnet werden."));
          };

          image.src = objectUrl;
        });

      const loadImageDimensionsFromUrl = (imageUrl) =>
        new Promise((resolve, reject) => {
          const image = new Image();

          image.onload = () => {
            resolve({
              width: image.naturalWidth,
              height: image.naturalHeight
            });
          };

          image.onerror = () => {
            reject(new Error("Das Bild konnte nicht geladen werden."));
          };

          image.src = imageUrl;
        });

      const releasePreviewSource = () => {
        if (previewSource.isObjectUrl && previewSource.src) {
          URL.revokeObjectURL(previewSource.src);
        }

        previewSource = emptyPreviewSource();
      };

      const syncActionState = () => {
        avatarTrigger.disabled = isUploading;
        selectButton.disabled = isUploading;
        saveButton.disabled = isUploading || isLoadingPreview || (!selectedFile && !currentAvatarUrl);
      };

      const updateFileMeta = () => {
        if (selectedFile && previewSource.src) {
          fileMeta.textContent = `${selectedFile.name} • ${previewSource.width} x ${previewSource.height} Pixel`;
          return;
        }

        if (currentAvatarUrl && previewSource.src) {
          fileMeta.textContent = "Der gespeicherte Ausschnitt wird danach überall für das runde Profilbild benutzt.";
          return;
        }

        fileMeta.textContent = "Wähle ein Bild vom PC aus, dann kannst du es hier direkt passend verschieben.";
      };

      const getPreviewMetrics = () => {
        if (!previewSource.src || !previewSource.width || !previewSource.height) {
          return null;
        }

        const stageRect = previewStage.getBoundingClientRect();
        const stageWidth = Math.max(1, stageRect.width);
        const stageHeight = Math.max(1, stageRect.height);
        const scale = Math.max(stageWidth / previewSource.width, stageHeight / previewSource.height);
        const displayWidth = previewSource.width * scale;
        const displayHeight = previewSource.height * scale;

        return {
          stageWidth,
          stageHeight,
          displayWidth,
          displayHeight,
          minOffsetX: Math.min(0, stageWidth - displayWidth),
          minOffsetY: Math.min(0, stageHeight - displayHeight)
        };
      };

      const getOffsetsFromFocus = (focusX, focusY, metrics) => ({
        offsetX: metrics.displayWidth > metrics.stageWidth
          ? (metrics.stageWidth - metrics.displayWidth) * (clampPercent(focusX, 50) / 100)
          : (metrics.stageWidth - metrics.displayWidth) / 2,
        offsetY: metrics.displayHeight > metrics.stageHeight
          ? (metrics.stageHeight - metrics.displayHeight) * (clampPercent(focusY, 50) / 100)
          : (metrics.stageHeight - metrics.displayHeight) / 2
      });

      const getFocusFromOffsets = (offsetX, offsetY, metrics) => ({
        focusX: metrics.displayWidth > metrics.stageWidth
          ? clampPercent((offsetX / (metrics.stageWidth - metrics.displayWidth)) * 100, 50)
          : 50,
        focusY: metrics.displayHeight > metrics.stageHeight
          ? clampPercent((offsetY / (metrics.stageHeight - metrics.displayHeight)) * 100, 50)
          : 50
      });

      const renderPreview = () => {
        const metrics = getPreviewMetrics();
        const hasImage = Boolean(metrics && previewSource.src);

        previewStage.classList.toggle("is-draggable", hasImage);
        previewStage.classList.toggle("is-dragging", Boolean(dragState));
        previewImage.hidden = !hasImage;
        previewFallback.hidden = hasImage;

        if (!hasImage) {
          previewImage.removeAttribute("src");
          previewImage.style.width = "";
          previewImage.style.height = "";
          previewImage.style.left = "";
          previewImage.style.top = "";
          updateFileMeta();
          syncActionState();
          return;
        }

        const offsets = getOffsetsFromFocus(draftFocusX, draftFocusY, metrics);
        previewImage.src = previewSource.src;
        previewImage.style.width = `${metrics.displayWidth}px`;
        previewImage.style.height = `${metrics.displayHeight}px`;
        previewImage.style.left = `${offsets.offsetX}px`;
        previewImage.style.top = `${offsets.offsetY}px`;
        updateFileMeta();
        syncActionState();
      };

      const applyAvatarImage = (imageUrl, focusX, focusY) => {
        const normalizedImageUrl = String(imageUrl || "").trim();
        const normalizedFocusX = clampPercent(focusX, 50);
        const normalizedFocusY = clampPercent(focusY, 50);
        const objectPosition = buildObjectPosition(normalizedFocusX, normalizedFocusY);

