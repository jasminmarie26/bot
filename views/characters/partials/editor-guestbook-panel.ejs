<% const { pages, activePage, settings } = activeGuestbookEditor; %>

<section
  id="guestbook-design"
  class="panel character-form-panel character-guestbook-panel"
  data-character-editor-panel="guestbook"
>
  <div class="header-line character-guestbook-header">
    <div>
      <h2>G&auml;stebuch bearbeiten</h2>
      <p>Schritt 2 regelt das Design, Schritt 3 Inhalt und Bilder. Alles bleibt direkt hier unter dem Charakter.</p>
    </div>

    <div class="gb-editor-actions">
      <button class="btn" type="submit" form="guestbook-editor-form">Speichern</button>

      <form method="POST" action="/characters/<%= character.id %>/guestbook/edit/add-page" class="inline-form">
        <input type="hidden" name="page_id" value="<%= activePage.id %>" />
        <button class="btn btn-secondary" type="submit">Seite hinzuf&uuml;gen</button>
      </form>

      <form method="POST" action="/characters/<%= character.id %>/guestbook/edit/delete-page" class="inline-form">
        <input type="hidden" name="page_id" value="<%= activePage.id %>" />
        <button
          class="btn btn-danger"
          type="submit"
          onclick="return confirm('Aktuelle Seite wirklich l&ouml;schen?')"
        >
          Aktuelle Seite l&ouml;schen
        </button>
      </form>
    </div>
  </div>

  <% if ((pages || []).length > 1) { %>
    <nav class="gb-editor-tabs" aria-label="G&auml;stebuch Seiten">
      <% pages.forEach((page) => { %>
        <a
          class="gb-editor-tab <%= page.id === activePage.id ? "is-active" : "" %>"
          data-character-guestbook-page-link
          href="/characters/<%= character.id %>/edit?guestbook_page_id=<%= page.id %>#guestbook-design"
        >
          <%= page.page_number %>
        </a>
      <% }) %>
    </nav>
  <% } %>

  <%- include("../../partials/guestbook-editor-form", {
    character,
    activePage,
    settings,
    guestbookEditorFormClass: "panel form gb-editor-form",
    guestbookEditorUseOuterNavigation: true
  }) %>
</section>
