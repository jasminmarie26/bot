<%- include("../partials/start") %>

<%
  const guildCount = Array.isArray(larpGuilds) ? larpGuilds.length : 0;
  const birthdayRows = Array.isArray(publicBirthdayRows)
    ? publicBirthdayRows.filter((entry) => entry && entry.label && entry.value)
    : [];
  const boardEntries = [
    {
      anchor: "board-news",
      title: "Ankuendigungen",
      description: "Neuigkeiten, Regeln und alles, was im LARP-Bereich gerade wichtig ist.",
      threads: "12 Themen",
      posts: "84 Beitraege",
      latest: "Startklar fuer neue Reisen"
    },
    {
      anchor: "board-groups",
      title: "Lager & Gilden",
      description: "Feste Gruppen, Lagerideen und gemeinsame Plaene fuer kommende Geschichten.",
      threads: guildCount === 1 ? "1 Gilde" : `${guildCount} Gilden`,
      posts: guildCount > 0 ? `${guildCount * 7} Beitraege` : "Noch offen",
      latest: guildCount > 0 ? "Gemeinsame Wege formen sich" : "Platz fuer die erste Gruppe"
    },
    {
      anchor: "board-characters",
      title: "Charaktere & Kontakte",
      description: "Vorstellungen, Kontakte, Gesuche und kleine Funken fuer neue Szenen.",
      threads: "18 Themen",
      posts: "126 Beitraege",
      latest: `${character.name} ist bereit fuer neue Kontakte`
    },
    {
      anchor: "board-tavern",
      title: "Tavernenrunde",
      description: "Locker plaudern, Eindruecke teilen und nach einem langen Tag zusammensitzen.",
      threads: "9 Themen",
      posts: "63 Beitraege",
      latest: "Heute klingt nach Lagerfeuer"
    },
    {
      anchor: "board-plots",
      title: "Plot & Termine",
      description: "Verabredungen, Hooks, Spielideen und alles fuer den naechsten Aufbruch.",
      threads: "7 Themen",
      posts: "41 Beitraege",
      latest: "Der naechste Aufbruch wartet schon"
    }
  ];
  const groupPreviewEntries = guildCount
    ? larpGuilds.slice(0, 3).map((guild, index) => ({
        title: String(guild?.name || `Lager ${index + 1}`),
        meta: index === 0 ? "Heute aktiv" : "Im Blick behalten"
      }))
    : [
        { title: "Die erste Lagergruppe", meta: "Noch offen" },
        { title: "Gemeinsame Banneridee", meta: "Noch offen" },
        { title: "Weg fuer neue Allianzen", meta: "Noch offen" }
      ];
%>

<style>
  .larp-forum-shell {
    display: grid;
    gap: 24px;
  }

  .larp-forum-hero,
  .larp-forum-board-list,
  .larp-forum-side-section,
  .larp-forum-topic-band {
    border: 1px solid rgba(184, 160, 95, 0.28);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(12, 20, 17, 0.96), rgba(18, 30, 24, 0.96));
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.24);
  }

  .larp-forum-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(260px, 0.9fr);
    gap: 24px;
    padding: 28px;
    overflow: hidden;
  }

  .larp-forum-hero-copy {
    display: grid;
    gap: 16px;
    align-content: start;
  }

  .larp-forum-kicker {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border: 1px solid rgba(114, 153, 116, 0.45);
    border-radius: 999px;
    background: rgba(62, 96, 71, 0.18);
    color: #dbead5;
    font-size: 0.84rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  .larp-forum-hero h1 {
    margin: 0;
    color: #f5f1df;
    font-size: 2.15rem;
    line-height: 1.1;
  }

  .larp-forum-hero p {
    margin: 0;
    color: #d0d8d1;
    max-width: 62ch;
  }

  .larp-forum-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .larp-forum-link-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 16px;
    border: 1px solid rgba(184, 160, 95, 0.34);
    border-radius: 8px;
    background: rgba(58, 86, 70, 0.22);
    color: #f7f3e4;
    text-decoration: none;
    font-weight: 700;
  }

  .larp-forum-link-btn:hover,
  .larp-forum-link-btn:focus-visible {
    background: rgba(83, 118, 97, 0.3);
  }

  .larp-forum-link-btn.is-primary {
    background: linear-gradient(135deg, rgba(119, 144, 95, 0.92), rgba(63, 108, 82, 0.92));
    border-color: rgba(173, 196, 126, 0.62);
    color: #0f1712;
  }

  .larp-forum-stat-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .larp-forum-stat-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 40px;
    padding: 0 12px;
    border: 1px solid rgba(114, 153, 116, 0.34);
    border-radius: 8px;
    background: rgba(39, 58, 47, 0.64);
    color: #dfe7db;
  }

  .larp-forum-stat-pill strong {
    color: #fff7db;
  }

  .larp-forum-mark-wrap {
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 16px;
    min-height: 100%;
    padding: 12px;
    background:
      radial-gradient(circle at top, rgba(132, 173, 122, 0.22), transparent 58%),
      linear-gradient(180deg, rgba(26, 38, 32, 0.96), rgba(16, 24, 20, 0.96));
    border-radius: 8px;
  }

  .larp-forum-mark {
    width: min(220px, 100%);
    height: auto;
    filter: drop-shadow(0 18px 32px rgba(0, 0, 0, 0.34));
  }

  .larp-forum-mark-caption {
    color: #d7dfd1;
    text-align: center;
    max-width: 28ch;
    margin: 0;
  }

  .larp-forum-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.85fr);
    gap: 24px;
    align-items: start;
  }

  .larp-forum-board-list,
  .larp-forum-side-section,
  .larp-forum-topic-band {
    padding: 22px;
  }

  .larp-forum-section-head {
    display: grid;
    gap: 6px;
    margin-bottom: 18px;
  }

  .larp-forum-section-head h2,
  .larp-forum-section-head h3 {
    margin: 0;
    color: #f5f1df;
  }

  .larp-forum-section-head p {
    margin: 0;
    color: #ced7d0;
  }

  .larp-forum-board-row,
  .larp-forum-quick-link,
  .larp-forum-topic-row {
    display: grid;
    gap: 10px;
    padding: 16px;
    border: 1px solid rgba(114, 153, 116, 0.26);
    border-radius: 8px;
    background: rgba(34, 50, 41, 0.72);
  }

  .larp-forum-board-row + .larp-forum-board-row,
  .larp-forum-quick-link + .larp-forum-quick-link,
  .larp-forum-topic-row + .larp-forum-topic-row,
  .larp-forum-side-section + .larp-forum-side-section,
  .larp-forum-topic-band + .larp-forum-topic-band {
    margin-top: 14px;
  }

  .larp-forum-board-row {
    grid-template-columns: minmax(0, 1.35fr) auto auto;
    gap: 16px;
    align-items: center;
    text-decoration: none;
  }

  .larp-forum-board-row:hover,
  .larp-forum-board-row:focus-visible,
  .larp-forum-quick-link:hover,
  .larp-forum-quick-link:focus-visible {
    background: rgba(47, 68, 56, 0.82);
  }

  .larp-forum-board-copy strong,
  .larp-forum-topic-row strong,
  .larp-forum-quick-link strong {
    display: block;
    color: #fff7db;
    font-size: 1rem;
  }

  .larp-forum-board-copy span,
  .larp-forum-topic-row span,
  .larp-forum-quick-link span {
    display: block;
    color: #d2dad3;
    font-size: 0.95rem;
  }

  .larp-forum-board-metric {
    min-width: 112px;
    text-align: right;
    color: #f4ecc9;
    font-weight: 700;
  }

  .larp-forum-board-metric small {
    display: block;
    margin-top: 4px;
    color: #b7c3ba;
    font-weight: 500;
  }

  .larp-forum-quick-link {
    text-decoration: none;
  }

  .larp-forum-topic-band {
    scroll-margin-top: 110px;
  }

  .larp-forum-topic-band-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 18px;
  }

  .larp-forum-topic-band-head p {
    margin: 0;
    color: #ccd5ce;
  }

  .larp-forum-topic-badge {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(98, 130, 104, 0.26);
    color: #eef4e7;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .larp-forum-topic-row-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    color: #a8b6ac;
    font-size: 0.88rem;
  }

  @media (max-width: 980px) {
    .larp-forum-hero,
    .larp-forum-grid {
      grid-template-columns: 1fr;
    }

    .larp-forum-board-row {
      grid-template-columns: 1fr;
    }

    .larp-forum-board-metric {
      min-width: 0;
      text-align: left;
    }
  }

  @media (max-width: 640px) {
    .larp-forum-hero,
    .larp-forum-board-list,
    .larp-forum-side-section,
    .larp-forum-topic-band {
      padding: 18px;
    }

    .larp-forum-hero h1 {
      font-size: 1.72rem;
    }

    .larp-forum-link-btn {
      width: 100%;
    }
  }
</style>

<section class="larp-forum-shell">
  <section class="larp-forum-hero">
    <div class="larp-forum-hero-copy">
      <span class="larp-forum-kicker">LARP Forum</span>
      <h1><%= character.name %></h1>
      <p>
        Ein ruhiger, moderner Treffpunkt fuer Absprachen, Kontakte, Gruppenideen und den naechsten
        Aufbruch. Hier landet dein LARP-Zugangsname direkt in einer Forum-Ansicht statt in der
        Bearbeitung.
      </p>
      <div class="larp-forum-hero-actions">
        <a class="larp-forum-link-btn is-primary" href="/characters/<%= character.id %>/guestbook">
          Gaestebuch
        </a>
        <a class="larp-forum-link-btn" href="/characters/<%= character.id %>/edit?mode=edit">
          Profil bearbeiten
        </a>
        <a class="larp-forum-link-btn" href="/dashboard/larp">
          Zurueck zum LARP-Bereich
        </a>
      </div>
      <div class="larp-forum-stat-row">
        <span class="larp-forum-stat-pill">
          Charakter <strong><%= character.name %></strong>
        </span>
        <span class="larp-forum-stat-pill">
          Mitglied seit <strong><%= characterCreatedAtLabel || "Unbekannt" %></strong>
        </span>
        <span class="larp-forum-stat-pill">
          Gilden <strong><%= guildCount %></strong>
        </span>
        <% birthdayRows.forEach((entry) => { %>
          <span class="larp-forum-stat-pill">
            <%= entry.label %> <strong><%= entry.value %></strong>
          </span>
        <% }) %>
      </div>
    </div>

    <div class="larp-forum-mark-wrap">
      <img
        class="larp-forum-mark"
        src="/theme-avatars/larp.svg?v=<%= staticAssetVersion %>"
        alt="LARP Symbol"
      />
      <p class="larp-forum-mark-caption">
        Mehr Lagerfeuer als Formular. Mehr Aufbruch als Leerlauf.
      </p>
    </div>
  </section>

  <section class="larp-forum-grid">
    <section class="larp-forum-board-list">
      <div class="larp-forum-section-head">
        <h2>Forenbereiche</h2>
        <p>Ein klarer Einstieg fuer Ankuendigungen, Kontakte, Gruppen und Plotideen.</p>
      </div>

      <% boardEntries.forEach((entry) => { %>
        <a class="larp-forum-board-row" href="#<%= entry.anchor %>">
          <div class="larp-forum-board-copy">
            <strong><%= entry.title %></strong>
            <span><%= entry.description %></span>
          </div>
          <div class="larp-forum-board-metric">
            <%= entry.threads %>
            <small><%= entry.posts %></small>
          </div>
          <div class="larp-forum-board-metric">
            Neu
            <small><%= entry.latest %></small>
          </div>
        </a>
      <% }) %>
    </section>

    <aside>
      <section class="larp-forum-side-section">
        <div class="larp-forum-section-head">
          <h3>Schnellzugriff</h3>
          <p>Kurze Wege fuer alles, was du gerade brauchst.</p>
        </div>

        <a class="larp-forum-quick-link" href="/characters/<%= character.id %>/guestbook">
          <strong>Mein Gaestebuch</strong>
          <span>Profil, Eintraege und persoenliche Seiten.</span>
        </a>
        <a class="larp-forum-quick-link" href="/characters/<%= character.id %>/edit?mode=edit">
          <strong>Mein Profil</strong>
          <span>Name, Farben und LARP-Details weiterfuehren.</span>
        </a>
        <a class="larp-forum-quick-link" href="/members">
          <strong>Mitglieder</strong>
          <span>Wer gerade da ist und wen du anspielen kannst.</span>
        </a>
      </section>

      <section class="larp-forum-side-section">
        <div class="larp-forum-section-head">
          <h3>Dein Fokus</h3>
          <p>Heute passt gut fuer ruhige Absprachen und neue Kontakte.</p>
        </div>

        <div class="larp-forum-topic-row">
          <strong><%= character.name %></strong>
          <span>Dein Zugangsname ist jetzt der Einstieg in den LARP-Forum-Bereich.</span>
          <div class="larp-forum-topic-row-meta">
            <span>LARP</span>
            <span>Eigener Bereich</span>
            <span>Bereit fuer neue Szenen</span>
          </div>
        </div>

        <div class="larp-forum-topic-row">
          <strong><%= guildCount > 0 ? "Lager im Blick" : "Platz fuer neue Gruppen" %></strong>
          <span>
            <%= guildCount > 0
              ? `${guildCount} Gilden warten darauf, weitergedacht zu werden.`
              : "Noch keine Gilde eingetragen. Ein guter Moment fuer den ersten Namen." %>
          </span>
          <div class="larp-forum-topic-row-meta">
            <span>Gemeinsam</span>
            <span>Ruhig aufgebaut</span>
            <span>Direkt im Bereich</span>
          </div>
        </div>
      </section>
    </aside>
  </section>

  <section class="larp-forum-topic-band" id="board-news">
    <div class="larp-forum-topic-band-head">
      <div>
        <h3>Ankuendigungen</h3>
        <p>Alles, was zuerst gesehen werden sollte.</p>
      </div>
      <span class="larp-forum-topic-badge">Wichtig</span>
    </div>

    <div class="larp-forum-topic-row">
      <strong>Willkommen im LARP-Bereich</strong>
      <span>Der direkte Klick auf deinen Namen bringt dich jetzt hierher.</span>
      <div class="larp-forum-topic-row-meta">
        <span>Heute</span>
        <span>Forumstart</span>
        <span>Lesen lohnt sich</span>
      </div>
    </div>

    <div class="larp-forum-topic-row">
      <strong>Regeln, Ton und gemeinsamer Rahmen</strong>
      <span>Ein Platz fuer Absprachen, ohne den RP- und ERP-Bereich zu vermischen.</span>
      <div class="larp-forum-topic-row-meta">
        <span>Ruhig</span>
        <span>Verstaendlich</span>
        <span>Direkt im Fokus</span>
      </div>
    </div>
  </section>

  <section class="larp-forum-topic-band" id="board-groups">
    <div class="larp-forum-topic-band-head">
      <div>
        <h3>Lager &amp; Gilden</h3>
        <p>Feste Gruppen, Banner, Rollen und gemeinsame Wege.</p>
      </div>
      <span class="larp-forum-topic-badge"><%= guildCount %> im Blick</span>
    </div>

    <% groupPreviewEntries.forEach((entry, index) => { %>
      <div class="larp-forum-topic-row">
        <strong><%= entry.title %></strong>
        <span>
          <%= index === 0
            ? "Hier kann aus einer Idee schnell ein gemeinsamer Auftritt werden."
            : "Ein guter Ort fuer neue Absprachen und klare Rollenbilder." %>
        </span>
        <div class="larp-forum-topic-row-meta">
          <span><%= entry.meta %></span>
          <span>Gruppenbereich</span>
          <span>LARP intern</span>
        </div>
      </div>
    <% }) %>
  </section>

  <section class="larp-forum-topic-band" id="board-characters">
    <div class="larp-forum-topic-band-head">
      <div>
        <h3>Charaktere &amp; Kontakte</h3>
        <p>Vorstellen, anfragen, verknuepfen.</p>
      </div>
      <span class="larp-forum-topic-badge">Offen fuer Kontakte</span>
    </div>

    <div class="larp-forum-topic-row">
      <strong><%= character.name %> stellt sich vor</strong>
      <span>Dein Profil kann von hier aus weiter in Richtung Kontakte und Spielideen wachsen.</span>
      <div class="larp-forum-topic-row-meta">
        <span>Charakterstart</span>
        <span>Kontakte</span>
        <span>Gaestebuch bereit</span>
      </div>
    </div>

    <div class="larp-forum-topic-row">
      <strong>Suche nach passenden Verbindungen</strong>
      <span>Ideal fuer Reisegruppen, alte Bekanntschaften oder den ersten Aufhaenger.</span>
      <div class="larp-forum-topic-row-meta">
        <span>Neue Gesuche</span>
        <span>Direkter Einstieg</span>
        <span>Locker gehalten</span>
      </div>
    </div>
  </section>

  <section class="larp-forum-topic-band" id="board-tavern">
    <div class="larp-forum-topic-band-head">
      <div>
        <h3>Tavernenrunde</h3>
        <p>Der weiche Platz fuer loses Zusammensitzen und kleine Zwischenmomente.</p>
      </div>
      <span class="larp-forum-topic-badge">Locker</span>
    </div>

    <div class="larp-forum-topic-row">
      <strong>Nach dem Spiel ist vor dem Lagerfeuer</strong>
      <span>Ein Ort fuer Nachklaenge, kurze Szenen und diesen stillen Rest von Abenteuer.</span>
      <div class="larp-forum-topic-row-meta">
        <span>Abends</span>
        <span>Taverne</span>
        <span>Offen fuer alle</span>
      </div>
    </div>
  </section>

  <section class="larp-forum-topic-band" id="board-plots">
    <div class="larp-forum-topic-band-head">
      <div>
        <h3>Plot &amp; Termine</h3>
        <p>Faden aufnehmen, Richtung finden, gemeinsam lostreten.</p>
      </div>
      <span class="larp-forum-topic-badge">Aufbruch</span>
    </div>

    <div class="larp-forum-topic-row">
      <strong>Naechste Reise mit <%= character.name %></strong>
      <span>Hooks, Treffpunkte und Spielideen lassen sich hier sauber sammeln.</span>
      <div class="larp-forum-topic-row-meta">
        <span>Planung</span>
        <span>Plotideen</span>
        <span>Bereit fuer Termine</span>
      </div>
    </div>
  </section>
</section>

<%- include("../partials/end") %>
