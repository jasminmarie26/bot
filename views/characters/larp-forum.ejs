<%- include("../partials/start") %>

<%
  const menuItems = [
    { label: "Home", href: "/", active: true },
    { label: "Forum", href: `/characters/${character.id}/edit`, caret: true },
    { label: "Projekte & Gilden", href: "#", caret: true },
    { label: "Mitglieder", href: "/members", caret: true },
    { label: "Kalender", href: "#", badge: "9", caret: true },
    { label: "Datenbank", href: `/characters/${character.id}/guestbook`, badge: "1", caret: true },
    { label: "Galerie", href: "#", badge: "1", caret: true },
    { label: "Storys", href: "#", caret: true },
    { label: "Artikel", href: "#", caret: false },
    { label: "Tickets", href: "#", caret: true }
  ];
%>

<style>
  .larp-list-shell {
    min-height: 220px;
    padding: 28px 0 10px;
  }

  .larp-list-stage {
    padding: 26px;
    border: 1px solid rgba(193, 209, 216, 0.44);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(179, 200, 209, 0.36), rgba(206, 215, 209, 0.26)),
      linear-gradient(135deg, rgba(176, 191, 181, 0.24), rgba(156, 183, 199, 0.28));
    box-shadow: 0 18px 44px rgba(35, 56, 68, 0.14);
    backdrop-filter: blur(8px);
  }

  .larp-list-nav {
    padding: 6px;
    border: 1px solid rgba(162, 181, 191, 0.45);
    border-radius: 8px;
    background: rgba(222, 231, 232, 0.42);
  }

  .larp-list-menu {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .larp-list-item {
    display: flex;
  }

  .larp-list-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 48px;
    padding: 0 14px;
    border-radius: 6px;
    color: #526777;
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
  }

  .larp-list-link.is-active {
    background: rgba(255, 255, 255, 0.38);
    color: #405767;
  }

  .larp-list-link:hover,
  .larp-list-link:focus-visible {
    background: rgba(255, 255, 255, 0.28);
    color: #425969;
  }

  .larp-list-icon {
    position: relative;
    width: 12px;
    height: 12px;
    border-radius: 3px;
    background: rgba(89, 105, 118, 0.9);
    flex: 0 0 12px;
  }

  .larp-list-icon::after {
    content: "";
    position: absolute;
    inset: 3px;
    border: 1px solid rgba(240, 245, 247, 0.6);
    border-radius: 2px;
  }

  .larp-list-text {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }

  .larp-list-caret {
    width: 6px;
    height: 6px;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(45deg) translateY(-1px);
    opacity: 0.8;
    flex: 0 0 auto;
  }

  .larp-list-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 19px;
    height: 19px;
    padding: 0 5px;
    border-radius: 999px;
    background: #ff4a3b;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1;
    box-shadow: 0 8px 18px rgba(255, 74, 59, 0.25);
  }

  @media (max-width: 920px) {
    .larp-list-stage {
      padding: 18px;
    }

    .larp-list-link {
      min-height: 44px;
      padding: 0 12px;
      font-size: 0.92rem;
    }
  }

  @media (max-width: 640px) {
    .larp-list-shell {
      padding-top: 18px;
    }

    .larp-list-stage {
      padding: 12px;
    }

    .larp-list-nav {
      padding: 4px;
    }

    .larp-list-menu {
      gap: 2px;
    }

    .larp-list-link {
      width: 100%;
      justify-content: flex-start;
    }

    .larp-list-item {
      width: 100%;
    }
  }
</style>

<section class="larp-list-shell">
  <div class="larp-list-stage">
    <nav class="larp-list-nav" aria-label="LARP Navigation">
      <ul class="larp-list-menu">
        <% menuItems.forEach((item) => { %>
          <li class="larp-list-item">
            <a
              class="larp-list-link<%= item.active ? " is-active" : "" %>"
              href="<%= item.href %>"
            >
              <span class="larp-list-icon" aria-hidden="true"></span>
              <span class="larp-list-text">
                <span><%= item.label %></span>
                <% if (item.badge) { %>
                  <span class="larp-list-badge"><%= item.badge %></span>
                <% } %>
                <% if (item.caret) { %>
                  <span class="larp-list-caret" aria-hidden="true"></span>
                <% } %>
              </span>
            </a>
          </li>
        <% }) %>
      </ul>
    </nav>
  </div>
</section>

<%- include("../partials/end") %>
