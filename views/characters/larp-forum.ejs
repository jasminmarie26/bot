<%- include("../partials/start") %>

<%
  const menuItems = [
    { label: "Home", href: "/", active: true },
    { label: "Forum", href: `/characters/${character.id}/edit`, caret: true },
    { label: "Projekte & Gilden", href: "#", caret: true },
    { label: "Mitglieder", href: "/members", caret: true },
    { label: "Kalender", href: "#", caret: true },
    { label: "Datenbank", href: `/characters/${character.id}/guestbook`, caret: true },
    { label: "Galerie", href: "#", caret: true },
    { label: "Storys", href: "#", caret: true },
    { label: "Artikel", href: "#", caret: false },
    { label: "Tickets", href: "#", caret: true }
  ];
%>

<style>
  .larp-list-shell {
    min-height: 160px;
    padding: 18px 0 6px;
  }

  .larp-list-stage {
    position: relative;
    padding: 10px 0;
  }

  .larp-list-nav {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--panel-edge);
    border-radius: 8px;
    background: color-mix(in srgb, var(--panel-bg) 72%, white 28%);
    box-shadow: 0 18px 38px -30px var(--panel-shadow);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
  }

  .larp-list-nav::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 56px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 160ms ease;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--panel-bg) 0%, transparent 100%) 0%,
      color-mix(in srgb, var(--panel-bg) 88%, white 12%) 100%
    );
  }

  .larp-list-nav.is-overflowing:not(.is-end)::after {
    opacity: 1;
  }

  .larp-list-scroll {
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .larp-list-scroll::-webkit-scrollbar {
    display: none;
  }

  .larp-list-overflow-arrow {
    position: absolute;
    top: 50%;
    right: 14px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border: 0;
    padding: 0;
    background: transparent;
    color: var(--text);
    opacity: 0;
    transform: translateY(-50%);
    pointer-events: none;
    transition: opacity 160ms ease;
  }

  .larp-list-nav.is-overflowing:not(.is-end) .larp-list-overflow-arrow {
    opacity: 0.82;
  }

  .larp-list-menu {
    display: flex;
    flex-wrap: nowrap;
    gap: 2px;
    margin: 0;
    padding: 4px;
    list-style: none;
    width: max-content;
    min-width: 100%;
  }

  .larp-list-item {
    display: flex;
    flex: 0 0 auto;
  }

  .larp-list-link {
    display: inline-flex;
    align-items: center;
    gap: 0;
    min-height: 40px;
    padding: 0 12px;
    border-radius: 6px;
    color: var(--text);
    font-size: 0.93rem;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    opacity: 0.92;
  }

  .larp-list-link.is-active {
    background: color-mix(in srgb, var(--field-bg) 52%, white 48%);
    color: var(--text);
  }

  .larp-list-link:hover,
  .larp-list-link:focus-visible {
    background: color-mix(in srgb, var(--field-bg) 44%, white 30%);
    color: var(--text);
    opacity: 1;
  }

  .larp-list-text {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .larp-list-caret {
    width: 7px;
    height: 7px;
    border-right: 1.4px solid currentColor;
    border-bottom: 1.4px solid currentColor;
    transform: rotate(45deg) translateY(-2px);
    opacity: 0.8;
    flex: 0 0 auto;
  }

  .larp-list-overflow-arrow::before {
    content: "";
    display: block;
    width: 9px;
    height: 9px;
    border-top: 1.8px solid currentColor;
    border-right: 1.8px solid currentColor;
    transform: rotate(45deg);
  }

  @media (max-width: 920px) {
    .larp-list-shell {
      padding-top: 14px;
    }

    .larp-list-link {
      min-height: 38px;
      padding: 0 10px;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 640px) {
    .larp-list-shell {
      padding-top: 10px;
    }

    .larp-list-menu {
      padding-right: 34px;
    }
  }
</style>

<section class="larp-list-shell">
  <div class="larp-list-stage">
    <nav class="larp-list-nav" aria-label="LARP Navigation" data-larp-list-nav>
      <div class="larp-list-scroll" data-larp-list-scroll>
        <ul class="larp-list-menu">
          <% menuItems.forEach((item) => { %>
            <li class="larp-list-item">
              <a
                class="larp-list-link<%= item.active ? " is-active" : "" %>"
                href="<%= item.href %>"
              >
                <span class="larp-list-text">
                  <span><%= item.label %></span>
                  <% if (item.caret) { %>
                    <span class="larp-list-caret" aria-hidden="true"></span>
                  <% } %>
                </span>
              </a>
            </li>
          <% }) %>
        </ul>
      </div>
      <span class="larp-list-overflow-arrow" aria-hidden="true"></span>
    </nav>
  </div>
</section>

<script>
  (() => {
    document.addEventListener("DOMContentLoaded", () => {
      const nav = document.querySelector("[data-larp-list-nav]");
      const scrollArea = document.querySelector("[data-larp-list-scroll]");
      if (!nav || !scrollArea) return;

      const syncOverflowState = () => {
        const maxScrollLeft = Math.max(0, scrollArea.scrollWidth - scrollArea.clientWidth);
        const isOverflowing = maxScrollLeft > 6;
        const isEnd = scrollArea.scrollLeft >= maxScrollLeft - 6;

        nav.classList.toggle("is-overflowing", isOverflowing);
        nav.classList.toggle("is-end", !isOverflowing || isEnd);
      };

      syncOverflowState();
      scrollArea.addEventListener("scroll", syncOverflowState, { passive: true });
      window.addEventListener("resize", syncOverflowState);

      if ("ResizeObserver" in window) {
        const observer = new ResizeObserver(syncOverflowState);
        observer.observe(scrollArea);
      }
    });
  })();
</script>

<%- include("../partials/end") %>
