<%- include("../../partials/start", { hideTopbar: true, enableRealtime: false }) %>

<section class="gb-editor-shell">
  <header class="gb-editor-topbar">
    <a class="rp-logo" href="/">Heldenhafte Reisen</a>

    <div class="gb-editor-actions">
      <a class="btn btn-secondary" href="/characters/<%= character.id %>/edit">Zum Charakter</a>
      <a class="btn btn-secondary" href="/characters/<%= character.id %>/guestbook">G&auml;stebuch ansehen</a>
      <button class="btn" type="submit" form="guestbook-editor-form">Speichern</button>
      <button
        class="btn btn-secondary"
        type="submit"
        form="guestbook-editor-form"
        formaction="/characters/<%= character.id %>/guestbook/edit/preview?page_id=<%= activePage.id %>"
        formmethod="POST"
        formtarget="guestbook-preview-<%= character.id %>"
      >
        Vorschau
      </button>

      <form method="POST" action="/characters/<%= character.id %>/guestbook/edit/add-page" class="inline-form">
        <input type="hidden" name="page_id" value="<%= activePage.id %>" />
        <button class="btn btn-secondary" type="submit">Seite hinzuf&uuml;gen</button>
      </form>

      <form method="POST" action="/characters/<%= character.id %>/guestbook/edit/delete-page" class="inline-form">
        <input type="hidden" name="page_id" value="<%= activePage.id %>" />
        <button
          class="btn btn-danger"
          type="submit"
          onclick="return confirm('Aktuelle Seite wirklich l&ouml;schen?')"
        >
          Aktuelle Seite l&ouml;schen
        </button>
      </form>
    </div>

    <form method="POST" action="/settings/theme" class="inline-form theme-form">
      <label for="gb-theme-select">Design</label>
      <input type="hidden" name="return_to" value="<%= currentPath || '/' %>" />
      <select
        id="gb-theme-select"
        name="theme"
        class="theme-select"
      >
        <% availableThemes.forEach((theme) => { %>
          <option value="<%= theme.id %>" <%= activeTheme === theme.id ? "selected" : "" %>>
            <%= theme.label %>
          </option>
        <% }) %>
      </select>
    </form>

    <form method="POST" action="/logout" class="inline-form">
      <button type="submit" class="ghost-btn">Logout</button>
    </form>
  </header>

  <section class="panel">
    <div class="header-line">
      <div>
        <h1>G&auml;stebuch bearbeiten</h1>
        <p class="muted">
          Du bearbeitest gerade das G&auml;stebuch von <strong><%= character.name %></strong> auf einer eigenen Seite.
        </p>
      </div>
    </div>
  </section>

  <nav class="panel character-editor-journey guestbook-editor-journey" aria-label="G&auml;stebuch Schritte">
    <div class="character-editor-journey-track">
      <a class="character-editor-journey-step" href="/characters/<%= character.id %>/edit">
        <span class="character-editor-journey-step-number">1</span>
        <span class="character-editor-journey-step-copy">
          <strong>Charakter</strong>
          <small>Zur&uuml;ck zur Bearbeitung</small>
        </span>
      </a>

      <button
        type="button"
        class="character-editor-journey-step"
        data-guestbook-journey-step="design"
        aria-controls="gb-editor-page-design"
        aria-selected="false"
      >
        <span class="character-editor-journey-step-number">2</span>
        <span class="character-editor-journey-step-copy">
          <strong>Design</strong>
          <small>Theme, Farben und Stil</small>
        </span>
      </button>

      <button
        type="button"
        class="character-editor-journey-step"
        data-guestbook-journey-step="content"
        aria-controls="gb-editor-page-content"
        aria-selected="false"
      >
        <span class="character-editor-journey-step-number">3</span>
        <span class="character-editor-journey-step-copy">
          <strong>Inhalt</strong>
          <small>Bilder, Texte und BBCode</small>
        </span>
      </button>
    </div>
  </nav>

  <% if ((pages || []).length > 1) { %>
    <nav class="gb-editor-tabs" aria-label="G&auml;stebuch Seiten">
      <% pages.forEach((page) => { %>
        <a
          class="gb-editor-tab <%= page.id === activePage.id ? "is-active" : "" %>"
          href="/characters/<%= character.id %>/guestbook/edit?page_id=<%= page.id %>"
        >
          <%= page.page_number %>
        </a>
      <% }) %>
    </nav>
  <% } %>

  <%- include("../../partials/guestbook-editor-form", {
    guestbookEditorFormClass: "panel form gb-editor-form",
    guestbookEditorUseOuterNavigation: true
  }) %>
</section>

<script>
  (() => {
    const journeyButtons = Array.from(document.querySelectorAll("[data-guestbook-journey-step]"));
    if (!journeyButtons.length) {
      return;
    }

    const setActiveStep = (stepName) => {
      const normalizedStep = String(stepName || "").trim().toLowerCase() === "content" ? "content" : "design";
      journeyButtons.forEach((button) => {
        const isActive =
          String(button.dataset.guestbookJourneyStep || "").trim().toLowerCase() === normalizedStep;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-selected", isActive ? "true" : "false");
      });
    };

    journeyButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const nextStep = String(button.dataset.guestbookJourneyStep || "").trim().toLowerCase() || "design";
        if (typeof window.setGuestbookEditorPage === "function") {
          window.setGuestbookEditorPage(nextStep);
        }
        setActiveStep(nextStep);
      });
    });

    window.addEventListener("guestbook-editor-pagechange", (event) => {
      setActiveStep(event.detail?.page);
    });

    const initialStep =
      typeof window.getGuestbookEditorPage === "function"
        ? window.getGuestbookEditorPage()
        : "design";
    setActiveStep(initialStep);
  })();
</script>

<%- include("../../partials/end") %>
