<%- include("partials/start") %>

<section class="header-line dashboard-page-header">
  <div>
    <h1>Geloeschte Charaktere</h1>
    <p class="muted">Hier kannst du geloeschte Charaktere mit Gaestebuch, Farbe und Gaestebucheintraegen wiederherstellen.</p>
  </div>
</section>

<section class="dashboard-block">
  <details class="dashboard-festplay-overview dashboard-character-overview" open>
    <summary class="dashboard-festplay-overview-header">
      <div class="dashboard-festplay-overview-title">
        <h3>Geloeschte Charaktere</h3>
        <span class="dashboard-festplay-count">(<%= Array.isArray(characterBackups) ? characterBackups.length : 0 %>)</span>
      </div>
      <span class="dashboard-festplay-toggle-icon" aria-hidden="true"></span>
    </summary>

    <div class="dashboard-server-panel dashboard-character-overview-body">
      <% if (!characterBackups || !characterBackups.length) { %>
        <p class="muted">Noch keine geloeschten Charaktere vorhanden.</p>
      <% } else { %>
        <div class="character-mini-grid">
          <% characterBackups.forEach((backup) => { %>
            <article class="character-mini-card">
              <div class="character-mini-item">
                <span class="character-mini-name"><%= backup.character_name %></span>
              </div>
              <div class="character-mini-actions">
                <form
                  method="POST"
                  action="/character-backups/<%= backup.id %>/restore"
                  class="character-mini-move-form"
                  onsubmit="return confirm('Charakter wirklich wiederherstellen?')"
                >
                  <button
                    type="submit"
                    class="character-mini-move-btn"
                    aria-label="Charakter wiederherstellen"
                    title="Charakter wiederherstellen"
                  >
                    &olarr;
                  </button>
                </form>
                <form
                  method="POST"
                  action="/character-backups/<%= backup.id %>/delete"
                  class="character-mini-delete-form"
                  onsubmit="return confirm('Backup endgueltig loeschen? Danach kann der Charakter nie wieder wiederhergestellt werden.')"
                >
                  <button
                    type="submit"
                    class="character-mini-delete-btn"
                    aria-label="Backup endgueltig loeschen"
                    title="Backup endgueltig loeschen"
                  >
                    X
                  </button>
                </form>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  </details>
</section>

<%- include("partials/end") %>
