<%- include("partials/start") %>

<%
  const overviewTitle = panelTitle || "Adminbereich";
  const overviewBasePath = panelBasePath || "/admin";
  const detailBasePath = userDetailsBasePath || "/admin/users";
  const allowUserDeletion =
    typeof canDeleteUsers === "undefined" ? true : Boolean(canDeleteUsers);
  const currentSearchQuery = String(searchQuery || "");
  const visibleUsers = Array.isArray(users) ? users : [];
  const pagination = userPagination || {};
  const currentPage = Number(pagination.currentPage) || 1;
  const totalPages = Number(pagination.totalPages) || 1;
  const pageSize = Number(pagination.pageSize) || 10;
  const totalFilteredUsers =
    typeof filteredUserCount === "number" ? filteredUserCount : visibleUsers.length;
  const visibleStart = totalFilteredUsers ? (currentPage - 1) * pageSize + 1 : 0;
  const visibleEnd = totalFilteredUsers ? visibleStart + visibleUsers.length - 1 : 0;
  const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);
  const buildUserPageUrl = (pageNumber) => {
    const queryParts = [];
    if (currentSearchQuery) {
      queryParts.push(`q=${encodeURIComponent(currentSearchQuery)}`);
    }
    if (pageNumber > 1) {
      queryParts.push(`page=${encodeURIComponent(String(pageNumber))}`);
    }
    const queryString = queryParts.join("&");
    return queryString ? `${overviewBasePath}?${queryString}` : overviewBasePath;
  };
%>

<section class="panel account-layout">
  <div class="header-line">
    <div>
      <h1><%= overviewTitle %></h1>
      <p class="muted">Hier ist alles gesammelt und als Tabelle aufger&auml;umt.</p>
    </div>
  </div>

  <div class="help-table-wrap">
    <table class="help-table admin-overview-table">
      <thead>
        <tr>
          <th>Bereich</th>
          <th>Wert</th>
          <th>Hinweis</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Accounts gesamt</td>
          <td><strong><%= accountCount %></strong></td>
          <td>Alle aktuell registrierten Konten auf der Plattform.</td>
        </tr>
        <tr>
          <td>Admins</td>
          <td><strong><%= adminCount %></strong></td>
          <td>Benutzer mit vollem Zugriff auf Verwaltung, Rollen und Einstellungen.</td>
        </tr>
        <tr>
          <td>Moderatoren</td>
          <td><strong><%= moderatorCount %></strong></td>
          <td>Benutzer mit Moderationsrechten ohne kompletten Adminzugriff.</td>
        </tr>
        <tr>
          <td>Verd&auml;chtige Accounts</td>
          <td><strong><%= suspiciousUsers?.length || 0 %></strong></td>
          <td>Auff&auml;llige Konten mit schneller Pr&uuml;fung und Direktzugriff.</td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<section class="panel account-layout">
  <h2>Als Benutzer testen</h2>
  <p class="muted">Der Testmodus startet direkt aus der Tabelle.</p>

  <form method="POST" action="/admin/impersonate" class="form admin-settings-form">
    <div class="help-table-wrap">
      <table class="help-table admin-settings-table">
        <thead>
          <tr>
            <th>Funktion</th>
            <th>Eingabe</th>
            <th>Aktion</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Testmodus</td>
            <td>
              <label class="account-table-field">
                <input
                  name="username"
                  type="text"
                  maxlength="24"
                  autocomplete="off"
                  placeholder="Benutzername eingeben"
                  required
                />
              </label>
            </td>
            <td>
              <button class="btn" type="submit">Testmodus starten</button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </form>
</section>

<% if (suspiciousUsers && suspiciousUsers.length) { %>
  <section class="panel account-layout">
    <h2>Verd&auml;chtige Accounts</h2>
    <p class="muted">Auff&auml;llige Konten mit schnellem Direktzugriff.</p>

    <div class="help-table-wrap">
      <table class="help-table admin-suspicious-table">
        <thead>
          <tr>
            <th>Account</th>
            <th>Daten</th>
            <th>Gr&uuml;nde</th>
            <th>Aktion</th>
          </tr>
        </thead>
        <tbody>
          <% suspiciousUsers.forEach((user) => { %>
            <tr>
              <td>
                <div class="admin-account-name">
                  <% if (user.is_online) { %>
                    <span class="admin-online-dot" aria-label="Online" title="Online"></span>
                  <% } %>
                  <strong><%= user.username %></strong>
                </div>
                <div class="admin-table-subline">
                  <span>#<%= user.account_number %></span>
                  <span>IP: <%= user.last_login_ip || "-" %></span>
                </div>
              </td>
              <td>
                <div class="admin-table-subline">
                  <span>E-Mail: <%= user.email || "-" %></span>
                  <span>Geburtsdatum: <%= user.birth_date || "-" %></span>
                </div>
              </td>
              <td><%= user.suspicion_reasons.join(", ") %></td>
              <td>
                <div class="admin-table-actions">
                  <a
                    class="btn btn-secondary"
                    href="<%= `${detailBasePath}/${user.id}` %>"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Pr&uuml;fen
                  </a>
                  <% if (allowUserDeletion && user.id !== currentUser.id) { %>
                    <form method="POST" action="/admin/users/<%= user.id %>/delete" class="inline-form">
                      <button class="btn btn-danger" type="submit">L&ouml;schen</button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
<% } %>

<section class="panel account-layout">
  <div class="header-line">
    <div>
      <h2>Benutzerverwaltung</h2>
      <p class="muted">
        Die Details &ouml;ffnen sich in einem neuen Tab. Dort findest du unten auch Charaktere und G&auml;steb&uuml;cher.
      </p>
    </div>
  </div>

  <form method="GET" action="<%= overviewBasePath %>" class="admin-tools">
    <label class="admin-search">
      <span>Suchen</span>
      <input
        id="admin-user-search"
        name="q"
        class="admin-search-input"
        type="search"
        placeholder="Name, E-Mail, Geburtsdatum oder IP"
        autocomplete="off"
        value="<%= currentSearchQuery %>"
      />
    </label>
    <div class="admin-table-actions">
      <button class="btn" type="submit">Suchen</button>
      <% if (currentSearchQuery) { %>
        <a class="btn btn-secondary" href="<%= overviewBasePath %>">Zur&uuml;cksetzen</a>
      <% } %>
    </div>
  </form>

  <p class="muted">
    <% if (totalFilteredUsers) { %>
      Zeige <%= visibleStart %> bis <%= visibleEnd %> von <%= totalFilteredUsers %> Accounts.
      Seite <%= currentPage %> von <%= totalPages %>.
    <% } else if (currentSearchQuery) { %>
      Keine passenden Benutzer gefunden.
    <% } else { %>
      Noch keine Benutzer vorhanden.
    <% } %>
  </p>

  <% if (visibleUsers.length) { %>
    <div class="help-table-wrap">
      <table class="help-table admin-user-table">
        <thead>
          <tr>
            <th>Account</th>
            <th>E-Mail</th>
            <th>Geburtsdatum</th>
            <th>Rollen</th>
            <th>Status</th>
            <th>Aktion</th>
          </tr>
        </thead>
        <tbody>
          <% visibleUsers.forEach((user) => { %>
            <tr class="admin-user-row">
              <td>
                <div class="admin-account-name">
                  <% if (user.is_online) { %>
                    <span class="admin-online-dot" aria-label="Online" title="Online"></span>
                  <% } %>
                  <strong><%= user.username %></strong>
                </div>
                <div class="admin-table-subline">
                  <span>#<%= user.account_number %></span>
                  <span>Erstellt: <%= user.created_at || "-" %></span>
                </div>
              </td>
              <td><%= user.email || "-" %></td>
              <td><%= user.birth_date || "-" %></td>
              <td>
                <div class="admin-table-badges">
                  <% if (user.is_admin) { %>
                    <span class="admin-role-badge is-admin">Admin</span>
                  <% } %>
                  <% if (user.is_moderator) { %>
                    <span class="admin-role-badge is-moderator">Moderator</span>
                  <% } %>
                  <% if (!user.is_admin && !user.is_moderator) { %>
                    <span class="admin-role-badge">User</span>
                  <% } %>
                </div>
              </td>
              <td>
                <div class="admin-table-subline">
                  <span><%= user.is_suspicious ? "Verd&auml;chtig" : "Unauff&auml;llig" %></span>
                  <span>Letzte IP: <%= user.last_login_ip || "-" %></span>
                </div>
              </td>
              <td>
                <div class="admin-table-actions">
                  <a
                    class="btn btn-secondary"
                    href="<%= `${detailBasePath}/${user.id}` %>"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Details
                  </a>
                  <% if (allowUserDeletion && user.id !== currentUser.id) { %>
                    <form method="POST" action="/admin/users/<%= user.id %>/delete" class="inline-form">
                      <button class="btn btn-danger" type="submit">L&ouml;schen</button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (totalPages > 1) { %>
      <nav class="site-updates-pagination" aria-label="Benutzer Seitenwechsel">
        <% if (pagination.hasPreviousPage) { %>
          <a class="site-updates-page-link" href="<%= buildUserPageUrl(pagination.previousPage) %>">
            &#8249;
          </a>
        <% } %>

        <% pageNumbers.forEach((pageNumber) => { %>
          <a
            class="site-updates-page-link<%= pageNumber === currentPage ? ' is-active' : '' %>"
            href="<%= buildUserPageUrl(pageNumber) %>"
          >
            <%= pageNumber %>
          </a>
        <% }) %>

        <% if (pagination.hasNextPage) { %>
          <a class="site-updates-page-link" href="<%= buildUserPageUrl(pagination.nextPage) %>">
            &#8250;
          </a>
        <% } %>
      </nav>
    <% } %>
  <% } %>
</section>

<%- include("partials/end") %>
