<%- include("partials/start") %>

<%
  const sortedUsers = [...users].sort((a, b) =>
    String(a.username || "").localeCompare(String(b.username || ""), "de", {
      sensitivity: "base"
    })
  );
  const groupedUsers = sortedUsers.reduce((groups, user) => {
    const firstChar = String(user.username || "").trim().charAt(0).toUpperCase();
    const letter = /[A-ZÄÖÜ]/i.test(firstChar) ? firstChar : "#";
    if (!groups[letter]) {
      groups[letter] = [];
    }
    groups[letter].push(user);
    return groups;
  }, {});
  const userLetters = Object.keys(groupedUsers).sort((a, b) =>
    a.localeCompare(b, "de", { sensitivity: "base" })
  );
%>

<section class="panel">
  <h1>Adminbereich</h1>
  <p class="muted">Accounts gesamt: <strong><%= accountCount %></strong></p>
  <p class="muted">Aktuelle Admins: <strong><%= adminCount %></strong></p>
  <p class="muted">Aktuelle Moderatoren: <strong><%= moderatorCount %></strong></p>
</section>

<% if (suspiciousUsers && suspiciousUsers.length) { %>
  <section class="panel">
    <h2>Verdächtige Accounts</h2>
    <p class="muted">
      Hier siehst du auffällige Accounts gesammelt, damit du sie schnell prüfen oder
      löschen kannst.
    </p>

    <div class="list">
      <% suspiciousUsers.forEach((user) => { %>
        <article class="list-item admin-user-card suspicious-user-card">
          <div class="admin-user-meta">
            <strong><%= user.username %></strong>
            <span>E-Mail: <%= user.email || "-" %></span>
            <span>Geburtsdatum: <%= user.birth_date || "-" %></span>
            <span>Letzte IP: <%= user.last_login_ip || "-" %></span>
            <span>Gründe: <%= user.suspicion_reasons.join(", ") %></span>
          </div>
          <div class="dashboard-server-actions">
            <a
              class="btn btn-secondary"
              href="/admin/users/<%= user.id %>"
              target="_blank"
              rel="noopener noreferrer"
            >
              Prüfen
            </a>
            <% if (user.id !== currentUser.id) { %>
              <form method="POST" action="/admin/users/<%= user.id %>/delete" class="inline-form">
                <button class="btn btn-danger" type="submit">Löschen</button>
              </form>
            <% } %>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
<% } %>

<section class="panel">
  <div class="header-line">
    <div>
      <h2>Benutzerverwaltung</h2>
      <p class="muted">
        Klicke auf einen Namen. Die Details öffnen sich in einem neuen Tab, dort
        findest du unten auch die Charaktere und Gästebücher.
      </p>
    </div>
  </div>

  <div class="admin-tools">
    <label class="admin-search">
      <span>Suchen</span>
      <input
        id="admin-user-search"
        class="admin-search-input"
        type="search"
        placeholder="Name, E-Mail, Geburtsdatum oder IP"
        autocomplete="off"
      />
    </label>

    <% if (userLetters.length) { %>
      <nav class="admin-letter-bar" aria-label="Benutzer nach Buchstaben">
        <% userLetters.forEach((letter) => { %>
          <a class="admin-letter-link" href="#admin-letter-<%= encodeURIComponent(letter) %>"><%= letter %></a>
        <% }) %>
      </nav>
    <% } %>
  </div>

  <% if (!sortedUsers.length) { %>
    <p class="muted">Noch keine Benutzer vorhanden.</p>
  <% } else { %>
    <div class="admin-user-groups">
      <% userLetters.forEach((letter) => { %>
        <section
          id="admin-letter-<%= encodeURIComponent(letter) %>"
          class="admin-letter-group"
          data-letter-group
        >
          <div class="admin-letter-heading">
            <h3><%= letter %></h3>
            <span><%= groupedUsers[letter].length %> Benutzer</span>
          </div>

          <div class="admin-name-grid">
            <% groupedUsers[letter].forEach((user) => { %>
              <%
                const searchValues = [
                  user.username,
                  user.email,
                  user.birth_date,
                  user.last_login_ip,
                  user.created_at
                ]
                  .filter(Boolean)
                  .join(" ");
              %>
              <a
                class="admin-user-link"
                href="/admin/users/<%= user.id %>"
                target="_blank"
                rel="noopener noreferrer"
                data-user-link
                data-search="<%= searchValues %>"
              >
                <span class="admin-user-link-top">
                  <span class="admin-user-link-name"><%= user.username %></span>
                  <span class="admin-user-link-meta">#<%= user.account_number %></span>
                </span>
                <span class="admin-user-link-details">
                  <span>E-Mail: <%= user.email || "-" %></span>
                  <span>Geburtsdatum: <%= user.birth_date || "-" %></span>
                </span>
                <span class="admin-user-link-badges">
                  <% if (user.is_admin) { %>
                    <span class="admin-role-badge is-admin">Admin</span>
                  <% } else if (user.is_moderator) { %>
                    <span class="admin-role-badge is-moderator">Moderator</span>
                  <% } %>
                  <% if (user.is_suspicious) { %>
                    <span class="admin-role-badge is-suspicious">Verdächtig</span>
                  <% } %>
                </span>
              </a>
            <% }) %>
          </div>
        </section>
      <% }) %>
    </div>
  <% } %>
</section>

<script>
  (() => {
    const normalizeSearchValue = (value) =>
      String(value || "")
        .toLowerCase()
        .replace(/ä/g, "ae")
        .replace(/ö/g, "oe")
        .replace(/ü/g, "ue")
        .replace(/ß/g, "ss")
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "");

    document.addEventListener("DOMContentLoaded", () => {
      const searchInput = document.getElementById("admin-user-search");
      if (!searchInput) return;

      const userLinks = Array.from(document.querySelectorAll("[data-user-link]"));
      const letterGroups = Array.from(document.querySelectorAll("[data-letter-group]"));

      const applyFilter = () => {
        const query = normalizeSearchValue(searchInput.value);

        userLinks.forEach((link) => {
          const haystack = normalizeSearchValue(link.getAttribute("data-search"));
          link.hidden = Boolean(query) && !haystack.includes(query);
        });

        letterGroups.forEach((group) => {
          const hasVisibleLinks = Array.from(group.querySelectorAll("[data-user-link]")).some(
            (link) => !link.hidden
          );
          group.hidden = !hasVisibleLinks;
        });
      };

      searchInput.addEventListener("input", applyFilter);
      applyFilter();
    });
  })();
</script>

<%- include("partials/end") %>
