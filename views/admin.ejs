<%- include("partials/start") %>

<%
  const sortedUsers = [...users].sort((a, b) =>
    String(a.username || "").localeCompare(String(b.username || ""), "de", {
      sensitivity: "base"
    })
  );
  const groupedUsers = sortedUsers.reduce((groups, user) => {
    const firstChar = String(user.username || "").trim().charAt(0).toUpperCase();
    const letter = /[A-ZÄÖÜ]/i.test(firstChar) ? firstChar : "#";
    if (!groups[letter]) {
      groups[letter] = [];
    }
    groups[letter].push(user);
    return groups;
  }, {});
  const userLetters = Object.keys(groupedUsers).sort((a, b) =>
    a.localeCompare(b, "de", { sensitivity: "base" })
  );
%>

<section class="panel">
  <h1>Adminbereich</h1>
  <p class="muted">Accounts gesamt: <strong><%= accountCount %></strong></p>
  <p class="muted">Aktuelle Admins: <strong><%= adminCount %></strong></p>
  <p class="muted">Aktuelle Moderatoren: <strong><%= moderatorCount %></strong></p>
  <p class="muted">Hinweis: Passwörter sind aus Sicherheitsgründen nicht lesbar. Du kannst sie nur zurücksetzen.</p>
</section>

<section class="panel">
  <h2>Festplays verwalten</h2>
  <form method="POST" action="/admin/festplays" class="form">
    <label>
      Neues Festplay
      <input name="name" maxlength="80" required placeholder="z. B. Sigel der Welten" />
    </label>
    <button class="btn" type="submit">Festplay anlegen</button>
  </form>

  <div class="list">
    <% festplays.forEach((festplay) => { %>
      <article class="list-item">
        <strong><%= festplay.name %></strong>
        <form method="POST" action="/admin/festplays/<%= festplay.id %>/delete" class="inline-form">
          <button class="btn btn-danger" type="submit">Löschen</button>
        </form>
      </article>
    <% }) %>
  </div>
</section>

<section class="panel">
  <div class="header-line">
    <div>
      <h2>Benutzerverwaltung</h2>
      <p class="muted">Nach Buchstaben sortiert. Ein Klick auf den Namen öffnet die Bearbeitung.</p>
    </div>
  </div>

  <div class="admin-tools">
    <label class="admin-search">
      <span>Suchen</span>
      <input
        id="admin-user-search"
        class="admin-search-input"
        type="search"
        placeholder="Name, E-Mail oder IP"
        autocomplete="off"
      />
    </label>

    <% if (userLetters.length) { %>
      <nav class="admin-letter-bar" aria-label="Benutzer nach Buchstaben">
        <% userLetters.forEach((letter) => { %>
          <a class="admin-letter-link" href="#admin-letter-<%= encodeURIComponent(letter) %>"><%= letter %></a>
        <% }) %>
      </nav>
    <% } %>
  </div>

  <% if (!sortedUsers.length) { %>
    <p class="muted">Noch keine Benutzer vorhanden.</p>
  <% } else { %>
    <div class="admin-user-groups">
      <% userLetters.forEach((letter) => { %>
        <section
          id="admin-letter-<%= encodeURIComponent(letter) %>"
          class="admin-letter-group"
          data-letter-group
        >
          <div class="admin-letter-heading">
            <h3><%= letter %></h3>
            <span><%= groupedUsers[letter].length %> Benutzer</span>
          </div>

          <div class="admin-user-stack">
            <% groupedUsers[letter].forEach((user) => { %>
              <%
                const searchValues = [
                  user.username,
                  user.email,
                  user.last_login_ip,
                  user.created_at
                ]
                  .filter(Boolean)
                  .join(" ");
              %>
              <details
                class="list-item admin-user-card admin-user-accordion"
                data-user-card
                data-search="<%= searchValues %>"
              >
                <summary class="admin-user-summary">
                  <div class="admin-user-summary-main">
                    <strong>#<%= user.account_number %> <%= user.username %></strong>
                    <div class="admin-user-role-list">
                      <% if (user.is_admin) { %>
                        <span class="admin-role-badge is-admin">Admin</span>
                      <% } %>
                      <% if (user.is_moderator) { %>
                        <span class="admin-role-badge is-moderator">Moderator</span>
                      <% } %>
                      <% if (!user.is_admin && !user.is_moderator) { %>
                        <span class="admin-role-badge">User</span>
                      <% } %>
                    </div>
                  </div>
                  <div class="admin-user-summary-meta">
                    <span><%= user.email || "Keine E-Mail" %></span>
                    <span><%= user.character_count %> Charaktere</span>
                  </div>
                </summary>

                <div class="admin-user-details">
                  <div class="admin-user-meta">
                    <span>E-Mail: <%= user.email || "-" %></span>
                    <span>Charaktere: <%= user.character_count %></span>
                    <span>Letzter Login: <%= user.last_login_at || "-" %></span>
                    <span>Letzte IP: <%= user.last_login_ip || "-" %></span>
                    <small>Erstellt: <%= user.created_at %></small>
                  </div>

                  <div class="admin-user-forms">
                    <form method="POST" action="/admin/users/<%= user.id %>/update-basic" class="admin-inline-form">
                      <label>
                        Name
                        <input name="username" maxlength="24" value="<%= user.username %>" required />
                      </label>
                      <label>
                        E-Mail
                        <input name="email" maxlength="255" value="<%= user.email %>" placeholder="name@domain.tld" />
                      </label>
                      <button class="btn btn-secondary" type="submit">Basisdaten speichern</button>
                    </form>

                    <form method="POST" action="/admin/users/<%= user.id %>/reset-password" class="admin-inline-form">
                      <label>
                        Neues Passwort
                        <input name="new_password" type="password" minlength="6" required placeholder="Mind. 6 Zeichen" />
                      </label>
                      <button class="btn btn-secondary" type="submit">Passwort zurücksetzen</button>
                    </form>

                    <div class="dashboard-server-actions">
                      <% if (user.id === currentUser.id) { %>
                        <small>Dein eigener Account</small>
                      <% } else { %>
                        <form method="POST" action="/admin/users/<%= user.id %>/toggle-admin" class="inline-form">
                          <% if (user.is_admin) { %>
                            <input type="hidden" name="action" value="demote" />
                            <button class="btn btn-danger" type="submit">Admin entfernen</button>
                          <% } else { %>
                            <input type="hidden" name="action" value="promote" />
                            <button class="btn" type="submit">Zu Admin machen</button>
                          <% } %>
                        </form>
                      <% } %>

                      <form method="POST" action="/admin/users/<%= user.id %>/toggle-moderator" class="inline-form">
                        <% if (user.is_moderator) { %>
                          <input type="hidden" name="action" value="demote" />
                          <button class="btn btn-secondary" type="submit">Moderator entfernen</button>
                        <% } else { %>
                          <input type="hidden" name="action" value="promote" />
                          <button class="btn btn-secondary" type="submit">Zu Moderator machen</button>
                        <% } %>
                      </form>

                      <% if (user.id !== currentUser.id) { %>
                        <form method="POST" action="/admin/users/<%= user.id %>/delete" class="inline-form">
                          <button class="btn btn-danger" type="submit">Account löschen</button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                </div>
              </details>
            <% }) %>
          </div>
        </section>
      <% }) %>
    </div>
  <% } %>
</section>

<section class="panel">
  <h2>Gästebücher verwalten</h2>
  <% if (!guestbookCharacters.length) { %>
    <p class="muted">Noch keine Charaktere vorhanden.</p>
  <% } else { %>
    <div class="list">
      <% guestbookCharacters.forEach((item) => { %>
        <article class="list-item admin-user-card">
          <strong><%= item.name %> (<%= item.server_id %>)</strong>
          <div class="admin-user-meta">
            <span>Besitzer: <%= item.owner_name %></span>
            <span>Seiten: <%= item.page_count %></span>
            <span>Einträge: <%= item.entry_count %></span>
            <span>Status: <%= item.is_public ? "öffentlich" : "privat" %></span>
          </div>

          <div class="dashboard-server-actions">
            <a class="btn btn-secondary" href="/characters/<%= item.id %>">Charakter öffnen</a>
            <a class="btn btn-secondary" href="/characters/<%= item.id %>/guestbook">Gästebuch ansehen</a>
            <a class="btn" href="/characters/<%= item.id %>/guestbook/edit">Gästebuch bearbeiten</a>
            <form method="POST" action="/admin/guestbooks/<%= item.id %>/clear" class="inline-form">
              <button class="btn btn-danger" type="submit">Gästebuch leeren</button>
            </form>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<script>
  (() => {
    const normalizeSearchValue = (value) =>
      String(value || "")
        .toLowerCase()
        .replace(/ä/g, "ae")
        .replace(/ö/g, "oe")
        .replace(/ü/g, "ue")
        .replace(/ß/g, "ss")
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "");

    document.addEventListener("DOMContentLoaded", () => {
      const searchInput = document.getElementById("admin-user-search");
      if (!searchInput) return;

      const userCards = Array.from(document.querySelectorAll("[data-user-card]"));
      const letterGroups = Array.from(document.querySelectorAll("[data-letter-group]"));

      const applyFilter = () => {
        const query = normalizeSearchValue(searchInput.value);

        userCards.forEach((card) => {
          const haystack = normalizeSearchValue(card.getAttribute("data-search"));
          card.hidden = Boolean(query) && !haystack.includes(query);
        });

        letterGroups.forEach((group) => {
          const hasVisibleCards = Array.from(group.querySelectorAll("[data-user-card]")).some(
            (card) => !card.hidden
          );
          group.hidden = !hasVisibleCards;
        });
      };

      searchInput.addEventListener("input", applyFilter);
      applyFilter();
    });
  })();
</script>

<%- include("partials/end") %>
