<%- include("partials/start", { hideTopbar: true }) %>

<section class="rp-shell">
  <header class="rp-topline">
  <a class="rp-logo" href="/">Heldenhafte Reisen</a>
    <nav class="rp-menu" aria-label="Charakter Navigation">
      <a href="/dashboard">Account</a>
      <a href="#roomlist">Raumliste</a>
      <% if (isOwner) { %>
        <div class="rp-dropdown">
          <button class="rp-dropdown-toggle" type="button">Charakter</button>
          <div class="rp-dropdown-menu">
            <a
              href="/characters/<%= character.id %>/guestbook/edit?page_id=<%= activeGuestbookPage.id %>"
              target="_blank"
              rel="noopener noreferrer"
            >
              Charakter editieren
            </a>
          </div>
        </div>
      <% } else { %>
        <a href="/characters/<%= character.id %>">Charakter</a>
      <% } %>
      <a href="/characters/<%= character.id %>#roomlist">Extras</a>
      <a href="/dashboard">Hilfe</a>
    </nav>
    <div class="rp-userline">
      <span>Charakter: <strong><%= character.name %></strong></span>
      <span>Server: <strong><%= character.server_id === "erp" ? "ERP" : "FREE-RP" %></strong></span>
      <form method="POST" action="/logout" class="inline-form">
        <button type="submit" class="rp-logout">Logout</button>
      </form>
    </div>
  </header>

  <section class="rp-room-panel" id="roomlist">
    <form method="POST" action="/characters/<%= character.id %>/enter-room" class="rp-room-form">
      <div class="rp-room-input">
        <span class="rp-room-icon" aria-hidden="true">&#128172;</span>
        <input
          id="room_name"
          name="room_name"
          maxlength="80"
          placeholder="Raumname (neu anlegen)"
          required
        />
      </div>
      <button class="rp-enter-btn" type="submit">Raum anlegen</button>
    </form>

    <div class="rp-room-list-wrap">
      <h2>Räume</h2>
      <% if (!rooms || !rooms.length) { %>
        <p class="muted">Noch keine Räume vorhanden.</p>
      <% } else { %>
        <div class="rp-room-list">
          <% rooms.forEach((room) => { %>
            <a
              class="rp-room-link"
              href="/chat?room_id=<%= room.id %>"
              title="Raum betreten"
            >
              <span class="rp-room-link-name"><%= room.name %></span>
              <div class="rp-room-link-meta">
                <small>Betreten</small>
                <small><%= room.has_room_rights ? "Raumrechte" : `Leitung: ${room.creator_name}` %></small>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>

  </section>
</section>

<%- include("partials/end") %>

