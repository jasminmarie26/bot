<%- include("partials/start", { hideTopbar: true, pageClass: "page-roomlist" }) %>

<section class="rp-shell">
  <% const roomlistDisplayName = currentUserDisplayName || (currentUser ? currentUser.display_name || currentUser.username : character.name); %>
  <% const roomlistAccountDisplayName = currentUserAccountName || (currentUser ? currentUser.username : character.name); %>
  <% const roomlistIdentityRoleStyle = isOwner && currentUser && currentUser.is_admin && Number(currentUser.admin_character_id) === Number(character.id)
    ? "admin"
    : isOwner && currentUser && currentUser.is_moderator && Number(currentUser.moderator_character_id) === Number(character.id)
      ? "moderator"
      : ""; %>
  <% const roomlistIdentityName = isOwner
    ? (roomlistIdentityRoleStyle === "moderator" ? `${character.name} (M)` : character.name)
    : roomlistDisplayName; %>
  <header class="rp-topline">
    <a class="rp-logo" href="/">Heldenhafte Reisen</a>
    <nav class="rp-menu" aria-label="Charakter Navigation">
      <a href="#roomlist">Raumliste</a>
    </nav>
    <form method="POST" action="/settings/theme" class="inline-form theme-form">
      <label for="rp-theme-select-roomlist">Design</label>
      <input type="hidden" name="return_to" value="<%= currentPath || '/' %>" />
      <select
        id="rp-theme-select-roomlist"
        name="theme"
        class="theme-select"
      >
        <% availableThemes.forEach((theme) => { %>
          <option value="<%= theme.id %>" <%= activeTheme === theme.id ? "selected" : "" %>>
            <%= theme.label %>
          </option>
        <% }) %>
      </select>
    </form>
    <%- include("partials/guestbook-notification-link") %>
    <details class="rp-user-menu">
      <summary
        class="rp-user-menu-toggle"
        aria-label="Benutzermen&uuml; &ouml;ffnen"
        title="Benutzermen&uuml;"
      >
        <span class="rp-user-menu-toggle-icon" aria-hidden="true">&#128100;</span>
      </summary>
      <div class="rp-user-menu-panel">
        <div class="rp-user-menu-meta">
          <strong class="<%= roomlistIdentityRoleStyle ? `role-name-${roomlistIdentityRoleStyle}` : "" %>"><%= roomlistIdentityName %></strong>
          <% if (roomlistAccountDisplayName && roomlistAccountDisplayName !== roomlistIdentityName) { %>
            <span>Konto: <%= roomlistAccountDisplayName %></span>
          <% } %>
          <span>Charakter: <%= character.name %></span>
          <span>Server: <%= character.server_id === "erp" ? "ERP" : "FREE-RP" %></span>
        </div>

        <nav class="rp-user-menu-links" aria-label="Benutzermen&uuml;">
          <a href="/account">Account</a>
          <a href="/dashboard">Dashboard</a>
          <% if (isOwner) { %>
            <a
              href="/characters/<%= character.id %>/guestbook/edit?page_id=<%= activeGuestbookPage.id %>"
              target="_blank"
              rel="noopener noreferrer"
            >
              Charakter editieren
            </a>
          <% } %>
          <a href="/characters/<%= character.id %>/guestbook">G&auml;stebuch</a>
          <% if (character.server_id === "free-rp" || character.server_id === "erp") { %>
            <a href="/characters/<%= character.id %>#roomlist">Festplays</a>
          <% } %>
          <a href="/help" target="_blank" rel="noopener noreferrer">Hilfe</a>
        </nav>

        <form method="POST" action="/logout" class="inline-form rp-user-menu-form">
          <button type="submit" class="rp-user-menu-logout">Logout</button>
        </form>
      </div>
    </details>
  </header>

  <section class="rp-room-panel" id="roomlist">
    <form method="POST" action="/characters/<%= character.id %>/enter-room" class="rp-room-form">
      <div class="rp-room-input">
        <span class="rp-room-icon" aria-hidden="true">&#128172;</span>
        <input
          id="room_name"
          name="room_name"
          maxlength="80"
          placeholder="Raumname (neu anlegen)"
          required
        />
      </div>
      <input
        name="room_teaser"
        maxlength="160"
        placeholder="Raumbeschreibung"
      />
      <button class="rp-enter-btn" type="submit">Raum anlegen</button>
    </form>

    <% if (isOwner && currentUser && (currentUser.is_admin || currentUser.is_moderator)) { %>
      <form method="POST" action="/characters/<%= character.id %>/role-character" class="rp-role-character-form">
        <fieldset class="gb-role-character-box">
          <legend>Rollenname</legend>
          <% if (currentUser.is_admin) { %>
            <label class="gb-role-character-option">
              <input
                type="checkbox"
                name="use_as_admin_character"
                value="1"
                <%= Number(currentUser.admin_character_id) === Number(character.id) ? "checked" : "" %>
              />
              Als Admin-Charakter verwenden
            </label>
          <% } %>
          <% if (currentUser.is_moderator) { %>
            <label class="gb-role-character-option">
              <input
                type="checkbox"
                name="use_as_moderator_character"
                value="1"
                <%= Number(currentUser.moderator_character_id) === Number(character.id) ? "checked" : "" %>
              />
              Als Moderator-Charakter verwenden
            </label>
          <% } %>
          <p class="gb-role-character-hint muted">
            Der markierte Charakter wird dann als sichtbarer Rollenname auf der Startseite, im Menü und im Chat verwendet.
          </p>
          <button class="btn btn-secondary rp-role-character-submit" type="submit">Rollenname speichern</button>
        </fieldset>
      </form>
    <% } %>

    <div class="rp-room-list-wrap">
      <% if (standardRooms && standardRooms.length) { %>
        <details class="rp-room-section rp-room-section-standard rp-room-accordion" open>
          <summary class="rp-room-section-summary">
            <span>Gemeinsamer Treffpunkt</span>
          </summary>
          <div class="rp-room-section-divider" aria-hidden="true"></div>
          <div class="rp-room-list rp-room-list-standard">
            <% standardRooms.forEach((standardRoom) => { %>
              <% const activeUsers = Array.isArray(standardRoomUsers?.[standardRoom.id]) ? standardRoomUsers[standardRoom.id] : []; %>
              <div class="rp-room-standard-card">
                <a
                  class="rp-room-link rp-room-link-standard"
                  href="/chat?server=<%= character.server_id %>&standard_room=<%= standardRoom.id %>&character_id=<%= character.id %>"
                  title="Treffpunkt betreten"
                >
                  <span class="rp-room-link-name"><%= standardRoom.name %></span>
                  <div class="rp-room-link-meta">
                    <small><%= standardRoom.category || "Offplay" %></small>
                    <small><%= standardRoom.teaser %></small>
                  </div>
                </a>
                <div
                  class="rp-room-occupants"
                  data-room-watch-target
                  data-room-watch-room=""
                  data-room-watch-server="<%= character.server_id %>"
                >
                  <% if (activeUsers.length) { %>
                    <% activeUsers.forEach((entry, index) => { %>
                      <% if (entry.character_id) { %>
                        <a class="rp-room-occupant <%= entry.role_style ? `role-name-${entry.role_style}` : "" %>" href="/characters/<%= entry.character_id %>/guestbook"><%= entry.name %></a>
                      <% } else { %>
                        <span class="rp-room-occupant <%= entry.role_style ? `role-name-${entry.role_style}` : "" %>"><%= entry.name %></span>
                      <% } %>
                      <% if (index < activeUsers.length - 1) { %>
                        <span class="rp-room-occupant-separator">, </span>
                      <% } %>
                    <% }) %>
                  <% } else { %>
                    <span class="muted">Gerade niemand dort.</span>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </details>
      <% } %>

      <details class="rp-room-section rp-room-accordion" open>
        <summary class="rp-room-section-summary">
          <span>Free RP</span>
        </summary>
        <div class="rp-room-section-divider" aria-hidden="true"></div>
        <% if (!rooms || !rooms.length) { %>
          <p class="muted">Noch keine serverweiten R&auml;ume vorhanden.</p>
        <% } else { %>
          <div class="rp-room-list rp-room-list-stacked">
            <% rooms.forEach((room) => { %>
              <% const activeUsers = Array.isArray(roomUsers?.[room.id]) ? roomUsers[room.id] : []; %>
              <div class="rp-room-standard-card rp-room-custom-card">
                <div class="rp-room-custom-titleline">
                  <span
                    class="rp-room-lock-indicator<%= room.is_locked ? ' is-visible' : '' %>"
                    data-room-lock-target
                    data-room-lock-room="<%= room.id %>"
                    data-room-lock-server="<%= character.server_id %>"
                    aria-hidden="<%= room.is_locked ? 'false' : 'true' %>"
                    title="Raum ist abgeschlossen"
                  ><svg class="room-lock-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path class="room-lock-fill" d="M12 3.7a4.45 4.45 0 0 0-4.45 4.45v1.92c0 .18-.06.35-.16.5l-1.31 2a1.08 1.08 0 0 0 .91 1.67h10.02a1.08 1.08 0 0 0 .91-1.67l-1.31-2c-.1-.15-.16-.32-.16-.5V8.15A4.45 4.45 0 0 0 12 3.7Z"/>
                    <path d="M8.1 10.02V8.35a3.9 3.9 0 1 1 7.8 0v1.67"/>
                    <rect x="6.35" y="10.02" width="11.3" height="9.28" rx="2.15" ry="2.15"/>
                    <path d="M12 13.15v2.8"/>
                  </svg></span>
                  <a
                    class="rp-room-link-name rp-room-custom-link<%= room.can_enter ? '' : ' is-disabled' %>"
                    href="<%= room.can_enter ? `/chat?room_id=${room.id}&character_id=${character.id}` : '#' %>"
                    title="<%= room.can_enter ? 'Raum betreten' : 'Raum ist abgeschlossen' %>"
                    data-room-link-target
                    data-room-link-room="<%= room.id %>"
                    data-room-link-server="<%= character.server_id %>"
                    data-room-link-url="/chat?room_id=<%= room.id %>&character_id=<%= character.id %>"
                    aria-disabled="<%= room.can_enter ? 'false' : 'true' %>"
                  ><%= room.name %></a>
                </div>
                <div class="rp-room-custom-meta">
                  <small><%= room.teaser || "Beschreibung folgt." %></small>
                </div>
                <div
                  class="rp-room-occupants"
                  data-room-watch-target
                  data-room-watch-room="<%= room.id %>"
                  data-room-watch-server="<%= character.server_id %>"
                >
                  <% if (activeUsers.length) { %>
                    <% activeUsers.forEach((entry, index) => { %>
                      <% if (entry.character_id) { %>
                        <a class="rp-room-occupant <%= entry.role_style ? `role-name-${entry.role_style}` : "" %>" href="/characters/<%= entry.character_id %>/guestbook"><%= entry.name %></a>
                      <% } else { %>
                        <span class="rp-room-occupant <%= entry.role_style ? `role-name-${entry.role_style}` : "" %>"><%= entry.name %></span>
                      <% } %>
                      <% if (index < activeUsers.length - 1) { %>
                        <span class="rp-room-occupant-separator">, </span>
                      <% } %>
                    <% }) %>
                  <% } else { %>
                    <span class="muted">Gerade niemand dort.</span>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </details>
    </div>
  </section>
</section>

<div data-server-presence="<%= character.server_id %>" hidden></div>
<script src="/server-presence.js?v=<%= staticAssetVersion %>"></script>

<%- include("partials/end") %>
