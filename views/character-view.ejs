<%- include("partials/start", { hideTopbar: true, pageClass: "page-roomlist" }) %>

<section class="rp-shell">
  <% const roomlistAccountDisplayName = currentUserDisplayName || (currentUser ? currentUser.display_name || currentUser.username : character.name); %>
  <% const roomlistIdentityName = isOwner ? character.name : roomlistAccountDisplayName; %>
  <header class="rp-topline">
    <a class="rp-logo" href="/">Heldenhafte Reisen</a>
    <nav class="rp-menu" aria-label="Charakter Navigation">
      <a href="#roomlist">Raumliste</a>
    </nav>
    <form method="POST" action="/settings/theme" class="inline-form theme-form">
      <label for="rp-theme-select-roomlist">Design</label>
      <input type="hidden" name="return_to" value="<%= currentPath || '/' %>" />
      <select
        id="rp-theme-select-roomlist"
        name="theme"
        class="theme-select"
      >
        <% availableThemes.forEach((theme) => { %>
          <option value="<%= theme.id %>" <%= activeTheme === theme.id ? "selected" : "" %>>
            <%= theme.label %>
          </option>
        <% }) %>
      </select>
    </form>
    <details class="rp-user-menu">
      <summary
        class="rp-user-menu-toggle"
        aria-label="Benutzermen&uuml; &ouml;ffnen"
        title="Benutzermen&uuml;"
      >
        <span class="rp-user-menu-toggle-icon" aria-hidden="true">&#128100;</span>
      </summary>
      <div class="rp-user-menu-panel">
        <div class="rp-user-menu-meta">
          <strong><%= roomlistIdentityName %></strong>
          <% if (roomlistAccountDisplayName && roomlistAccountDisplayName !== roomlistIdentityName) { %>
            <span>Konto: <%= roomlistAccountDisplayName %></span>
          <% } %>
          <span>Charakter: <%= character.name %></span>
          <span>Server: <%= character.server_id === "erp" ? "ERP" : "FREE-RP" %></span>
        </div>

        <nav class="rp-user-menu-links" aria-label="Benutzermen&uuml;">
          <a href="/dashboard">Dashboard</a>
          <% if (isOwner) { %>
            <a
              href="/characters/<%= character.id %>/guestbook/edit?page_id=<%= activeGuestbookPage.id %>"
              target="_blank"
              rel="noopener noreferrer"
            >
              Charakter editieren
            </a>
          <% } %>
          <a href="/characters/<%= character.id %>/guestbook">G&auml;stebuch</a>
          <% if (character.server_id === "free-rp" || character.server_id === "erp") { %>
            <a href="/characters/<%= character.id %>#roomlist">Festplays</a>
          <% } %>
          <a href="/dashboard">Hilfe</a>
        </nav>

        <form method="POST" action="/logout" class="inline-form rp-user-menu-form">
          <button type="submit" class="rp-user-menu-logout">Logout</button>
        </form>
      </div>
    </details>
  </header>

  <section class="rp-room-panel" id="roomlist">
    <form method="POST" action="/characters/<%= character.id %>/enter-room" class="rp-room-form">
      <div class="rp-room-input">
        <span class="rp-room-icon" aria-hidden="true">&#128172;</span>
        <input
          id="room_name"
          name="room_name"
          maxlength="80"
          placeholder="Raumname (neu anlegen)"
          required
        />
      </div>
      <input
        name="room_teaser"
        maxlength="160"
        placeholder="Raumbeschreibung"
      />
      <button class="rp-enter-btn" type="submit">Raum anlegen</button>
    </form>

    <div class="rp-room-list-wrap">
      <% if (standardRooms && standardRooms.length) { %>
        <details class="rp-room-section rp-room-section-standard rp-room-accordion" open>
          <summary class="rp-room-section-summary">
            <span>Gemeinsamer Treffpunkt</span>
          </summary>
          <div class="rp-room-section-divider" aria-hidden="true"></div>
          <div class="rp-room-list rp-room-list-standard">
            <% standardRooms.forEach((standardRoom) => { %>
              <% const activeUsers = Array.isArray(standardRoomUsers?.[standardRoom.id]) ? standardRoomUsers[standardRoom.id] : []; %>
              <div class="rp-room-standard-card">
                <a
                  class="rp-room-link rp-room-link-standard"
                  href="/chat?server=<%= character.server_id %>&standard_room=<%= standardRoom.id %>&character_id=<%= character.id %>"
                  title="Treffpunkt betreten"
                >
                  <span class="rp-room-link-name"><%= standardRoom.name %></span>
                  <div class="rp-room-link-meta">
                    <small><%= standardRoom.category || "Offplay" %></small>
                    <small><%= standardRoom.teaser %></small>
                  </div>
                </a>
                <div
                  class="rp-room-occupants"
                  data-room-watch-target
                  data-room-watch-room=""
                  data-room-watch-server="<%= character.server_id %>"
                >
                  <% if (activeUsers.length) { %>
                    <% activeUsers.forEach((entry, index) => { %>
                      <% if (entry.character_id) { %>
                        <a class="rp-room-occupant" href="/characters/<%= entry.character_id %>/guestbook"><%= entry.name %></a>
                      <% } else { %>
                        <span class="rp-room-occupant"><%= entry.name %></span>
                      <% } %>
                      <% if (index < activeUsers.length - 1) { %>
                        <span class="rp-room-occupant-separator">, </span>
                      <% } %>
                    <% }) %>
                  <% } else { %>
                    <span class="muted">Gerade niemand dort.</span>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </details>
      <% } %>

      <details class="rp-room-section rp-room-accordion" open>
        <summary class="rp-room-section-summary">
          <span>Free RP</span>
        </summary>
        <div class="rp-room-section-divider" aria-hidden="true"></div>
        <% if (!rooms || !rooms.length) { %>
          <p class="muted">Noch keine serverweiten R&auml;ume vorhanden.</p>
        <% } else { %>
          <div class="rp-room-list rp-room-list-stacked">
            <% rooms.forEach((room) => { %>
              <% const activeUsers = Array.isArray(roomUsers?.[room.id]) ? roomUsers[room.id] : []; %>
              <div class="rp-room-standard-card rp-room-custom-card">
                <a
                  class="rp-room-link-name rp-room-custom-link"
                  href="/chat?room_id=<%= room.id %>&character_id=<%= character.id %>"
                  title="Raum betreten"
                ><%= room.name %></a>
                <div class="rp-room-custom-meta">
                  <small><%= room.teaser || "Beschreibung folgt." %></small>
                </div>
                <div
                  class="rp-room-occupants"
                  data-room-watch-target
                  data-room-watch-room="<%= room.id %>"
                  data-room-watch-server="<%= character.server_id %>"
                >
                  <% if (activeUsers.length) { %>
                    <% activeUsers.forEach((entry, index) => { %>
                      <% if (entry.character_id) { %>
                        <a class="rp-room-occupant" href="/characters/<%= entry.character_id %>/guestbook"><%= entry.name %></a>
                      <% } else { %>
                        <span class="rp-room-occupant"><%= entry.name %></span>
                      <% } %>
                      <% if (index < activeUsers.length - 1) { %>
                        <span class="rp-room-occupant-separator">, </span>
                      <% } %>
                    <% }) %>
                  <% } else { %>
                    <span class="muted">Gerade niemand dort.</span>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </details>
    </div>
  </section>
</section>

<div data-server-presence="<%= character.server_id %>" hidden></div>
<script src="/server-presence.js?v=<%= staticAssetVersion %>"></script>

<%- include("partials/end") %>
