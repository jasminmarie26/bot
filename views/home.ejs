<%- include("partials/start") %>

<div class="home-layout">
  <aside class="home-stats" aria-label="Plattform Statistiken">
    <article class="home-stat">
      <strong><%= stats.accountCount %></strong>
      <span>Registrierte Accounts</span>
    </article>
    <article class="home-stat">
      <strong><%= stats.characterCount %></strong>
      <span>Erstellte Charaktere</span>
    </article>
    <article class="home-stat">
      <strong><%= stats.loggedInUserCount %></strong>
      <span>Gerade eingeloggt</span>
    </article>
    <article class="home-stat">
      <strong><%= stats.adminOnlineCount %></strong>
      <span>Admins online</span>
      <% if (stats.adminOnlineNames && stats.adminOnlineNames.length) { %>
        <small class="home-stat-names">
          <% stats.adminOnlineNames.forEach((name, index) => { %>
            <span class="staff-name-admin"><%= name %></span><%= index < stats.adminOnlineNames.length - 1 ? ", " : "" %>
          <% }) %>
        </small>
      <% } %>
    </article>
    <article class="home-stat">
      <strong><%= stats.moderatorOnlineCount %></strong>
      <span>Moderatoren online</span>
      <% if (stats.moderatorOnlineNames && stats.moderatorOnlineNames.length) { %>
        <small class="home-stat-names">
          <% stats.moderatorOnlineNames.forEach((name, index) => { %>
            <span class="staff-name-moderator"><%= name %></span><%= index < stats.moderatorOnlineNames.length - 1 ? ", " : "" %>
          <% }) %>
        </small>
      <% } %>
    </article>
  </aside>

  <div class="home-main">
    <section
      id="home-hero"
      class="hero <%= currentUser && currentUser.is_admin ? "has-update-actions" : "" %>"
    >
      <input id="home-hero-title-source" type="hidden" value="<%= homeContent.hero_title %>" />
      <textarea id="home-hero-body-source" hidden><%= homeContent.hero_body %></textarea>

      <% if (currentUser && currentUser.is_admin) { %>
        <div class="hero-update-actions">
          <button
            class="ghost-btn icon-btn update-pen-btn"
            type="button"
            data-site-content-open="hero"
            aria-label="Startseitenbereich bearbeiten"
            title="Startseitenbereich bearbeiten"
          >
            &#9998;
          </button>
        </div>
      <% } %>

      <h1 id="home-hero-title"><%= homeContent.hero_title %></h1>
      <div id="home-hero-body" class="hero-copy guestbook-entry-body"><%- homeContent.hero_body_html %></div>
      <div class="hero-actions">
        <% if (currentUser) { %>
          <a class="btn" href="/dashboard">Zum Dashboard</a>
        <% } else { %>
          <a class="btn" href="/register">Jetzt starten</a>
          <a class="btn btn-secondary" href="/login">Einloggen</a>
        <% } %>
      </div>
    </section>

    <section class="panel updates-panel">
      <div class="updates-header">
        <input id="updates-section-title-source" type="hidden" value="<%= homeContent.updates_title %>" />
        <h2 id="updates-section-title" data-updates-title="<%= homeContent.updates_title %>"><%= homeContent.updates_title %></h2>
        <% if (currentUser && (currentUser.is_admin || currentUser.is_moderator)) { %>
          <div class="updates-header-actions">
            <button
              id="update-open-btn"
              class="ghost-btn icon-btn update-create-btn"
              type="button"
              data-update-open
              aria-label="Neues Live-Update"
              title="Neues Live-Update"
            >
              +
            </button>
            <% if (currentUser.is_admin) { %>
              <button
                class="ghost-btn icon-btn update-pen-btn"
                type="button"
                data-site-content-open="updates-title"
                aria-label="Live-Updates-Ueberschrift bearbeiten"
                title="Live-Updates-Ueberschrift bearbeiten"
              >
                &#9998;
              </button>
            <% } %>
          </div>
        <% } %>
      </div>

      <div id="site-updates-list" class="site-updates-list">
        <% if (!siteUpdates || !siteUpdates.length) { %>
          <p id="site-updates-empty" class="muted">Noch keine Neuigkeiten veroeffentlicht.</p>
        <% } else { %>
          <% siteUpdates.forEach((item) => { %>
            <article
              class="update-item"
              data-update-id="<%= item.id %>"
              data-update-author-name="<%= item.author_name %>"
              data-update-content="<%= item.content %>"
              data-update-created-at="<%= item.created_at %>"
            >
              <header class="update-meta">
                <strong><%= item.author_name %></strong>
                <div class="update-meta-right">
                  <small><%= item.created_at %></small>
                  <% if (currentUser && (currentUser.is_admin || currentUser.is_moderator)) { %>
                    <div class="update-item-actions">
                      <button
                        class="ghost-btn icon-btn update-edit-btn"
                        type="button"
                        data-update-edit
                        aria-label="Update-Inhalt bearbeiten"
                        title="Update-Inhalt bearbeiten"
                      >
                        &#9998;
                      </button>
                      <form
                        method="POST"
                        action="/updates/<%= item.id %>/delete"
                        class="inline-form"
                        onsubmit="return confirm('Update wirklich loeschen?')"
                      >
                        <button
                          class="ghost-btn icon-btn update-delete-btn"
                          type="submit"
                          aria-label="Update loeschen"
                          title="Update loeschen"
                        >
                          X
                        </button>
                      </form>
                    </div>
                  <% } %>
                </div>
              </header>
              <div class="update-body guestbook-entry-body"><%- item.content_html %></div>
            </article>
          <% }) %>
        <% } %>
      </div>
    </section>
  </div>
</div>

<% if (currentUser && (currentUser.is_admin || currentUser.is_moderator)) { %>
  <div id="update-modal" class="update-modal" hidden>
    <section class="panel update-modal-card">
      <div class="updates-header">
        <h2 id="update-modal-title">Neues Live-Update</h2>
        <button id="update-close-btn" class="ghost-btn" type="button">Schliessen</button>
      </div>

      <form id="update-form" method="POST" action="/updates" class="form update-form">
        <div class="update-toolbar" role="toolbar" aria-label="BBCode Werkzeuge">
          <button class="ghost-btn update-tool-btn" type="button" data-bbcode-tag="b">B</button>
          <button class="ghost-btn update-tool-btn" type="button" data-bbcode-tag="i">I</button>
          <button class="ghost-btn update-tool-btn" type="button" data-bbcode-tag="u">U</button>
          <button class="ghost-btn update-tool-btn" type="button" data-bbcode-tag="h2">H2</button>
          <button class="ghost-btn update-tool-btn" type="button" data-bbcode-tag="left">Links</button>
          <button class="ghost-btn update-tool-btn" type="button" data-bbcode-tag="center">Mitte</button>
          <button class="ghost-btn update-tool-btn" type="button" data-bbcode-tag="right">Rechts</button>
          <button class="ghost-btn update-tool-btn" type="button" data-bbcode-tag="block">Einr.</button>
          <button class="ghost-btn update-tool-btn" type="button" data-bbcode-tag="quote">Zitat</button>
          <button class="ghost-btn update-tool-btn" type="button" data-bbcode-link>Link</button>
        </div>

        <label>
          Inhalt (BBCode)
          <textarea name="content" rows="6" maxlength="1200" required></textarea>
        </label>

        <details class="bbcode-help">
          <summary>BBCode Hilfe</summary>
          <div class="bbcode-help-content">
            <p><code>[b]fett[/b]</code> <code>[i]kursiv[/i]</code> <code>[u]unterstrichen[/u]</code></p>
            <p><code>[h2]Titel[/h2]</code> <code>[left]Links[/left]</code> <code>[center]Mitte[/center]</code></p>
            <p><code>[right]Rechts[/right]</code> <code>[block]Einruecken[/block]</code> <code>[quote]Zitat[/quote]</code></p>
            <p><code>[url=https://beispiel.de]Linktext[/url]</code></p>
          </div>
        </details>

        <div class="update-form-actions">
          <button id="update-submit-btn" type="submit" class="btn">Veroeffentlichen</button>
        </div>
      </form>
    </section>
  </div>

  <% if (currentUser.is_admin) { %>
    <div id="site-content-modal" class="update-modal" hidden>
      <section class="panel update-modal-card">
        <div class="updates-header">
          <h2 id="site-content-modal-title">Bereich bearbeiten</h2>
          <button id="site-content-close-btn" class="ghost-btn" type="button">Schliessen</button>
        </div>

        <form id="site-content-form" method="POST" action="/site-content/hero" class="form update-form">
          <label>
            Ueberschrift
            <input id="site-content-title-input" name="title" maxlength="120" required />
          </label>

          <div id="site-content-body-wrap">
            <div class="update-toolbar" role="toolbar" aria-label="BBCode Werkzeuge fuer den Startseitentext">
              <button class="ghost-btn update-tool-btn" type="button" data-bbcode-target="site-content-body" data-bbcode-tag="b">B</button>
              <button class="ghost-btn update-tool-btn" type="button" data-bbcode-target="site-content-body" data-bbcode-tag="i">I</button>
              <button class="ghost-btn update-tool-btn" type="button" data-bbcode-target="site-content-body" data-bbcode-tag="u">U</button>
              <button class="ghost-btn update-tool-btn" type="button" data-bbcode-target="site-content-body" data-bbcode-tag="h2">H2</button>
              <button class="ghost-btn update-tool-btn" type="button" data-bbcode-target="site-content-body" data-bbcode-tag="left">Links</button>
              <button class="ghost-btn update-tool-btn" type="button" data-bbcode-target="site-content-body" data-bbcode-tag="center">Mitte</button>
              <button class="ghost-btn update-tool-btn" type="button" data-bbcode-target="site-content-body" data-bbcode-tag="right">Rechts</button>
              <button class="ghost-btn update-tool-btn" type="button" data-bbcode-target="site-content-body" data-bbcode-tag="quote">Zitat</button>
              <button class="ghost-btn update-tool-btn" type="button" data-bbcode-target="site-content-body" data-bbcode-link>Link</button>
            </div>

            <label>
              Inhalt (BBCode)
              <textarea id="site-content-body-input" name="body" rows="6" maxlength="2000"></textarea>
            </label>

            <details class="bbcode-help">
              <summary>BBCode Hilfe</summary>
              <div class="bbcode-help-content">
                <p><code>[b]fett[/b]</code> <code>[i]kursiv[/i]</code> <code>[u]unterstrichen[/u]</code></p>
                <p><code>[h2]Titel[/h2]</code> <code>[left]Links[/left]</code> <code>[center]Mitte[/center]</code></p>
                <p><code>[right]Rechts[/right]</code> <code>[quote]Zitat[/quote]</code></p>
                <p><code>[url=https://beispiel.de]Linktext[/url]</code></p>
              </div>
            </details>
          </div>

          <div class="update-form-actions">
            <button id="site-content-submit-btn" type="submit" class="btn">Speichern</button>
          </div>
        </form>
      </section>
    </div>
  <% } %>
<% } %>

<script src="/updates.js"></script>

<%- include("partials/end") %>
