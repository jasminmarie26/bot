<% if (guestbookPageNavigation?.hasMultiplePages) { %>
  <div class="guestbook-page-nav-layer">
    <% if (guestbookPageNavigation.previousPage?.url) { %>
      <a
        class="guestbook-page-nav guestbook-page-nav-prev"
        href="<%= guestbookPageNavigation.previousPage.url %>"
        aria-label="Vorherige Gästebuch-Seite"
        title="Vorherige Seite"
      >
        &#8249;
      </a>
    <% } else { %>
      <span class="guestbook-page-nav guestbook-page-nav-prev is-disabled" aria-hidden="true">&#8249;</span>
    <% } %>

    <% if (guestbookPageNavigation.nextPage?.url) { %>
      <a
        class="guestbook-page-nav guestbook-page-nav-next"
        href="<%= guestbookPageNavigation.nextPage.url %>"
        aria-label="Nächste Gästebuch-Seite"
        title="Nächste Seite"
      >
        &#8250;
      </a>
    <% } else { %>
      <span class="guestbook-page-nav guestbook-page-nav-next is-disabled" aria-hidden="true">&#8250;</span>
    <% } %>
  </div>
<% } %>
