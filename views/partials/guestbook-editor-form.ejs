              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-insert="hr" title="Linie" aria-label="Linie"><span class="gb-bbcode-btn-glyph" aria-hidden="true">-</span></button>
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-wrap="story" title="Story Kasten" aria-label="Story Kasten"><span class="gb-bbcode-btn-glyph gb-bbcode-btn-glyph-svg" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M7 5h11a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H7"></path><path d="M7 5a3 3 0 0 0 0 14"></path><path d="M9 8h7"></path><path d="M9 12h7"></path></svg></span></button>
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-wrap="dark" title="Dark Box" aria-label="Dark Box"><span class="gb-bbcode-btn-glyph gb-bbcode-btn-glyph-svg" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="5" y="6" width="14" height="12" rx="1.5"></rect><path d="M8 10h8"></path></svg></span></button>
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-wrap="light" title="Light Box" aria-label="Light Box"><span class="gb-bbcode-btn-glyph gb-bbcode-btn-glyph-svg" aria-hidden="true"><svg viewBox="0 0 24 24"><rect x="5" y="6" width="14" height="12" rx="1.5"></rect></svg></span></button>
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-wrap="fn" title="Info" aria-label="Info"><span class="gb-bbcode-btn-glyph gb-bbcode-btn-glyph-svg" aria-hidden="true"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8"></circle><path d="M12 10v5"></path><path d="M12 7h.01"></path></svg></span></button>
