<form
  id="guestbook-editor-form"
  method="POST"
  action="/characters/<%= character.id %>/guestbook/edit/save"
  class="<%= guestbookEditorFormClass || 'panel form gb-editor-form' %>"
  data-preview-sync-url="/characters/<%= character.id %>/guestbook/edit/preview?page_id=<%= activePage.id %>"
>
  <input type="hidden" name="page_id" value="<%= activePage.id %>" />

  <h2>Einstellungen</h2>

  <div class="gb-editor-section">
    <span class="gb-editor-subheading">Zensur</span>
    <div class="gb-radio-list">
      <label><input type="radio" name="censor_level" value="ab18" <%= settings.censor_level === "ab18" ? "checked" : "" %> /> ab 18 schalten</label>
      <label><input type="radio" name="censor_level" value="sexual" <%= settings.censor_level === "sexual" ? "checked" : "" %> /> sexuelle Darstellung</label>
      <label><input type="radio" name="censor_level" value="none" <%= settings.censor_level !== "ab18" && settings.censor_level !== "sexual" ? "checked" : "" %> /> keine Altersbeschr&auml;nkung</label>
    </div>
  </div>

  <label>
    Style
    <select name="theme_style">
      <option value="pergament-gold" <%= settings.theme_style === "pergament-gold" ? "selected" : "" %>>Pergament Gold</option>
      <option value="rosenlack" <%= settings.theme_style === "rosenlack" ? "selected" : "" %>>Rosenlack</option>
      <option value="mondsilber" <%= settings.theme_style === "mondsilber" ? "selected" : "" %>>Mondsilber</option>
      <option value="elfenhain" <%= settings.theme_style === "elfenhain" ? "selected" : "" %>>Elfenhain</option>
      <option value="kupferpatina" <%= settings.theme_style === "kupferpatina" ? "selected" : "" %>>Kupferpatina</option>
      <option value="bernsteinfeuer" <%= settings.theme_style === "bernsteinfeuer" ? "selected" : "" %>>Bernsteinfeuer</option>
      <option value="sternsamt" <%= settings.theme_style === "sternsamt" ? "selected" : "" %>>Sternensamt</option>
      <option value="winterglas" <%= settings.theme_style === "winterglas" ? "selected" : "" %>>Winterglas</option>
      <option value="tintenmeer" <%= settings.theme_style === "tintenmeer" ? "selected" : "" %>>Tintenmeer</option>
      <option value="obsidian-ornament" <%= settings.theme_style === "obsidian-ornament" ? "selected" : "" %>>Obsidian Ornament</option>
    </select>
  </label>

  <div class="gb-color-row">
    <div>
      <span class="gb-editor-subheading">Rahmenfarbe</span>
      <span class="gb-editor-helptext">Leer = Standard vom gew&auml;hlten Style.</span>
    </div>

    <div class="gb-color-input-wrap">
      <input
        id="guestbook-frame-color-text"
        name="frame_color"
        value="<%= settings.frame_color || '' %>"
        maxlength="9"
        placeholder="#7A6855CC"
        spellcheck="false"
        autocomplete="off"
      />
      <input
        id="guestbook-frame-color-picker"
        class="gb-color-picker"
        type="color"
        value="<%= /^#[0-9a-f]{6}(?:[0-9a-f]{2})?$/i.test(String(settings.frame_color || '').trim()) ? String(settings.frame_color).trim().slice(0, 7) : '#7A6855' %>"
        aria-label="Rahmenfarbe ausw&auml;hlen"
      />
      <span id="guestbook-frame-color-preview" class="gb-color-preview gb-color-preview-swatch" aria-hidden="true"></span>
      <button type="button" class="btn btn-secondary gb-color-reset" data-color-reset="guestbook-frame-color">
        Standard
      </button>
      <label class="gb-color-alpha-field" for="guestbook-frame-color-alpha">
        Transparenz
        <div class="gb-color-alpha-controls">
          <input
            id="guestbook-frame-color-alpha"
            class="gb-color-alpha-range"
            type="range"
            min="0"
            max="100"
            step="1"
            value="100"
          />
          <input
            id="guestbook-frame-color-alpha-number"
            class="gb-color-alpha-number"
            type="number"
            min="0"
            max="100"
            step="1"
            value="100"
            inputmode="numeric"
            aria-label="Rahmenfarbe Transparenz in Prozent"
          />
          <span class="gb-color-alpha-unit">%</span>
        </div>
      </label>
    </div>
  </div>

  <div class="gb-color-row">
    <div>
      <span class="gb-editor-subheading">Hintergrundfarbe</span>
      <span class="gb-editor-helptext">Leer = Standard vom gew&auml;hlten Style.</span>
    </div>

    <div class="gb-color-input-wrap">
      <input
        id="guestbook-background-color-text"
        name="background_color"
        value="<%= settings.background_color || '' %>"
        maxlength="9"
        placeholder="#3E3935CC"
        spellcheck="false"
        autocomplete="off"
      />
      <input
        id="guestbook-background-color-picker"
        class="gb-color-picker"
        type="color"
        value="<%= /^#[0-9a-f]{6}(?:[0-9a-f]{2})?$/i.test(String(settings.background_color || '').trim()) ? String(settings.background_color).trim().slice(0, 7) : '#3E3935' %>"
        aria-label="Hintergrundfarbe ausw&auml;hlen"
      />
      <span
        id="guestbook-background-color-preview"
        class="gb-color-preview gb-color-preview-swatch"
        aria-hidden="true"
      ></span>
      <button type="button" class="btn btn-secondary gb-color-reset" data-color-reset="guestbook-background-color">
        Standard
      </button>
      <label class="gb-color-alpha-field" for="guestbook-background-color-alpha">
        Transparenz
        <div class="gb-color-alpha-controls">
          <input
            id="guestbook-background-color-alpha"
            class="gb-color-alpha-range"
            type="range"
            min="0"
            max="100"
            step="1"
            value="100"
          />
          <input
            id="guestbook-background-color-alpha-number"
            class="gb-color-alpha-number"
            type="number"
            min="0"
            max="100"
            step="1"
            value="100"
            inputmode="numeric"
            aria-label="Hintergrundfarbe Transparenz in Prozent"
          />
          <span class="gb-color-alpha-unit">%</span>
        </div>
      </label>
    </div>
  </div>

  <div class="gb-color-row">
    <div>
      <span class="gb-editor-subheading">Fl&auml;che hinter dem Rahmen</span>
      <span class="gb-editor-helptext">F&auml;rbt den gro&szlig;en Bereich um das G&auml;stebuch, aber nicht den Header oben.</span>
    </div>

    <div class="gb-color-input-wrap">
      <input
        id="guestbook-surround-color-text"
        name="surround_color"
        value="<%= settings.surround_color || '' %>"
        maxlength="9"
        placeholder="#2C2118CC"
        spellcheck="false"
        autocomplete="off"
      />
      <input
        id="guestbook-surround-color-picker"
        class="gb-color-picker"
        type="color"
        value="<%= /^#[0-9a-f]{6}(?:[0-9a-f]{2})?$/i.test(String(settings.surround_color || '').trim()) ? String(settings.surround_color).trim().slice(0, 7) : '#2C2118' %>"
        aria-label="Fl&auml;chenfarbe ausw&auml;hlen"
      />
      <span
        id="guestbook-surround-color-preview"
        class="gb-color-preview gb-color-preview-swatch"
        aria-hidden="true"
      ></span>
      <button type="button" class="btn btn-secondary gb-color-reset" data-color-reset="guestbook-surround-color">
        Standard
      </button>
      <label class="gb-color-alpha-field" for="guestbook-surround-color-alpha">
        Transparenz
        <div class="gb-color-alpha-controls">
          <input
            id="guestbook-surround-color-alpha"
            class="gb-color-alpha-range"
            type="range"
            min="0"
            max="100"
            step="1"
            value="100"
          />
          <input
            id="guestbook-surround-color-alpha-number"
            class="gb-color-alpha-number"
            type="number"
            min="0"
            max="100"
            step="1"
            value="100"
            inputmode="numeric"
            aria-label="Fl&auml;chenfarbe Transparenz in Prozent"
          />
          <span class="gb-color-alpha-unit">%</span>
        </div>
      </label>
    </div>
  </div>

  <div class="gb-image-field">
    <label>
      Bild innerhalb des Rahmens
      <span class="gb-editor-helptext">Bild-URL f&uuml;r die Fl&auml;che direkt im G&auml;stebuchrahmen.</span>
      <span class="gb-editor-helptext">Wird automatisch skaliert, sichtbare Fl&auml;che bis ca. 620px Breite.</span>
      <input
        name="inner_image_url"
        value="<%= settings.inner_image_url || '' %>"
        maxlength="500"
        placeholder="https://..."
        spellcheck="false"
        autocomplete="off"
      />
    </label>

    <div class="gb-image-controls">
      <label class="gb-image-toggle">
        <input type="checkbox" name="clear_inner_image" value="1" />
        Hintergrund l&ouml;schen
      </label>

      <label class="gb-image-opacity-field">
        Transparenz
        <input
          type="number"
          name="inner_image_opacity"
          min="0"
          max="100"
          step="1"
          value="<%= Number.isFinite(Number(settings.inner_image_opacity)) ? Number(settings.inner_image_opacity) : 100 %>"
        />
      </label>
    </div>
  </div>

  <div class="gb-image-field">
    <label>
      Bild au&szlig;erhalb des Rahmens
      <span class="gb-editor-helptext">Bild-URL f&uuml;r den Bereich um das G&auml;stebuch herum.</span>
      <span class="gb-editor-helptext">Wird automatisch als Hintergrund skaliert, keine feste Pixelgr&ouml;&szlig;e n&ouml;tig.</span>
      <input
        name="outer_image_url"
        value="<%= settings.outer_image_url || '' %>"
        maxlength="500"
        placeholder="https://..."
        spellcheck="false"
        autocomplete="off"
      />
    </label>

    <div class="gb-image-controls">
      <label class="gb-image-toggle">
        <input type="checkbox" name="clear_outer_image" value="1" />
        Hintergrund l&ouml;schen
      </label>

      <label class="gb-image-opacity-field">
        Transparenz
        <input
          type="number"
          name="outer_image_opacity"
          min="0"
          max="100"
          step="1"
          value="<%= Number.isFinite(Number(settings.outer_image_opacity)) ? Number(settings.outer_image_opacity) : 100 %>"
        />
      </label>
    </div>
  </div>

  <label>
    Font
    <select name="font_style">
      <% (guestbookFontOptions || []).forEach((fontOption) => { %>
        <option value="<%= fontOption.id %>" <%= settings.font_style === fontOption.id ? "selected" : "" %>>
          <%= fontOption.label %>
        </option>
      <% }) %>
    </select>
  </label>

  <p class="gb-editor-link-row">
    <a
      class="gb-editor-text-link"
      href="https://heldenhaftereisen.net/help/gaestebuch-design-bbcode"
      target="_blank"
      rel="noopener noreferrer"
    >
      BBCode Hilfe
    </a>
  </p>
  <div>
    <span class="gb-editor-helptext">Normales BBCode-Bild im G&auml;stebuch: max. 600px Breite</span>
    <span class="gb-editor-helptext">BBCode-Bild links oder rechts: max. 120px Breite</span>
    <span class="gb-editor-helptext">Gro&szlig;es Bild oben auf der G&auml;stebuch-Seite: volle Breite, max. 240px H&ouml;he</span>
    <span class="gb-editor-helptext">Bild innerhalb des Rahmens: wird als Hintergrund &uuml;ber die G&auml;stebuchfl&auml;che gelegt und automatisch skaliert; die Seite selbst liegt bei max. 620px Breite</span>
  </div>

  <label>
    Seiteninhalt (BBCode)
    <textarea name="page_content" rows="12" maxlength="12000"><%= activePage.content %></textarea>
  </label>

  </form>

<div class="gb-editor-inline-extra-row">
  <button class="btn gb-editor-inline-save" type="submit" form="guestbook-editor-form">Speichern</button>
  <button
    class="btn btn-secondary"
    type="submit"
    form="guestbook-editor-form"
    formaction="/characters/<%= character.id %>/guestbook/edit/preview?page_id=<%= activePage.id %>"
    formmethod="POST"
    formtarget="guestbook-preview-<%= character.id %>"
  >
    Vorschau
  </button>

  <form method="POST" action="/characters/<%= character.id %>/guestbook/edit/add-page" class="inline-form">
    <input type="hidden" name="page_id" value="<%= activePage.id %>" />
    <button class="btn btn-secondary" type="submit">Seite hinzuf&uuml;gen</button>
  </form>

  <form method="POST" action="/characters/<%= character.id %>/guestbook/edit/delete-page" class="inline-form">
    <input type="hidden" name="page_id" value="<%= activePage.id %>" />
    <button
      class="btn btn-danger"
      type="submit"
      onclick="return confirm('Aktuelle Seite wirklich l&ouml;schen?')"
    >
      Aktuelle Seite l&ouml;schen
    </button>
  </form>
</div>

<script>
  (() => {
    const censorRadios = Array.from(document.querySelectorAll('input[name="censor_level"]'));

    censorRadios.forEach((radio) => {
      radio.addEventListener("pointerdown", () => {
        radio.dataset.wasChecked = radio.checked ? "1" : "";
      });

      radio.addEventListener("keydown", (event) => {
        if (event.key === " " || event.key === "Spacebar" || event.key === "Enter") {
          radio.dataset.wasChecked = radio.checked ? "1" : "";
        }
      });

      radio.addEventListener("click", () => {
        if (radio.dataset.wasChecked === "1") {
          window.requestAnimationFrame(() => {
            radio.checked = true;
          });
        }
        delete radio.dataset.wasChecked;
      });
    });

    const normalizeHexColor = (value) => {
      const normalized = String(value || "").trim().toUpperCase();
      return /^#[0-9A-F]{6}$/.test(normalized) ? normalized : "";
    };

    const normalizeColorWithAlpha = (value) => {
      const normalized = String(value || "").trim().toUpperCase();
      return /^#[0-9A-F]{8}$/.test(normalized) ? normalized : "";
    };

    const alphaHexToPercent = (value) => {
      const parsed = Number.parseInt(String(value || "").trim(), 16);
      if (!Number.isFinite(parsed)) {
        return 100;
      }
      return Math.min(100, Math.max(0, Math.round((parsed / 255) * 100)));
    };

    const percentToAlphaHex = (value) => {
      const clamped = Math.min(100, Math.max(0, Number.parseInt(String(value ?? "").trim(), 10) || 0));
      return Math.round((clamped / 100) * 255)
        .toString(16)
        .padStart(2, "0")
        .toUpperCase();
    };

    const normalizeAlphaPercent = (value) =>
      Math.min(100, Math.max(0, Number.parseInt(String(value ?? "").trim(), 10) || 0));

    const buildColorValue = (hexColor, alphaPercent) => {
      const normalizedHex = normalizeHexColor(hexColor);
      if (!normalizedHex) {
        return "";
      }
      const normalizedAlpha = normalizeAlphaPercent(alphaPercent);
      return normalizedAlpha >= 100
        ? normalizedHex
        : `${normalizedHex}${percentToAlphaHex(normalizedAlpha)}`;
    };

    const bindColorField = (key, defaultColor) => {
      const textInput = document.getElementById(`${key}-text`);
      const pickerInput = document.getElementById(`${key}-picker`);
      const preview = document.getElementById(`${key}-preview`);
      const alphaRangeInput = document.getElementById(`${key}-alpha`);
      const alphaNumberInput = document.getElementById(`${key}-alpha-number`);
      const resetButton = document.querySelector(`[data-color-reset="${key}"]`);

      if (!textInput || !pickerInput || !preview || !alphaRangeInput || !alphaNumberInput || !resetButton) {
        return null;
      }

      const renderSwatch = (colorValue, isActive) => {
        preview.style.setProperty("--gb-color-preview-color", colorValue);
        preview.style.opacity = isActive ? "1" : "0.42";
      };

      const parseColorState = (value) => {
        const normalizedHex = normalizeHexColor(value);
        if (normalizedHex) {
          return {
            isActive: true,
            isValid: true,
            hexColor: normalizedHex,
            alphaPercent: 100
          };
        }

        const normalizedWithAlpha = normalizeColorWithAlpha(value);
        if (normalizedWithAlpha) {
          return {
            isActive: true,
            isValid: true,
            hexColor: normalizedWithAlpha.slice(0, 7),
            alphaPercent: alphaHexToPercent(normalizedWithAlpha.slice(7))
          };
        }

        return {
          isActive: false,
          isValid: String(value || "").trim() === "",
          hexColor: normalizeHexColor(defaultColor) || "#000000",
          alphaPercent: 100
        };
      };

      const applyColorState = (state, force = true) => {
        const fallbackHex = normalizeHexColor(defaultColor) || "#000000";
        const nextHex = normalizeHexColor(state?.hexColor) || fallbackHex;
        const nextAlpha = normalizeAlphaPercent(state?.alphaPercent);
        const nextValue = state?.isActive ? buildColorValue(nextHex, nextAlpha) : "";

        if (force) {
          textInput.value = nextValue;
        }
        pickerInput.value = nextHex.toLowerCase();
        alphaRangeInput.value = String(nextAlpha);
        alphaNumberInput.value = String(nextAlpha);
        renderSwatch(buildColorValue(nextHex, nextAlpha) || nextHex, Boolean(state?.isActive));
      };

      const syncFromText = (force = false) => {
        const state = parseColorState(textInput.value);
        if (!state.isValid && !force) {
          renderSwatch(normalizeHexColor(defaultColor) || "#000000", false);
          return;
        }
        applyColorState(state, force);
      };

      applyColorState(parseColorState(textInput.value), true);

      textInput.addEventListener("input", () => {
        syncFromText(false);
      });

      textInput.addEventListener("blur", () => {
        syncFromText(true);
      });

      pickerInput.addEventListener("input", () => {
        const currentState = parseColorState(textInput.value);
        applyColorState(
          {
            isActive: true,
            isValid: true,
            hexColor: pickerInput.value,
            alphaPercent: currentState.isActive ? currentState.alphaPercent : normalizeAlphaPercent(alphaRangeInput.value)
          },
          true
        );
      });

      const handleAlphaInput = (rawValue) => {
        const normalizedAlpha = normalizeAlphaPercent(rawValue);
        const currentState = parseColorState(textInput.value);
        applyColorState(
          {
            isActive: true,
            isValid: true,
            hexColor: currentState.isActive ? currentState.hexColor : pickerInput.value,
            alphaPercent: normalizedAlpha
          },
          true
        );
      };

      alphaRangeInput.addEventListener("input", () => {
        handleAlphaInput(alphaRangeInput.value);
      });

      alphaNumberInput.addEventListener("input", () => {
        handleAlphaInput(alphaNumberInput.value);
      });

      alphaNumberInput.addEventListener("blur", () => {
        handleAlphaInput(alphaNumberInput.value);
      });

      resetButton.addEventListener("click", () => {
        applyColorState(
          {
            isActive: false,
            isValid: true,
            hexColor: defaultColor,
            alphaPercent: 100
          },
          true
        );
      });

      return {
        commit() {
          syncFromText(true);
        }
      };
    };

    const colorFieldControllers = [
      bindColorField("guestbook-frame-color", "#7A6855"),
      bindColorField("guestbook-background-color", "#3E3935"),
      bindColorField("guestbook-surround-color", "#2C2118")
    ].filter(Boolean);

    const initialPageContent = <%- JSON.stringify(String(activePage.content || ""))
      .replace(/<\//g, "<\\/")
      .replace(/\u2028/g, "\\u2028")
      .replace(/\u2029/g, "\\u2029") %>;
    const editorForm = document.getElementById("guestbook-editor-form");
    const pageContentField = editorForm?.querySelector('textarea[name="page_content"]') || null;
    const previewSyncUrl = String(editorForm?.dataset?.previewSyncUrl || "").trim();
    let previewSyncTimeout = null;

    if (pageContentField) {
      pageContentField.value = initialPageContent;
    }

    const syncPreviewDraft = () => {
      if (!editorForm || !previewSyncUrl) {
        return;
      }

      const formData = new FormData(editorForm);
      fetch(previewSyncUrl, {
        method: "POST",
        body: formData,
        credentials: "same-origin",
        headers: {
          "X-Requested-With": "XMLHttpRequest"
        }
      }).catch(() => {});
    };

    const schedulePreviewSync = (delay = 220) => {
      if (!editorForm || !previewSyncUrl) {
        return;
      }

      if (previewSyncTimeout) {
        window.clearTimeout(previewSyncTimeout);
      }

      previewSyncTimeout = window.setTimeout(() => {
        previewSyncTimeout = null;
        syncPreviewDraft();
      }, delay);
    };

    if (editorForm) {
      editorForm.addEventListener("submit", () => {
        colorFieldControllers.forEach((controller) => controller.commit());
      });
    }

    if (editorForm && previewSyncUrl) {

      editorForm.addEventListener("input", () => {
        schedulePreviewSync();
      });

      editorForm.addEventListener("change", () => {
        schedulePreviewSync(80);
      });

      schedulePreviewSync(0);
    }

    if (pageContentField) {
      pageContentField.addEventListener("keydown", (event) => {
        if (
          event.key !== "Enter" ||
          event.shiftKey ||
          event.altKey ||
          event.ctrlKey ||
          event.metaKey ||
          event.isComposing
        ) {
          return;
        }

        event.preventDefault();

        const selectionStart = pageContentField.selectionStart ?? pageContentField.value.length;
        const selectionEnd = pageContentField.selectionEnd ?? pageContentField.value.length;
        const nextValue =
          `${pageContentField.value.slice(0, selectionStart)}\n${pageContentField.value.slice(selectionEnd)}`;

        pageContentField.value = nextValue;
        pageContentField.setSelectionRange(selectionStart + 1, selectionStart + 1);
        pageContentField.dispatchEvent(new Event("input", { bubbles: true }));
      });
    }
  })();
</script>
