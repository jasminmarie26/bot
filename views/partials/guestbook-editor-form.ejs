      const storageKey = "guestbook-editor-window-name";
      try {
        editorWindowName = String(window.sessionStorage.getItem(storageKey) || "").trim();
      } catch (error) {}

      if (!editorWindowName) {
        editorWindowName = `guestbook-editor-<%= character.id %>-${Math.random().toString(36).slice(2, 10)}`;
        try {
          window.sessionStorage.setItem(storageKey, editorWindowName);
        } catch (error) {}
      }

      try {
        window.name = editorWindowName;
      } catch (error) {}

      return editorWindowName;
    };

    const preparePreviewSubmit = () => {
      syncEditorReturnStepFields();

      const keepaliveState = window.__hrSessionKeepalive || null;
      if (sessionTabIdField) {
        sessionTabIdField.value =
          typeof keepaliveState?.getTabId === "function" ? String(keepaliveState.getTabId() || "").trim() : "";
      }
      if (sessionPagePathField) {
        sessionPagePathField.value =
          typeof keepaliveState?.getCurrentPagePath === "function"
            ? String(keepaliveState.getCurrentPagePath() || "").trim()
            : `${window.location.pathname}${window.location.search}${window.location.hash}`;
      }
      if (sessionPageTitleField) {
        sessionPageTitleField.value =
          typeof keepaliveState?.getCurrentPageTitle === "function"
            ? String(keepaliveState.getCurrentPageTitle() || "").trim()
            : String(document.title || "").trim();
      }

      if (previewReturnToField) {
        previewReturnToField.value = `${window.location.pathname}${window.location.search}${window.location.hash}`;
      }

      if (previewSourceWindowNameField) {
        previewSourceWindowNameField.value = ensureEditorWindowName();
      }
    };

    ensureEditorWindowName();
    previewSubmitButtons.forEach((button) => {
      button.addEventListener("click", preparePreviewSubmit);
    });

    const syncThemeSensitiveFields = () => {
      const isTransparentPurTheme =
        String(themeStyleField?.value || "").trim().toLowerCase() === "transparent-pur";
      colorFieldControllers.forEach((controller) => {
        controller.setDisabled(isTransparentPurTheme);
      });
    };

    const getActiveEditorPage = () =>
      String(
        editorPages.find((page) => !page.hidden)?.dataset?.gbEditorPage ||
        editorPages[0]?.dataset?.gbEditorPage ||
        ""
      )
        .trim()
        .toLowerCase();

    const getCurrentEditorReturnStep = () => {
      if (editorNavigationMode === "outer") {
        const activeJourneyTrigger = Array.from(
          document.querySelectorAll("[data-character-editor-step-trigger]")
        ).find((trigger) => {
          if (!(trigger instanceof HTMLElement)) {
            return false;
          }

          return (
            trigger.classList.contains("is-active") ||
            String(trigger.getAttribute("aria-selected") || "").trim().toLowerCase() === "true"
          );
        });
        const activeJourneyStep = String(
          activeJourneyTrigger?.dataset?.characterEditorStepTrigger || ""
        )
          .trim()
          .toLowerCase();

        if (activeJourneyStep === "character") {
          return "character";
        }

        if (activeJourneyStep === "guestbook-content") {
          return "guestbook-content";
        }
        if (activeJourneyStep === "guestbook-settings") {
          return "guestbook-settings";
        }
        return "guestbook-design";
      }

      const activeEditorPage = getActiveEditorPage();
      if (activeEditorPage === "content") {
        return "guestbook-content";
      }
      if (activeEditorPage === "settings") {
        return "guestbook-settings";
      }
      return "guestbook-design";
    };

    const setEditorReturnStepFields = (nextStep) => {
      editorReturnStepFields.forEach((field) => {
        if (field instanceof HTMLInputElement) {
          field.value = nextStep;
        }
      });
      return nextStep;
    };

    const syncEditorReturnStepFields = () => setEditorReturnStepFields(getCurrentEditorReturnStep());

    const setActiveEditorPage = (pageName, persist = true) => {
      const normalizedPageName = String(pageName || "").trim().toLowerCase();
      const fallbackPageName = String(editorPages[0]?.dataset?.gbEditorPage || "").trim().toLowerCase();
      const nextPageName = editorPages.some((page) => String(page.dataset.gbEditorPage || "").trim().toLowerCase() === normalizedPageName)
        ? normalizedPageName
        : fallbackPageName;

      editorPages.forEach((page) => {
        const isActive = String(page.dataset.gbEditorPage || "").trim().toLowerCase() === nextPageName;
        page.hidden = !isActive;
        page.classList.toggle("is-active", isActive);
      });

      editorPageTriggers.forEach((trigger) => {
        const isActive = String(trigger.dataset.gbEditorPageTrigger || "").trim().toLowerCase() === nextPageName;
        trigger.classList.toggle("is-active", isActive);
        trigger.setAttribute("aria-selected", isActive ? "true" : "false");
