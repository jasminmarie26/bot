    ]);

    const normalizeGuestbookTagLabel = (value) =>
      String(value || "")
        .replace(/\r\n?/g, "\n")
        .replace(/[;,|]+/g, " ")
        .replace(/\s+/g, " ")
        .trim()
        .slice(0, 28);

    const normalizeGuestbookTagKey = (value) =>
      normalizeGuestbookTagLabel(value).toLocaleLowerCase("de-DE");

    const availableGuestbookTagSuggestions = Array.from(
      new Map(
        (Array.isArray(initialGuestbookTagSuggestions) ? initialGuestbookTagSuggestions : [])
          .map((tagLabel) => normalizeGuestbookTagLabel(tagLabel))
          .filter(Boolean)
          .map((tagLabel) => [normalizeGuestbookTagKey(tagLabel), tagLabel])
      ).values()
    );

    const readGuestbookDraftState = () => {
      if (!guestbookDraftStorageKey) {
        return { pages: {}, settings: {}, updatedAt: 0 };
      }

      try {
        const parsed = JSON.parse(window.sessionStorage.getItem(guestbookDraftStorageKey) || "{}");
        const updatedAt = Number(parsed?.updatedAt) || 0;
        if (updatedAt && Date.now() - updatedAt > guestbookDraftMaxAgeMs) {
          window.sessionStorage.removeItem(guestbookDraftStorageKey);
          return { pages: {}, settings: {}, updatedAt: 0 };
        }
        return {
          pages: parsed?.pages && typeof parsed.pages === "object" ? parsed.pages : {},
          settings: parsed?.settings && typeof parsed.settings === "object" ? parsed.settings : {},
          updatedAt
        };
      } catch (error) {
        return { pages: {}, settings: {}, updatedAt: 0 };
      }
    };

    const writeGuestbookDraftState = (state) => {
      if (!guestbookDraftStorageKey) {
        return;
      }

      try {
        window.sessionStorage.setItem(guestbookDraftStorageKey, JSON.stringify(state));
      } catch (error) {}
    };

    const readGuestbookSettingsDraftFields = () => {
      if (!editorForm) {
        return {};
      }

      return Array.from(editorForm.elements).reduce((fields, control) => {
        const fieldName = String(control?.name || "").trim();
        if (!fieldName || !guestbookDraftSettingNames.has(fieldName)) {
          return fields;
        }

        if (control instanceof HTMLInputElement && control.type === "radio") {
          if (control.checked) {
            fields[fieldName] = control.value;
          }
          return fields;
        }

        if (control instanceof HTMLInputElement && control.type === "checkbox") {
          fields[fieldName] = control.checked ? "1" : "";
          return fields;
        }

        fields[fieldName] = String(control.value || "");
        return fields;
      }, {});
    };

    const getGuestbookDraftControls = (fieldName) => {
      const safeFieldName = String(fieldName || "").replace(/\\/g, "\\\\").replace(/"/g, "\\\"");
      return Array.from(editorForm?.querySelectorAll(`[name="${safeFieldName}"]`) || []);
    };

    const rememberGuestbookDraft = () => {
      if (restoringGuestbookDraft || !guestbookDraftStorageKey) {
        return;
      }

      const now = Date.now();
      const draftState = readGuestbookDraftState();
      const nextState = {
        ...draftState,
        pages: {
          ...(draftState.pages || {})
        },
        settings: {
          fields: readGuestbookSettingsDraftFields(),
          updatedAt: now
        },
        updatedAt: now
      };

      if (currentGuestbookPageId && pageContentField) {
        nextState.pages[currentGuestbookPageId] = {
          content: pageContentField.value,
          updatedAt: now
        };
      }

      writeGuestbookDraftState(nextState);
    };

    const applyGuestbookSettingsDraft = (fields) => {
      if (!editorForm || !fields || typeof fields !== "object") {
        return;
      }

      Object.entries(fields).forEach(([fieldName, fieldValue]) => {
        if (!guestbookDraftSettingNames.has(fieldName)) {
          return;
        }

        const controls = getGuestbookDraftControls(fieldName);
        controls.forEach((control) => {
          if (control instanceof HTMLInputElement && control.type === "radio") {
            control.checked = String(control.value) === String(fieldValue);
            return;
          }

          if (control instanceof HTMLInputElement && control.type === "checkbox") {
            control.checked = String(fieldValue || "").trim() === "1";
            return;
          }

          if (
            control instanceof HTMLInputElement ||
            control instanceof HTMLTextAreaElement ||
            control instanceof HTMLSelectElement
          ) {
            control.value = String(fieldValue || "");
          }
        });
      });

      Object.keys(fields).forEach((fieldName) => {
        getGuestbookDraftControls(fieldName).forEach((control) => {
          control.dispatchEvent(new Event("input", { bubbles: true }));
          control.dispatchEvent(new Event("change", { bubbles: true }));
        });
      });
    };

    const restoreGuestbookDraft = () => {
      if (!guestbookDraftStorageKey) {
        return;
      }

      const draftState = readGuestbookDraftState();
      restoringGuestbookDraft = true;
      try {
        applyGuestbookSettingsDraft(draftState.settings?.fields);

        const activePageDraft = currentGuestbookPageId
          ? draftState.pages?.[currentGuestbookPageId]
          : null;
        if (pageContentField && activePageDraft && typeof activePageDraft.content === "string") {
          pageContentField.value = activePageDraft.content;
        }
      } finally {
        restoringGuestbookDraft = false;
      }
    };

    const removeGuestbookDraftInputs = () => {
      if (!editorForm) {
        return;
      }

      editorForm.querySelectorAll("[data-guestbook-draft-submit-field]").forEach((field) => {
        field.remove();
      });
    };

    const appendGuestbookDraftInput = (name, value) => {
      if (!editorForm) {
        return;
      }

      const input = document.createElement("input");
      input.type = "hidden";
      input.name = name;
      input.value = String(value || "");
      input.dataset.guestbookDraftSubmitField = "true";
      editorForm.appendChild(input);
    };

    const appendGuestbookDraftPageContentFields = () => {
      removeGuestbookDraftInputs();
      rememberGuestbookDraft();

      const draftState = readGuestbookDraftState();
      Object.entries(draftState.pages || {}).forEach(([pageId, pageDraft]) => {
        const normalizedPageId = String(pageId || "").trim();
        if (!/^\d+$/.test(normalizedPageId) || typeof pageDraft?.content !== "string") {
          return;
        }

        appendGuestbookDraftInput("guestbook_page_content_id", normalizedPageId);
        appendGuestbookDraftInput("guestbook_page_content_value", pageDraft.content);
      });
    };

    const readGuestbookTagInputState = () => {
      const rawParts = String(guestbookTagsInput?.value || "").split(",");
      const committedParts = rawParts.slice(0, -1);
      const activeFragment = normalizeGuestbookTagLabel(rawParts[rawParts.length - 1] || "");
      const committedKeys = new Set(
        committedParts
          .map((entry) => normalizeGuestbookTagKey(entry))
          .filter(Boolean)
      );

      return {
        rawParts,
        activeFragment,
        committedKeys
      };
    };

    const closeGuestbookTagSuggestions = () => {
      guestbookTagSuggestionResults = [];
      activeGuestbookTagSuggestionIndex = -1;

      if (!guestbookTagSuggestionList) {
        return;
      }

      guestbookTagSuggestionList.hidden = true;
      guestbookTagSuggestionList.innerHTML = "";
      guestbookTagsInput?.setAttribute("aria-expanded", "false");
    };

    const setActiveGuestbookTagSuggestion = (nextIndex) => {
      if (!guestbookTagSuggestionList) {
        return;
      }

      const buttons = Array.from(guestbookTagSuggestionList.querySelectorAll("[data-gb-tag-suggestion-index]"));
      if (!buttons.length) {
        activeGuestbookTagSuggestionIndex = -1;
        return;
      }

      const maxIndex = buttons.length - 1;
      const clampedIndex = Math.min(maxIndex, Math.max(0, nextIndex));
      activeGuestbookTagSuggestionIndex = clampedIndex;

      buttons.forEach((button, buttonIndex) => {
        const isActive = buttonIndex === clampedIndex;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-selected", isActive ? "true" : "false");
      });

      buttons[clampedIndex]?.scrollIntoView?.({ block: "nearest" });
    };

    const applyGuestbookTagSuggestion = (tagLabel) => {
      if (!guestbookTagsInput) {
        return;
      }

      const rawParts = String(guestbookTagsInput.value || "").split(",");
      const nextLabels = rawParts
        .slice(0, -1)
        .map((entry) => normalizeGuestbookTagLabel(entry))
        .filter(Boolean);
      nextLabels.push(normalizeGuestbookTagLabel(tagLabel));

      const seen = new Set();
      const uniqueLabels = nextLabels.filter((entry) => {
        const entryKey = normalizeGuestbookTagKey(entry);
        if (!entryKey || seen.has(entryKey)) {
          return false;
        }

        seen.add(entryKey);
        return true;
      });

      guestbookTagsInput.value = uniqueLabels.length ? `${uniqueLabels.join(", ")}, ` : "";
      closeGuestbookTagSuggestions();
      guestbookTagsInput.focus();
      guestbookTagsInput.setSelectionRange(guestbookTagsInput.value.length, guestbookTagsInput.value.length);
      guestbookTagsInput.dispatchEvent(new Event("input", { bubbles: true }));
    };

    const renderGuestbookTagSuggestions = () => {
      if (!guestbookTagsInput || !guestbookTagSuggestionList) {
        return;
      }

      const { activeFragment, committedKeys } = readGuestbookTagInputState();
      const fragmentKey = normalizeGuestbookTagKey(activeFragment);

      if (!fragmentKey) {
        closeGuestbookTagSuggestions();
        return;
      }

      guestbookTagSuggestionResults = availableGuestbookTagSuggestions
        .filter((tagLabel) => {
          const tagKey = normalizeGuestbookTagKey(tagLabel);
          return tagKey && !committedKeys.has(tagKey) && tagKey.includes(fragmentKey);
        })
        .sort((left, right) => {
          const leftKey = normalizeGuestbookTagKey(left);
          const rightKey = normalizeGuestbookTagKey(right);
          const leftStartsWith = leftKey.startsWith(fragmentKey) ? 0 : 1;
          const rightStartsWith = rightKey.startsWith(fragmentKey) ? 0 : 1;
          if (leftStartsWith !== rightStartsWith) {
            return leftStartsWith - rightStartsWith;
          }
          return left.localeCompare(right, "de", { sensitivity: "base" });
        })
        .slice(0, 8);

      if (!guestbookTagSuggestionResults.length) {
        closeGuestbookTagSuggestions();
        return;
      }

      guestbookTagSuggestionList.innerHTML = "";
      guestbookTagSuggestionResults.forEach((tagLabel, suggestionIndex) => {
        const suggestionButton = document.createElement("button");
        suggestionButton.type = "button";
        suggestionButton.className = "gb-tag-suggestion-btn";
        suggestionButton.dataset.gbTagSuggestionIndex = String(suggestionIndex);
        suggestionButton.setAttribute("role", "option");
        suggestionButton.textContent = tagLabel;
        suggestionButton.addEventListener("mousedown", (event) => {
          event.preventDefault();
        });
        suggestionButton.addEventListener("click", () => {
          applyGuestbookTagSuggestion(tagLabel);
        });
        guestbookTagSuggestionList.appendChild(suggestionButton);
      });

      guestbookTagSuggestionList.hidden = false;
      guestbookTagsInput.setAttribute("aria-expanded", "true");
      setActiveGuestbookTagSuggestion(0);
    };

    const ensureEditorWindowName = () => {
      if (editorWindowName) {
        return editorWindowName;
