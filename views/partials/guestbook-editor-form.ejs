<script>
  (() => {
    const censorRadios = Array.from(document.querySelectorAll('input[name="censor_level"]'));

    censorRadios.forEach((radio) => {
      radio.addEventListener("pointerdown", () => {
        radio.dataset.wasChecked = radio.checked ? "1" : "";
      });

      radio.addEventListener("keydown", (event) => {
        if (event.key === " " || event.key === "Spacebar" || event.key === "Enter") {
          radio.dataset.wasChecked = radio.checked ? "1" : "";
        }
      });

      radio.addEventListener("click", () => {
        if (radio.dataset.wasChecked === "1") {
          window.requestAnimationFrame(() => {
            radio.checked = true;
          });
        }
        delete radio.dataset.wasChecked;
      });
    });

    const normalizeHexColor = (value) => {
      const normalized = String(value || "").trim().toUpperCase();
      return /^#[0-9A-F]{6}$/.test(normalized) ? normalized : "";
    };

    const normalizeColorWithAlpha = (value) => {
      const normalized = String(value || "").trim().toUpperCase();
      return /^#[0-9A-F]{8}$/.test(normalized) ? normalized : "";
    };

    const alphaHexToPercent = (value) => {
      const parsed = Number.parseInt(String(value || "").trim(), 16);
      if (!Number.isFinite(parsed)) {
        return 0;
      }
      const opacityPercent = Math.min(100, Math.max(0, Math.round((parsed / 255) * 100)));
      return 100 - opacityPercent;
    };

    const percentToAlphaHex = (value) => {
      const clampedTransparency = Math.min(100, Math.max(0, Number.parseInt(String(value ?? "").trim(), 10) || 0));
      const opacityPercent = 100 - clampedTransparency;
      return Math.round((opacityPercent / 100) * 255)
        .toString(16)
        .padStart(2, "0")
        .toUpperCase();
    };

    const normalizeAlphaPercent = (value) =>
      Math.min(100, Math.max(0, Number.parseInt(String(value ?? "").trim(), 10) || 0));

    const buildColorValue = (hexColor, alphaPercent) => {
      const normalizedHex = normalizeHexColor(hexColor);
      if (!normalizedHex) {
        return "";
      }
      const normalizedAlpha = normalizeAlphaPercent(alphaPercent);
      return normalizedAlpha >= 100
        ? normalizedHex
        : `${normalizedHex}${percentToAlphaHex(normalizedAlpha)}`;
    };

    const bindColorField = (key, defaultColor) => {
      const textInput = document.getElementById(`${key}-text`);
      const pickerInput = document.getElementById(`${key}-picker`);
      const preview = document.getElementById(`${key}-preview`);
      const alphaRangeInput = document.getElementById(`${key}-alpha`);
      const alphaNumberInput = document.getElementById(`${key}-alpha-number`);
      const resetButton = document.querySelector(`[data-color-reset="${key}"]`);

      if (!textInput || !pickerInput || !preview || !alphaRangeInput || !alphaNumberInput || !resetButton) {
        return null;
      }

      const renderSwatch = (colorValue, isActive) => {
        preview.style.setProperty("--gb-color-preview-color", colorValue);
        preview.style.opacity = isActive ? "1" : "0.42";
      };

      const parseColorState = (value) => {
        const normalizedHex = normalizeHexColor(value);
        if (normalizedHex) {
          return {
            isActive: true,
            isValid: true,
            hexColor: normalizedHex,
            alphaPercent: 0
          };
        }

        const normalizedWithAlpha = normalizeColorWithAlpha(value);
        if (normalizedWithAlpha) {
          return {
            isActive: true,
            isValid: true,
            hexColor: normalizedWithAlpha.slice(0, 7),
            alphaPercent: alphaHexToPercent(normalizedWithAlpha.slice(7))
          };
        }

        return {
          isActive: false,
          isValid: String(value || "").trim() === "",
          hexColor: normalizeHexColor(defaultColor) || "#000000",
          alphaPercent: 0
        };
      };

      const applyColorState = (state, force = true) => {
        const fallbackHex = normalizeHexColor(defaultColor) || "#000000";
        const nextHex = normalizeHexColor(state?.hexColor) || fallbackHex;
        const nextAlpha = normalizeAlphaPercent(state?.alphaPercent);
        const nextValue = state?.isActive ? buildColorValue(nextHex, nextAlpha) : "";

        if (force) {
          textInput.value = nextValue;
        }
        pickerInput.value = nextHex.toLowerCase();
        alphaRangeInput.value = String(nextAlpha);
        alphaNumberInput.value = String(nextAlpha);
        renderSwatch(buildColorValue(nextHex, nextAlpha) || nextHex, Boolean(state?.isActive));
      };

      const syncFromText = (force = false) => {
        const state = parseColorState(textInput.value);
        if (!state.isValid && !force) {
          renderSwatch(normalizeHexColor(defaultColor) || "#000000", false);
          return;
        }
        applyColorState(state, force);
      };

      applyColorState(parseColorState(textInput.value), true);

      textInput.addEventListener("input", () => {
        syncFromText(false);
      });

      textInput.addEventListener("blur", () => {
        syncFromText(true);
      });

      pickerInput.addEventListener("input", () => {
        const currentState = parseColorState(textInput.value);
        applyColorState(
          {
            isActive: true,
            isValid: true,
            hexColor: pickerInput.value,
            alphaPercent: currentState.isActive ? currentState.alphaPercent : normalizeAlphaPercent(alphaRangeInput.value)
          },
          true
        );
      });

      const handleAlphaInput = (rawValue) => {
        const normalizedAlpha = normalizeAlphaPercent(rawValue);
        const currentState = parseColorState(textInput.value);
        applyColorState(
          {
            isActive: true,
            isValid: true,
            hexColor: currentState.isActive ? currentState.hexColor : pickerInput.value,
            alphaPercent: normalizedAlpha
          },
          true
        );
      };

      alphaRangeInput.addEventListener("input", () => {
        handleAlphaInput(alphaRangeInput.value);
      });

      alphaNumberInput.addEventListener("input", () => {
        handleAlphaInput(alphaNumberInput.value);
      });

      alphaNumberInput.addEventListener("blur", () => {
        handleAlphaInput(alphaNumberInput.value);
      });

      resetButton.addEventListener("click", () => {
        applyColorState(
          {
            isActive: false,
            isValid: true,
            hexColor: defaultColor,
            alphaPercent: 0
          },
          true
        );
      });

      const rowElement = textInput.closest("[data-gb-theme-color-row]");

      return {
        commit() {
          syncFromText(true);
        },
        setDisabled(isDisabled) {
          const nextDisabled = Boolean(isDisabled);
          textInput.disabled = nextDisabled;
          pickerInput.disabled = nextDisabled;
          alphaRangeInput.disabled = nextDisabled;
          alphaNumberInput.disabled = nextDisabled;
          resetButton.disabled = nextDisabled;
          if (rowElement) {
            rowElement.classList.toggle("is-disabled", nextDisabled);
            rowElement.setAttribute("aria-disabled", nextDisabled ? "true" : "false");
          }
        }
      };
    };

    const colorFieldControllers = [
      bindColorField("guestbook-frame-color", "#7A6855"),
      bindColorField("guestbook-background-color", "#3E3935"),
      bindColorField("guestbook-surround-color", "#2C2118")
    ].filter(Boolean);

    const initialPageContent = <%- JSON.stringify(String(activePage.content || ""))
      .replace(/<\//g, "<\\/")
      .replace(/\u2028/g, "\\u2028")
      .replace(/\u2029/g, "\\u2029") %>;
    const initialGuestbookTagSuggestions = <%- JSON.stringify(guestbookTagSuggestions)
      .replace(/<\//g, "<\\/")
      .replace(/\u2028/g, "\\u2028")
