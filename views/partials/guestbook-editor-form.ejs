<%
  const usesOuterNavigation = typeof guestbookEditorUseOuterNavigation !== "undefined" && guestbookEditorUseOuterNavigation;
  const selectedGuestbookTags = Array.isArray(settings?.tag_list) ? settings.tag_list : [];
  const guestbookTagSuggestions = Array.isArray(guestbookDiscoveryTagSuggestions)
    ? guestbookDiscoveryTagSuggestions
    : [];
%>

<form
  id="guestbook-editor-form"
  method="POST"
  action="/characters/<%= character.id %>/guestbook/edit/save"
  class="<%= guestbookEditorFormClass || 'panel form gb-editor-form' %>"
  data-preview-sync-url="/characters/<%= character.id %>/guestbook/edit/preview?page_id=<%= activePage.id %>"
  data-html-source-url="/characters/<%= character.id %>/guestbook/edit/render-html?page_id=<%= activePage.id %>"
  data-editor-page-storage-key="guestbook-editor-pane-<%= character.id %>"
  data-editor-navigation-mode="<%= usesOuterNavigation ? 'outer' : 'inner' %>"
  data-editor-character-id="<%= character.id %>"
  data-editor-current-page-id="<%= activePage.id %>"
>
  <input type="hidden" name="page_id" value="<%= activePage.id %>" />
  <input type="hidden" name="editor_return_step" value="guestbook-content" />
  <input type="hidden" name="preview_return_to" value="" />
  <input type="hidden" name="preview_source_window_name" value="" />
  <input type="hidden" name="session_tab_id" value="" />
  <input type="hidden" name="session_page_path" value="" />
  <input type="hidden" name="session_page_title" value="" />

<div class="gb-editor-heading">
    <h2>Einstellungen</h2>
    <span class="gb-editor-helptext">
      <%= usesOuterNavigation
        ? "Schritt 2 bis 4 trennen Design, Seiteninhalt und globale G&auml;stebuch-Einstellungen sauber voneinander."
        : "Aufgeteilt in drei ruhige Seiten, damit Inhalt und Gesamt-Einstellungen nicht mehr durcheinander geraten." %>
    </span>
  </div>

  <% if (!usesOuterNavigation) { %>
    <div class="gb-editor-page-switch" role="tablist" aria-label="G&auml;stebuch Editor Seiten">
      <button
        type="button"
        class="gb-editor-page-tab"
        data-gb-editor-page-trigger="design"
        aria-controls="gb-editor-page-design"
        aria-selected="false"
      >
        1. Design
      </button>
      <button
        type="button"
        class="gb-editor-page-tab"
        data-gb-editor-page-trigger="content"
        aria-controls="gb-editor-page-content"
        aria-selected="false"
      >
        2. Seiteninhalt
      </button>
      <button
        type="button"
        class="gb-editor-page-tab"
        data-gb-editor-page-trigger="settings"
        aria-controls="gb-editor-page-settings"
        aria-selected="false"
      >
        3. Gesamt &amp; Musik
      </button>
    </div>
  <% } %>

  <section
    id="gb-editor-page-design"
    class="gb-editor-page"
    data-gb-editor-page="design"
    aria-labelledby="gb-editor-page-design-title"
  >
    <div class="gb-editor-page-heading">
      <h3 id="gb-editor-page-design-title"><%= usesOuterNavigation ? "Schritt 2: Design & Stil" : "Seite 1: Design & Stil" %></h3>
      <p class="gb-editor-helptext">Theme, Schrift und Farben f&uuml;r das gesamte G&auml;stebuch.</p>
    </div>

    <details class="gb-editor-fold" open>
      <summary class="gb-editor-fold-summary">
        <span>Grunddesign</span>
        <small>Style, Font und Gesamtwirkung</small>
      </summary>

    <div class="gb-editor-basics">
      <label class="gb-editor-card gb-editor-card-field">
        <span class="gb-editor-subheading">Style</span>
        <span class="gb-editor-helptext">Enth&auml;lt jetzt auch ein rahmenloses Transparent-Design.</span>
        <select name="theme_style" data-guestbook-theme-style>
          <option value="pergament-gold" <%= settings.theme_style === "pergament-gold" ? "selected" : "" %>>Pergament Gold</option>
          <option value="rosenlack" <%= settings.theme_style === "rosenlack" ? "selected" : "" %>>Rosenlack</option>
          <option value="mondsilber" <%= settings.theme_style === "mondsilber" ? "selected" : "" %>>Mondsilber</option>
          <option value="elfenhain" <%= settings.theme_style === "elfenhain" ? "selected" : "" %>>Elfenhain</option>
          <option value="kupferpatina" <%= settings.theme_style === "kupferpatina" ? "selected" : "" %>>Kupferpatina</option>
          <option value="bernsteinfeuer" <%= settings.theme_style === "bernsteinfeuer" ? "selected" : "" %>>Bernsteinfeuer</option>
          <option value="sternsamt" <%= settings.theme_style === "sternsamt" ? "selected" : "" %>>Sternensamt</option>
          <option value="winterglas" <%= settings.theme_style === "winterglas" ? "selected" : "" %>>Winterglas</option>
          <option value="tintenmeer" <%= settings.theme_style === "tintenmeer" ? "selected" : "" %>>Tintenmeer</option>
          <option value="obsidian-ornament" <%= settings.theme_style === "obsidian-ornament" ? "selected" : "" %>>Obsidian Ornament</option>
          <option value="transparent-pur" <%= settings.theme_style === "transparent-pur" ? "selected" : "" %>>Transparent Pur</option>
        </select>
      </label>

      <label class="gb-editor-card gb-editor-card-field">
        <span class="gb-editor-subheading">Font</span>
        <span class="gb-editor-helptext">Schriftwahl f&uuml;r Seite und Vorschau.</span>
        <select name="font_style">
          <% (guestbookFontOptions || []).forEach((fontOption) => { %>
            <option value="<%= fontOption.id %>" <%= settings.font_style === fontOption.id ? "selected" : "" %>>
              <%= fontOption.label %>
            </option>
          <% }) %>
        </select>
      </label>

      <div class="gb-editor-card gb-editor-card-field">
        <span class="gb-editor-subheading">Gilt f&uuml;r alle Seiten</span>
        <span class="gb-editor-helptext">
          Alles aus diesem Schritt wird mit einem Speichern direkt f&uuml;r das komplette G&auml;stebuch &uuml;bernommen.
        </span>
      </div>
    </div>
    </details>

    <details class="gb-editor-fold" open>
      <summary class="gb-editor-fold-summary">
        <span>Farben</span>
        <small>Rahmen, Hintergrund und Fl&auml;che</small>
      </summary>

    <div class="gb-editor-grid">
  <div class="gb-color-row" data-gb-theme-color-row>
    <div>
      <span class="gb-editor-subheading">Rahmenfarbe</span>
      <span class="gb-editor-helptext">Leer = Standard vom gew&auml;hlten Style.</span>
    </div>

    <div class="gb-color-input-wrap">
      <input
        id="guestbook-frame-color-text"
        name="frame_color"
        value="<%= settings.frame_color || '' %>"
        maxlength="9"
        placeholder="#7A6855CC"
        spellcheck="false"
        autocomplete="off"
      />
      <input
        id="guestbook-frame-color-picker"
        class="gb-color-picker"
        type="color"
        value="<%= /^#[0-9a-f]{6}(?:[0-9a-f]{2})?$/i.test(String(settings.frame_color || '').trim()) ? String(settings.frame_color).trim().slice(0, 7) : '#7A6855' %>"
        aria-label="Rahmenfarbe ausw&auml;hlen"
      />
      <span id="guestbook-frame-color-preview" class="gb-color-preview gb-color-preview-swatch" aria-hidden="true"></span>
      <button type="button" class="btn btn-secondary gb-color-reset" data-color-reset="guestbook-frame-color">
        Standard
      </button>
      <label class="gb-color-alpha-field" for="guestbook-frame-color-alpha">
        Transparenz
        <div class="gb-color-alpha-controls">
          <input
            id="guestbook-frame-color-alpha"
            class="gb-color-alpha-range"
            type="range"
            min="0"
            max="100"
            step="1"
            value="0"
          />
          <input
            id="guestbook-frame-color-alpha-number"
            class="gb-color-alpha-number"
            type="number"
            min="0"
            max="100"
            step="1"
            value="0"
            inputmode="numeric"
            aria-label="Rahmenfarbe Transparenz in Prozent"
          />
          <span class="gb-color-alpha-unit">%</span>
        </div>
      </label>
    </div>
  </div>

  <div class="gb-color-row" data-gb-theme-color-row>
    <div>
      <span class="gb-editor-subheading">Hintergrundfarbe</span>
      <span class="gb-editor-helptext">Beim Transparent-Design bleibt die Seite ohne Farbe leer und offen.</span>
    </div>

    <div class="gb-color-input-wrap">
      <input
        id="guestbook-background-color-text"
        name="background_color"
        value="<%= settings.background_color || '' %>"
        maxlength="9"
        placeholder="#3E3935CC"
        spellcheck="false"
        autocomplete="off"
      />
      <input
        id="guestbook-background-color-picker"
        class="gb-color-picker"
        type="color"
        value="<%= /^#[0-9a-f]{6}(?:[0-9a-f]{2})?$/i.test(String(settings.background_color || '').trim()) ? String(settings.background_color).trim().slice(0, 7) : '#3E3935' %>"
        aria-label="Hintergrundfarbe ausw&auml;hlen"
      />
      <span
        id="guestbook-background-color-preview"
        class="gb-color-preview gb-color-preview-swatch"
        aria-hidden="true"
      ></span>
      <button type="button" class="btn btn-secondary gb-color-reset" data-color-reset="guestbook-background-color">
        Standard
      </button>
      <label class="gb-color-alpha-field" for="guestbook-background-color-alpha">
        Transparenz
        <div class="gb-color-alpha-controls">
          <input
            id="guestbook-background-color-alpha"
            class="gb-color-alpha-range"
            type="range"
            min="0"
            max="100"
            step="1"
            value="0"
          />
          <input
            id="guestbook-background-color-alpha-number"
            class="gb-color-alpha-number"
            type="number"
            min="0"
            max="100"
            step="1"
            value="0"
            inputmode="numeric"
            aria-label="Hintergrundfarbe Transparenz in Prozent"
          />
          <span class="gb-color-alpha-unit">%</span>
        </div>
      </label>
    </div>
  </div>

  <div class="gb-color-row" data-gb-theme-color-row>
    <div>
      <span class="gb-editor-subheading">Fl&auml;che hinter dem Rahmen</span>
      <span class="gb-editor-helptext">F&auml;rbt den gro&szlig;en Bereich um das G&auml;stebuch, aber nicht den Header oben.</span>
    </div>

    <div class="gb-color-input-wrap">
      <input
        id="guestbook-surround-color-text"
        name="surround_color"
        value="<%= settings.surround_color || '' %>"
        maxlength="9"
        placeholder="#2C2118CC"
        spellcheck="false"
        autocomplete="off"
      />
      <input
        id="guestbook-surround-color-picker"
        class="gb-color-picker"
        type="color"
        value="<%= /^#[0-9a-f]{6}(?:[0-9a-f]{2})?$/i.test(String(settings.surround_color || '').trim()) ? String(settings.surround_color).trim().slice(0, 7) : '#2C2118' %>"
        aria-label="Fl&auml;chenfarbe ausw&auml;hlen"
      />
      <span
        id="guestbook-surround-color-preview"
        class="gb-color-preview gb-color-preview-swatch"
        aria-hidden="true"
      ></span>
      <button type="button" class="btn btn-secondary gb-color-reset" data-color-reset="guestbook-surround-color">
        Standard
      </button>
      <label class="gb-color-alpha-field" for="guestbook-surround-color-alpha">
        Transparenz
        <div class="gb-color-alpha-controls">
          <input
            id="guestbook-surround-color-alpha"
            class="gb-color-alpha-range"
            type="range"
            min="0"
            max="100"
            step="1"
            value="0"
          />
          <input
            id="guestbook-surround-color-alpha-number"
            class="gb-color-alpha-number"
            type="number"
            min="0"
            max="100"
            step="1"
            value="0"
            inputmode="numeric"
            aria-label="Fl&auml;chenfarbe Transparenz in Prozent"
          />
          <span class="gb-color-alpha-unit">%</span>
        </div>
      </label>
    </div>
  </div>
    </div>
    </details>
  </section>

  <section
    id="gb-editor-page-content"
    class="gb-editor-page"
    data-gb-editor-page="content"
    aria-labelledby="gb-editor-page-content-title"
    hidden
  >
    <div class="gb-editor-page-heading">
      <h3 id="gb-editor-page-content-title"><%= usesOuterNavigation ? "Schritt 3: Seiteninhalt" : "Seite 2: Seiteninhalt" %></h3>
      <p class="gb-editor-helptext">Hier bearbeitest du nur den Inhalt der aktuell gew&auml;hlten G&auml;stebuch-Seite.</p>
    </div>

    <div class="gb-editor-grid">
  <div class="gb-editor-card gb-editor-card-full gb-editor-section">
    <span class="gb-editor-subheading">Seitenweise</span>
    <span class="gb-editor-helptext">
      BBCode und Texte gelten nur f&uuml;r die gerade ausgew&auml;hlte Seite. Die g&auml;stebuchweiten Bilder und die Musik findest du gesammelt in Schritt 4.
    </span>
  </div>
  <div class="gb-editor-row gb-editor-notes-row">
    <div class="gb-editor-row-meta">
      <span class="gb-editor-subheading">BBCode</span>
      <span class="gb-editor-helptext">Hilfe und Bildgr&ouml;&szlig;en kompakt an einer Stelle.</span>
    </div>
    <div class="gb-editor-row-content">
      <p class="gb-editor-link-row">
        <a
          class="gb-editor-text-link"
          href="https://heldenhaftereisen.net/help/gaestebuch-design-bbcode"
          target="_blank"
          rel="noopener noreferrer"
        >
          BBCode Hilfe
        </a>
      </p>
      <details class="gb-editor-notes">
        <summary>Hinweise anzeigen</summary>
        <div class="gb-editor-notes-list">
          <span class="gb-editor-helptext">Normales BBCode-Bild im G&auml;stebuch: max. 600px Breite</span>
          <span class="gb-editor-helptext">BBCode-Bild links oder rechts: max. 120px Breite</span>
          <span class="gb-editor-helptext">Gro&szlig;es Bild oben auf der G&auml;stebuch-Seite: volle Breite, max. 240px H&ouml;he</span>
          <span class="gb-editor-helptext">Bild innerhalb des Rahmens: wird als Hintergrund &uuml;ber die G&auml;stebuchfl&auml;che gelegt und automatisch skaliert; die Seite selbst liegt bei max. 620px Breite</span>
        </div>
      </details>
    </div>
  </div>

  <div class="gb-editor-content-row">
    <div class="gb-editor-row-meta">
      <span class="gb-editor-subheading">Seiteninhalt</span>
      <span class="gb-editor-helptext">BBCode bleibt voll erhalten, nur die Darstellung des Editors ist kompakter.</span>
    </div>
    <div class="gb-editor-row-content">
      <div class="gb-bbcode-toolbar-wrap">
        <details class="gb-bbcode-toolbar-shell" open>
          <summary>BBCode Werkzeuge</summary>
          <div class="gb-bbcode-toolbar" data-gb-bbcode-toolbar aria-label="BBCode Werkzeugleiste">
            <div class="gb-bbcode-toolbar-group">
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-action="source-toggle" title="Quellcode Ansicht" aria-label="Quellcode Ansicht"><span class="gb-bbcode-btn-glyph gb-bbcode-btn-glyph-svg" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M9 9l-3 3 3 3"></path><path d="M15 9l3 3-3 3"></path><path d="M13 7l-2 10"></path><path d="M14 3H7a2 2 0 0 0-2 2v14l3.5-3H17a2 2 0 0 0 2-2V8l-5-5z"></path></svg></span></button>
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-history="undo" title="Rückgängig" aria-label="Rückgängig"><span class="gb-bbcode-btn-glyph gb-bbcode-btn-glyph-svg" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M9 7H5v4"></path><path d="M5 11a8 8 0 1 0 2.4-5.7L5 7"></path></svg></span></button>
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-history="redo" title="Wiederholen" aria-label="Wiederholen"><span class="gb-bbcode-btn-glyph gb-bbcode-btn-glyph-svg" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M15 7h4v4"></path><path d="M19 11a8 8 0 1 1-2.4-5.7L19 7"></path></svg></span></button>
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-action="fullscreen-toggle" title="Vollbild" aria-label="Vollbild"><span class="gb-bbcode-btn-glyph gb-bbcode-btn-glyph-svg" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M8 4H4v4"></path><path d="M16 4h4v4"></path><path d="M20 16v4h-4"></path><path d="M4 16v4h4"></path><path d="M9 9L4 4"></path><path d="M15 9l5-5"></path><path d="M15 15l5 5"></path><path d="M9 15l-5 5"></path></svg></span></button>
            </div>

            <div class="gb-bbcode-toolbar-group">
              <details class="gb-bbcode-menu">
                <summary class="gb-bbcode-btn gb-bbcode-btn-icon" title="Überschrift" aria-label="Überschrift"><span class="gb-bbcode-btn-glyph" aria-hidden="true">H</span></summary>
                <div class="gb-bbcode-menu-list">
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-wrap="h1">Überschrift 1</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-wrap="h2">Überschrift 2</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-wrap="h3">Überschrift 3</button>
                </div>
              </details>
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-wrap="b" title="Fett" aria-label="Fett"><span class="gb-bbcode-btn-glyph" aria-hidden="true">B</span></button>
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-wrap="i" title="Kursiv" aria-label="Kursiv"><span class="gb-bbcode-btn-glyph gb-bbcode-btn-glyph-italic" aria-hidden="true">I</span></button>
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-wrap="u" title="Unterstrichen" aria-label="Unterstrichen"><span class="gb-bbcode-btn-glyph gb-bbcode-btn-glyph-underline" aria-hidden="true">U</span></button>
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-wrap="s" title="Durchgestrichen" aria-label="Durchgestrichen"><span class="gb-bbcode-btn-glyph gb-bbcode-btn-glyph-strike" aria-hidden="true">S</span></button>
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-wrap="sub" title="Tiefgestellt" aria-label="Tiefgestellt"><span class="gb-bbcode-btn-glyph" aria-hidden="true">x<sub>2</sub></span></button>
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-wrap="sup" title="Hochgestellt" aria-label="Hochgestellt"><span class="gb-bbcode-btn-glyph" aria-hidden="true">x<sup>2</sup></span></button>
              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-option="color" title="Farbe" aria-label="Farbe"><span class="gb-bbcode-btn-glyph gb-bbcode-btn-glyph-svg" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M14.5 4.5l5 5"></path><path d="M12 7l5 5"></path><path d="M4 20l4.5-1.2L18 9.3a1.8 1.8 0 0 0 0-2.6l-.7-.7a1.8 1.8 0 0 0-2.6 0L5.2 15.5 4 20z"></path></svg></span></button>
            </div>

            <div class="gb-bbcode-toolbar-group">
              <details class="gb-bbcode-menu">
                <summary class="gb-bbcode-btn gb-bbcode-btn-icon" title="Schriftart" aria-label="Schriftart"><span class="gb-bbcode-btn-glyph" aria-hidden="true">T|</span></summary>
                <div class="gb-bbcode-menu-list">
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-font-value="Arial">Arial</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-font-value="Comic Sans MS">Comic Sans MS</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-font-value="Consolas">Consolas</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-font-value="Georgia">Georgia</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-font-value="Lucida Sans Unicode">Lucida Sans Unicode</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-font-value="Tahoma">Tahoma</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-font-value="Times New Roman">Times New Roman</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-font-value="Trebuchet MS">Trebuchet MS</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-font-value="Verdana">Verdana</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-option="size">Schriftgr&ouml;&szlig;e...</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-font-clear="true">Schriftart entfernen</button>
                </div>
              </details>

              <details class="gb-bbcode-menu">
                <summary class="gb-bbcode-btn gb-bbcode-btn-icon" title="Liste" aria-label="Liste"><span class="gb-bbcode-btn-glyph gb-bbcode-btn-glyph-svg" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M9 6h11"></path><path d="M9 12h11"></path><path d="M9 18h11"></path><circle cx="5" cy="6" r="1"></circle><circle cx="5" cy="12" r="1"></circle><circle cx="5" cy="18" r="1"></circle></svg></span></summary>
                <div class="gb-bbcode-menu-list">
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-template="list-bullet">Punkte</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-template="list-numbered">Nummeriert</button>
                </div>
              </details>

              <details class="gb-bbcode-menu">
                <summary class="gb-bbcode-btn gb-bbcode-btn-icon" title="Ausrichtung" aria-label="Ausrichtung"><span class="gb-bbcode-btn-glyph gb-bbcode-btn-glyph-svg" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 7h16"></path><path d="M8 12h12"></path><path d="M6 17h14"></path></svg></span></summary>
                <div class="gb-bbcode-menu-list">
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-wrap="left">Linksbündig</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-wrap="center">Zentrieren</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-wrap="right">Rechtsbündig</button>
                  <button type="button" class="gb-bbcode-menu-item" data-bbcode-wrap="block">Blocksatz</button>
                </div>
              </details>

              <details class="gb-bbcode-menu">
