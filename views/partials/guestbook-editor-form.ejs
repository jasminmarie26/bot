    let restoringGuestbookDraft = false;
    const guestbookDraftStorageKey = editorCharacterId ? `guestbook-editor-drafts-v1-${editorCharacterId}` : "";
    const guestbookDraftMaxAgeMs = 24 * 60 * 60 * 1000;
    const guestbookDraftSettingNames = new Set([
      "theme_style",
      "font_style",
      "frame_color",
      "background_color",
      "surround_color",
      "censor_level",
      "guestbook_tags_custom",
      "inner_image_url",
