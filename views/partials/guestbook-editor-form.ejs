              <button type="button" class="gb-bbcode-btn gb-bbcode-btn-icon" data-bbcode-wrap="icode" title="Inline-Code" aria-label="Inline-Code"><span class="gb-bbcode-btn-glyph" aria-hidden="true">&gt;_</span></button>
