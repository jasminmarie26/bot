    if (editorPageTriggers.length && editorPages.length) {
      let initialEditorPage = "";
      if (editorPageStorageKey) {
        try {
          initialEditorPage = window.localStorage.getItem(editorPageStorageKey) || "";
        } catch (error) {}
      }
      setActiveEditorPage(initialEditorPage || "design", false);

      editorPageTriggers.forEach((trigger) => {
        trigger.addEventListener("click", () => {
          setActiveEditorPage(trigger.dataset.gbEditorPageTrigger || "design");
        });
      });
    }

    window.requestAnimationFrame(() => {
      syncEditorReturnStepFields();
    });

    if (editorPages.length) {
      window.setGuestbookEditorPage = (pageName, options = {}) => {
        const shouldPersist = options && Object.prototype.hasOwnProperty.call(options, "persist")
          ? Boolean(options.persist)
          : true;
        setActiveEditorPage(pageName, shouldPersist);
      };
      window.getGuestbookEditorPage = () => getActiveEditorPage();
