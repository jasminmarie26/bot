      if (persist && editorPageStorageKey) {
        try {
          window.localStorage.setItem(editorPageStorageKey, nextPageName);
        } catch (error) {}
      }

      window.dispatchEvent(
        new CustomEvent("guestbook-editor-pagechange", {
          detail: {
            page: nextPageName
          }
        })
      );

      syncEditorReturnStepFields();
