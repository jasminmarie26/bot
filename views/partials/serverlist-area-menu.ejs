<%
  const areaMenuMode = String(typeof serverlistAreaMenuMode !== "undefined" ? serverlistAreaMenuMode || "" : "").trim().toLowerCase();
  const areaMenuOpenInNewTab = Boolean(typeof serverlistAreaMenuNewTab !== "undefined" && serverlistAreaMenuNewTab);
  const areaMenuLinks = areaMenuMode === "servers"
    ? [
        { href: "/dashboard/areas/free-rp", label: "Free-RP" },
        { href: "/dashboard/areas/erp", label: "ERP" }
      ]
    : [
        { href: "/dashboard", label: "Rollenspiel" },
        { href: "/dashboard/larp", label: "LARP" }
      ];
  const areaMenuTargetAttributes = areaMenuOpenInNewTab
    ? ' target="_blank" rel="noopener noreferrer"'
    : "";
%>
<div class="rp-dropdown topbar-area-menu">
  <button
    type="button"
    class="rp-dropdown-toggle topbar-area-menu-toggle"
    aria-haspopup="menu"
    aria-expanded="false"
  >
    Serverliste
  </button>
  <div class="rp-dropdown-menu topbar-area-menu-list" role="menu">
    <% areaMenuLinks.forEach((link) => { %>
      <a href="<%= link.href %>" role="menuitem"<%- areaMenuTargetAttributes %>><%= link.label %></a>
    <% }) %>
  </div>
</div>
