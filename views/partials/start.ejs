<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <script>
      (() => {
        const isEdgeBrowser = /\bEdg\//.test(window.navigator.userAgent);
        if (!isEdgeBrowser) return;

        if ("scrollRestoration" in window.history) {
          window.history.scrollRestoration = "manual";
        }

        const navigationEntry = window.performance.getEntriesByType?.("navigation")?.[0];
        const navigationType =
          navigationEntry?.type ||
          (window.performance.navigation?.type === 1 ? "reload" : "");

        if (navigationType !== "reload") return;

        const scrollToTop = () => {
          window.scrollTo(0, 0);
          document.documentElement.scrollTop = 0;
          document.body.scrollTop = 0;
        };

        window.addEventListener(
          "load",
          () => {
            window.requestAnimationFrame(() => {
              window.requestAnimationFrame(scrollToTop);
            });
          },
          { once: true }
        );
      })();
    </script>
    <script>
      (() => {
        const isGuestbookPath = /^\/characters\/\d+\/guestbook\/?$/.test(window.location.pathname);
        if (!isGuestbookPath) return;

        const urlParams = new URLSearchParams(window.location.search);
        const pageId = urlParams.get("page_id") || "default";
        const storageKey = `guestbook-panel:${window.location.pathname}:${pageId}`;
        const hasGuestbookEntryHash = window.location.hash.startsWith("#guestbook-entry-");

        try {
          if (window.sessionStorage.getItem(storageKey) === "open" || hasGuestbookEntryHash) {
            document.documentElement.classList.add("guestbook-panel-open");
          }
        } catch (_error) {
          if (hasGuestbookEntryHash) {
            document.documentElement.classList.add("guestbook-panel-open");
          }
        }
      })();
    </script>
    <script>
      (() => {
        const NOCTRA_PATTERN = /^noctra(?:\b|\s|\[|\()/i;
        const TARGET_SELECTOR = [
          ".role-name-admin",
          ".staff-name-admin",
          ".rp-header-identity",
          ".topbar-user-menu-meta > strong"
        ].join(", ");

        const syncNoctraHorns = (root = document) => {
          const targets = [];
          if (root instanceof Element && root.matches(TARGET_SELECTOR)) {
            targets.push(root);
          }
          if (root?.querySelectorAll) {
            targets.push(...root.querySelectorAll(TARGET_SELECTOR));
          }

          targets.forEach((node) => {
            const label = String(node.textContent || "").trim();
            node.classList.toggle("has-noctra-horns", NOCTRA_PATTERN.test(label));
          });
        };

        const boot = () => {
          syncNoctraHorns(document);

          if (!document.body || typeof MutationObserver !== "function") {
            return;
          }

          const observer = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
              if (mutation.type === "characterData") {
                syncNoctraHorns(mutation.target?.parentElement || document);
                return;
              }

              mutation.addedNodes.forEach((node) => {
                if (node instanceof Element) {
                  syncNoctraHorns(node);
                }
              });

              if (mutation.target instanceof Element) {
                syncNoctraHorns(mutation.target);
              }
            });
          });

          observer.observe(document.body, {
            subtree: true,
            childList: true,
            characterData: true
          });
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", boot, { once: true });
        } else {
          boot();
        }
      })();
    </script>
    <% const includeRealtimeAssets = typeof enableRealtime !== "undefined" ? Boolean(enableRealtime) : true; %>
    <% if (includeRealtimeAssets) { %>
      <script src="/socket.io/socket.io.js?v=<%= staticAssetVersion %>"></script>
    <% } %>
    <link rel="icon" type="image/x-icon" href="/favicon-hr.ico?v=<%= staticAssetVersion %>" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-hr-32.png?v=<%= staticAssetVersion %>" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-hr-16.png?v=<%= staticAssetVersion %>" />
    <link rel="apple-touch-icon" href="/apple-touch-icon-hr.png?v=<%= staticAssetVersion %>" />
    <link rel="shortcut icon" href="/favicon-hr.ico?v=<%= staticAssetVersion %>" />
    <link rel="stylesheet" href="/styles.css?v=<%= staticAssetVersion %>" />
  </head>
    <% const bodyClassNames = [`theme-${activeTheme}`]; %>
    <% if (typeof pageClass !== "undefined" && pageClass) { bodyClassNames.push(pageClass); } %>
  <body class="<%= bodyClassNames.join(' ') %>">
    <% const topbarHidden = typeof hideTopbar !== "undefined" ? hideTopbar : false; %>
    <% const showAccountDeleteControl = Boolean(
      currentUser &&
      currentPath &&
      currentPath.startsWith("/account")
    ); %>
    <% const menuCharacter =
      typeof topbarCharacter !== "undefined"
        ? topbarCharacter
        : typeof activeCharacter !== "undefined" && activeCharacter
          ? activeCharacter
          : typeof character !== "undefined" && character
            ? character
            : null; %>
    <% const canEditMenuCharacter = Boolean(
      menuCharacter &&
      (
        (typeof isOwner !== "undefined" && isOwner) ||
        menuCharacter.is_owner
      )
    ); %>
    <% const displayIdentityName =
      currentUserDisplayName || (currentUser ? currentUser.display_name || currentUser.username : ""); %>
    <% const accountDisplayName =
      currentUserAccountName || (currentUser ? currentUser.username : ""); %>
    <% const menuCharacterIsAdmin = Boolean(
      menuCharacter &&
      currentUser &&
      currentUser.is_admin &&
      Number(currentUser.admin_character_id) === Number(menuCharacter.id)
    ); %>
    <% const menuCharacterIsModerator = Boolean(
      menuCharacter &&
      currentUser &&
      currentUser.is_moderator &&
      Number(currentUser.moderator_character_id) === Number(menuCharacter.id)
    ); %>
    <% const activeMenuIdentityName = menuCharacter
      ? (menuCharacterIsModerator ? `${menuCharacter.name} (M)` : menuCharacter.name)
      : displayIdentityName; %>
    <% const activeMenuIdentityRoleStyle = menuCharacter
      ? (menuCharacterIsAdmin ? "admin" : (menuCharacterIsModerator ? "moderator" : ""))
      : (currentUserDisplayRoleStyle || ""); %>
    <% const topbarBrandText =
      typeof topbarBrandLabel !== "undefined" && topbarBrandLabel
        ? topbarBrandLabel
        : "Heldenhafte Reisen"; %>
    <% const topbarBrandTarget =
      typeof topbarBrandHref !== "undefined" && topbarBrandHref
        ? topbarBrandHref
        : "/"; %>
    <% const topbarBrandClass =
      typeof topbarBrandModifier !== "undefined" && topbarBrandModifier
        ? `brand ${topbarBrandModifier}`
        : "brand"; %>
    <% const topbarBrandHasNoctraHorns = String(topbarBrandText || "").trim().toLowerCase() === "noctra"; %>
    <% const topbarBrandClassName = topbarBrandHasNoctraHorns
      ? `${topbarBrandClass} has-noctra-horns`
      : topbarBrandClass; %>
    <% const topbarRoleplayAreaHref =
      menuCharacter && (menuCharacter.server_id === "free-rp" || menuCharacter.server_id === "erp")
        ? `/dashboard/areas/${menuCharacter.server_id}`
        : "/dashboard"; %>
    <% const topbarAreaLabel = "Serverliste"; %>
    <% const isDashboardPath = Boolean(currentPath && currentPath.startsWith("/dashboard")); %>
    <% const topbarGuestbookModeActive = Boolean(
      typeof topbarGuestbookMode !== "undefined" && topbarGuestbookMode
    ); %>
    <% const topbarCharacterCreatedAtLabel =
      typeof characterCreatedAtLabel !== "undefined" ? String(characterCreatedAtLabel || "").trim() : ""; %>
    <% const showTopbarGuestbookCreatedAt = Boolean(
      topbarGuestbookModeActive && topbarCharacterCreatedAtLabel
    ); %>
    <% const showTopbarLiveUpdatesLink = Boolean(!topbarGuestbookModeActive); %>
    <% const showTopbarBackupLink = Boolean(
      currentUser &&
      !topbarGuestbookModeActive &&
      isDashboardPath
    ); %>
    <% const showTopbarRpBoardLink = Boolean(
      !topbarGuestbookModeActive &&
      menuCharacter &&
      (menuCharacter.server_id === "free-rp" || menuCharacter.server_id === "erp")
    ); %>
    <% const topbarRpBoardHref = showTopbarRpBoardLink
      ? `/rp-board?server_id=${menuCharacter.server_id}&character_id=${Number(menuCharacter.id)}`
      : ""; %>
    <% const topbarLiveUpdatesInitialRevision = String(
      typeof latestSiteUpdateRevisionToken !== "undefined" ? latestSiteUpdateRevisionToken || "" : ""
    ).trim(); %>
    <% const topbarLiveUpdatesInitialRevisions = Array.isArray(recentSiteUpdateRevisions)
      ? recentSiteUpdateRevisions
      : []; %>
    <% if (!topbarHidden) { %>
      <header class="topbar">
        <div class="topbar-inner<%= showTopbarGuestbookCreatedAt ? " has-guestbook-created-at" : "" %>">
          <% if (!topbarGuestbookModeActive) { %>
            <a class="<%= topbarBrandClass %>" href="<%= topbarBrandTarget %>"><%= topbarBrandText %></a>
          <% } else { %>
            <div class="topbar-guestbook-control">
              <button
                type="button"
                class="guestbook-entry-toggle"
                data-guestbook-panel-toggle
                aria-controls="guestbook-entry-panel"
                aria-expanded="false"
                aria-label="Gästebuch-Einträge öffnen"
                title="Gästebuch-Einträge öffnen"
              >
                <span class="guestbook-entry-toggle-icon" aria-hidden="true"></span>
              </button>
              <span class="guestbook-entry-heading">G&auml;stebuch-Eintr&auml;ge</span>
            </div>
            <% if (showTopbarGuestbookCreatedAt) { %>
              <div class="topbar-guestbook-created-wrap">
                <span class="topbar-guestbook-created-at">
                  <span>Charakter erstellt am</span>
                  <strong><%= topbarCharacterCreatedAtLabel %></strong>
                </span>
              </div>
            <% } %>
          <% } %>
          <nav class="nav <%= topbarGuestbookModeActive ? "nav-guestbook-mode" : "" %>">
            <% if (currentUser) { %>
              <% if (!topbarGuestbookModeActive) { %>
                <a href="<%= topbarRoleplayAreaHref %>"><%= topbarAreaLabel %></a>
                <a href="/members" target="_blank" rel="noopener noreferrer">Mitglieder</a>
                <% if (menuCharacter && (menuCharacter.server_id === "free-rp" || menuCharacter.server_id === "erp")) { %>
                  <a href="/characters/<%= menuCharacter.id %>/festplays/public" target="_blank" rel="noopener noreferrer">Festspiele</a>
                <% } %>
                <% if (showTopbarRpBoardLink) { %>
                  <a
                    class="rp-board-nav-link"
                    href="<%= topbarRpBoardHref %>"
                    target="_blank"
                    rel="noopener noreferrer"
                    data-rp-board-link-root
                    data-rp-board-server-id="<%= menuCharacter.server_id %>"
                    data-rp-board-festplay-id="0"
                    data-rp-board-character-id="<%= Number(menuCharacter.id) %>"
                  >
                    <span>RP-Aushang</span>
                    <span class="rp-board-nav-badge" data-rp-board-badge hidden>1</span>
                  </a>
                <% } %>
              <% } %>
              <% if (currentUser.is_admin) { %>
                <a href="/admin">Admin</a>
              <% } %>
            <% } else { %>
              <a href="/login">Login</a>
              <a href="/register">Registrieren</a>
            <% } %>
            <% if (showTopbarBackupLink) { %>
              <a href="/character-backups" target="_blank" rel="noopener noreferrer">Backup</a>
            <% } %>
            <% if (showTopbarLiveUpdatesLink) { %>
              <a
                class="live-updates-nav-link"
                href="/live-updates"
                target="site-live-updates"
                data-live-updates-link-root
                data-live-updates-target="site-live-updates"
                data-live-updates-initial-revision="<%= topbarLiveUpdatesInitialRevision %>"
                data-live-updates-initial-revisions="<%= topbarLiveUpdatesInitialRevisions.join('|') %>"
              >
                <span>Live Updates</span>
                <span class="live-updates-nav-badge" data-live-updates-badge hidden>1</span>
              </a>
            <% } %>
            <% if (!topbarGuestbookModeActive) { %>
              <form method="POST" action="/settings/theme" class="inline-form theme-form">
                <label for="theme-select">Design</label>
                <input type="hidden" name="return_to" value="<%= currentPath || '/' %>" />
                <select
                  id="theme-select"
                  name="theme"
                  class="theme-select"
                >
                  <% availableThemes.forEach((theme) => { %>
                    <option value="<%= theme.id %>" <%= activeTheme === theme.id ? "selected" : "" %>>
                      <%= theme.label %>
                    </option>
                  <% }) %>
                </select>
              </form>
            <% } %>
            <% if (currentUser) { %>
              <% if (topbarGuestbookModeActive) { %>
                <a class="<%= `${topbarBrandClassName} brand-in-nav` %>" href="<%= topbarBrandTarget %>">
                  <span class="<%= topbarBrandHasNoctraHorns ? 'noctra-nameplate' : '' %>"><%= topbarBrandText %></span>
                </a>
              <% } %>
              <%- include("guestbook-notification-link") %>
              <details class="topbar-user-menu">
                <summary
                  class="topbar-user-menu-toggle"
                  aria-label="Benutzermen&uuml; &ouml;ffnen"
                  title="Benutzermen&uuml;"
                >
                  <span class="topbar-user-menu-toggle-icon" aria-hidden="true">&#128100;</span>
                </summary>
                <div class="topbar-user-menu-panel">
                  <div class="topbar-user-menu-meta">
                    <strong class="<%= activeMenuIdentityRoleStyle ? `role-name-${activeMenuIdentityRoleStyle}` : "" %>"><%= activeMenuIdentityName %></strong>
                    <% if (accountDisplayName && accountDisplayName !== activeMenuIdentityName) { %>
                      <span>Konto: <%= accountDisplayName %></span>
                    <% } %>
                    <span>Account Nr.: <%= currentUser.account_number %></span>
                    <% if (menuCharacter) { %>
                      <span>Charakter: <%= menuCharacter.name %></span>
                      <span>Server: <%= menuCharacter.server_id === "erp" ? "ERP" : "FREE-RP" %></span>
                    <% } %>
                  </div>

                  <nav class="topbar-user-menu-links" aria-label="Kontomen&uuml;">
                    <a href="/account" target="_blank" rel="noopener noreferrer">Account</a>
                    <% if (!isDashboardPath) { %>
                      <a href="/dashboard" target="_blank" rel="noopener noreferrer">Serverliste</a>
                    <% } %>
                    <% if (menuCharacter) { %>
                      <a href="/characters/<%= menuCharacter.id %>">Charakter</a>
                      <% if (canEditMenuCharacter) { %>
                        <a href="/characters/<%= menuCharacter.id %>/edit" target="_blank" rel="noopener noreferrer">Charakter editieren</a>
                      <% } %>
                      <a href="/characters/<%= menuCharacter.id %>/guestbook" target="_blank" rel="noopener noreferrer">G&auml;stebuch</a>
                      <% if (menuCharacter.server_id === "free-rp" || menuCharacter.server_id === "erp") { %>
                        <a href="/characters/<%= menuCharacter.id %>/festplays" target="_blank" rel="noopener noreferrer">Meine Festplays</a>
                      <% } %>
                    <% } %>
                    <a href="/help" target="_blank" rel="noopener noreferrer">Hilfe</a>
                  </nav>

                  <form method="POST" action="/logout" class="inline-form topbar-user-menu-form">
                    <button type="submit" class="topbar-user-menu-logout">Logout</button>
                  </form>
                </div>
              </details>
            <% } %>
          </nav>
        </div>
      </header>
    <% } %>

    <% if (showAccountDeleteControl) { %>
      <div id="account-delete-modal" class="account-delete-modal" hidden>
        <div class="account-delete-backdrop" data-account-delete-close></div>
        <section
          class="account-delete-card panel"
          role="dialog"
          aria-modal="true"
          aria-labelledby="account-delete-title"
        >
          <h2 id="account-delete-title">Account löschen</h2>
          <p class="muted">
            Dieser Schritt ist dauerhaft. Dein Account und alle dazugehörigen Daten
            (Charaktere, Räume, Einträge) werden unwiderruflich entfernt.
          </p>

          <form method="POST" action="/account/delete" class="form">
            <label>
              Username zur Bestätigung
              <input
                name="confirm_username"
                required
                maxlength="24"
                autocomplete="off"
                placeholder="<%= currentUser.username %>"
              />
            </label>
            <label>
              Passwort
              <input
                type="password"
                name="password"
                required
                minlength="6"
                autocomplete="current-password"
              />
            </label>
            <div class="account-delete-actions">
              <button type="button" class="btn btn-secondary" data-account-delete-close>
                Abbrechen
              </button>
              <button type="submit" class="btn btn-danger">Account endgültig löschen</button>
            </div>
          </form>
        </section>
      </div>

      <script>
        (() => {
          document.addEventListener("DOMContentLoaded", () => {
            const openButton = document.getElementById("account-delete-open");
            const modal = document.getElementById("account-delete-modal");
            if (!openButton || !modal) return;

            const closeElements = modal.querySelectorAll("[data-account-delete-close]");
            const closeModal = () => {
              modal.hidden = true;
              document.body.classList.remove("modal-open");
            };
            const openModal = () => {
              modal.hidden = false;
              document.body.classList.add("modal-open");
            };

            openButton.addEventListener("click", openModal);
            closeElements.forEach((element) => {
              element.addEventListener("click", closeModal);
            });
            document.addEventListener("keydown", (event) => {
              if (event.key === "Escape" && !modal.hidden) {
                closeModal();
              }
            });
          });
        })();
      </script>
    <% } %>

    <% const mainContainerClass = typeof containerClass !== "undefined" && containerClass ? `container ${containerClass}` : "container"; %>
    <% const mainContainerStyle = typeof containerStyle !== "undefined" ? containerStyle : ""; %>
    <main class="<%= mainContainerClass %>"<% if (mainContainerStyle) { %> style="<%= mainContainerStyle %>"<% } %>>
      <% if (flash) { %>
        <div class="flash <%= flash.type === "error" ? "flash-error" : "flash-success" %>">
          <%= flash.text %>
        </div>
      <% } %>

