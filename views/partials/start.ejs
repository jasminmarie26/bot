            : null;
          const topbar = document.querySelector(".topbar");
          const userMenus = Array.from(document.querySelectorAll(".topbar-user-menu"));
          const serverWorkNoticeConfig = serverWorkNotice
            ? {
                timeZone: String(serverWorkNotice.dataset.serverWorkTimeZone || "Europe/Berlin").trim() || "Europe/Berlin",
                weekdays: String(serverWorkNotice.dataset.serverWorkWeekdays || "Mon,Wed,Fri")
                  .split(",")
                  .map((value) => value.trim())
                  .filter(Boolean),
                startMinutes: Number.parseInt(serverWorkNotice.dataset.serverWorkStartMinutes || "", 10),
                endMinutes: Number.parseInt(serverWorkNotice.dataset.serverWorkEndMinutes || "", 10),
                title: String(
                  serverWorkNotice.querySelector("[data-server-work-title]")?.textContent || "Heute Serverarbeit"
                ).trim() || "Heute Serverarbeit",
                message: String(
                  serverWorkNotice.querySelector("[data-server-work-message]")?.textContent || "17:00 bis 20:30 Uhr."
                ).trim()
              }
            : null;
          const serverWorkNoticeClockFormatter = serverWorkNoticeConfig
            ? new Intl.DateTimeFormat("en-US", {
                timeZone: serverWorkNoticeConfig.timeZone,
                weekday: "short",
                hour: "2-digit",
                minute: "2-digit",
                hourCycle: "h23"
              })
            : null;

          const getServerWorkNoticeState = () => {
            if (!serverWorkNoticeConfig || !serverWorkNoticeClockFormatter) {
              return {
                visible: false,
                title: "Heute Serverarbeit",
                message: "17:00 bis 20:30 Uhr."
              };
            }

            const formattedParts = serverWorkNoticeClockFormatter.formatToParts(new Date());
            const partMap = {};
            formattedParts.forEach((part) => {
              if (part.type !== "literal") {
                partMap[part.type] = part.value;
              }
            });

            const weekday = String(partMap.weekday || "");
            const hour = Number(partMap.hour) || 0;
            const minute = Number(partMap.minute) || 0;
            const currentMinutes = hour * 60 + minute;
            const visible =
              serverWorkNoticeConfig.weekdays.includes(weekday) &&
              currentMinutes >= serverWorkNoticeConfig.startMinutes &&
              currentMinutes < serverWorkNoticeConfig.endMinutes;

            return {
              visible,
              title: serverWorkNoticeConfig.title,
              message: serverWorkNoticeConfig.message
            };
          };

          const applyServerWorkNoticeState = (element, state) => {
            if (!element) return;

            const titleNode = element.querySelector("[data-server-work-title]");
            const messageNode = element.querySelector("[data-server-work-message]");

            if (titleNode) {
              titleNode.textContent = state.title;
            }

            if (messageNode) {
              messageNode.textContent = state.message;
              messageNode.hidden = !state.message;
            }

            element.hidden = !state.visible;
          };

          const syncTopbarOffset = () => {
            const serverWorkNoticeOffset = serverWorkNotice
              ? Math.max(0, Math.round(serverWorkNotice.getBoundingClientRect().height))
              : 0;
            const fallbackOffset = 72 + serverWorkNoticeOffset;
            const offset = topbar
              ? Math.max(0, Math.round(topbar.getBoundingClientRect().bottom))
              : Math.max(serverWorkNoticeOffset, fallbackOffset);

            document.documentElement.style.setProperty(
              "--server-work-notice-height",
              `${serverWorkNoticeOffset}px`
            );
            document.documentElement.style.setProperty("--topbar-bottom-offset", `${offset}px`);
          };

          const syncServerWorkNoticeState = () => {
            const state = getServerWorkNoticeState();

            applyServerWorkNoticeState(serverWorkNotice, state);
            applyServerWorkNoticeState(chatServerWorkNotice, state);

            if (chatTopline) {
              chatTopline.classList.toggle("has-server-work-notice", state.visible);
            }

            syncTopbarOffset();
          };

          syncServerWorkNoticeState();
          window.addEventListener("resize", syncTopbarOffset);
          window.addEventListener("orientationchange", syncTopbarOffset);
          window.addEventListener("load", syncTopbarOffset, { once: true });
          window.setInterval(syncServerWorkNoticeState, 5000);
          document.addEventListener("visibilitychange", () => {
            if (!document.hidden) {
              syncServerWorkNoticeState();
            }
          });

          if (topbar && "ResizeObserver" in window) {
            const topbarObserver = new ResizeObserver(syncTopbarOffset);
            topbarObserver.observe(topbar);
          }

          if (serverWorkNotice && "ResizeObserver" in window) {
            const serverWorkNoticeObserver = new ResizeObserver(syncTopbarOffset);
            serverWorkNoticeObserver.observe(serverWorkNotice);
          }

          if (!userMenus.length) return;

          document.addEventListener("click", (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;

            userMenus.forEach((menu) => {
              if (!menu.open || menu.contains(target)) return;
              menu.open = false;
            });
          });
        });
      })();
    </script>

    <% if (showAccountDeleteControl) { %>
      <div id="account-delete-modal" class="account-delete-modal" hidden>
        <div class="account-delete-backdrop" data-account-delete-close></div>
        <section
          class="account-delete-card panel"
          role="dialog"
          aria-modal="true"
          aria-labelledby="account-delete-title"
        >
          <h2 id="account-delete-title">Account löschen</h2>
          <p class="muted">
            Dieser Schritt ist dauerhaft. Dein Account und alle dazugehörigen Daten
            (Charaktere, Räume, Einträge) werden unwiderruflich entfernt.
          </p>

          <form method="POST" action="/account/delete" class="form">
            <label>
              Username zur Bestätigung
              <input
                name="confirm_username"
                required
                maxlength="24"
                autocomplete="off"
                placeholder="<%= currentUser.username %>"
              />
            </label>
            <label>
              Passwort
              <input
                type="password"
                name="password"
                required
                minlength="6"
                autocomplete="current-password"
              />
            </label>
            <div class="account-delete-actions">
              <button type="button" class="btn btn-secondary" data-account-delete-close>
                Abbrechen
              </button>
              <button type="submit" class="btn btn-danger">Account endgültig löschen</button>
            </div>
          </form>
        </section>
      </div>

      <script>
        (() => {
          document.addEventListener("DOMContentLoaded", () => {
            const openButton = document.getElementById("account-delete-open");
            const modal = document.getElementById("account-delete-modal");
            if (!openButton || !modal) return;

            const closeElements = modal.querySelectorAll("[data-account-delete-close]");
            const closeModal = () => {
              modal.hidden = true;
              document.body.classList.remove("modal-open");
            };
            const openModal = () => {
              modal.hidden = false;
              document.body.classList.add("modal-open");
            };

            openButton.addEventListener("click", openModal);
            closeElements.forEach((element) => {
              element.addEventListener("click", closeModal);
            });
            document.addEventListener("keydown", (event) => {
              if (event.key === "Escape" && !modal.hidden) {
                closeModal();
              }
            });
          });
        })();
      </script>
    <% } %>

    <% const mainContainerClass = typeof containerClass !== "undefined" && containerClass ? `container ${containerClass}` : "container"; %>
    <% const mainContainerStyle = typeof containerStyle !== "undefined" ? containerStyle : ""; %>
    <main class="<%= mainContainerClass %>"<% if (mainContainerStyle) { %> style="<%= mainContainerStyle %>"<% } %>>
      <% if (flash) { %>
        <div class="flash <%= flash.type === "error" ? "flash-error" : "flash-success" %>">
          <%= flash.text %>
        </div>
      <% } %>
      <% if (adminImpersonation?.active) { %>
        <div class="flash flash-error">
          Testmodus aktiv: Du bist gerade als <strong><%= currentUserAccountName %></strong> unterwegs.
          Admin im Hintergrund: <strong><%= adminImpersonation.adminUsername %></strong>.
          <div class="dashboard-server-actions" style="margin-top: 0.65rem;">
            <form method="POST" action="/admin/impersonation/stop" class="inline-form">
              <button class="btn btn-secondary" type="submit">Zur&uuml;ck zum Admin</button>
            </form>
          </div>
        </div>
      <% } %>
