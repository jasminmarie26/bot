<!doctype html>
<html lang="de">
  <head>
    <% const pageTitle = String(typeof title !== "undefined" && title ? title : "Heldenhafte Reisen"); %>
    <% const resolvedSiteName = String(typeof siteName !== "undefined" && siteName ? siteName : "Heldenhafte Reisen"); %>
    <% const fullPageTitle = pageTitle.toLowerCase().includes(resolvedSiteName.toLowerCase())
      ? pageTitle
      : `${pageTitle} | ${resolvedSiteName}`; %>
    <% const resolvedMetaDescription = String(
      typeof metaDescription !== "undefined" && metaDescription
        ? metaDescription
        : "Heldenhafte Reisen ist eine kostenlose deutschsprachige Rollenspiel-Community mit getrennten Bereichen für Free RP, ERP und LARP, Charakterprofilen, Gästebüchern und Community-Austausch."
    ); %>
    <% const resolvedCanonicalUrl = String(typeof canonicalUrl !== "undefined" ? canonicalUrl || "" : "").trim(); %>
    <% const resolvedMetaImageUrl = String(typeof metaImageUrl !== "undefined" ? metaImageUrl || "" : "").trim(); %>
    <% const resolvedRobotsMeta = String(
      typeof robotsMeta !== "undefined" && robotsMeta
        ? robotsMeta
        : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    ); %>
    <% const websiteJsonLd = JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: resolvedSiteName,
      description: resolvedMetaDescription,
      url: resolvedCanonicalUrl || undefined
    }); %>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= fullPageTitle %></title>
    <meta name="description" content="<%= resolvedMetaDescription %>" />
    <meta name="robots" content="<%= resolvedRobotsMeta %>" />
    <meta property="og:site_name" content="<%= resolvedSiteName %>" />
    <meta property="og:title" content="<%= fullPageTitle %>" />
    <meta property="og:description" content="<%= resolvedMetaDescription %>" />
    <meta property="og:type" content="website" />
    <% if (resolvedCanonicalUrl) { %>
      <meta property="og:url" content="<%= resolvedCanonicalUrl %>" />
      <link rel="canonical" href="<%= resolvedCanonicalUrl %>" />
    <% } %>
    <% if (resolvedMetaImageUrl) { %>
      <meta property="og:image" content="<%= resolvedMetaImageUrl %>" />
      <meta name="twitter:image" content="<%= resolvedMetaImageUrl %>" />
    <% } %>
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="<%= fullPageTitle %>" />
    <meta name="twitter:description" content="<%= resolvedMetaDescription %>" />
    <meta name="application-name" content="<%= resolvedSiteName %>" />
    <script type="application/ld+json"><%- websiteJsonLd %></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&family=Manrope:wght@400;600;700&family=Audiowide&family=Berkshire+Swash&family=Cardo:wght@400;700&family=Della+Respira&family=Flamenco:wght@300;400&family=Indie+Flower&family=Josefin+Slab:wght@400;600;700&family=Kelly+Slab&family=MedievalSharp&family=Old+Standard+TT:wght@400;700&family=Russo+One&family=Sunshiney&family=UnifrakturCook:wght@700&family=Pirata+One&family=Poller+One&family=Orbitron:wght@400;600;700&family=Cinzel+Decorative:wght@400;700&family=Metamorphous&family=Great+Vibes&family=IM+Fell+English+SC&display=swap"
    />
    <script>
      (() => {
        const userAgent = String(window.navigator.userAgent || "");
        const isChromiumBrowser =
          /\b(?:Chrome|Chromium|CriOS)\//.test(userAgent) &&
          !/\b(?:Edg|OPR)\//.test(userAgent);

        if (!isChromiumBrowser) {
          return;
        }

        const root = document.documentElement;
        const enableSoftwareRendererFallback = () => {
          root.classList.add("software-renderer");
        };

        try {
          const canvas = document.createElement("canvas");
          const contextOptions = {
            alpha: false,
            antialias: false,
            depth: false,
            failIfMajorPerformanceCaveat: false,
            powerPreference: "low-power",
            preserveDrawingBuffer: false,
            stencil: false
          };
          const gl =
            canvas.getContext("webgl2", contextOptions) ||
            canvas.getContext("webgl", contextOptions) ||
            canvas.getContext("experimental-webgl", contextOptions);

          if (!gl) {
            enableSoftwareRendererFallback();
            return;
          }

          let renderer = "";
          let vendor = "";

          try {
            const debugInfo = gl.getExtension("WEBGL_debug_renderer_info");
            if (debugInfo) {
              renderer = String(gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL) || "");
              vendor = String(gl.getParameter(debugInfo.UNMASKED_VENDOR_WEBGL) || "");
            }
          } catch (_error) {
            // Renderer detection is best-effort only.
          }

          if (!renderer) {
            try {
              renderer = String(gl.getParameter(gl.RENDERER) || "");
              vendor = vendor || String(gl.getParameter(gl.VENDOR) || "");
            } catch (_error) {
              // Ignore renderer fallback errors.
            }
          }

          const rendererFingerprint = `${vendor} ${renderer}`.trim().toLowerCase();
          if (
            /swiftshader|software|llvmpipe|softpipe|basic render|microsoft basic render|mesa offscreen/i.test(
              rendererFingerprint
            )
          ) {
            enableSoftwareRendererFallback();
          }

          try {
            gl.getExtension("WEBGL_lose_context")?.loseContext();
          } catch (_error) {
            // Ignore context cleanup errors.
          }
        } catch (_error) {
          enableSoftwareRendererFallback();
        }
      })();
    </script>
    <script>
      (() => {
        const isEdgeBrowser = /\bEdg\//.test(window.navigator.userAgent);
        if (!isEdgeBrowser) return;

        if ("scrollRestoration" in window.history) {
          window.history.scrollRestoration = "manual";
        }

        const navigationEntry = window.performance.getEntriesByType?.("navigation")?.[0];
        const navigationType =
          navigationEntry?.type ||
          (window.performance.navigation?.type === 1 ? "reload" : "");

        if (navigationType !== "reload") return;

        const scrollToTop = () => {
          window.scrollTo(0, 0);
          document.documentElement.scrollTop = 0;
          document.body.scrollTop = 0;
        };

        window.addEventListener(
          "load",
          () => {
            window.requestAnimationFrame(() => {
              window.requestAnimationFrame(scrollToTop);
            });
          },
          { once: true }
        );
      })();
    </script>
    <script>
      (() => {
        const isGuestbookPath = /^\/characters\/\d+\/guestbook\/?$/.test(window.location.pathname);
        if (!isGuestbookPath) return;

        const urlParams = new URLSearchParams(window.location.search);
        const pageId = urlParams.get("page_id") || "default";
        const storageKey = `guestbook-panel:${window.location.pathname}:${pageId}`;
        const hasGuestbookEntryHash = window.location.hash.startsWith("#guestbook-entry-");

        try {
          if (window.sessionStorage.getItem(storageKey) === "open" || hasGuestbookEntryHash) {
            document.documentElement.classList.add("guestbook-panel-open");
          }
        } catch (_error) {
          if (hasGuestbookEntryHash) {
            document.documentElement.classList.add("guestbook-panel-open");
          }
        }
      })();
    </script>
    <script>
      (() => {
        const NOCTRA_PATTERN = /^noctra(?:\b|\s|\[|\()/i;
        const CRESCENTIA_PATTERN = /^(?:crescentia|cresentia)(?:\b|\s|\[|\()/i;
        const CERBERUS_PATTERN = /^cerberus(?:\b|\s|\[|\()/i;
        const TARGET_SELECTOR = [
          ".role-name-admin",
          ".role-name-moderator",
          ".staff-name-admin",
          ".staff-name-moderator",
          ".rp-header-identity",
          ".rp-user-menu-meta > strong",
          ".topbar-user-menu-meta > strong",
          ".guestbook-author-link strong",
          ".guestbook-item-authorline > strong",
          ".rp-room-occupant"
        ].join(", ");

        const syncSpecialNameDecor = (root = document) => {
          const targets = [];
          if (root instanceof Element && root.matches(TARGET_SELECTOR)) {
            targets.push(root);
          }
          if (root?.querySelectorAll) {
            targets.push(...root.querySelectorAll(TARGET_SELECTOR));
          }

          targets.forEach((node) => {
            if (node.classList?.contains("rp-room-occupant")) {
              node.classList.remove("has-noctra-wings", "has-crescentia-moons", "has-cerberus-flame");
              return;
            }
            const label = String(node.textContent || "").trim();
            node.classList.toggle("has-noctra-wings", NOCTRA_PATTERN.test(label));
            node.classList.toggle("has-crescentia-moons", CRESCENTIA_PATTERN.test(label));
            node.classList.toggle("has-cerberus-flame", CERBERUS_PATTERN.test(label));
          });
        };

        const boot = () => {
          syncSpecialNameDecor(document);

          if (!document.body || typeof MutationObserver !== "function") {
            return;
          }

          const observer = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
              if (mutation.type === "characterData") {
                syncSpecialNameDecor(mutation.target?.parentElement || document);
                return;
              }

              mutation.addedNodes.forEach((node) => {
                if (node instanceof Element) {
                  syncSpecialNameDecor(node);
                }
              });

              if (mutation.target instanceof Element) {
                syncSpecialNameDecor(mutation.target);
              }
            });
          });

          observer.observe(document.body, {
            subtree: true,
            childList: true,
            characterData: true
          });
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", boot, { once: true });
        } else {
          boot();
        }
      })();
    </script>
    <% const includeRealtimeAssets =
      (typeof currentUser !== "undefined" && Boolean(currentUser)) ||
      (typeof enableRealtime !== "undefined" ? Boolean(enableRealtime) : true); %>
    <% if (includeRealtimeAssets) { %>
      <script src="/socket.io/socket.io.js?v=<%= staticAssetVersion %>"></script>
    <% } %>
    <link rel="icon" type="image/x-icon" href="/favicon-hr.ico?v=<%= staticAssetVersion %>" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-hr-32.png?v=<%= staticAssetVersion %>" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-hr-16.png?v=<%= staticAssetVersion %>" />
    <link rel="apple-touch-icon" href="/apple-touch-icon-hr.png?v=<%= staticAssetVersion %>" />
    <link rel="shortcut icon" href="/favicon-hr.ico?v=<%= staticAssetVersion %>" />
    <link rel="stylesheet" href="/styles.css?v=<%= staticAssetVersion %>" />
    <% if (Array.isArray(pageStyles)) { %>
      <% pageStyles.forEach((href) => { %>
        <% const resolvedHref = String(href || "").trim(); %>
        <% if (resolvedHref) { %>
          <link rel="stylesheet" href="<%= resolvedHref %>" />
        <% } %>
      <% }) %>
    <% } %>
  </head>
    <% const menuCharacter =
      typeof topbarCharacter !== "undefined"
        ? topbarCharacter
        : typeof activeCharacter !== "undefined" && activeCharacter
          ? activeCharacter
          : typeof character !== "undefined" && character
            ? character
            : null; %>
    <% const themeCharacter =
      menuCharacter ||
      (typeof activeThemeCharacter !== "undefined" && activeThemeCharacter
        ? activeThemeCharacter
        : null); %>
    <% const viewCharacterTheme =
      themeCharacter && themeCharacter.theme
        ? String(themeCharacter.theme || "").trim().toLowerCase()
        : ""; %>
    <% const viewActiveTheme =
      viewCharacterTheme && availableThemes.some((theme) => theme.id === viewCharacterTheme)
        ? viewCharacterTheme
        : activeTheme; %>
    <% const bodyClassNames = [`theme-${viewActiveTheme}`]; %>
    <% if (typeof pageClass !== "undefined" && pageClass) { bodyClassNames.push(pageClass); } %>
  <body
    class="<%= bodyClassNames.join(' ') %>"
    data-current-user-is-admin="<%= currentUser && currentUser.is_admin ? 'true' : 'false' %>"
    data-theme-character-id="<%= themeCharacter ? Number(themeCharacter.id) : '' %>"
  >
    <% const topbarHidden = typeof hideTopbar !== "undefined" ? hideTopbar : false; %>
    <% const showAccountDeleteControl = Boolean(
      currentUser &&
      currentPath &&
      currentPath.startsWith("/account")
    ); %>
    <% const canEditMenuCharacter = Boolean(
      menuCharacter &&
      (
        (typeof isOwner !== "undefined" && isOwner) ||
        menuCharacter.is_owner ||
        (
          currentUser &&
          Number(menuCharacter.user_id) === Number(currentUser.id)
        )
      )
    ); %>
    <% const displayIdentityName =
      currentUserDisplayName || (currentUser ? currentUser.display_name || currentUser.username : ""); %>
    <% const accountDisplayName =
      currentUserAccountName || (currentUser ? currentUser.username : ""); %>
    <% const showServerlistAccountIconEditor = Boolean(
      currentUser &&
      menuCharacter &&
      canEditMenuCharacter
    ); %>
    <% const serverlistAccountIconUrl = menuCharacter
      ? String(menuCharacter.serverlist_icon_url || "").trim()
      : ""; %>
    <% const serverlistAccountIconFocusX = menuCharacter
      ? Number(menuCharacter.serverlist_icon_focus_x ?? 50)
      : 50; %>
    <% const serverlistAccountIconFocusY = menuCharacter
      ? Number(menuCharacter.serverlist_icon_focus_y ?? 50)
      : 50; %>
    <% const isLarpMenuContext = Boolean(menuCharacter && menuCharacter.server_id === "larp"); %>
    <% const menuCharacterEditHref = menuCharacter
      ? (isLarpMenuContext
        ? `/characters/${menuCharacter.id}?edit=about#larp-profile-about`
        : `/characters/${menuCharacter.id}/edit`)
      : ""; %>
    <% const menuCharacterEditHrefTemplate = isLarpMenuContext
      ? "/characters/__CHARACTER_ID__?edit=about#larp-profile-about"
      : "/characters/__CHARACTER_ID__/edit"; %>
    <% const accountMenuHref = isLarpMenuContext ? "/account/larp" : "/account"; %>
    <% const menuCharacterIsAdmin = Boolean(
      menuCharacter &&
      currentUser &&
      currentUser.is_admin &&
      Number(currentUser.admin_character_id) === Number(menuCharacter.id)
    ); %>
    <% const menuCharacterIsModerator = Boolean(
      menuCharacter &&
      currentUser &&
      currentUser.is_moderator &&
      Number(currentUser.moderator_character_id) === Number(menuCharacter.id)
    ); %>
    <% const activeMenuIdentityName = menuCharacter
      ? menuCharacter.name
      : displayIdentityName; %>
    <% const activeMenuIdentityRoleStyle = menuCharacter
      ? (menuCharacterIsAdmin ? "admin" : (menuCharacterIsModerator ? "moderator" : ""))
      : (currentUserDisplayRoleStyle || ""); %>
    <% const topbarBrandText =
      typeof topbarBrandLabel !== "undefined" && topbarBrandLabel
        ? topbarBrandLabel
        : "Heldenhafte Reisen"; %>
    <% const topbarBrandTarget =
      typeof topbarBrandHref !== "undefined" && topbarBrandHref
        ? topbarBrandHref
        : "/"; %>
    <% const topbarBrandPrefixText =
      typeof topbarBrandPrefix !== "undefined" ? String(topbarBrandPrefix || "").trim() : ""; %>
    <% const topbarBrandClass =
      typeof topbarBrandModifier !== "undefined" && topbarBrandModifier
        ? `brand ${topbarBrandModifier}`
        : "brand"; %>
    <% const normalizedTopbarBrandText = String(topbarBrandText || "").trim().toLowerCase(); %>
    <% const normalizedActiveMenuIdentityName = String(activeMenuIdentityName || "").trim().toLowerCase(); %>
    <% const normalizedAccountDisplayName = String(accountDisplayName || "").trim().toLowerCase(); %>
    <% const isTopbarBrandCrescentia = /^(crescentia|cresentia)$/.test(normalizedTopbarBrandText); %>
    <% const isTopbarBrandCerberus = normalizedTopbarBrandText === "cerberus"; %>
    <% const topbarBrandSpecialClass = normalizedTopbarBrandText === "noctra"
      ? "has-noctra-wings"
      : (isTopbarBrandCerberus ? "has-cerberus-flame" : (isTopbarBrandCrescentia ? "has-crescentia-moons" : "")); %>
    <% const topbarBrandWrapperClass = normalizedTopbarBrandText === "noctra"
      ? "noctra-nameplate"
      : (isTopbarBrandCerberus ? "cerberus-nameplate" : (isTopbarBrandCrescentia ? "crescentia-nameplate" : "")); %>
    <% const topbarBrandClassName = topbarBrandClass; %>
    <% const topbarRoleplayAreaHref =
      menuCharacter && menuCharacter.server_id === "larp"
        ? "/dashboard/larp"
        : menuCharacter && (menuCharacter.server_id === "free-rp" || menuCharacter.server_id === "erp")
          ? `/dashboard/areas/${menuCharacter.server_id}`
        : "/dashboard"; %>
    <% const topbarAreaLabel = "Serverliste"; %>
    <% const isDashboardPath = Boolean(currentPath && currentPath.startsWith("/dashboard")); %>
    <% const topbarGuestbookModeActive = Boolean(
      typeof topbarGuestbookMode !== "undefined" && topbarGuestbookMode
    ); %>
    <% const hideTopbarAreaLinkOnLoggedInHome = Boolean(
      currentUser &&
      !topbarGuestbookModeActive &&
      currentPath === "/"
    ); %>
    <% const topbarCharacterCreatedAtLabel =
      typeof characterCreatedAtLabel !== "undefined" ? String(characterCreatedAtLabel || "").trim() : ""; %>
    <% const topbarBirthdayRows = Array.isArray(
      typeof publicBirthdayRows !== "undefined" ? publicBirthdayRows : []
    )
      ? (typeof publicBirthdayRows !== "undefined" ? publicBirthdayRows : []).filter(
        (entry) => entry && entry.label && entry.value
      )
      : []; %>
    <% const topbarGuestbookSearchCharactersList = Array.isArray(
      typeof topbarGuestbookSearchCharacters !== "undefined" ? topbarGuestbookSearchCharacters : []
    )
      ? (typeof topbarGuestbookSearchCharacters !== "undefined" ? topbarGuestbookSearchCharacters : []).filter(
        (entry) => entry && entry.id && entry.name && entry.url
      )
      : []; %>
    <% const topbarGuestbookPageLinksList = Array.isArray(
      typeof topbarGuestbookPageLinks !== "undefined" ? topbarGuestbookPageLinks : []
    )
      ? (typeof topbarGuestbookPageLinks !== "undefined" ? topbarGuestbookPageLinks : []).filter(
        (entry) => entry && entry.label && entry.url
      )
      : []; %>
    <% const topbarGuestbookMusicVideoIdValue =
      typeof topbarGuestbookMusicVideoId !== "undefined" ? String(topbarGuestbookMusicVideoId || "").trim() : ""; %>
    <% const showTopbarGuestbookCreatedAt = Boolean(
      topbarGuestbookModeActive && (topbarCharacterCreatedAtLabel || topbarBirthdayRows.length)
    ); %>
    <% const showTopbarGuestbookTools = Boolean(
      topbarGuestbookModeActive &&
      (
        topbarGuestbookPageLinksList.length ||
        topbarGuestbookSearchCharactersList.length ||
        topbarGuestbookMusicVideoIdValue
      )
    ); %>
    <% const showTopbarGuestbookInfoBlock = Boolean(
      topbarGuestbookModeActive && (showTopbarGuestbookCreatedAt || showTopbarGuestbookTools)
    ); %>
    <% const hideTopbarGuestbookControl = Boolean(
      topbarGuestbookModeActive &&
      typeof topbarGuestbookControlHidden !== "undefined" &&
      topbarGuestbookControlHidden
    ); %>
    <% const showTopbarLiveUpdatesLink = Boolean(!topbarGuestbookModeActive); %>
    <% const topbarUseSameTabNavigation = Boolean(isDashboardPath); %>
    <% const showTopbarBackupLink = Boolean(
      currentUser &&
      !topbarGuestbookModeActive &&
      isDashboardPath
    ); %>
    <% const topbarBackupHref = (
      (typeof isLarpBackupView !== "undefined" && isLarpBackupView) ||
      (currentPath && currentPath.startsWith("/dashboard/larp")) ||
      (menuCharacter && menuCharacter.server_id === "larp")
    )
      ? "/character-backups?server=larp"
      : "/character-backups"; %>
    <% const showTopbarStaffAreaLink = Boolean(
      currentUser &&
      (currentUser.is_admin || currentUser.is_moderator)
    ); %>
    <% const topbarStaffAreaHref = currentUser
      ? (currentUser.is_admin ? "/admin" : "/staff")
      : ""; %>
    <% const topbarStaffAreaLabel = currentUser
      ? (currentUser.is_admin ? "Admin" : "Moderator")
      : ""; %>
    <% const showTopbarStaffUserBackupLink = Boolean(
      showTopbarStaffAreaLink &&
      isDashboardPath
    ); %>
    <% const topbarStaffUserBackupHref = currentUser
      ? (currentUser.is_admin ? "/admin/user-backups" : "/staff/user-backups")
      : ""; %>
    <% const showTopbarRpBoardLink = Boolean(
      !topbarGuestbookModeActive &&
      menuCharacter &&
      (menuCharacter.server_id === "free-rp" || menuCharacter.server_id === "erp")
    ); %>
    <% const topbarRpBoardHref = showTopbarRpBoardLink
      ? `/rp-board?server_id=${menuCharacter.server_id}&character_id=${Number(menuCharacter.id)}`
      : ""; %>
    <% const topbarLiveUpdatesInitialRevision = String(
      typeof latestSiteUpdateRevisionToken !== "undefined" ? latestSiteUpdateRevisionToken || "" : ""
    ).trim(); %>
    <% const topbarLiveUpdatesInitialRevisions = Array.isArray(recentSiteUpdateRevisions)
      ? recentSiteUpdateRevisions
      : []; %>
    <% const resolvedServerWorkNoticeConfig =
      typeof serverWorkNoticeConfig !== "undefined" && serverWorkNoticeConfig
        ? serverWorkNoticeConfig
        : null; %>
    <% const showServerWorkNotice = Boolean(serverWorkNotice && serverWorkNotice.visible); %>
    <% const serverWorkNoticeTimeZone = resolvedServerWorkNoticeConfig && resolvedServerWorkNoticeConfig.timeZone
      ? String(resolvedServerWorkNoticeConfig.timeZone).trim() || "Europe/Berlin"
      : "Europe/Berlin"; %>
    <% const serverWorkNoticeWeekdays = Array.isArray(
      resolvedServerWorkNoticeConfig && resolvedServerWorkNoticeConfig.weekdays
    ) && resolvedServerWorkNoticeConfig.weekdays.length
      ? resolvedServerWorkNoticeConfig.weekdays
          .map((value) => String(value || "").trim())
          .filter(Boolean)
      : ["Mon", "Wed", "Fri"]; %>
    <% const serverWorkNoticeStartMinutes = Number.isFinite(Number(
      resolvedServerWorkNoticeConfig && resolvedServerWorkNoticeConfig.startMinutes
    ))
      ? Number(resolvedServerWorkNoticeConfig.startMinutes)
      : 16 * 60 + 45; %>
    <% const serverWorkNoticeEndMinutes = Number.isFinite(Number(
      resolvedServerWorkNoticeConfig && resolvedServerWorkNoticeConfig.endMinutes
    ))
      ? Number(resolvedServerWorkNoticeConfig.endMinutes)
      : 20 * 60 + 30; %>
    <% const serverWorkNoticeTitle = showServerWorkNotice
      ? String(serverWorkNotice.title || "Heute Serverarbeit").trim() || "Heute Serverarbeit"
      : (resolvedServerWorkNoticeConfig && resolvedServerWorkNoticeConfig.title
          ? String(resolvedServerWorkNoticeConfig.title).trim() || "Heute Serverarbeit"
          : "Heute Serverarbeit"); %>
    <% const serverWorkNoticeMessage = showServerWorkNotice
      ? String(serverWorkNotice.message || "").trim()
      : (resolvedServerWorkNoticeConfig && resolvedServerWorkNoticeConfig.message
          ? String(resolvedServerWorkNoticeConfig.message || "").trim()
          : "17:00 bis 20:30 Uhr."); %>
    <section
      class="server-work-notice"
      data-server-work-notice
      data-server-work-time-zone="<%= serverWorkNoticeTimeZone %>"
      data-server-work-weekdays="<%= serverWorkNoticeWeekdays.join(',') %>"
      data-server-work-start-minutes="<%= serverWorkNoticeStartMinutes %>"
      data-server-work-end-minutes="<%= serverWorkNoticeEndMinutes %>"
      role="status"
      aria-live="polite"
      <%= showServerWorkNotice ? "" : "hidden" %>
    >
      <div class="server-work-notice-inner">
        <strong data-server-work-title><%= serverWorkNoticeTitle %></strong>
        <span data-server-work-message <%= serverWorkNoticeMessage ? "" : "hidden" %>><%= serverWorkNoticeMessage %></span>
      </div>
    </section>
    <% if (!topbarHidden) { %>
      <header class="topbar">
        <div class="topbar-inner<%= showTopbarGuestbookInfoBlock ? " has-guestbook-created-at" : "" %>">
          <% if (!topbarGuestbookModeActive) { %>
            <a class="<%= topbarBrandClass %>" href="<%= topbarBrandTarget %>">
              <% if (topbarBrandPrefixText) { %>
                <span class="brand-prefix" aria-hidden="true"><%= topbarBrandPrefixText %></span>
              <% } %>
              <%= topbarBrandText %>
            </a>
          <% } else { %>
            <% if (!hideTopbarGuestbookControl) { %>
              <div class="topbar-guestbook-control">
                <button
                  type="button"
                  class="guestbook-entry-toggle"
                  data-guestbook-panel-toggle
                  aria-controls="guestbook-entry-panel"
                  aria-expanded="false"
                  aria-label="Gästebuch-Einträge öffnen"
                  title="Gästebuch-Einträge öffnen"
                >
                  <span class="guestbook-entry-toggle-icon" aria-hidden="true"></span>
                </button>
                <span class="guestbook-entry-heading">G&auml;stebuch-Eintr&auml;ge</span>
              </div>
            <% } %>
            <% if (showTopbarGuestbookInfoBlock) { %>
              <div class="topbar-guestbook-created-wrap">
                <% if (topbarCharacterCreatedAtLabel) { %>
                  <span class="topbar-guestbook-created-at">
                    <span>Charakter erstellt am</span>
                    <strong><%= topbarCharacterCreatedAtLabel %></strong>
                  </span>
                <% } %>
                <% topbarBirthdayRows.forEach((entry) => { %>
                  <span class="topbar-guestbook-created-at is-birthday">
                    <span><%= entry.label %></span>
                    <strong><%= entry.value %></strong>
                  </span>
                <% }) %>

              </div>
            <% } %>
