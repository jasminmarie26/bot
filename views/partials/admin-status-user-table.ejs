<%
  const statusUsers = Array.isArray(users) ? users : [];
  const statusSectionKey = String(sectionKey || "default").trim() || "default";
  const statusPageSize = 10;
  const statusTotalPages = Math.max(1, Math.ceil(statusUsers.length / statusPageSize));
%>

<div class="help-table-wrap" data-admin-status-pagination-root="<%= statusSectionKey %>">
  <table class="help-table admin-user-table admin-user-table-compact">
    <thead>
      <tr>
        <th>Account</th>
        <th>E-Mail</th>
        <th>Geburtsdatum</th>
        <th>Rollen</th>
        <th>Status / Notiz</th>
        <th>Aktion</th>
      </tr>
    </thead>
    <tbody>
      <% statusUsers.forEach((user, index) => { %>
        <tr
          class="admin-user-row"
          data-admin-status-row
          data-admin-status-page="<%= Math.floor(index / statusPageSize) + 1 %>"
          <%= index >= statusPageSize ? "hidden" : "" %>
        >
          <td>
            <div class="admin-account-name">
              <% if (user.is_online) { %>
                <span class="admin-online-dot" aria-label="Online" title="Online"></span>
              <% } %>
              <strong><%= user.username %></strong>
            </div>
            <div class="admin-table-subline">
              <span>#<%= user.account_number %></span>
              <span>Erstellt: <%= user.created_at_date_label || "-" %> | <%= user.created_at_time_label || "--:--" %></span>
              <span>Letzter Login: <%= user.last_login_at_date_label || "-" %> | <%= user.last_login_at_time_label || "--:--" %></span>
              <% if (user.is_online && user.online_location_label) { %>
                <span>Ort: <%= user.online_location_label %></span>
              <% } %>
            </div>
          </td>
          <td><%= user.email || "-" %></td>
          <td><%= user.birth_date_label || "-" %></td>
          <td>
            <div class="admin-table-badges">
              <% if (user.is_admin) { %>
                <span class="admin-role-badge is-admin">Admin</span>
              <% } %>
              <% if (user.is_moderator) { %>
                <span class="admin-role-badge is-moderator">Moderator</span>
              <% } %>
              <% if (!user.is_admin && !user.is_moderator) { %>
                <span class="admin-role-badge">User</span>
              <% } %>
            </div>
          </td>
          <td>
            <div class="admin-table-subline">
              <% const statusNoteText = user.moderation_status_note_preview || "Keine Notiz."; %>
              <% const statusNoteIsEmpty = !user.moderation_status_note_preview; %>
              <span class="admin-status-badge is-<%= user.moderation_status.slug %>">
                <%= user.moderation_status.label %>
              </span>
              <span class="admin-status-note<%= statusNoteIsEmpty ? ' is-empty' : '' %>"><%= statusNoteText %></span>
            </div>
          </td>
          <td>
            <div class="admin-table-actions">
              <a
                class="btn btn-secondary"
                href="<%= `${detailBasePath}/${user.id}` %>"
              >
                Details
              </a>
              <% if (allowUserDeletion && user.id !== currentUser.id) { %>
                <form method="POST" action="/admin/users/<%= user.id %>/delete" class="inline-form">
                  <button class="btn btn-danger" type="submit">L&ouml;schen</button>
                </form>
              <% } %>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <% if (statusTotalPages > 1) { %>
    <nav class="admin-status-pagination" aria-label="Seitennavigation">
      <button
        class="admin-status-page-link"
        type="button"
        data-admin-status-page-prev
        aria-label="Vorherige Seite"
      >&lsaquo;</button>

      <% for (let pageNumber = 1; pageNumber <= statusTotalPages; pageNumber += 1) { %>
        <button
          class="admin-status-page-link <%= pageNumber === 1 ? "is-active" : "" %>"
          type="button"
          data-admin-status-page-button="<%= pageNumber %>"
          aria-label="Seite <%= pageNumber %>"
          aria-current="<%= pageNumber === 1 ? "page" : "false" %>"
        ><%= pageNumber %></button>
      <% } %>

      <button
        class="admin-status-page-link"
        type="button"
        data-admin-status-page-next
        aria-label="Nächste Seite"
      >&rsaquo;</button>
    </nav>
  <% } %>
</div>
