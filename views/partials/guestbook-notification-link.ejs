<% if (currentUser) { %>
  <% const noteCharacters = Array.isArray(topbarOwnedCharacters) ? topbarOwnedCharacters : []; %>
  <% const selectedNoteCharacterCandidateIds = [
    typeof selectedCharacterNotesCharacterId !== "undefined" ? Number(selectedCharacterNotesCharacterId) : null,
    typeof activeCharacter !== "undefined" ? Number(activeCharacter?.id) : null,
    typeof menuCharacter !== "undefined" ? Number(menuCharacter?.id) : null,
    typeof topbarCharacter !== "undefined" ? Number(topbarCharacter?.id) : null,
    typeof character !== "undefined" ? Number(character?.id) : null
  ].filter((value) => Number.isInteger(value) && value > 0); %>
  <% const selectedNoteCharacterId = selectedNoteCharacterCandidateIds.find((candidateId) =>
    noteCharacters.some((entry) => Number(entry.id) === candidateId)
  ) || Number(noteCharacters[0]?.id || 0); %>
  <% const guestbookNotificationBadgeText = guestbookNotificationCount > 99 ? "99+" : String(guestbookNotificationCount || 0); %>
  <% const canComposePersonalStaffPm = Boolean(currentUser); %>
  <% const canComposeGuestbookMail = Boolean(currentUser?.is_admin || currentUser?.is_moderator); %>
  <% const canComposeGuestbookSystemMessage = Boolean(currentUser?.is_admin); %>
  <% const guestbookComposeTitle = canComposeGuestbookSystemMessage
    ? "Brief oder Systemnachricht schreiben"
    : canComposeGuestbookMail
      ? "Brief schreiben"
      : "Persönliche PM schreiben"; %>
  <% const latestNotificationType = latestGuestbookNotification?.type || latestGuestbookNotification?.notification_type || "guestbook_entry"; %>
  <% const systemNotificationTypes = [
    "festplay_approval",
    "birthday_greeting",
    "holiday_easter",
    "holiday_christmas",
    "holiday_nikolaus",
    "staff_pm",
    "staff_mail",
    "admin_system_message"
  ]; %>
  <% const isSystemNotification = systemNotificationTypes.includes(latestNotificationType); %>
  <% const guestbookNotificationTitle = !latestGuestbookNotification
    ? "Briefe"
    : latestNotificationType === "festplay_application"
    ? latestGuestbookNotification?.festplay_name
      ? latestGuestbookNotification?.applicant_character_name
        ? `Neue Bewerbung von ${latestGuestbookNotification.applicant_character_name} fuer ${latestGuestbookNotification.festplay_name}`
        : `Neue Bewerbung fuer ${latestGuestbookNotification.festplay_name}`
      : "Neue Festspiel-Bewerbung"
    : latestNotificationType === "festplay_approval"
      ? latestGuestbookNotification?.festplay_name
        ? latestGuestbookNotification?.actor_name
          ? `${latestGuestbookNotification.actor_name} hat dich fuer ${latestGuestbookNotification.festplay_name} freigeschaltet`
          : `Du wurdest fuer ${latestGuestbookNotification.festplay_name} freigeschaltet`
        : "Neue Festspiel-Freischaltung"
    : isSystemNotification
      ? latestGuestbookNotification?.title || "Geburtstagsgrüße vom Heldenhafte Reisen Team"
    : latestGuestbookNotification?.character_name
      ? `Neuer Gaestebucheintrag fuer ${latestGuestbookNotification.character_name}`
      : "Neuer Gaestebucheintrag"; %>
  <% if (noteCharacters.length > 0) { %>
    <button
      type="button"
      class="character-notes-link"
      aria-label="Charakternotizen öffnen"
      title="Charakternotizen"
      aria-haspopup="dialog"
      aria-controls="character-notes-panel"
      aria-expanded="false"
      data-character-notes-toggle
      data-character-notes-selected-character-id="<%= selectedNoteCharacterId || '' %>"
    >
      <span class="character-notes-link-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path class="character-notes-paper-fill" d="M7 3.35h8.85l3.15 3.2v12.1A2.35 2.35 0 0 1 16.65 21H7.35A2.35 2.35 0 0 1 5 18.65V5.7A2.35 2.35 0 0 1 7 3.35Z" />
          <path d="M15.85 3.35v3.2h3.15" />
          <path d="M8.2 9.15h7.6" />
          <path d="M8.2 12.15h7.6" />
          <path d="M8.2 15.15h5.1" />
          <path d="M7 3.35h8.85l3.15 3.2v12.1A2.35 2.35 0 0 1 16.65 21H7.35A2.35 2.35 0 0 1 5 18.65V5.7A2.35 2.35 0 0 1 7 3.35Z" />
        </svg>
      </span>
    </button>

    <div
      id="character-notes-panel"
      class="chat-whisper-panel character-notes-panel"
      data-character-notes-panel
      hidden
    >
      <div class="chat-whisper-panel-card character-notes-panel-card">
        <header class="chat-whisper-panel-head">
          <div class="chat-whisper-panel-copy">
            <h3>Notizblatt</h3>
            <p>Private Charakternotizen, nur f&uuml;r dich sichtbar.</p>
          </div>
          <button
            type="button"
            class="chat-whisper-close-btn"
            aria-label="Schließen"
            data-character-notes-close
          >
            &times;
          </button>
        </header>

        <form class="character-notes-form" data-character-notes-form>
          <label class="character-notes-field">
            <span>Charakter</span>
            <select data-character-notes-select>
              <% noteCharacters.forEach((entry) => { %>
                <% const noteServerLabel = entry.server_id === "larp" ? "LARP" : (entry.server_id === "erp" ? "ERP" : "FREE-RP"); %>
                <option
                  value="<%= entry.id %>"
                  <%= Number(entry.id) === Number(selectedNoteCharacterId) ? "selected" : "" %>
                >
                  <%= entry.name %> (<%= noteServerLabel %>)
                </option>
              <% }) %>
            </select>
          </label>

          <label class="character-notes-field">
            <span>Notizen</span>
            <textarea
              rows="9"
              maxlength="4000"
              placeholder="Hier kannst du dir private Notizen zu deinem Charakter aufschreiben."
              data-character-notes-input
            ></textarea>
          </label>

          <div class="character-notes-actions">
            <p class="muted character-notes-status" data-character-notes-status>W&auml;hle einen Charakter aus.</p>
            <button type="submit" class="btn" data-character-notes-save>Speichern</button>
          </div>
        </form>
      </div>
    </div>
  <% } %>
  <button
    type="button"
    class="social-panel-toggle"
    aria-label="Freunde und Ignorieren öffnen"
    title="Freunde und Ignorieren"
    aria-haspopup="dialog"
    aria-controls="social-panel"
    aria-expanded="false"
    data-social-panel-toggle
  >
    <span class="social-panel-toggle-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" focusable="false">
        <path class="social-panel-fill" d="M8.1 6.2a3 3 0 1 1 0 6 3 3 0 0 1 0-6Zm7.9 1a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM4.2 18.4c0-2 1.8-3.7 4.3-3.7s4.3 1.7 4.3 3.7v.6H4.2v-.6Zm10.2.6c.1-1.3.7-2.4 1.7-3.1.7-.5 1.5-.8 2.4-.8 1.8 0 3.3 1.2 3.3 2.9v1H14.4Z" />
        <path d="M8.1 6.2a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z" />
        <path d="M16 7.2a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5Z" />
        <path d="M4.2 18.4c0-2 1.8-3.7 4.3-3.7s4.3 1.7 4.3 3.7v.6H4.2v-.6Z" />
        <path d="M14.4 19c.1-1.3.7-2.4 1.7-3.1.7-.5 1.5-.8 2.4-.8 1.8 0 3.3 1.2 3.3 2.9v1H14.4Z" />
      </svg>
    </span>
    <span class="social-panel-badge" data-social-panel-badge hidden aria-hidden="true"></span>
  </button>

  <div
    id="social-panel"
    class="chat-whisper-panel social-panel"
    data-social-panel
    data-social-source-character-id="<%= selectedNoteCharacterId || '' %>"
    hidden
  >
    <div class="chat-whisper-panel-card social-panel-card">
      <header class="chat-whisper-panel-head">
        <div class="chat-whisper-panel-copy">
          <h3>Freunde &amp; Ignorieren</h3>
          <p>Freunde sehen, blockieren oder wieder freigeben.</p>
        </div>
        <button
          type="button"
          class="chat-whisper-close-btn"
          aria-label="Schließen"
          data-social-panel-close
        >
          &times;
        </button>
      </header>

      <div class="social-panel-body">
        <section class="social-panel-section">
          <h4>Freund hinzuf&uuml;gen</h4>
          <form class="social-panel-add-form" data-social-friend-form>
            <input
              type="text"
              maxlength="80"
              placeholder="Charaktername"
              autocomplete="off"
              data-social-friend-input
            />
            <button type="submit" class="btn">Hinzuf&uuml;gen</button>
          </form>
          <p class="muted social-panel-feedback" data-social-panel-feedback hidden></p>
        </section>

        <div class="social-panel-grid">
          <section class="social-panel-section">
            <h4>Freunde &amp; Ignorieren</h4>
            <div class="social-panel-tabs" role="tablist" aria-label="Freunde und ignorierte Eintr&auml;ge">
              <button
                type="button"
                class="social-panel-tab-btn is-active"
                data-social-tab-button="friends"
                role="tab"
                aria-selected="true"
                aria-controls="social-tab-friends"
              >
                Freunde
              </button>
              <button
                type="button"
                class="social-panel-tab-btn"
                data-social-tab-button="ignored-accounts"
                role="tab"
                aria-selected="false"
                aria-controls="social-tab-ignored-accounts"
              >
                Ignorierte Accounts
              </button>
              <button
                type="button"
                class="social-panel-tab-btn"
                data-social-tab-button="ignored-characters"
                role="tab"
                aria-selected="false"
                aria-controls="social-tab-ignored-characters"
              >
                Ignorierte Charaktere
              </button>
            </div>

            <div
              id="social-tab-friends"
              class="social-panel-tab-panel"
              data-social-tab-panel="friends"
              role="tabpanel"
            >
              <p class="muted social-panel-hint">Hier werden nur Freunde angezeigt, die gerade online sind.</p>
              <div class="social-panel-table">
                <div class="social-panel-list-head" aria-hidden="true">
                  <span>Name</span>
                  <span>Ort</span>
                  <span>Funktion</span>
                </div>
                <div class="social-panel-list" data-social-friends-list>
                  <p class="muted">Noch keine Freunde gespeichert.</p>
                </div>
                <div class="social-panel-pager" data-social-friends-pager hidden></div>
              </div>
            </div>

            <div
              id="social-tab-ignored-accounts"
              class="social-panel-tab-panel"
              data-social-tab-panel="ignored-accounts"
              role="tabpanel"
              hidden
            >
              <div class="social-panel-table">
                <div class="social-panel-list-head" aria-hidden="true">
                  <span>Name</span>
                  <span>Ort</span>
                  <span>Funktion</span>
                </div>
                <div class="social-panel-list" data-social-ignored-accounts-list>
                  <p class="muted">Keine ignorierten Accounts.</p>
                </div>
                <div class="social-panel-pager" data-social-ignored-accounts-pager hidden></div>
              </div>
            </div>

            <div
              id="social-tab-ignored-characters"
              class="social-panel-tab-panel"
              data-social-tab-panel="ignored-characters"
              role="tabpanel"
              hidden
            >
              <div class="social-panel-table">
                <div class="social-panel-list-head" aria-hidden="true">
                  <span>Name</span>
                  <span>Ort</span>
                  <span>Funktion</span>
                </div>
                <div class="social-panel-list" data-social-ignored-characters-list>
                  <p class="muted">Keine ignorierten Charaktere.</p>
                </div>
                <div class="social-panel-pager" data-social-ignored-characters-pager hidden></div>
              </div>
            </div>
          </section>
        </div>
      </div>
    </div>
  </div>
  <% if (canComposePersonalStaffPm) { %>
    <button
      type="button"
      class="guestbook-compose-link"
      aria-label="<%= guestbookComposeTitle %>"
      title="<%= guestbookComposeTitle %>"
      aria-haspopup="dialog"
      aria-controls="guestbook-notification-panel"
      aria-expanded="false"
      data-guestbook-compose-root
    >
      <span class="guestbook-compose-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path class="guestbook-compose-paper-fill" d="M6.1 4.1h8.9l3 3v11.15A1.65 1.65 0 0 1 16.35 20H6.75A1.65 1.65 0 0 1 5.1 18.35V5.75A1.65 1.65 0 0 1 6.75 4.1Z" />
          <path d="M15 4.1v3h3" />
          <path d="M8.05 9.25h6.8" />
          <path d="M8.05 12.1h4.35" />
          <path d="m11.7 16.95 4.65-4.65 1.85 1.85-4.65 4.65-2.65.8z" />
          <path d="m15.95 12.7 1.2-1.2a1.15 1.15 0 0 1 1.65 0l.35.35a1.17 1.17 0 0 1 0 1.65l-1.2 1.2" />
        </svg>
      </span>
    </button>
  <% } %>
  <a
    class="guestbook-notification-link<%= isSystemNotification ? ' guestbook-notification-link-system' : '' %>"
    href="/guestbook/notifications/open"
    aria-label="<%= guestbookNotificationTitle %>"
    title="<%= guestbookNotificationTitle %>"
    <%= latestNotificationType === "guestbook_entry" ? 'target="_blank" rel="noopener noreferrer"' : "" %>
    aria-expanded="false"
    data-guestbook-notification-root
    data-can-compose-personal-staff-pm="<%= canComposePersonalStaffPm ? "true" : "false" %>"
    data-can-compose-staff-mail="<%= canComposeGuestbookMail ? "true" : "false" %>"
    data-can-compose-admin-system="<%= canComposeGuestbookSystemMessage ? "true" : "false" %>"
    data-notification-count="<%= guestbookNotificationCount || 0 %>"
    data-notification-id="<%= latestGuestbookNotification?.id || 0 %>"
    data-notification-type="<%= latestNotificationType %>"
    data-notification-character-name="<%= latestGuestbookNotification?.character_name || "" %>"
    data-notification-festplay-name="<%= latestGuestbookNotification?.festplay_name || "" %>"
    data-notification-applicant-character-name="<%= latestGuestbookNotification?.applicant_character_name || "" %>"
    data-notification-actor-name="<%= latestGuestbookNotification?.actor_name || "" %>"
    data-notification-title="<%= latestGuestbookNotification?.title || "" %>"
    data-notification-message="<%= latestGuestbookNotification?.message || "" %>"
    data-notification-intro="<%= latestGuestbookNotification?.intro || "" %>"
    data-notification-wish="<%= latestGuestbookNotification?.wish || "" %>"
    data-notification-signoff="<%= latestGuestbookNotification?.signoff || "" %>"
    data-notification-decoration="<%= latestGuestbookNotification?.decoration || "" %>"
    <%= guestbookNotificationCount > 0 || latestGuestbookNotification ? "" : "hidden" %>
  >
    <span class="guestbook-notification-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" focusable="false">
        <path class="guestbook-envelope-fill" d="M4.4 6.25h15.2c.8 0 1.45.65 1.45 1.45v8.6c0 .8-.65 1.45-1.45 1.45H4.4c-.8 0-1.45-.65-1.45-1.45V7.7c0-.8.65-1.45 1.45-1.45Z" />
        <path d="M3.15 7.25 12 13.7l8.85-6.45" />
        <path d="M4.1 17.1 9.2 12.55" />
        <path d="m19.9 17.1-5.1-4.55" />
        <rect x="3.15" y="6.25" width="17.7" height="11.5" rx="1.55" ry="1.55" />
      </svg>
    </span>
    <span class="guestbook-notification-badge" data-guestbook-notification-badge <%= guestbookNotificationCount > 0 ? "" : "hidden" %>><%= guestbookNotificationBadgeText %></span>
  </a>
<% } %>
