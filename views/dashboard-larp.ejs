<%- include("partials/start") %>

<section class="header-line dashboard-page-header">
  <div>
    <span class="dashboard-kicker">LARP</span>
    <h1><%= larpSection.title %></h1>
    <p class="muted">
      Bevor du ins Forum gehst, w&auml;hlst du hier deinen Charakter f&uuml;r den separaten LARP-Zugang.
    </p>
  </div>

  <div class="dashboard-server-actions">
    <a
      class="btn dashboard-add-character-btn"
      href="/characters/new?server=larp&return_to=<%= encodeURIComponent('/dashboard/larp') %>"
      aria-label="LARP-Charakter hinzufuegen"
      title="LARP-Charakter hinzufuegen"
    >
      +
    </a>
  </div>
</section>

<section class="dashboard-block larp-character-shell">
  <section class="panel larp-character-intro">
    <div class="larp-character-intro-copy">
      <span class="dashboard-status-pill"><%= larpSection.intro_badge %></span>
      <h2>W&auml;hle deinen Charakter f&uuml;r das LARP-Forum</h2>
      <p class="muted">
        <%= larpSection.note %> Mit einem Klick auf deinen Charakter betrittst du das Forum direkt in diesem Zugang.
      </p>
    </div>

    <% if (Number(larpPreferredCharacterId) > 0) { %>
      <div class="larp-character-intro-actions">
        <a class="btn" href="/larp-forum?character_id=<%= Number(larpPreferredCharacterId) %>">
          Zuletzt genutzten Charakter &ouml;ffnen
        </a>
      </div>
    <% } %>
  </section>

  <section class="panel dashboard-server-panel dashboard-subpanel">
    <div class="header-line">
      <div>
        <h3>Meine LARP-Charaktere</h3>
        <p class="muted">
          Dieser Bereich ist getrennt vom RP-Zugang. Jeder Charakter f&uuml;hrt direkt ins LARP-Forum.
        </p>
      </div>
    </div>

    <% if (!larpCharacters.length) { %>
      <p class="muted">
        Noch keine LARP-Charaktere angelegt. Erstelle zuerst einen Charakter, bevor du das Forum betrittst.
      </p>
    <% } else { %>
      <div class="character-mini-grid larp-character-grid">
        <% larpCharacters.forEach((char) => { %>
          <article class="character-mini-card larp-character-card">
            <a
              class="character-mini-item"
              href="/larp-forum?character_id=<%= char.id %>"
              title="LARP-Forum mit <%= char.name %> oeffnen"
            >
              <span class="character-mini-name"><%= char.name %></span>
              <span class="larp-character-card-note">Forum als <%= char.name %> &ouml;ffnen</span>
            </a>

            <div class="character-mini-actions">
              <a class="larp-character-open-link" href="/larp-forum?character_id=<%= char.id %>">
                Forum
              </a>

              <form
                method="POST"
                action="/characters/<%= char.id %>/delete"
                class="character-mini-delete-form"
                onsubmit="return confirm('Charakter wirklich loeschen?')"
              >
                <input type="hidden" name="return_to" value="/dashboard/larp">
                <button
                  type="submit"
                  class="character-mini-delete-btn"
                  aria-label="Charakter loeschen"
                  title="Charakter loeschen"
                >
                  X
                </button>
              </form>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</section>

<%- include("partials/end") %>
