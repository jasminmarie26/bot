<%- include("partials/start") %>

<section class="panel">
  <div class="header-line">
    <div>
      <h1>Vorschau: Gästebuch <%= character.name %></h1>
      <p class="muted">Ungespeicherte Vorschau von Seite <strong><%= pageNumber %></strong>.</p>
    </div>
    <div class="dashboard-server-actions">
      <a class="btn btn-secondary" href="<%= previewBackUrl %>">Zurück zum Editor</a>
      <a class="btn" href="/characters/<%= character.id %>/guestbook?page_id=<%= pageId %>" target="_blank" rel="noopener noreferrer">Gespeichertes Gästebuch</a>
    </div>
  </div>

  <article
    class="guestbook-page-preview gb-font-<%= guestbookSettings?.font_style || 'default' %>"
    style="color:<%= guestbookSettings?.chat_text_color || '#AEE7B7' %>;"
  >
    <% if (guestbookSettings?.image_url) { %>
      <img class="guestbook-page-image" src="<%= guestbookSettings.image_url %>" alt="Gästebuch Bild" />
    <% } %>
    <% if (previewHtml) { %>
      <div class="guestbook-entry-body"><%- previewHtml %></div>
    <% } else { %>
      <p class="muted">Diese Seite ist noch leer.</p>
    <% } %>
  </article>
</section>

<div data-server-presence="<%= character.server_id %>" hidden></div>
<script src="/server-presence.js?v=<%= staticAssetVersion %>"></script>
<script src="/guestbook-media.js?v=<%= staticAssetVersion %>"></script>

<%- include("partials/end") %>
