<%
  const hideTopbar = true;
  const pageClass = "page-guestbook-preview";
  const isTransparentPurTheme = String(guestbookSettings?.theme_style || "").trim().toLowerCase() === "transparent-pur";
  const isFullyTransparentGuestbookColor = (value) => {
    const normalized = String(value || "").trim().toUpperCase();
    return /^#[0-9A-F]{8}$/.test(normalized) && normalized.endsWith("00");
  };
  const normalizeGuestbookOpacity = (value, fallback = 100) => {
    const parsed = Number(value);
    if (!Number.isFinite(parsed)) {
      return fallback;
    }
    return Math.min(100, Math.max(0, Math.round(parsed)));
  };
  const buildGuestbookCssUrl = (value) => {
    const normalized = String(value || "").trim();
    return normalized ? `url(${JSON.stringify(normalized)})` : "";
  };
  const resolveGuestbookBackgroundColor = (rawColor, opacityValue) => {
    const normalized = String(rawColor || "").trim();
    if (!normalized) return "";
    const clamped = Math.min(100, Math.max(0, Math.round(Number(opacityValue))));
    return clamped >= 100
      ? normalized
      : `color-mix(in srgb, ${normalized} ${clamped}%, transparent)`;
  };
  const innerImageOpacity = normalizeGuestbookOpacity(guestbookSettings?.inner_image_opacity, 100);
  const outerImageOpacity = normalizeGuestbookOpacity(guestbookSettings?.outer_image_opacity, 100);
  const innerImageRepeat = Number(guestbookSettings?.inner_image_repeat) === 1;
  const outerImageRepeat = Number(guestbookSettings?.outer_image_repeat) === 1;
  const guestbookFrameColor = isTransparentPurTheme ? "" : String(guestbookSettings?.frame_color || "").trim();
  const guestbookBaseBackgroundColor = isTransparentPurTheme
    ? ""
    : String(guestbookSettings?.background_color || "").trim();
  const guestbookSurroundColor = isTransparentPurTheme
    ? ""
    : String(guestbookSettings?.surround_color || "").trim();
  const hasCustomGuestbookColors = Boolean(
    guestbookFrameColor ||
    guestbookBaseBackgroundColor ||
    guestbookSurroundColor
  );
  const guestbookBackgroundColor = resolveGuestbookBackgroundColor(
    guestbookBaseBackgroundColor,
    innerImageOpacity
  );
  const shouldHideGuestbookThemeShadow =
    isTransparentPurTheme ||
    (isFullyTransparentGuestbookColor(guestbookFrameColor) &&
      isFullyTransparentGuestbookColor(guestbookBaseBackgroundColor));
  const guestbookPageStyle = [
    `color:${guestbookPageTextColor || '#EED7AE'}`,
    guestbookFrameColor ? `--gb-frame-color:${guestbookFrameColor}` : "",
    guestbookBackgroundColor ? `--gb-background-color:${guestbookBackgroundColor}` : "",
    shouldHideGuestbookThemeShadow ? "--gb-theme-shadow:none" : "",
    guestbookSettings?.inner_image_url ? `--gb-inner-image:${buildGuestbookCssUrl(guestbookSettings.inner_image_url)}` : "",
    `--gb-inner-image-opacity:${innerImageOpacity / 100}`,
    `--gb-inner-image-repeat:${innerImageRepeat ? "repeat" : "no-repeat"}`,
    `--gb-inner-image-size:${innerImageRepeat ? "auto" : "cover"}`,
    `--gb-inner-image-position:${innerImageRepeat ? "top left" : "center top"}`
  ].filter(Boolean).join(";");
  const effectiveGuestbookSurroundColor = guestbookSurroundColor || guestbookBaseBackgroundColor || "";
  const normalizedGuestbookName = String(character?.name || "").trim().toLowerCase();
  const isGuestbookNameCrescentia = /^(crescentia|cresentia)$/.test(normalizedGuestbookName);
  const guestbookNameSpecialClass = normalizedGuestbookName === "noctra"
    ? "has-noctra-wings"
    : (isGuestbookNameCrescentia ? "has-crescentia-moons" : "");
  const guestbookNameWrapperClass = normalizedGuestbookName === "noctra"
    ? "noctra-nameplate"
    : (isGuestbookNameCrescentia ? "crescentia-nameplate" : "");
  const guestbookPreviewShellStyle = [
    effectiveGuestbookSurroundColor ? `--gb-surround-color:${effectiveGuestbookSurroundColor}` : "",
    guestbookSettings?.outer_image_url ? `--gb-outer-image:${buildGuestbookCssUrl(guestbookSettings.outer_image_url)}` : "",
    `--gb-outer-image-opacity:${outerImageOpacity / 100}`,
    `--gb-outer-image-repeat:${outerImageRepeat ? "repeat" : "no-repeat"}`,
    `--gb-outer-image-size:${outerImageRepeat ? "auto" : "cover"}`,
    `--gb-outer-image-position:${outerImageRepeat ? "top left" : "center top"}`
  ].filter(Boolean).join(";");
%>
<%- include("partials/start", { hideTopbar, pageClass, enableRealtime: false }) %>

<section class="guestbook-preview-shell" style="<%= guestbookPreviewShellStyle %>">
  <header class="guestbook-preview-header">
    <div class="guestbook-preview-header-row">
      <div class="guestbook-preview-brandline">
        <span class="guestbook-preview-name">
          <% if (guestbookNameWrapperClass) { %>
            <span class="<%= guestbookNameWrapperClass %>"><%= character.name %></span>
          <% } else { %>
            <%= character.name %>
          <% } %>
        </span>
        <span class="guestbook-preview-separator">-</span>
        <span class="guestbook-preview-label">G&auml;stebuch-Vorschau</span>
      </div>

      <div class="guestbook-preview-actions">
        <a class="btn btn-secondary" href="<%= previewBackUrl %>">Zur&uuml;ck zum Editor</a>
        <a class="btn" href="/characters/<%= character.id %>/guestbook?page_id=<%= pageId %>" target="_blank" rel="noopener noreferrer">Gespeichertes G&auml;stebuch</a>
      </div>
    </div>

    <p class="guestbook-preview-subtitle">
      Ungespeicherte Vorschau von Seite <strong><%= pageNumber %></strong>.
    </p>
  </header>

  <div class="guestbook-page-shell guestbook-preview-page-shell">
    <%- include("partials/guestbook-page-nav", { guestbookPageNavigation }) %>

    <article
      class="guestbook-page-preview gb-theme-<%= guestbookSettings?.theme_style || 'pergament-gold' %> gb-font-<%= guestbookSettings?.font_style || 'default' %><%= hasCustomGuestbookColors ? ' gb-custom-colors' : '' %>"
      style="<%= guestbookPageStyle %>"
    >
      <% if (guestbookSettings?.image_url) { %>
        <img class="guestbook-page-image" src="<%= guestbookSettings.image_url %>" alt="G&auml;stebuch Bild" />
      <% } %>
      <% if (previewHtml) { %>
        <div class="guestbook-entry-body"><%- previewHtml %></div>
      <% } else { %>
        <p class="muted">Diese Seite ist noch leer.</p>
      <% } %>
    </article>
  </div>
</section>

<script src="/guestbook-media.js?v=<%= staticAssetVersion %>"></script>

<%- include("partials/end") %>
