<%- include("../partials/start") %>

<% const usernameChangeDaysLeft = usernameChangeInfo.available_at
  ? Math.max(
    0,
    Math.ceil((usernameChangeInfo.available_at.getTime() - Date.now()) / (1000 * 60 * 60 * 24))
  )
  : 0; %>
<section class="panel admin-user-page account-layout">
  <div class="header-line">
    <div>
      <h1>Account</h1>
      <p class="muted">Hier kannst du deine Kontodaten bearbeiten.</p>
    </div>
    <div class="dashboard-server-actions">
      <button
        type="button"
        class="btn btn-secondary dashboard-delete-btn"
        id="account-delete-open"
        aria-haspopup="dialog"
        aria-controls="account-delete-modal"
      >
        Account l&ouml;schen
      </button>
    </div>
  </div>

  <% if (error) { %>
    <div class="flash flash-error"><%= error %></div>
  <% } %>

  <div class="help-table-wrap">
    <table class="help-table account-overview-table">
      <thead>
        <tr>
          <th>Info</th>
          <th>Wert</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Account Nr.</td>
          <td><%= accountUser.account_number %></td>
        </tr>
        <tr>
          <td>Aktueller Account-Name</td>
          <td><%= accountUser.username %></td>
        </tr>
        <tr>
          <td>Account erstellt</td>
          <td><%= accountCreatedAtLabel || accountUser.created_at %></td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<section class="panel account-layout">
  <h2>Kontodaten bearbeiten</h2>
  <p class="muted">Alle Einstellungen kannst du direkt in der Tabelle anpassen.</p>

  <form method="POST" action="/account/update" class="form account-settings-form">
    <div class="help-table-wrap">
      <table class="help-table account-settings-table">
        <thead>
          <tr>
            <th>Einstellung</th>
            <th>Wert</th>
            <th>Hinweis</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Account-Name</td>
            <td>
              <label class="account-table-field">
                <input
                  name="username"
                  maxlength="24"
                  value="<%= formValues.username %>"
                  required
                  autocomplete="username"
                />
              </label>
            </td>
            <td>
              <% if (usernameChangeInfo.is_admin_bypass) { %>
                Dein Account-Name ist jederzeit &auml;nderbar.
              <% } else if (usernameChangeInfo.can_change) { %>
                Dein Account-Name ist nur alle 182 Tage &auml;nderbar.
              <% } else { %>
                Dein Account-Name ist nur alle 182 Tage &auml;nderbar. N&auml;chste
                &Auml;nderung ab <strong><%= usernameChangeInfo.available_at_text %></strong>
                <% if (usernameChangeDaysLeft > 0) { %>
                  (noch <%= usernameChangeDaysLeft %> Tag<%= usernameChangeDaysLeft === 1 ? "" : "e" %>).
                <% } %>
              <% } %>
            </td>
          </tr>
          <tr>
            <td>E-Mail</td>
            <td>
              <label class="account-table-field">
                <input
                  name="email"
                  maxlength="255"
                  value="<%= formValues.email %>"
                  placeholder="name@domain.tld"
                  autocomplete="email"
                />
              </label>
            </td>
            <td>Wird f&uuml;r Benachrichtigungen, Exporte und Log-Versand genutzt.</td>
          </tr>
          <tr>
            <td>Geburtsdatum</td>
            <td>
              <label class="account-table-field">
                <input
                  type="date"
                  name="birth_date"
                  max="<%= new Date().toISOString().slice(0, 10) %>"
                  value="<%= formValues.birth_date || '' %>"
                  disabled
                />
              </label>
            </td>
            <td>Dient der Alterspr&uuml;fung f&uuml;r Bereiche wie ERP.</td>
          </tr>
          <tr>
            <td>AFK nach Minuten</td>
            <td>
              <label class="account-table-field">
                <input
                  type="number"
                  name="afk_timeout_minutes"
                  min="5"
                  max="240"
                  step="1"
                  value="<%= formValues.afk_timeout_minutes %>"
                  required
                />
              </label>
            </td>
            <td>Gez&auml;hlt wird nur Schreibaktivit&auml;t im Chat oder beim Fl&uuml;stern. Reine Klicks setzen den Timer nicht zur&uuml;ck.</td>
          </tr>
          <tr>
            <td>Auto-AFK im Chat</td>
            <td>
              <label class="checkbox account-table-checkbox">
                <input
                  id="account-auto-afk-enabled"
                  name="auto_afk_enabled"
                  type="checkbox"
                  value="1"
                  <%= formValues.auto_afk_enabled ? "checked" : "" %>
                />
                <span>Aktivieren</span>
              </label>
            </td>
            <td>Wenn diese Option aktiv ist, gehst du nach der eingestellten Zeit ohne Schreibaktivit&auml;t automatisch afk.</td>
          </tr>
          <tr>
            <td>Log-Backups per E-Mail</td>
            <td>
              <label class="checkbox account-table-checkbox">
                <input
                  id="account-room-log-email-enabled"
                  name="room_log_email_enabled"
                  type="checkbox"
                  value="1"
                  <%= formValues.room_log_email_enabled ? "checked" : "" %>
                />
                <span>Aktivieren</span>
              </label>
            </td>
            <td>Log-Backups werden immer gespeichert. Wenn diese Option aktiv ist, bekommst du sie zus&auml;tzlich per E-Mail.</td>
          </tr>
          <tr>
            <td>G&auml;stebuch-Musik h&ouml;ren</td>
            <td>
              <label class="checkbox account-table-checkbox">
                <input
                  id="account-guestbook-music-enabled"
                  name="guestbook_music_enabled"
                  type="checkbox"
                  value="1"
                  <%= formValues.guestbook_music_enabled ? "checked" : "" %>
                />
                <span>Aktivieren</span>
              </label>
            </td>
            <td>Wenn ein G&auml;stebuch eine YouTube-Hintergrundmusik hat, wird sie beim &Ouml;ffnen nur abgespielt, wenn dieser Haken aktiv ist.</td>
          </tr>
          <tr>
            <td>Eigene Chat-Uhrzeit</td>
            <td>
              <label class="checkbox account-table-checkbox">
                <input
                  id="chat-show-own-message-time"
                  name="show_own_chat_time"
                  type="checkbox"
                  value="1"
                  <%= formValues.show_own_chat_time ? "checked" : "" %>
                />
                <span>Aktivieren</span>
              </label>
            </td>
            <td>Zeigt vor deinen eigenen Chat-Nachrichten eine Uhrzeit vor dem Namen an. Sichtbar ist das nur f&uuml;r dich.</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="dashboard-server-actions account-settings-actions">
      <button class="btn" type="submit">Account speichern</button>
    </div>
  </form>
</section>

<section class="panel account-layout">
  <h2>Doppelaccounts</h2>

  <div class="help-table-wrap">
    <table class="help-table">
      <thead>
        <tr>
          <th>Thema</th>
          <th>Erkl&auml;rung</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Doppelaccounts</td>
          <td>
            Doppelaccounts sind verboten und nur nach Freigabe durch einen Admin erlaubt.
            <a href="/kontakt" target="_blank" rel="noopener noreferrer">Doppel Accounts Beantragen</a>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<%- include("../partials/end") %>
