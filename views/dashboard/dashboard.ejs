<%- include("../partials/start") %>

<% const larpActionLabel = "LARP-Bereich öffnen"; %>
<% const larpAccessNote = "Im LARP-Bereich nutzt jeder Account nur einen Zugangsname, nicht wie im RP Bereich mehrere Charaktere."; %>

<section class="header-line dashboard-page-header">
  <div>
    <h1>Serverliste</h1>
  </div>
</section>

<section class="dashboard-block dashboard-accordion-stack">
  <details class="dashboard-accordion" <%= openLarpSection ? "" : "open" %>>
    <summary class="dashboard-accordion-summary">
      <div class="dashboard-accordion-copy">
        <h2>Rollenspiel</h2>
      </div>
      <span class="dashboard-accordion-icon" aria-hidden="true"></span>
    </summary>

    <div class="dashboard-accordion-body">
      <div class="dashboard-role-switch" aria-label="Rollenspiel-Bereiche">
        <% serverSections.forEach((section) => { %>
          <a
            class="dashboard-role-link"
            href="/dashboard/areas/<%= section.id %>"
          >
            <span class="dashboard-role-tab-title"><%= section.dashboard_area_title %></span>
          </a>
        <% }) %>
      </div>
    </div>
  </details>

  <details class="dashboard-accordion dashboard-larp-accordion" <%= openLarpSection ? "open" : "" %>>
    <summary class="dashboard-accordion-summary">
      <div class="dashboard-accordion-copy">
        <h2>LARP BEREICH</h2>
        <p class="muted"><%= larpSection.description %></p>
      </div>
      <span class="dashboard-accordion-icon" aria-hidden="true"></span>
    </summary>

    <div class="dashboard-accordion-body">
      <section class="panel dashboard-larp-panel dashboard-subpanel">
        <div class="dashboard-larp-orb" aria-hidden="true"></div>
        <div class="dashboard-larp-copy">
          <p class="muted"><%= larpAccessNote %></p>

          <div class="dashboard-larp-actions">
            <a class="btn btn-secondary" href="/dashboard/larp">
              <%= larpActionLabel %>
            </a>
          </div>
        </div>
      </section>
    </div>
  </details>
</section>

<%- include("../partials/end") %>
