<%- include("partials/start") %>

<section class="panel legal-page-shell">
  <header class="legal-page-header">
    <h1>Kontakt</h1>
    <p class="muted legal-page-intro">
      Hier kannst du direkt eine Nachricht zu <strong><%= legalMeta.siteName %></strong> senden.
    </p>
  </header>

  <div class="legal-grid">
    <section class="legal-section">
      <h2>Allgemeiner Kontakt</h2>
      <p>
        <strong><%= legalMeta.contactName %></strong><br />
        &lt;<a href="mailto:<%= legalMeta.contactEmail %>"><%= legalMeta.contactEmail %></a>&gt;
      </p>
      <p>
        Betreiberin:<br />
        <strong><%= legalMeta.operatorName %></strong><br />
        <%= legalMeta.operatorStreet %><br />
        <%= legalMeta.operatorCity %>
      </p>
    </section>

    <section class="legal-section legal-section-wide">
      <h2>Nachricht senden</h2>
      <% if (contactError) { %>
        <div class="inline-error"><%= contactError %></div>
      <% } %>
      <% if (contactSuccess) { %>
        <div class="inline-success"><%= contactSuccess %></div>
      <% } %>
      <form method="POST" action="/kontakt" class="form contact-form">
        <div class="bot-trap" aria-hidden="true">
          <label>
            Webseite
            <input name="website" tabindex="-1" autocomplete="off" />
          </label>
        </div>

        <label>
          Name
          <input name="name" maxlength="80" required value="<%= contactValues && contactValues.name ? contactValues.name : '' %>" />
        </label>

        <label>
          E-Mail
          <input
            name="email"
            type="email"
            maxlength="160"
            required
            value="<%= contactValues && contactValues.email ? contactValues.email : '' %>"
          />
        </label>

        <label>
          Betreff
          <input
            name="subject"
            maxlength="140"
            required
            value="<%= contactValues && contactValues.subject ? contactValues.subject : '' %>"
          />
        </label>

        <label>
          Nachricht
          <textarea
            name="message"
            rows="8"
            maxlength="5000"
            required
          ><%= contactValues && contactValues.message ? contactValues.message : '' %></textarea>
        </label>

        <label class="checkbox">
          <input
            name="privacy_consent"
            type="checkbox"
            value="1"
            required
            <%= contactValues && contactValues.privacy_consent ? "checked" : "" %>
          />
          <span>
            Ich habe die
            <a href="/datenschutz" target="_blank" rel="noopener noreferrer">Datenschutzerkl&auml;rung</a>
            gelesen
          </span>
        </label>

        <p class="muted">
          Mit dem Absenden deiner Anfrage erkl&auml;rst du dich damit einverstanden, dass deine
          Angaben zur Bearbeitung deiner Anfrage verarbeitet werden. Weitere Informationen findest
          du in der <a href="/datenschutz" target="_blank" rel="noopener noreferrer">Datenschutzerkl&auml;rung</a>.
        </p>

        <div class="update-form-actions">
          <button type="submit" class="btn">Nachricht senden</button>
        </div>
      </form>
    </section>
  </div>
</section>

<%- include("partials/end") %>
