                <tr>
                  <td>Wiederherstellen</td>
                  <td>Mit dem Button vor dem <code>X</code> stellst du den Charakter wieder her.</td>
                </tr>
                <tr>
                  <td>Wiederherstellungsumfang</td>
                  <td>Dabei kommen G&auml;stebuch, Farben und G&auml;stebucheintr&auml;ge zur&uuml;ck.</td>
                </tr>
                <tr>
                  <td>Festspiele</td>
                  <td>Beim L&ouml;schen eines Charakters wird ein Festspiel nicht automatisch gel&ouml;scht. Es bleibt bestehen, bis es ausdr&uuml;cklich selbst gel&ouml;scht wird.</td>
                </tr>
                <tr>
                  <td><code>X</code></td>
                  <td>Mit dem <code>X</code> l&ouml;schst du das Backup endg&uuml;ltig.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="help-table-group">
          <h3>Tab <code>Logs</code></h3>
          <div class="help-table-wrap">
            <table class="help-table">
              <thead>
                <tr>
                  <th>Funktion</th>
                  <th>Erkl&auml;rung</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Anzeige</td>
