<%- include("partials/start", {
  pageClass: "page-larp-forum",
  topbarCharacter: larpActiveCharacter,
  activeCharacter: larpActiveCharacter
}) %>

<section class="header-line larp-forum-page-header">
  <div>
    <p class="larp-forum-page-kicker"><%= larpSection.title %></p>
    <h1><%= larpSection.hero_title %></h1>
    <p class="muted"><%= larpSection.hero_text %></p>
  </div>

  <div class="larp-forum-page-actions">
    <a class="btn btn-secondary" href="/dashboard">Zur Serverliste</a>
  </div>
</section>

<section class="larp-forum-layout">
  <section class="panel larp-forum-overview">
    <div class="larp-forum-overview-copy">
      <span class="dashboard-status-pill"><%= larpSection.intro_badge %></span>
      <h2>Getrennt vom RP-Bereich</h2>
      <p class="muted"><%= larpSection.note %></p>
    </div>

    <div class="larp-active-character">
      <span class="larp-active-character-label">Aktiver Charakter</span>
      <strong><%= larpActiveCharacter.name %></strong>
      <a class="btn btn-secondary" href="/dashboard/larp">Charakter wechseln</a>
    </div>

    <div class="larp-forum-stat-grid">
      <% (Array.isArray(larpSection.stats) ? larpSection.stats : []).forEach((stat) => { %>
        <article class="larp-forum-stat-card">
          <strong><%= stat.value %></strong>
          <span><%= stat.label %></span>
          <p><%= stat.note %></p>
        </article>
      <% }) %>
    </div>
  </section>

  <aside class="larp-forum-side">
    <% (Array.isArray(larpSection.side_notes) ? larpSection.side_notes : []).forEach((item) => { %>
      <section class="panel larp-forum-sidecard">
        <h2><%= item.title %></h2>
        <p class="muted"><%= item.text %></p>
      </section>
    <% }) %>
  </aside>
</section>

<%- include("partials/larp-forum-categories", { larpSection, compactView: false }) %>

<%- include("partials/end") %>
