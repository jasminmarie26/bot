<%- include("../partials/start", { topbarBrandLabel: "Heldenhafte Reisen" }) %>

<%
  const staffAreas = [];
  if (currentUser?.is_admin) {
    staffAreas.push({
      title: "Adminbereich",
      description: "Volle Verwaltung f&uuml;r Accounts, Rollen, Rechte und verd&auml;chtige Konten.",
      hint: "Nur f&uuml;r Admins sichtbar.",
      href: staffOverviewPath || "/admin",
      label: "Adminbereich &ouml;ffnen",
      external: false
    });
  } else if (currentUser?.is_moderator) {
    staffAreas.push({
      title: "Moderatorenbereich",
      description: "&Uuml;bersicht &uuml;ber Moderationsstatus, Online-Accounts und Staff-Werkzeuge.",
      hint: "F&uuml;r Admins und Moderatoren.",
      href: staffOverviewPath || "/staff/overview",
      label: "Moderatorenbereich &ouml;ffnen",
      external: false
    });
  }
  staffAreas.push({
    title: "USER BACKUP",
    description: "Beendete Raum-Logs in der Staff-Sicht durchsuchen und nachverfolgen.",
    hint: currentUser?.is_admin ? "Nur f&uuml;r Admins sichtbar." : "F&uuml;r Admins und Moderatoren.",
    href: staffUserBackupsPath || (currentUser?.is_admin ? "/admin/user-backups" : "/staff/user-backups"),
    label: "USER BACKUP &ouml;ffnen",
    external: false
  });
  staffAreas.push(
    {
      title: "Live Updates",
      description: "Neue Meldungen lesen sowie als Staff direkt ver&ouml;ffentlichen, bearbeiten oder l&ouml;schen.",
      hint: "F&uuml;r Admins und Moderatoren.",
      href: "/live-updates",
      label: "Live Updates &ouml;ffnen",
      external: true
    },
    {
      title: "Mitgliederliste",
      description: "Alle Mitglieder &ouml;ffnen und direkt in G&auml;steb&uuml;cher oder Profile springen.",
      hint: "F&uuml;r Admins und Moderatoren.",
      href: "/members",
      label: "Mitgliederliste &ouml;ffnen",
      external: true
    }
  );
%>

<section class="panel account-layout">
  <div class="header-line">
    <div>
      <h1>Admin- und Moderatorenbereich</h1>
      <p class="muted">Hier landest du direkt &uuml;ber deinen Namen im Header.</p>
    </div>
  </div>

  <div class="help-table-wrap">
    <table class="help-table staff-overview-table">
      <thead>
        <tr>
          <th>Bereich</th>
          <th>Funktion</th>
          <th>Zugriff</th>
          <th>Link</th>
        </tr>
      </thead>
      <tbody>
        <% staffAreas.forEach((entry) => { %>
          <tr>
            <td><strong><%= entry.title %></strong></td>
            <td><%= entry.description %></td>
            <td><%= entry.hint %></td>
            <td>
              <a
                class="btn btn-secondary"
                href="<%= entry.href %>"
                <% if (entry.external) { %>target="_blank" rel="noopener noreferrer"<% } %>
              >
                <%= entry.label %>
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (currentUser?.is_moderator && !currentUser?.is_admin) { %>
    <p class="muted admin-overview-note">
      Als Moderator kommst du hier gesammelt zu deinen Bereichen. Der volle Adminbereich bleibt nur f&uuml;r Admins offen.
    </p>
  <% } %>
</section>

<%- include("../partials/end") %>
