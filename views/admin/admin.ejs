<%- include("../partials/start") %>

<%
  const overviewTitle = panelTitle || "Adminbereich";
  const overviewBasePath = panelBasePath || "/admin";
  const userBackupBasePath = panelUserBackupsPath || `${overviewBasePath}/user-backups`;
  const detailBasePath = userDetailsBasePath || "/admin/users";
  const allowUserDeletion =
    typeof canDeleteUsers === "undefined" ? true : Boolean(canDeleteUsers);
  const currentSearchQuery = String(searchQuery || "");
  const currentSort = String(selectedSort || "name");
  const resetFilterHref = currentSort !== "name"
    ? `${overviewBasePath}?sort=${encodeURIComponent(currentSort)}`
    : overviewBasePath;
  const visibleUsers = Array.isArray(users) ? users : [];
  const totalFilteredUsers =
    typeof filteredUserCount === "number" ? filteredUserCount : visibleUsers.length;
  const groupedSections = [
    {
      key: "online",
      title: "Online User",
      tone: "online",
      users: Array.isArray(onlineUsers) ? onlineUsers : [],
      description: "Accounts, die gerade irgendwo auf der Seite online sind.",
      open: true
    },
    {
      key: "green",
      title: "Grüne User",
      tone: "green",
      users: Array.isArray(greenUsers) ? greenUsers : [],
      description: "1 = Grün. Alles okay.",
      open: true
    },
    {
      key: "minor",
      title: "Minderjährige User",
      tone: "minor",
      users: Array.isArray(minorUsers) ? minorUsers : [],
      description: "Accounts mit hinterlegtem Geburtsdatum unter 18.",
      open: true
    },
    {
      key: "yellow",
      title: "Gelbe User",
      tone: "yellow",
      users: Array.isArray(yellowUsers) ? yellowUsers : [],
      description: "2 = Gelb. Beobachtung oder leichte Verwarnung.",
      open: false
    },
    {
      key: "red",
      title: "Rote User",
      tone: "red",
      users: Array.isArray(redUsers) ? redUsers : [],
      description: "3 = Rot. User mit ernsteren Problemen oder Verwarnungen.",
      open: false
    },
    {
      key: "violet",
      title: "Violette User",
      tone: "violet",
      users: Array.isArray(violetUsers) ? violetUsers : [],
      description: "4 = Violett. Gebannte oder hart markierte Accounts.",
      open: false
    }
  ];
%>

<section class="panel account-layout">
  <div class="header-line">
    <div>
      <h1><%= overviewTitle %></h1>
      <p class="muted">Hier ist alles gesammelt und als Tabelle aufger&auml;umt.</p>
    </div>
  </div>

  <nav class="dashboard-role-switch" aria-label="Staff Navigation">
    <a
      class="dashboard-role-link<%= activeStaffTab === 'overview' ? ' is-active' : '' %>"
      href="<%= overviewBasePath %>"
    >
      <span class="dashboard-role-tab-title">&Uuml;bersicht</span>
    </a>
    <a
      class="dashboard-role-link<%= activeStaffTab === 'user-backups' ? ' is-active' : '' %>"
      href="<%= userBackupBasePath %>"
    >
      <span class="dashboard-role-tab-title">USER BACKUP</span>
    </a>
  </nav>

  <div class="help-table-wrap">
    <table class="help-table admin-overview-table">
      <thead>
        <tr>
          <th>Bereich</th>
          <th>Wert</th>
          <th>Hinweis</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Accounts gesamt</td>
          <td><strong><%= accountCount %></strong></td>
          <td>Alle aktuell registrierten Konten auf der Plattform.</td>
        </tr>
        <tr>
          <td>Admins</td>
          <td><strong><%= adminCount %></strong></td>
          <td>Benutzer mit vollem Zugriff auf Verwaltung, Rollen und Einstellungen.</td>
        </tr>
        <tr>
          <td>Moderatoren</td>
          <td><strong><%= moderatorCount %></strong></td>
          <td>Benutzer mit Moderationsrechten ohne kompletten Adminzugriff.</td>
        </tr>
        <tr>
          <td>Online jetzt</td>
          <td><strong><%= statusCounts?.online || 0 %></strong></td>
          <td>Accounts, die gerade irgendwo auf der Seite online sind.</td>
        </tr>
        <tr>
          <td>Minderj&auml;hrig</td>
          <td><strong><%= statusCounts?.minor || 0 %></strong></td>
          <td>Accounts unter 18 mit hinterlegtem Geburtsdatum.</td>
        </tr>
        <tr>
          <td>Gr&uuml;n / Okay</td>
          <td><strong><%= statusCounts?.green || 0 %></strong></td>
          <td>Stufe 1: Unauff&auml;llig oder okay.</td>
        </tr>
        <tr>
          <td>Gelb</td>
          <td><strong><%= statusCounts?.yellow || 0 %></strong></td>
          <td>Stufe 2: Beobachtung oder leichte Verwarnung.</td>
        </tr>
        <tr>
          <td>Rot</td>
          <td><strong><%= statusCounts?.red || 0 %></strong></td>
          <td>Stufe 3: Accounts mit deutlicheren Problemen.</td>
        </tr>
        <tr>
          <td>Violett</td>
          <td><strong><%= statusCounts?.violet || 0 %></strong></td>
          <td>Stufe 4: Gebannte oder hart markierte Accounts.</td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<section class="panel account-layout">
  <h2>Als Benutzer testen</h2>
  <p class="muted">Der Testmodus startet direkt aus der Tabelle.</p>

  <form method="POST" action="/admin/impersonate" class="form admin-settings-form">
    <div class="help-table-wrap">
      <table class="help-table admin-settings-table">
        <thead>
          <tr>
            <th>Funktion</th>
            <th>Eingabe</th>
            <th>Aktion</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Testmodus</td>
            <td>
              <label class="account-table-field">
                <input
                  name="username"
                  type="text"
                  maxlength="24"
                  autocomplete="off"
                  placeholder="Benutzername eingeben"
                  required
                />
              </label>
            </td>
            <td>
              <button class="btn" type="submit">Testmodus starten</button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </form>
</section>

<section class="panel account-layout">
  <div class="header-line">
    <div>
      <h2>Accountstatus</h2>
      <p class="muted">
        Vergib in der Detailansicht die Stufen 1 bis 4. Danach taucht der Account automatisch im passenden Bereich auf.
      </p>
    </div>
  </div>

  <form method="GET" action="<%= overviewBasePath %>" class="admin-tools">
    <label class="admin-search">
      <span>Suchen</span>
      <input
        id="admin-user-search"
        name="q"
        class="admin-search-input"
        type="search"
        placeholder="Name, E-Mail, Geburtsdatum oder IP"
        autocomplete="off"
        value="<%= currentSearchQuery %>"
      />
    </label>
    <label class="admin-sort-field">
      <span>Sortieren nach</span>
      <select name="sort" class="admin-sort-select">
        <option value="name" <%= currentSort === "name" ? "selected" : "" %>>Name</option>
        <option value="created_at" <%= currentSort === "created_at" ? "selected" : "" %>>Erstellungsdatum</option>
        <option value="last_online" <%= currentSort === "last_online" ? "selected" : "" %>>Zuletzt online</option>
      </select>
    </label>
    <div class="admin-table-actions">
      <button class="btn" type="submit">Anwenden</button>
      <% if (currentSearchQuery) { %>
        <a class="btn btn-secondary" href="<%= resetFilterHref %>">Zur&uuml;cksetzen</a>
      <% } %>
    </div>
  </form>

  <p class="muted">
    <% if (totalFilteredUsers) { %>
      <%= totalFilteredUsers %> Accounts gefunden.
    <% } else if (currentSearchQuery) { %>
      Keine passenden Benutzer gefunden.
    <% } else { %>
      Noch keine Benutzer vorhanden.
    <% } %>
  </p>

  <% if (visibleUsers.length) { %>
    <div class="admin-status-groups">
      <% groupedSections.forEach((section) => { %>
        <details class="admin-status-group is-<%= section.tone %>" <%= section.open ? "open" : "" %>>
          <summary class="admin-status-summary">
            <span class="admin-status-summary-badge is-<%= section.tone %>"><%= section.title %></span>
            <span class="admin-status-summary-count"><%= section.users.length %></span>
          </summary>
          <p class="muted"><%= section.description %></p>

          <% if (section.users.length) { %>
            <%- include("../partials/admin-status-user-table", {
              users: section.users,
              sectionKey: section.key,
              detailBasePath,
              allowUserDeletion,
              currentUser
            }) %>
          <% } else { %>
            <p class="muted">Keine Accounts in diesem Bereich.</p>
          <% } %>
        </details>
      <% }) %>
    </div>
  <% } %>
</section>

<script>
  (() => {
    const pageSize = 10;
    const roots = Array.from(document.querySelectorAll("[data-admin-status-pagination-root]"));

    roots.forEach((root) => {
      const rows = Array.from(root.querySelectorAll("[data-admin-status-row]"));
      const prevButton = root.querySelector("[data-admin-status-page-prev]");
      const nextButton = root.querySelector("[data-admin-status-page-next]");
      const pageButtons = Array.from(root.querySelectorAll("[data-admin-status-page-button]"));
      const totalPages = Math.max(1, Math.ceil(rows.length / pageSize));
      let currentPage = 1;

      if (totalPages <= 1) {
        return;
      }

      const renderPage = (pageNumber) => {
        currentPage = Math.min(Math.max(Number(pageNumber) || 1, 1), totalPages);

        rows.forEach((row, index) => {
          const pageForRow = Math.floor(index / pageSize) + 1;
          row.hidden = pageForRow !== currentPage;
        });

        pageButtons.forEach((button) => {
          const buttonPage = Number(button.dataset.adminStatusPageButton || "1");
          const isActive = buttonPage === currentPage;
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-current", isActive ? "page" : "false");
        });

        if (prevButton) {
          prevButton.disabled = currentPage <= 1;
        }

        if (nextButton) {
          nextButton.disabled = currentPage >= totalPages;
        }
      };

      pageButtons.forEach((button) => {
        button.addEventListener("click", () => {
          renderPage(button.dataset.adminStatusPageButton);
        });
      });

      if (prevButton) {
        prevButton.addEventListener("click", () => {
          renderPage(currentPage - 1);
        });
      }

      if (nextButton) {
        nextButton.addEventListener("click", () => {
          renderPage(currentPage + 1);
        });
      }

      renderPage(1);
    });
  })();
</script>

<%- include("../partials/end") %>
