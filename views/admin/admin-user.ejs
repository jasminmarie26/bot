<%- include("../partials/start") %>

<%
  const characters = Array.isArray(userCharacters) ? userCharacters : [];
  const panelHomePath = panelBasePath || "/admin";
  const panelHomeLabel = panelTitle || "Adminbereich";
  const canEditUserBasics =
    typeof canEditUsers === "undefined" ? true : Boolean(canEditUsers);
  const canResetUserPassword =
    typeof canResetPasswords === "undefined" ? true : Boolean(canResetPasswords);
  const canManageUserRoles =
    typeof canManageUsers === "undefined" ? true : Boolean(canManageUsers);
  const canModerateAccount =
    typeof canModerateUsers === "undefined" ? false : Boolean(canModerateUsers);
  const canClearUserGuestbooks =
    typeof canClearGuestbooks === "undefined" ? true : Boolean(canClearGuestbooks);
  const noteCategories = Array.isArray(moderationNoteCategories) ? moderationNoteCategories : [];
  const moderationNoteLog = String(targetUser.moderation_status_note || "").trim();
  const blockedIpEntry = blockedLoginIpEntry || null;
  const loginIpBlockPath = `${userDetailsBasePath}/${targetUser.id}/login-ip-block`;
%>

<section class="panel admin-user-page">
  <div class="header-line">
    <div>
      <div class="admin-account-name admin-account-name-large">
        <% if (targetUser.is_online) { %>
          <span class="admin-online-dot" aria-label="Online" title="Online"></span>
        <% } %>
        <h1><%= targetUser.username %></h1>
      </div>
      <p class="muted">Account #<%= targetUser.account_number %></p>
    </div>
    <div class="dashboard-server-actions">
      <% if (currentUser?.is_admin && Number(targetUser.id) !== Number(currentUser.id)) { %>
        <form method="POST" action="/admin/impersonate" class="inline-form">
          <input type="hidden" name="username" value="<%= targetUser.username %>" />
          <button class="btn" type="submit">Als diesen User testen</button>
        </form>
      <% } %>
      <a class="btn btn-secondary" href="<%= panelHomePath %>">Zur&uuml;ck zum <%= panelHomeLabel %></a>
    </div>
  </div>

  <div class="admin-user-role-list">
    <% if (targetUser.is_admin) { %>
      <span class="admin-role-badge is-admin">Admin</span>
    <% } %>
    <% if (targetUser.is_moderator) { %>
      <span class="admin-role-badge is-moderator">Moderator</span>
    <% } %>
    <% if (!targetUser.is_admin && !targetUser.is_moderator) { %>
      <span class="admin-role-badge">User</span>
    <% } %>
    <% if (targetUser.is_suspicious) { %>
      <span class="admin-role-badge is-suspicious">Verd&auml;chtig</span>
    <% } %>
    <% if (targetUser.is_minor_account) { %>
      <span class="admin-role-badge is-minor">Minderj&auml;hrig</span>
    <% } %>
    <span class="admin-status-badge is-<%= targetUser.moderation_status.slug %>">
      <%= targetUser.moderation_status.label %>
    </span>
  </div>

  <% if (targetUser.is_minor_account) { %>
    <div class="admin-minor-alert" role="alert">
      <strong>Minderj&auml;hriger User</strong>
      <span>
        Dieser Account ist <%= targetUser.account_age_label || "unter 18" %>.
        Bitte beim Moderieren und beim &Ouml;ffnen von G&auml;steb&uuml;chern den Jugendschutz beachten.
      </span>
    </div>
  <% } %>

  <div class="admin-user-meta">
    <span>E-Mail: <%= targetUser.email || "-" %></span>
    <span>Geburtsdatum: <%= targetUser.birth_date_label || "-" %></span>
    <% if (targetUser.account_age_label) { %>
      <span>Alter: <%= targetUser.account_age_label %></span>
    <% } %>
    <span>Charaktere: <%= targetUser.character_count %></span>
    <% if (targetUser.is_online && targetUser.online_location_label) { %>
      <span>Ort: <%= targetUser.online_location_label %></span>
    <% } %>
    <span>Letzter Login: <%= targetUser.last_login_at_label || "-" %></span>
    <span>Letzte IP: <%= targetUser.last_login_ip || "-" %></span>
    <span>Doppelaccounts: <%= Number(targetUser.duplicate_accounts_allowed) === 1 ? "freigeschaltet" : "gesperrt" %></span>
    <small>Erstellt: <%= targetUser.created_at_label || "-" %></small>
  </div>
</section>

<section class="panel">
  <h2>Moderationsstatus</h2>
  <p class="muted">1 = Gr&uuml;n, 2 = Gelb, 3 = Rot, 4 = Violett / Gebannt.</p>

  <% if (canModerateAccount) { %>
    <form
      method="POST"
      action="<%= `${userDetailsBasePath}/${targetUser.id}/moderation-status` %>"
      class="admin-inline-form admin-moderation-form"
    >
      <label>
        Stufe
        <select name="moderation_status_level">
          <% statusDefinitions.forEach((statusEntry) => { %>
            <option
              value="<%= statusEntry.level %>"
              <%= Number(targetUser.moderation_status_level) === Number(statusEntry.level) ? "selected" : "" %>
            >
              <%= statusEntry.label %> - <%= statusEntry.description %>
            </option>
          <% }) %>
        </select>
      </label>
      <label>
        Kategorie
        <select name="moderation_note_category">
          <option value="">Kategorie w&auml;hlen</option>
          <% noteCategories.forEach((entry) => { %>
            <option value="<%= entry.id %>"><%= entry.label %></option>
          <% }) %>
        </select>
      </label>
      <label class="admin-moderation-note-field">
        Neue Notiz
        <textarea
          name="moderation_note_text"
          rows="5"
          placeholder="Notiz wird automatisch mit Datum, Uhrzeit und deinem Namen gespeichert."
        ></textarea>
      </label>
      <button class="btn btn-secondary" type="submit">Status / Notiz speichern</button>
    </form>

    <% if (moderationNoteLog) { %>
      <div class="admin-note-log-wrap">
        <h3>Notizverlauf</h3>
        <pre class="admin-note-log"><%= moderationNoteLog %></pre>
      </div>
    <% } else { %>
      <p class="muted">Noch keine Moderationsnotiz vorhanden.</p>
    <% } %>
  <% } else { %>
    <div class="admin-user-meta">
      <span>Status: <%= targetUser.moderation_status.label %></span>
    </div>
    <div class="admin-note-log-wrap">
      <h3>Notizverlauf</h3>
      <pre class="admin-note-log"><%= moderationNoteLog || "Keine Notiz." %></pre>
    </div>
  <% } %>
</section>

<section class="panel">
  <h2>IP-Sperre</h2>
  <p class="muted">Gesperrte IPs k&ouml;nnen sich weder per Passwort noch per Google/Facebook anmelden.</p>

  <div class="admin-user-meta">
    <span>Letzte Login-IP: <%= targetUser.last_login_ip || "-" %></span>
    <% if (blockedIpEntry) { %>
      <span>Status: Gesperrt</span>
      <span>Von: <%= blockedIpEntry.created_by_label || "-" %></span>
      <span>Seit: <%= blockedIpEntry.created_at_label || "-" %></span>
    <% } else { %>
      <span>Status: Nicht gesperrt</span>
    <% } %>
  </div>

  <% if (canModerateAccount) { %>
    <% if (targetUser.last_login_ip) { %>
      <form method="POST" action="<%= loginIpBlockPath %>" class="admin-inline-form admin-ip-block-quick-form">
        <input type="hidden" name="ip_address" value="<%= targetUser.last_login_ip %>" />
        <input type="hidden" name="action" value="<%= blockedIpEntry ? "unblock" : "block" %>" />
        <button class="btn <%= blockedIpEntry ? "btn-secondary" : "btn-danger" %>" type="submit">
          <%= blockedIpEntry ? "Letzte IP entsperren" : "Letzte IP sperren" %>
        </button>
      </form>
    <% } %>

    <form method="POST" action="<%= loginIpBlockPath %>" class="admin-inline-form admin-ip-block-form">
      <label>
        IP-Adresse
        <input
          name="ip_address"
          maxlength="120"
          placeholder="127.0.0.1 oder 2001:db8::1"
          autocomplete="off"
          required
        />
      </label>
      <div class="admin-table-actions">
        <button class="btn btn-danger" type="submit" name="action" value="block">IP sperren</button>
        <button class="btn btn-secondary" type="submit" name="action" value="unblock">IP entsperren</button>
      </div>
    </form>
  <% } %>
</section>

<% if (targetUser.is_suspicious) { %>
  <section class="panel suspicious-user-card">
    <h2>Verdachtsgr&uuml;nde</h2>
    <div class="admin-user-meta">
      <% targetUser.suspicion_reasons.forEach((reason) => { %>
        <span><%= reason %></span>
      <% }) %>
    </div>
  </section>
<% } %>

<section class="panel">
  <h2>Basisdaten</h2>
  <% if (canEditUserBasics) { %>
    <form method="POST" action="/admin/users/<%= targetUser.id %>/update-basic" class="admin-inline-form">
      <label>
        Name
        <input name="username" maxlength="24" value="<%= targetUser.username %>" required />
      </label>
      <label>
        E-Mail
        <input name="email" maxlength="255" value="<%= targetUser.email %>" placeholder="name@domain.tld" />
      </label>
      <label>
        Geburtsdatum
        <input
          type="date"
          name="birth_date"
          max="<%= new Date().toISOString().slice(0, 10) %>"
          value="<%= targetUser.birth_date || "" %>"
        />
      </label>
      <button class="btn btn-secondary" type="submit">Basisdaten speichern</button>
    </form>
    <p class="muted">
      Admin- und Moderatornamen werden direkt im gew&uuml;nschten Charakter gesetzt.
      &Ouml;ffne daf&uuml;r den Charakter und aktiviere dort
      &bdquo;Als Admin-Charakter verwenden&ldquo; oder
      &bdquo;Als Moderator-Charakter verwenden&ldquo;.
    </p>
  <% } else { %>
    <p class="muted">Im Moderatorenbereich ist dieser Abschnitt nur lesbar.</p>
    <div class="admin-user-meta">
      <span>Name: <%= targetUser.username %></span>
      <span>E-Mail: <%= targetUser.email || "-" %></span>
      <span>Geburtsdatum: <%= targetUser.birth_date_label || "-" %></span>
    </div>
  <% } %>
</section>

<% if (canResetUserPassword) { %>
  <section class="panel">
    <h2>Passwort</h2>
    <p class="muted">
      Passw&ouml;rter sind aus Sicherheitsgr&uuml;nden nicht lesbar. Du kannst sie hier nur zur&uuml;cksetzen.
    </p>
    <form method="POST" action="/admin/users/<%= targetUser.id %>/reset-password" class="admin-inline-form">
      <label>
        Neues Passwort
        <input name="new_password" type="password" minlength="6" required placeholder="Mind. 6 Zeichen" />
      </label>
      <button class="btn btn-secondary" type="submit">Passwort zur&uuml;cksetzen</button>
    </form>
  </section>
<% } %>

<% if (canManageUserRoles) { %>
  <section class="panel">
    <h2>Rollen und Aktionen</h2>
    <div class="dashboard-server-actions">
      <% if (targetUser.id === currentUser.id) { %>
        <small>Dein eigener Account</small>
      <% } else { %>
        <form method="POST" action="/admin/users/<%= targetUser.id %>/toggle-admin" class="inline-form">
          <% if (targetUser.is_admin) { %>
            <input type="hidden" name="action" value="demote" />
            <button class="btn btn-danger" type="submit">Admin entfernen</button>
          <% } else { %>
            <input type="hidden" name="action" value="promote" />
            <button class="btn" type="submit">Zu Admin machen</button>
          <% } %>
        </form>
      <% } %>

      <form method="POST" action="/admin/users/<%= targetUser.id %>/toggle-moderator" class="inline-form">
        <% if (targetUser.is_moderator) { %>
          <input type="hidden" name="action" value="demote" />
          <button class="btn btn-secondary" type="submit">Moderator entfernen</button>
        <% } else { %>
          <input type="hidden" name="action" value="promote" />
          <button class="btn btn-secondary" type="submit">Zu Moderator machen</button>
        <% } %>
      </form>

      <form method="POST" action="/admin/users/<%= targetUser.id %>/toggle-duplicate-accounts" class="inline-form">
        <% if (Number(targetUser.duplicate_accounts_allowed) === 1) { %>
          <input type="hidden" name="action" value="disable" />
          <button class="btn btn-secondary" type="submit">Doppelaccounts sperren</button>
        <% } else { %>
          <input type="hidden" name="action" value="enable" />
          <button class="btn btn-secondary" type="submit">Doppelaccounts freischalten</button>
        <% } %>
      </form>

      <% if (targetUser.id !== currentUser.id) { %>
        <form method="POST" action="/admin/users/<%= targetUser.id %>/delete" class="inline-form">
          <button class="btn btn-danger" type="submit">Account l&ouml;schen</button>
        </form>
      <% } %>
    </div>
  </section>
<% } %>

<section class="panel">
  <div class="header-line">
    <div>
      <h2>Charaktere und G&auml;steb&uuml;cher</h2>
      <p class="muted">Klicke auf einen Charakter, um direkt sein G&auml;stebuch zu &ouml;ffnen.</p>
    </div>
  </div>

  <% if (!characters.length) { %>
    <p class="muted">Dieser User hat noch keine Charaktere angelegt.</p>
  <% } else { %>
    <div class="admin-character-grid">
      <% characters.forEach((character) => { %>
        <% const guestbookStaffHref = `/characters/${character.id}/guestbook?staff_view=1`; %>
        <article class="list-item admin-character-card">
          <a
            class="admin-character-primary"
            href="<%= guestbookStaffHref %>"
            title="G&auml;stebuch von <%= character.name %> &ouml;ffnen"
          >
            <span class="admin-character-name"><%= character.name %></span>
            <span class="admin-character-server">
              <%= character.server_id === "erp" ? "ERP" : "FREE-RP" %>
            </span>
            <div class="admin-character-meta">
              <span><%= character.page_count %> Seiten</span>
              <span><%= character.entry_count %> Eintr&auml;ge</span>
              <span><%- character.is_public ? "&ouml;ffentlich" : "privat" %></span>
            </div>
          </a>

          <div class="dashboard-server-actions admin-character-actions">
            <a class="btn btn-secondary" href="/characters/<%= character.id %>">Charakter &ouml;ffnen</a>
            <a class="btn" href="<%= guestbookStaffHref %>">G&auml;stebuch &ouml;ffnen</a>
            <% if (canClearUserGuestbooks) { %>
              <a class="btn" href="/characters/<%= character.id %>/guestbook/edit?staff_view=1">G&auml;stebuch bearbeiten</a>
              <form method="POST" action="/admin/guestbooks/<%= character.id %>/clear" class="inline-form">
                <button class="btn btn-danger" type="submit">G&auml;stebuch leeren</button>
              </form>
            <% } %>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include("../partials/end") %>
