<%- include("partials/start") %>

<section class="panel admin-user-page">
  <div class="header-line">
    <div>
      <h1>Account</h1>
      <p class="muted">Hier kannst du deine Kontodaten bearbeiten.</p>
    </div>
    <div class="dashboard-server-actions">
      <button
        type="button"
        class="btn btn-secondary dashboard-delete-btn"
        id="account-delete-open"
        aria-haspopup="dialog"
        aria-controls="account-delete-modal"
      >
        Account l&ouml;schen
      </button>
    </div>
  </div>

  <% if (error) { %>
    <div class="flash flash-error"><%= error %></div>
  <% } %>

  <div class="admin-user-meta">
    <span>Account Nr.: <%= accountUser.account_number %></span>
    <span>Aktueller Account-Name: <%= accountUser.username %></span>
    <span>Account erstellt: <%= accountCreatedAtLabel || accountUser.created_at %></span>
  </div>
</section>

<section class="panel">
  <h2>Kontodaten bearbeiten</h2>
  <form method="POST" action="/account/update" class="form">
    <% const usernameChangeMonthsLeft = usernameChangeInfo.available_at
      ? Math.max(
        0,
        Math.ceil((usernameChangeInfo.available_at.getTime() - Date.now()) / (1000 * 60 * 60 * 24 * 30.5))
      )
      : 0; %>
    <% if (usernameChangeInfo.is_admin_bypass) { %>
      <p class="muted">
        Hinweis: Dein Account-Name ist jederzeit &auml;nderbar.
      </p>
    <% } else if (usernameChangeInfo.can_change) { %>
      <p class="muted">
        Hinweis: Dein Account-Name ist nur alle 182 Tage &auml;nderbar.
      </p>
    <% } else { %>
      <p class="muted">
        Hinweis: Dein Account-Name ist nur alle 182 Tage &auml;nderbar. N&auml;chste
        &Auml;nderung ab <strong><%= usernameChangeInfo.available_at_text %></strong>
        <% if (usernameChangeMonthsLeft > 0) { %>
          (noch ca. <%= usernameChangeMonthsLeft %> Monat<%= usernameChangeMonthsLeft === 1 ? "" : "e" %>).
        <% } %>
      </p>
    <% } %>

    <label>
      Account-Name
      <input
        name="username"
        maxlength="24"
        value="<%= formValues.username %>"
        required
        autocomplete="username"
      />
    </label>

    <label>
      E-Mail
      <input
        name="email"
        maxlength="255"
        value="<%= formValues.email %>"
        placeholder="name@domain.tld"
        autocomplete="email"
      />
    </label>

    <label>
      Geburtsdatum
      <input
        type="date"
        name="birth_date"
        max="<%= new Date().toISOString().slice(0, 10) %>"
        value="<%= formValues.birth_date || '' %>"
      />
    </label>

    <label>
      AFK nach Minuten
      <input
        type="number"
        name="afk_timeout_minutes"
        min="5"
        max="240"
        step="1"
        value="<%= formValues.afk_timeout_minutes %>"
        required
      />
    </label>
    <p class="muted">
      Nach dieser Zeit ohne Aktivität im Chat gilt dein Charakter automatisch als afk.
    </p>

    <label class="checkbox">
      <input
        id="account-room-log-email-enabled"
        name="room_log_email_enabled"
        type="checkbox"
        value="1"
        <%= formValues.room_log_email_enabled ? "checked" : "" %>
      />
      <span>Logs f&uuml;r alle deine Charaktere zus&auml;tzlich per E-Mail senden</span>
    </label>
    <p class="muted">
      Log-Backups werden immer gespeichert. Wenn diese Option aktiv ist, bekommst du sie zus&auml;tzlich per E-Mail.
    </p>

    <label class="checkbox">
      <input
        id="chat-show-own-message-time"
        name="show_own_chat_time"
        type="checkbox"
        value="1"
        <%= formValues.show_own_chat_time ? "checked" : "" %>
      />
      <span>Eigene Chat-Nachrichten mit Uhrzeit vor dem Namen anzeigen</span>
    </label>

    <div class="dashboard-server-actions">
      <button class="btn" type="submit">Account speichern</button>
    </div>
  </form>
</section>

<section class="panel">
  <h2>Doppelaccounts</h2>
  <p class="muted">
    Doppelaccounts sind verboten und nur nach Freigabe durch einen Admin erlaubt.
    <a href="/kontakt" target="_blank" rel="noopener noreferrer">Doppel Accounts Beantragen</a>
  </p>
</section>

<%- include("partials/end") %>
