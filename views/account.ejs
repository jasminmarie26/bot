<%- include("partials/start") %>

<section class="panel admin-user-page">
  <div class="header-line">
    <div>
      <h1>Account</h1>
      <p class="muted">Hier kannst du deine Kontodaten bearbeiten.</p>
    </div>
    <div class="dashboard-server-actions">
      <button
        type="button"
        class="btn btn-secondary dashboard-delete-btn"
        id="account-delete-open"
        aria-haspopup="dialog"
        aria-controls="account-delete-modal"
      >
        Account l&ouml;schen
      </button>
    </div>
  </div>

  <% if (error) { %>
    <div class="flash flash-error"><%= error %></div>
  <% } %>

  <div class="admin-user-meta">
    <span>Account Nr.: <%= accountUser.account_number %></span>
    <span>Aktueller Account-Name: <%= accountUser.username %></span>
    <span>Account erstellt: <%= accountCreatedAtLabel || accountUser.created_at %></span>
  </div>
</section>

<section class="panel">
  <h2>Kontodaten bearbeiten</h2>
  <form method="POST" action="/account/update" class="form">
    <label>
      Account-Name
      <input
        name="username"
        maxlength="24"
        value="<%= formValues.username %>"
        required
        autocomplete="username"
      />
    </label>

    <% if (usernameChangeInfo.is_admin_bypass) { %>
      <p class="muted">
        Als Admin kannst du deinen Account-Namen jederzeit &auml;ndern.
      </p>
    <% } else if (usernameChangeInfo.can_change) { %>
      <p class="muted">
        Du kannst deinen Account-Namen jetzt &auml;ndern. Danach ist die n&auml;chste
        &Auml;nderung wieder nach 182 Tagen m&ouml;glich.
      </p>
    <% } else { %>
      <p class="muted">
        Dein n&auml;chster Account-Namenswechsel ist ab
        <strong><%= usernameChangeInfo.available_at_text %></strong> m&ouml;glich.
      </p>
    <% } %>

    <label>
      E-Mail
      <input
        name="email"
        maxlength="255"
        value="<%= formValues.email %>"
        placeholder="name@domain.tld"
        autocomplete="email"
      />
    </label>

    <label>
      Geburtsdatum
      <input
        type="date"
        name="birth_date"
        max="<%= new Date().toISOString().slice(0, 10) %>"
        value="<%= formValues.birth_date || '' %>"
      />
    </label>

    <label>
      AFK nach Minuten
      <input
        type="number"
        name="afk_timeout_minutes"
        min="5"
        max="240"
        step="1"
        value="<%= formValues.afk_timeout_minutes %>"
        required
      />
    </label>
    <p class="muted">
      Nach dieser Zeit ohne Aktivität im Chat gilt dein Charakter automatisch als afk.
    </p>

    <label class="checkbox">
      <input id="chat-show-own-message-time" type="checkbox" />
      <span>Eigene Chat-Nachrichten mit Uhrzeit vor dem Namen anzeigen</span>
    </label>

    <div class="dashboard-server-actions">
      <button class="btn" type="submit">Account speichern</button>
    </div>
  </form>
</section>

<% if (accountUser?.is_admin || accountUser?.is_moderator) { %>
  <section class="panel">
    <h2>Hinweis</h2>
    <p class="muted">
      Die 182-Tage-Sperre gilt nur f&uuml;r normale Nutzer. Admins sind davon ausgenommen.
      E-Mail und Geburtsdatum kannst du jederzeit anpassen.
    </p>
  </section>
<% } %>

<script>
  (() => {
    const checkbox = document.getElementById("chat-show-own-message-time");
    const storageKey = "chat-show-own-message-time";
    if (!checkbox) return;
    const legacyHintCandidates = Array.from(
      checkbox.closest("form")?.querySelectorAll("p.muted") || []
    );

    legacyHintCandidates.forEach((node) => {
      const text = String(node.textContent || "").trim();
      if (
        text.includes("Beispiel:") ||
        text.includes("[11:30]") ||
        text.includes("Name: Blabla")
      ) {
        node.remove();
      }
    });

    try {
      checkbox.checked = window.localStorage.getItem(storageKey) === "1";
    } catch (_error) {
      checkbox.checked = false;
    }

    checkbox.addEventListener("change", () => {
      try {
        window.localStorage.setItem(storageKey, checkbox.checked ? "1" : "0");
      } catch (_error) {
        // Ignore unavailable localStorage; the setting remains local-only when possible.
      }
    });
  })();
</script>

<%- include("partials/end") %>
