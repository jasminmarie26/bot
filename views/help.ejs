<%- include("partials/start") %>

<section class="help-layout">
  <% if (!helpTopic) { %>
    <section class="panel help-intro">
      <div class="header-line">
        <div>
          <h1>Hilfe</h1>
          <p class="muted">Kurz, zusammengefasst und direkt nutzbar.</p>
        </div>
      </div>

      <p>Wähle ein Sammelthema. Alles Wichtige bleibt drin, aber kompakter.</p>
    </section>

    <section class="panel help-link-panel">
      <h2>Themen</h2>
      <nav class="help-topic-links" aria-label="Hilfethemen">
        <% (helpTopics || []).forEach((topic) => { %>
          <a class="help-topic-link" href="/help/<%= topic.slug %>"><%= topic.title %></a>
        <% }) %>
      </nav>
    </section>
  <% } else { %>
    <section class="panel help-intro">
      <div class="header-line">
        <div>
          <h1><%= helpTopic.title %></h1>
          <p class="muted">Kurz erklärt. Ohne unnötige Einzelthemen.</p>
        </div>
      </div>

      <a class="help-topic-link" href="/help">Zur Themenübersicht</a>
    </section>

    <% if (helpTopic.slug === "bereich-charaktere") { %>
      <section class="panel help-section">
        <h2>Bereich & Charaktere</h2>
        <p>Hier geht es um Serverwahl, Charaktere und die normale Bereichsübersicht.</p>

        <ul class="help-list">
          <li>Im Dashboard öffnest du deinen Bereich über <code>Rollenspiel - Free</code> oder <code>Rollenspiel - Erotik</code>.</li>
          <li>Neue Charaktere legst du dort über <code>+ Charakter</code> an.</li>
          <li>Danach kannst du Räume, Chat, Gästebuch und Festspiele nutzen.</li>
          <li>Die Bereichsseite zeigt deine Charaktere und Festspiele getrennt an.</li>
        </ul>

        <ul class="help-list">
          <li>Neben jedem eigenen Charakter sitzt der Export-Button für den Gästebuch-Code per E-Mail.</li>
          <li>Der Haken neben <code>+</code> verschickt die Codes aller dort sichtbaren eigenen Charaktere gesammelt.</li>
          <li>Der Versand enthält den Gästebuch-Code direkt sowie zusätzlich als PDF- und Word-Datei.</li>
          <li>Dabei werden keine Gästebucheinträge mitgeschickt, nur der eigentliche Gästebuch-Code.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "raeume-chat") { %>
      <section class="panel help-section">
        <h2>Räume & Chat</h2>
        <p>Hier findest du alles zu Raumliste, eigenen Räumen, Flüstern und Chatbefehlen.</p>

        <ul class="help-list">
          <li>Die Raumliste findest du auf der Charakterseite.</li>
          <li><code>Gemeinsamer Treffpunkt</code> ist der feste Standardraum des Bereichs.</li>
          <li>Ein Schloss bedeutet: Raum ist abgeschlossen.</li>
          <li>Eigene Räume legst du über <code>Raum erstellen/editieren</code> an.</li>
          <li>Eigene Räume werden live aktualisiert und lassen sich in ihrer Reihenfolge verschieben.</li>
          <li>Private eigene Räume sehen andere erst, wenn du sie betrittst.</li>
        </ul>

        <ul class="help-list">
          <li>Klick auf einen Namen im Chat öffnet das kleine Menü.</li>
          <li><code>Flüstern</code> öffnet rechts das Flüsterfenster.</li>
          <li>Pfeil hoch und runter holt alte eigene Eingaben im Chat zurück.</li>
          <li><code>/roll 1w20</code>, <code>/roll 1w10</code> oder ähnliche Würfe sind für alle im Raum sichtbar.</li>
          <li>Beim Würfeln bleibt der Name in der eingestellten Farbe sichtbar.</li>
        </ul>

        <ul class="help-list">
          <li><code>/fl Name Nachricht</code> = flüstern</li>
          <li><code>/rw Raumname "Beschreibung"</code> = Raum wechseln</li>
          <li><code>/s</code> = eigenen Raum schließen oder öffnen</li>
          <li><code>/i Name</code> = einladen</li>
          <li><code>/rr Name</code> und <code>/rrw Name</code> = Rechte geben oder nehmen</li>
          <li><code>/werfen Name</code> = Person aus dem Raum werfen</li>
          <li><code>/log</code> startet ein Log, <code>/logoff</code> beendet es und verschickt es per E-Mail</li>
          <li><code>*Text*</code> = kursiv, <code>"Text"</code> = fett, <code>/me</code> = Emote</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "festspiele-rp-aushang") { %>
      <section class="panel help-section">
        <h2>Festspiele & RP-Aushang</h2>
        <p>Festspiele und RP-Aushang gehören zusammen, bleiben aber getrennte Funktionen.</p>

        <ul class="help-list">
          <li>Es gibt <code>Eigene Festplays</code> und <code>Andere Festplays</code>.</li>
          <li>Öffentliche Festspiele findest du oben über <code>Festspiele</code>.</li>
          <li>Im Tab <code>Allgemein</code> bearbeitest du Name, Beschreibung und Sichtbarkeit des gewählten Festspiels.</li>
          <li>Im Tab <code>Räume</code> legst du Festspiel-Räume an, sortierst sie und bearbeitest sie über <code>Räume bearbeiten</code> in einem neuen Tab.</li>
          <li>Im Tab <code>Bewerbungen & Spieler</code> verwaltest du Bewerbungen, Rechte und Spieler.</li>
          <li>Bewerber können offene Bewerbungen selbst wieder zurückziehen.</li>
          <li>Nach Freischaltung kommt die Nachricht über den Brief als grüner System-Brief vom <code>System Administrator</code>.</li>
        </ul>

        <ul class="help-list">
          <li>Der Link <code>RP-Aushang</code> sitzt im Header und öffnet eine eigene Seite in einem neuen Tab.</li>
          <li>Der Aushang ist serverweit sichtbar.</li>
          <li><code>FREE-RP</code> und die dazugehörigen Festspiele teilen sich denselben Aushang.</li>
          <li><code>ERP</code> hat einen eigenen getrennten Aushang.</li>
          <li>Neue Einträge erscheinen dort live untereinander.</li>
          <li>Die Zahl am Link zählt neue Einträge live, bis du den Aushang öffnest.</li>
          <li>Eigene Einträge kannst du wieder löschen.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "gaestebuch-design-bbcode") { %>
      <section class="panel help-section">
        <h2>Gästebuch, Design & BBCode</h2>
        <p>Hier geht es um Gästebuch, Vorschau, Design und BBCode.</p>

        <ul class="help-list">
          <li><code>Charakter editieren</code> öffnet die Gästebuch-Bearbeitung.</li>
          <li>Die Vorschau zeigt das Gästebuch so, wie es später für andere aussieht.</li>
          <li>Wenn die Vorschau offen ist, übernimmt ein Neuladen auch den aktuellen Entwurfsstand.</li>
          <li>Farben, Design und Hintergründe werden pro Seite einzeln gespeichert.</li>
          <li>Nur die vorgefertigten Designs haben Verlauf. Eigene Farbwerte bleiben ohne Verlauf.</li>
          <li>Bilder innerhalb und außerhalb des Rahmens funktionieren über Bild-URL und Transparenz.</li>
          <li>Private Einträge sehen nur du, der Besitzer und Admins.</li>
          <li>Das Briefsymbol zeigt neue Gästebuch- oder Systemnachrichten. Grüne Briefe stehen für Systemnachrichten.</li>
        </ul>

        <div class="help-example-grid">
          <% (helpBbcodeExamples || []).forEach((entry) => { %>
            <article class="help-example-card">
              <h3><%= entry.title %></h3>
              <div class="help-example-split">
                <code class="help-example-code"><%= entry.code %></code>
                <div class="help-example-preview guestbook-entry-body"><%- entry.preview_html %></div>
              </div>
            </article>
          <% }) %>
        </div>

        <ul class="help-list">
          <li>Über <code>Schreiben als</code> wählst du den Absender.</li>
          <li><code>[center]Text[/center]</code> schreibt den Text mittig.</li>
          <li>Mit Backslashes wie <code>\[center\]Text\[/center\]</code> zeigst du BBCode nur als Text.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "backup") { %>
      <section class="panel help-section">
        <h2>Backup</h2>
        <p>Hier findest du gelöschte Charaktere zur Wiederherstellung.</p>

        <ul class="help-list">
          <li>Den Link <code>Backup</code> findest du nur im Bereich mit Charakterauswahl vor <code>Live Updates</code>.</li>
          <li>Er öffnet eine eigene Seite in einem neuen Tab.</li>
          <li>Dort werden nur gelöschte Charaktere angezeigt.</li>
          <li>Mit dem Button vor dem <code>X</code> stellst du den Charakter wieder her.</li>
          <li>Dabei kommen Gästebuch, Farben, Seiten und Gästebucheinträge zurück.</li>
          <li>Mit dem <code>X</code> löschst du das Backup endgültig.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "staff-sicherheit") { %>
      <section class="panel help-section">
        <h2>Staff & Sicherheit</h2>
        <p>Hier geht es um sichtbare Staff-Namen und den automatischen Logout.</p>

        <ul class="help-list">
          <li>Admins und Moderatoren wählen ihren sichtbaren Rollennamen über einen Charakter.</li>
          <li>Dafür setzt du im Charakter <code>Als Admin-Charakter</code> oder <code>Als Moderator-Charakter</code> und speicherst.</li>
          <li>Admins sind farbig sichtbar, Moderatoren tragen <code>(M)</code>.</li>
        </ul>

        <ul class="help-list">
          <li>Normale Nutzer werden bei Inaktivität automatisch ausgeloggt.</li>
          <li>Nach 29 Minuten 45 Sekunden erscheint eine Warnung mit 15 Sekunden Countdown.</li>
          <li>Scrollen, Tippen und Eingaben zählen als Aktivität.</li>
          <li>Nur klicken oder nur Tab-Wechsel zählen nicht.</li>
          <li>Admins und Moderatoren sind vom Auto-Logoff ausgenommen.</li>
        </ul>
      </section>
    <% } %>
  <% } %>
</section>

<%- include("partials/end") %>
