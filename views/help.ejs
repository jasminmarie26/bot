<%- include("partials/start") %>

<section class="help-layout">
  <% if (!helpTopic) { %>
    <section class="panel help-intro">
      <div class="header-line">
        <div>
          <h1>Hilfe</h1>
          <p class="muted">Kurz, direkt und pro Thema nur das Wichtigste.</p>
        </div>
      </div>

      <p>W&auml;hle ein Thema. Die Hilfe bleibt bewusst kurz.</p>
    </section>

    <section class="panel help-link-panel">
      <h2>Themen</h2>
      <nav class="help-topic-links" aria-label="Hilfethemen">
        <% (helpTopics || []).forEach((topic) => { %>
          <a class="help-topic-link" href="/help/<%= topic.slug %>"><%= topic.title %></a>
        <% }) %>
      </nav>
    </section>
  <% } else { %>
    <section class="panel help-intro">
      <div class="header-line">
        <div>
          <h1><%= helpTopic.title %></h1>
          <p class="muted">Kurz erkl&auml;rt. Ohne lange Texte.</p>
        </div>
      </div>

      <a class="help-topic-link" href="/help">Zur Themen&uuml;bersicht</a>
    </section>

    <% if (helpTopic.slug === "charakter-anlegen") { %>
      <section class="panel help-section">
        <h2>Charakter anlegen</h2>
        <p>Neue Charaktere erstellst du im RP-Bereich.</p>
        <ul class="help-list">
          <li>Im Dashboard <code>Rollenspiel</code> &ouml;ffnen.</li>
          <li><code>Rollenspiel - Free</code> oder <code>Rollenspiel - Erotik</code> w&auml;hlen.</li>
          <li>Auf <code>+ Charakter</code> klicken.</li>
          <li>Daten eintragen und speichern.</li>
          <li>Danach kannst du Chat, R&auml;ume und G&auml;stebuch nutzen.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "raumliste-raeume") { %>
      <section class="panel help-section">
        <h2>Raumliste &amp; R&auml;ume</h2>
        <p>Die Raumliste findest du auf der Charakterseite.</p>
        <ul class="help-list">
          <li><code>Gemeinsamer Treffpunkt</code> = fester Standardraum.</li>
          <li><code>Raumliste</code> zeigt alle R&auml;ume des Bereichs.</li>
          <li>Ein Schloss bedeutet: Raum ist abgeschlossen.</li>
          <li>Eigene private R&auml;ume sehen nur du.</li>
          <li>Mehr dazu steht im Thema <code>Eigene R&auml;ume</code>.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "eigene-raeume") { %>
      <section class="panel help-section">
        <h2>Eigene R&auml;ume</h2>
        <p>Eigene R&auml;ume sind private R&auml;ume nur f&uuml;r deinen Account.</p>

        <h3>Kurz so geht&apos;s</h3>
        <ul class="help-list">
          <li>Oben rechts <code>Eigenen Raum erstellen/editieren</code> &ouml;ffnen.</li>
          <li>Raumnamen eintragen und speichern.</li>
          <li>Der Raum erscheint unter <code>Eigene R&auml;ume</code>.</li>
          <li>Ein Klick auf den Namen &ouml;ffnet den Raum.</li>
        </ul>

        <h3>Wichtig</h3>
        <ul class="help-list">
          <li>Der Raum ist nur f&uuml;r dich sichtbar.</li>
          <li>Er bleibt gespeichert, bis du ihn l&ouml;schst.</li>
          <li>Bilder f&uuml;gst du per BBCode in die Beschreibung ein.</li>
          <li>Ein Schloss bedeutet: Raum ist abgeschlossen.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "festspiele-anlegen") { %>
      <section class="panel help-section">
        <h2>Festspiele anlegen</h2>
        <p>Festspiele sind ein eigener Bereich. Sie sind getrennt von privaten R&auml;umen.</p>

        <h3>Start</h3>
        <ul class="help-list">
          <li>Oben rechts <code>Meine Festplays</code> &ouml;ffnen.</li>
          <li>Dort legst du neue Festspiele an.</li>
          <li>&Ouml;ffentliche Festspiele findest du oben &uuml;ber <code>Festspiele</code>.</li>
        </ul>

        <h3>Verwalten</h3>
        <ul class="help-list">
          <li>Es gibt <code>Eigene Festplays</code> und <code>Andere Festplays</code>.</li>
          <li>Im Tab <code>Allgemein</code> bearbeitest du Sichtbarkeit und Beschreibung.</li>
          <li>Die Beschreibung unterst&uuml;tzt dieselben BBCodes wie das G&auml;stebuch.</li>
          <li>Ein Festspiel bleibt auf dem Server, auf dem es erstellt wurde.</li>
        </ul>

        <h3>Im Dashboard</h3>
        <ul class="help-list">
          <li>Unter <code>Rollenspiel</code> sind Charaktere und Festspiele getrennt sichtbar.</li>
          <li>Festspiel-Charaktere lassen sich in den normalen Bereich und zur&uuml;ck schieben.</li>
          <li><code>Bewerbungen &amp; Spieler</code> regelt Freischaltungen und Rechte.</li>
        </ul>

        <h3>&Ouml;ffentlich</h3>
        <ul class="help-list">
          <li>Im &ouml;ffentlichen Bereich siehst du nur sichtbare Festspiele.</li>
          <li><code>Bewerben</code> schickt eine Anfrage mit deinem aktuellen Charakter.</li>
          <li>Nach Freigabe erscheint das Festspiel auch in deiner &Uuml;bersicht.</li>
          <li>Unter 18 bleibt <code>ERP</code> gesperrt.</li>
        </ul>

        <h3>Wichtig</h3>
        <ul class="help-list">
          <li>Festspiele ersetzen keine privaten R&auml;ume.</li>
          <li>Festspiele mit aktiven Charakteren lassen sich nicht einfach l&ouml;schen.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "gaestebuch-design-bbcode") { %>
      <section class="panel help-section">
        <h2>G&auml;stebuch Design &amp; BBCode</h2>
        <p>Unten siehst du kurze BBCode-Beispiele direkt mit Vorschau.</p>

        <div class="help-example-grid">
          <% (helpBbcodeExamples || []).forEach((entry) => { %>
            <article class="help-example-card">
              <h3><%= entry.title %></h3>
              <div class="help-example-split">
                <code class="help-example-code"><%= entry.code %></code>
                <div class="help-example-preview guestbook-entry-body"><%- entry.preview_html %></div>
              </div>
            </article>
          <% }) %>
        </div>

        <ul class="help-list">
          <li><code>Charakter editieren</code> &ouml;ffnet die G&auml;stebuch-Bearbeitung.</li>
          <li>&Uuml;ber <code>Schreiben als</code> w&auml;hlst du den Absender.</li>
          <li><code>Privater Eintrag</code> sehen nur du, Besitzer und Admins.</li>
          <li>Das Briefsymbol zeigt neue Eintr&auml;ge.</li>
          <li>Mit Backslashes zeigst du BBCode nur als Text.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "auto-logoff") { %>
      <section class="panel help-section">
        <h2>Auto-Logoff</h2>
        <p>Normale Nutzer werden bei Inaktivit&auml;t automatisch ausgeloggt.</p>

        <h3>Ablauf</h3>
        <ul class="help-list">
          <li>Nach 29 Minuten 45 Sekunden erscheint eine Warnung.</li>
          <li>Danach laufen 15 Sekunden herunter.</li>
          <li><code>Abbrechen</code> h&auml;lt dich eingeloggt.</li>
          <li>Ohne Reaktion folgt der Logout.</li>
        </ul>

        <h3>Aktivit&auml;t</h3>
        <ul class="help-list">
          <li>Scrollen, Tippen und Eingaben z&auml;hlen.</li>
          <li>Nur klicken z&auml;hlt nicht.</li>
          <li>Nur Tab-Wechsel z&auml;hlt nicht.</li>
        </ul>

        <h3>Ausnahme</h3>
        <ul class="help-list">
          <li>Admins sind ausgeschlossen.</li>
          <li>Moderatoren sind ausgeschlossen.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "admin-moderatorname") { %>
      <section class="panel help-section">
        <h2>Admin- und Moderatorname</h2>
        <p>Staff w&auml;hlt den sichtbaren Rollennamen &uuml;ber einen Charakter.</p>
        <ul class="help-list">
          <li>Charakter &ouml;ffnen.</li>
          <li><code>Als Admin-Charakter</code> oder <code>Als Moderator-Charakter</code> setzen.</li>
          <li>Speichern.</li>
          <li>Admins sind farbig, Moderatoren tragen <code>(M)</code>.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "chat-fluestern") { %>
      <section class="panel help-section">
        <h2>Chat &amp; Fl&uuml;stern</h2>
        <p>Die wichtigsten Chatfunktionen in Kurzform.</p>

        <h3>Direkt im Chat</h3>
        <ul class="help-list">
          <li>Klick auf einen Namen &ouml;ffnet das kleine Men&uuml;.</li>
          <li>Die Sprechblase &ouml;ffnet Fl&uuml;stern.</li>
          <li>Die Zahl an der Sprechblase zeigt neue Nachrichten.</li>
          <li>Verl&auml;ufe bleiben bis zum Raumwechsel sichtbar.</li>
        </ul>

        <h3>Wichtige Befehle</h3>
        <ul class="help-list">
          <li><code>/fl Name Nachricht</code> = fl&uuml;stern.</li>
          <li><code>/rw Raumname "Beschreibung"</code> = Raum wechseln.</li>
          <li><code>/s</code> = eigenen Raum schlie&szlig;en oder &ouml;ffnen.</li>
          <li><code>/i Name</code> = einladen.</li>
          <li><code>/rr Name</code> = Rechte geben, <code>/rrw Name</code> = Rechte entfernen.</li>
          <li><code>/werfen Name</code> = Person aus dem Raum werfen.</li>
        </ul>

        <h3>Logs</h3>
        <ul class="help-list">
          <li><code>/log</code> startet ein Chat-Log.</li>
          <li><code>/logoff</code> beendet es und verschickt es per E-Mail.</li>
          <li>Wenn alle gehen, endet das Log automatisch.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "chat-formatierung") { %>
      <section class="panel help-section">
        <h2>Chat-Formatierung</h2>
        <p>Diese Kurzbefehle funktionieren direkt im Chat.</p>
        <ul class="help-list">
          <li><code>*Text*</code> = kursiv</li>
          <li><code>"Text"</code> = fett</li>
          <li><code>""Text""</code> = fett ohne sichtbare Zusatzzeichen</li>
          <li><code>/me betritt den Raum</code> = Emote</li>
          <li><code>/me betritt den Raum "Hallo"</code> = Emote mit fetter Rede</li>
        </ul>
      </section>
    <% } %>
  <% } %>
</section>

<%- include("partials/end") %>
