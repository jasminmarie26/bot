<%- include("partials/start") %>

<section class="help-layout">
  <% if (!helpTopic) { %>
    <section class="panel help-intro">
      <div class="header-line">
        <div>
          <h1>Hilfe</h1>
          <p class="muted">Waehle ein Thema aus. Die Erklaerung wird im selben Fenster geoeffnet.</p>
        </div>
      </div>

      <p>
        Hier findest du die Themen als Uebersicht. Nach einem Klick wird nur das gewaehlte Thema geladen.
      </p>
    </section>

    <section class="panel help-link-panel">
      <h2>Themen</h2>
      <nav class="help-topic-links" aria-label="Hilfethemen">
        <% (helpTopics || []).forEach((topic) => { %>
          <a class="help-topic-link" href="/help/<%= topic.slug %>"><%= topic.title %></a>
        <% }) %>
      </nav>
    </section>
  <% } else { %>
    <section class="panel help-intro">
      <div class="header-line">
        <div>
          <h1><%= helpTopic.title %></h1>
          <p class="muted">Ein einzelnes Hilfethema im selben Fenster.</p>
        </div>
      </div>

      <a class="help-topic-link" href="/help">Zur Themenuebersicht</a>
    </section>

    <% if (helpTopic.slug === "charakter-anlegen") { %>
      <section class="panel help-section">
        <h2>Charakter anlegen</h2>
        <p>Neue Charaktere legst du im Dashboard im jeweiligen Bereich an.</p>
        <ul class="help-list">
          <li><code>+ Charakter</code> im Bereich <code>Free - RP</code> oder <code>ERP</code> anklicken.</li>
          <li>Server, Festplay, Name und optional Avatar eintragen.</li>
          <li>Nach dem Speichern landest du direkt im Charakterbereich und kannst Raeume oder das Gaestebuch nutzen.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "raumliste-raeume") { %>
      <section class="panel help-section">
        <h2>Raumliste & Raeume</h2>
        <p>Auf der Charakterseite findest du die gesamte Raumliste fuer den jeweiligen Bereich.</p>
        <ul class="help-list">
          <li><code>Raumname</code> und <code>Raumbeschreibung</code> oben ausfuellen.</li>
          <li><code>Raum anlegen</code> erstellt einen neuen serverweiten Raum.</li>
          <li><code>Gemeinsamer Treffpunkt</code> sind feste Standardraeume.</li>
          <li>Unter <code>Free RP</code> siehst du alle angelegten Raeume darunter aufgelistet.</li>
          <li>Ein kleines Schloss vor dem Raumnamen zeigt: Dieser Raum ist gerade abgeschlossen.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "gaestebuch-design-bbcode") { %>
      <section class="panel help-section">
        <h2>Gaestebuch Design & BBCode</h2>
        <p>
          Im Gaestebuch kannst du Texte formatieren, Farben setzen und einfache Layouts bauen.
          Unten siehst du jeweils den Code und direkt daneben eine Vorschau.
        </p>

        <div class="help-example-grid">
          <% (helpBbcodeExamples || []).forEach((entry) => { %>
            <article class="help-example-card">
              <h3><%= entry.title %></h3>
              <div class="help-example-split">
                <code class="help-example-code"><%= entry.code %></code>
                <div class="help-example-preview guestbook-entry-body"><%- entry.preview_html %></div>
              </div>
            </article>
          <% }) %>
        </div>

        <ul class="help-list">
          <li>Ueber <code>Charakter editieren</code> kommst du in die Gaestebuch-Bearbeitung.</li>
          <li>Dort findest du auch die BBCode-Hilfe direkt noch einmal eingeblendet.</li>
          <li>Farben, Gradients und Schriften kannst du dort frei kombinieren.</li>
          <li>Wenn du einen BBCode-Tag nur als Text zeigen willst, schreibe ihn mit Backslashes: <code>\[center\]Text\[/center\]</code>.</li>
          <li>Wenn jemand auf irgendeinen deiner Charaktere schreibt, erscheint oben ein Brief-Symbol.</li>
          <li>Ein Klick auf den Brief oeffnet direkt das passende Gaestebuch mit dem neuen Eintrag.</li>
          <li>Ueber <code>Schreiben als</code> waehlst du, welcher deiner Charaktere den Eintrag hinterlaesst.</li>
          <li>Mit <code>Privater Eintrag</code> sehen nur du, der Besitzer und Admins diesen Eintrag.</li>
          <li>Ein Klick auf den Absendernamen oeffnet dessen Gaestebuch, damit du direkt zurueckschreiben kannst.</li>
          <li>Deine eigenen Eintraege in fremden Gaestebuechern kannst du spaeter bearbeiten oder loeschen.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "admin-moderatorname") { %>
      <section class="panel help-section">
        <h2>Admin- und Moderatorname</h2>
        <p>Admins und Moderatoren setzen ihren sichtbaren Rollennamen direkt ueber einen Charakter.</p>
        <ul class="help-list">
          <li>Gewuenschten Charakter oeffnen.</li>
          <li><code>Als Admin-Charakter verwenden</code> oder <code>Als Moderator-Charakter verwenden</code> anhaken.</li>
          <li><code>Rollenname speichern</code> klicken.</li>
          <li>Admins werden mit Farbverlauf hervorgehoben, Moderatoren mit <code>(M)</code>.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "chat-fluestern") { %>
      <section class="panel help-section">
        <h2>Chat & Fluestern</h2>
        <p>Im Chat siehst du links die Online-Charaktere und rechts den Verlauf.</p>
        <ul class="help-list">
          <li>Die Glocke oben schaltet den Eintrittston an oder aus.</li>
          <li>Ein Klick auf einen Namen links oeffnet Gaestebuch oder Fluesterfenster.</li>
          <li>Beim Designwechsel bleibst du im Raum und die laufenden Nachrichten bleiben sichtbar.</li>
          <li><code>/s</code> schaltet einen selbst erstellten Raum um: einmal eingeben schliesst ihn, das naechste Mal oeffnet ihn wieder.</li>
          <li>Danach erscheint kursiv <code>Der Raum wurde abgeschlossen.</code> oder <code>Der Raum wurde geoeffnet.</code></li>
          <li>Abgeschlossene Raeume zeigen ein Schloss in der Raumliste und koennen von anderen nicht betreten werden.</li>
          <li><code>/log</code> startet ein Chat-Log. In benutzererstellten Raeumen darf das nur der Ersteller nutzen, Admins und Moderatoren duerfen es ueberall.</li>
          <li>Beim Start erscheint kursiv die Systemmeldung <code>Log wurde gestartet.</code></li>
          <li><code>/logoff</code> beendet das Log wieder. Danach wird es per E-Mail an alle gesendet, die waehrenddessen im Raum waren.</li>
          <li>Beim Beenden erscheint kursiv die Systemmeldung <code>Log wurde beendet.</code></li>
          <li>Das Log wird zuerst mit PDF- und Word-Anhang verschickt. Wenn der Mailserver das nicht akzeptiert, gibt es automatisch einen Fallback auf nur PDF oder notfalls nur die E-Mail selbst.</li>
          <li>Formatierungen wie kursiv, fett, Emotes und farblich hervorgehobene Namen werden im Log uebernommen.</li>
          <li>Wenn alle den Raum verlassen, endet ein aktives Log automatisch und wird ebenfalls per E-Mail verschickt.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "chat-formatierung") { %>
      <section class="panel help-section">
        <h2>Chat-Formatierung</h2>
        <p>Im Chat gibt es eine einfache Schnellformatierung direkt beim Schreiben.</p>
        <ul class="help-list">
          <li><code>*Text*</code> = kursiv</li>
          <li><code>"Text"</code> = fett</li>
          <li><code>""Text""</code> = ebenfalls fett, ohne dass die zusaetzlichen Anfuehrungszeichen sichtbar bleiben</li>
          <li><code>/me betritt den Raum</code> = Emote, der Charaktername steht ohne Doppelpunkt davor und die ganze Aktion ist kursiv</li>
          <li><code>/me betritt den Raum "Hallo"</code> = Emote kursiv, <code>Hallo</code> darin fett</li>
          <li><code>*Kommt heute an "Hallo"*</code> = alles kursiv, <code>Hallo</code> darin fett</li>
        </ul>
      </section>
    <% } %>
  <% } %>
</section>

<%- include("partials/end") %>
