<%- include("partials/start") %>

<section class="help-layout">
  <% if (!helpTopic) { %>
    <section class="panel help-intro">
      <div class="header-line">
        <div>
          <h1>Hilfe</h1>
          <p class="muted">W&auml;hle ein Thema aus. Die Erkl&auml;rung wird im selben Fenster ge&ouml;ffnet.</p>
        </div>
      </div>

      <p>
        Hier findest du die Themen als &Uuml;bersicht. Nach einem Klick wird nur das gew&auml;hlte Thema geladen.
      </p>
    </section>

    <section class="panel help-link-panel">
      <h2>Themen</h2>
      <nav class="help-topic-links" aria-label="Hilfethemen">
        <% (helpTopics || []).forEach((topic) => { %>
          <a class="help-topic-link" href="/help/<%= topic.slug %>"><%= topic.title %></a>
        <% }) %>
      </nav>
    </section>
  <% } else { %>
    <section class="panel help-intro">
      <div class="header-line">
        <div>
          <h1><%= helpTopic.title %></h1>
          <p class="muted">Ein einzelnes Hilfethema im selben Fenster.</p>
        </div>
      </div>

      <a class="help-topic-link" href="/help">Zur Themen&uuml;bersicht</a>
    </section>

    <% if (helpTopic.slug === "charakter-anlegen") { %>
      <section class="panel help-section">
        <h2>Charakter anlegen</h2>
        <p>Neue Charaktere legst du direkt im Dashboard im passenden Rollenspiel-Bereich an.</p>
        <ul class="help-list">
          <li>Im Dashboard den Klappbereich <code>Rollenspiel</code> &ouml;ffnen.</li>
          <li>Dort <code>Rollenspiel - Free</code> oder <code>Rollenspiel - Erotik</code> anklicken.</li>
          <li>Die passende &Uuml;bersicht &ouml;ffnet sich direkt im selben Fenster.</li>
          <li>Dort auf <code>+ Charakter</code> klicken.</li>
          <li>Server, Festplay, Name und optional Avatar eintragen.</li>
          <li>Nach dem Speichern landest du direkt im Charakterbereich und kannst R&auml;ume oder das G&auml;stebuch nutzen.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "raumliste-raeume") { %>
      <section class="panel help-section">
        <h2>Raumliste &amp; R&auml;ume</h2>
        <p>Auf der Charakterseite findest du die gesamte Raumliste f&uuml;r den jeweiligen Bereich.</p>
        <ul class="help-list">
          <li><code>Gemeinsamer Treffpunkt</code> sind feste Standardr&auml;ume.</li>
          <li>&Uuml;ber <code>Raumliste</code> kommst du immer zur &Uuml;bersicht der R&auml;ume deines Bereichs.</li>
          <li>Ein kleines Schloss vor dem Raumnamen zeigt: Dieser Raum ist gerade abgeschlossen.</li>
          <li>Eigene private R&auml;ume werden nicht f&uuml;r andere Nutzer angezeigt.</li>
          <li>F&uuml;r die genaue Anleitung zu privaten R&auml;umen gibt es das eigene Hilfethema <code>Eigene R&auml;ume</code>.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "eigene-raeume") { %>
      <section class="panel help-section">
        <h2>Eigene R&auml;ume</h2>
        <p>Eigene R&auml;ume sind gespeicherte Privatr&auml;ume, die nur dein eigener Account in der Raumliste sieht.</p>

        <h3>Anleitung</h3>
        <ul class="help-list">
          <li>Den Punkt findest du im Benutzermen&uuml; oben rechts, direkt unter <code>Charakter editieren</code> als <code>Eigenen Raum erstellen/editieren</code>.</li>
          <li>Dieser Men&uuml;punkt ist in der Raumliste und auch direkt im Chat sichtbar.</li>
          <li>Deinen gew&uuml;nschten Raumnamen eingeben und <code>Raum anlegen</code> klicken.</li>
          <li>Danach bleibst du auf derselben Seite und der neue Raum erscheint direkt darunter im Bereich <code>Eigene R&auml;ume</code>.</li>
          <li>Ein Klick auf den angezeigten Namen &ouml;ffnet den Raum.</li>
        </ul>

        <h3>Wichtig</h3>
        <ul class="help-list">
          <li>Eigene R&auml;ume bleiben gespeichert, bis du sie l&ouml;schst oder nicht mehr nutzt.</li>
          <li>Sie sind nur f&uuml;r den Nutzer sichtbar, der sie selbst angelegt hat.</li>
          <li>Der Raumname ist an deinen eigenen Account gebunden. Derselbe private Raumname wird nicht als fremde Kopie f&uuml;r andere Nutzer angelegt.</li>
          <li>F&uuml;r eigene R&auml;ume gibt es keinen separaten Bild-Upload mehr.</li>
          <li>Wenn du ein Bild im Raum zeigen willst, f&uuml;ge es in <code>Beschreibung im Raum</code> per BBCode ein, zum Beispiel <code>[img]https://beispiel.de/bild.jpg[/img]</code>.</li>
          <li>Die passende Formatierung findest du jederzeit &uuml;ber die <a href="/help/gaestebuch-design-bbcode">BBCode-Hilfe</a>.</li>
          <li>Ein kleines Schloss vor dem Raumnamen zeigt: Dieser Raum ist gerade abgeschlossen.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "festspiele-anlegen") { %>
      <section class="panel help-section">
        <h2>Festspiele anlegen</h2>
        <p>Festspiele haben einen eigenen Bereich und sind von den privaten R&auml;umen getrennt.</p>

        <h3>So findest du den Bereich</h3>
        <ul class="help-list">
          <li>Im Benutzermen&uuml; oben rechts findest du den Punkt <code>Meine Festplays</code>.</li>
          <li>Ein Klick darauf &ouml;ffnet den Bereich <code>Festspiele erstellen</code> in einem neuen Tab.</li>
          <li>Auf der Raumliste siehst du darunter auch den Klappbereich <code>Meine Festspiele</code>.</li>
          <li>Die dort angezeigten Namen sieht nur der Account, der die Festspiele selbst erstellt hat.</li>
          <li>Oben in der Navigation steht neben <code>Mitglieder</code> jetzt auch der Punkt <code>Festspiele</code>.</li>
          <li>Dort werden nur Festspiele gezeigt, bei denen im Tab <code>Allgemein</code> das H&auml;kchen <code>&Ouml;ffentlich</code> gesetzt wurde.</li>
        </ul>

        <h3>Erstellen und bearbeiten</h3>
        <ul class="help-list">
          <li>Oben gibt es die Tabs <code>Eigene Festplays</code> und <code>Andere Festplays</code>.</li>
          <li>Unter <code>Eigene Festplays</code> siehst du nur die Festspiele, die du selbst auf diesem Server erstellt hast.</li>
          <li>Unter <code>Andere Festplays</code> siehst du die Festspiele anderer Spieler, in denen einer deiner Charaktere auf diesem Server eingetragen ist.</li>
          <li>Unten gibst du zuerst nur den <code>Festspielname (neu anlegen)</code> ein und speicherst.</li>
          <li>Danach taucht das Festspiel oben in deiner Liste auf.</li>
          <li>Ein Klick auf den Namen &ouml;ffnet die Festspiel-&Uuml;bersicht im neuen Tab direkt auf diesem Eintrag.</li>
          <li>Im Tab <code>Allgemein</code> kannst du <code>&Ouml;ffentlich</code> und die <code>Festplay Beschreibung</code> pflegen.</li>
          <li>Direkt neben <code>Festplay Beschreibung</code> findest du einen Link zur <code>BBCode-Hilfe</code>.</li>
          <li>In der Festplay Beschreibung kannst du dieselben BBCode-Tags wie im G&auml;stebuch verwenden.</li>
          <li>Jedes Festspiel bleibt auf dem Server, auf dem du es erstellt hast, und kann nicht auf den anderen RP-Server verschoben werden.</li>
          <li>Das Dashboard zeigt dir den Klappbereich <code>Rollenspiel</code> und darunter den separaten <code>LARP Bereich</code>.</li>
          <li>Im Klappbereich <code>Rollenspiel</code> findest du die Links <code>Rollenspiel - Free</code> und <code>Rollenspiel - Erotik</code>.</li>
          <li>Ein Klick darauf &ouml;ffnet die passende &Uuml;bersicht mit Charakteren und Festspielen direkt im selben Fenster.</li>
          <li>Eigene Festspiele erscheinen dort ebenfalls als eigene Kachel, verkn&uuml;pft mit dem Charakter, mit dem du sie erstellt hast.</li>
          <li>Darunter gibt es den Bereich <code>Meine Festspiele</code>, in dem die Festspiele als eigene Kacheln nebeneinander stehen, solange genug Platz da ist.</li>
          <li>Liegt ein Festspiel-Charakter gerade auf diesem RP-Server, taucht er oben zus&auml;tzlich auch in der normalen Charakter-Liste dieses Bereichs auf.</li>
          <li>Beim Verschieben &ouml;ffnet sich eine Auswahl, ob der Charakter nach <code>Free RP</code> oder <code>ERP</code> soll.</li>
          <li>Wird ein Festspiel-Charakter auf den anderen RP-Server gelegt, bleibt in der urspr&uuml;nglichen Festspiel-Kachel eine ausgegraute, nicht anklickbare Kopie des Namens stehen.</li>
          <li>Freischaltungen an Festspielen bleiben beim Serverwechsel erhalten.</li>
          <li>In den Festspiel-Listen und in der Detailansicht wird immer der Ersteller-Charakter angezeigt, nicht der Accountname.</li>
          <li>Im Tab <code>Bewerbungen &amp; Spieler</code> siehst du, wie viele Mitspieler und Charaktere aktuell zu diesem Festspiel geh&ouml;ren.</li>
          <li>Dort kannst du offene Bewerbungen freischalten, &uuml;ber einen Charakternamen Rechte vergeben und bestehende Rechte wieder entfernen.</li>
          <li>Mit <code>Speichern</code> werden die &Auml;nderungen direkt in diesem Festspiel aktualisiert.</li>
        </ul>

        <h3>&Ouml;ffentliche Festspiele</h3>
        <ul class="help-list">
          <li>Im &ouml;ffentlichen Bereich <code>Festspiele</code> siehst du eine alphabetisch sortierte &Uuml;bersicht aller sichtbaren Festspiele anderer Spieler.</li>
          <li>Dort werden bewusst nur die Namen gezeigt, damit die &Uuml;bersicht kompakt bleibt.</li>
          <li>Ein Klick auf den Namen &ouml;ffnet das jeweilige Festspiel in einem neuen Tab.</li>
          <li>In der Detailansicht siehst du nur die <code>Festplay Beschreibung</code> und direkt darunter den Bewerbungsbereich.</li>
          <li>&Uuml;ber <code>Bewerben</code> schickst du mit deinem aktuellen Charakter eine Anfrage an den Ersteller, wenn noch keine Bewerbung von dir offen ist.</li>
          <li>Nur der Ersteller dieses Festspiels kann die Bewerbung sp&auml;ter im Tab <code>Bewerbungen &amp; Spieler</code> freischalten.</li>
          <li>Nach der Freischaltung erscheint in der passenden Dashboard-&Uuml;bersicht eine eigene Festspiel-Kachel mit dem Festspielnamen und deinem freigeschalteten Charakter.</li>
          <li>Auch diese Kachel steht dort im Bereich <code>Meine Festspiele</code> unter den normalen Charakteren.</li>
          <li>Liegt der freigeschaltete Charakter auf diesem RP-Server, steht er zus&auml;tzlich auch oben in der normalen Charakter-Liste derselben Bereichsseite.</li>
          <li>Auch freigeschaltete Festspiel-Charaktere bleiben weiterhin f&uuml;r ihr Festspiel freigeschaltet und k&ouml;nnen &uuml;ber die Zielauswahl zwischen <code>Free RP</code> und <code>ERP</code> verschoben werden.</li>
          <li>Ist dein Account unter 18, bleibt <code>ERP</code> dabei gesperrt und es erscheint eine Meldung.</li>
        </ul>

        <h3>Wichtig</h3>
        <ul class="help-list">
          <li>Festspiele sind kein Ersatz f&uuml;r private R&auml;ume und werden getrennt verwaltet.</li>
          <li>Wenn ein Festspiel noch von Charakteren verwendet wird, kannst du es nicht einfach l&ouml;schen.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "gaestebuch-design-bbcode") { %>
      <section class="panel help-section">
        <h2>G&auml;stebuch Design &amp; BBCode</h2>
        <p>
          Im G&auml;stebuch kannst du Texte formatieren, Farben setzen und einfache Layouts bauen.
          Unten siehst du jeweils den Code und direkt daneben eine Vorschau.
        </p>

        <div class="help-example-grid">
          <% (helpBbcodeExamples || []).forEach((entry) => { %>
            <article class="help-example-card">
              <h3><%= entry.title %></h3>
              <div class="help-example-split">
                <code class="help-example-code"><%= entry.code %></code>
                <div class="help-example-preview guestbook-entry-body"><%- entry.preview_html %></div>
              </div>
            </article>
          <% }) %>
        </div>

        <ul class="help-list">
          <li>&Uuml;ber <code>Charakter editieren</code> kommst du in die G&auml;stebuch-Bearbeitung.</li>
          <li>Dort findest du auch die BBCode-Hilfe direkt noch einmal eingeblendet.</li>
          <li>Farben, Gradients und Schriften kannst du dort frei kombinieren.</li>
          <li>Wenn du einen BBCode-Tag nur als Text zeigen willst, schreibe ihn mit Backslashes: <code>\[center\]Text\[/center\]</code>.</li>
          <li>Wenn jemand auf irgendeinen deiner Charaktere schreibt, erscheint oben ein Brief-Symbol.</li>
          <li>Ein Klick auf den Brief &ouml;ffnet direkt das passende G&auml;stebuch mit dem neuen Eintrag.</li>
          <li>&Uuml;ber <code>Schreiben als</code> w&auml;hlst du, welcher deiner Charaktere den Eintrag hinterl&auml;sst.</li>
          <li>Mit <code>Privater Eintrag</code> sehen nur du, der Besitzer und Admins diesen Eintrag.</li>
          <li>Ein Klick auf den Absendernamen &ouml;ffnet dessen G&auml;stebuch, damit du direkt zur&uuml;ckschreiben kannst.</li>
          <li>Deine eigenen Eintr&auml;ge in fremden G&auml;steb&uuml;chern kannst du sp&auml;ter bearbeiten oder l&ouml;schen.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "admin-moderatorname") { %>
      <section class="panel help-section">
        <h2>Admin- und Moderatorname</h2>
        <p>Admins und Moderatoren setzen ihren sichtbaren Rollennamen direkt &uuml;ber einen Charakter.</p>
        <ul class="help-list">
          <li>Gew&uuml;nschten Charakter &ouml;ffnen.</li>
          <li><code>Als Admin-Charakter verwenden</code> oder <code>Als Moderator-Charakter verwenden</code> anhaken.</li>
          <li><code>Rollenname speichern</code> klicken.</li>
          <li>Admins werden mit Farbverlauf hervorgehoben, Moderatoren mit <code>(M)</code>.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "chat-fluestern") { %>
      <section class="panel help-section">
        <h2>Chat &amp; Fl&uuml;stern</h2>
        <p>Im Chat siehst du links die Online-Charaktere und rechts den Verlauf. Die wichtigsten Funktionen sind hier nach Themen sortiert.</p>

        <h3>Direkt im Chat</h3>
        <ul class="help-list">
          <li>Die Glocke oben schaltet den Eintrittston an oder aus.</li>
          <li>Ein Klick auf einen Namen links &ouml;ffnet das kleine Men&uuml; f&uuml;r G&auml;stebuch oder Fl&uuml;stern.</li>
          <li>Fl&uuml;stern &ouml;ffnet kein Extra-Fenster mehr. Neben dem Briefkasten sitzt eine Sprechblase.</li>
          <li>Das Fl&uuml;sterfeld geht nur auf, wenn du direkt auf die Sprechblase klickst.</li>
          <li>Die Zahl an der Sprechblase zeigt neue Fl&uuml;sternachrichten und verschwindet, sobald du die Sprechblase &ouml;ffnest.</li>
          <li>Wenn du bei einem Namen auf Fl&uuml;stern klickst, wird das Gespr&auml;ch vorbereitet, aber nicht automatisch aufgeklappt.</li>
          <li>Die Verl&auml;ufe bleiben sichtbar, bis du den Raum verl&auml;sst.</li>
          <li><code>/fl Name Nachricht</code> = fl&uuml;stert direkt aus dem Chat. Die Nachricht landet danach im Verlauf unter der Sprechblase.</li>
          <li>Bei Namen mit Leerzeichen geht auch <code>/fl "Charaktername" Nachricht</code>.</li>
          <li>Das Fl&uuml;stern geht serverweit, also auch wenn die Person gerade in einem anderen Raum ist. Es funktioniert aber nur auf demselben Server.</li>
          <li>Beim Designwechsel bleibst du im Raum und die laufenden Nachrichten bleiben sichtbar.</li>
        </ul>

        <h3>Raum wechseln &amp; verwalten</h3>
        <ul class="help-list">
          <li><code>/rw Raumname "Beschreibung"</code> = Raum wechseln. <strong>Raumname</strong> ist der Name des Zielraums, die Angabe in Anf&uuml;hrungszeichen ist die Beschreibung und optional.</li>
          <li>Beispiel: <code>/rw Taverne "Wir suchen Leute"</code></li>
          <li><code>/s</code> schaltet einen selbst erstellten Raum um: einmal eingeben schlie&szlig;t ihn, das n&auml;chste Mal &ouml;ffnet ihn wieder.</li>
          <li>Danach erscheint kursiv <code>Der Raum wurde abgeschlossen.</code> oder <code>Der Raum wurde ge&ouml;ffnet.</code></li>
          <li>Abgeschlossene R&auml;ume zeigen ein Schloss in der Raumliste und k&ouml;nnen von anderen nicht betreten werden.</li>
        </ul>

        <h3>Einladen, Rechte &amp; Werfen</h3>
        <ul class="help-list">
          <li><code>/i Charaktername</code> = Person in deinen aktuellen Raum einladen. Bei Namen mit Leerzeichen geht auch <code>/i "Charaktername"</code>.</li>
          <li>Die eingeladene Person bekommt ein Fenster mit Haken zum Annehmen und X zum Ablehnen. Du bekommst danach im Chat direkt die R&uuml;ckmeldung.</li>
          <li><code>/rr Charaktername</code> = Raumrechte f&uuml;r den aktuellen Raum vergeben. Das kann nur der Raumbesitzer.</li>
          <li><code>/rrw Charaktername</code> = Raumrechte wieder entziehen. <code>/rw</code> bleibt weiter f&uuml;r Raum wechseln reserviert.</li>
          <li><code>/werfen Charaktername</code> = Person aus dem aktuellen Raum werfen. Das d&uuml;rfen der Raumbesitzer und Personen mit Raumrechten.</li>
          <li>Wichtig: Personen mit Raumrechten k&ouml;nnen den Raumbesitzer nicht werfen.</li>
          <li>Personen mit Raumrechten k&ouml;nnen die Raumfunktionen wie Schloss, Log, Einladungen und Werfen mitverwenden.</li>
        </ul>

        <h3>Logs</h3>
        <ul class="help-list">
          <li><code>/log</code> startet ein Chat-Log. In benutzererstellten R&auml;umen d&uuml;rfen das der Raumbesitzer und Personen mit Raumrechten, Admins und Moderatoren d&uuml;rfen es &uuml;berall.</li>
          <li>Beim Start erscheint kursiv die Systemmeldung <code>Log wurde gestartet.</code></li>
          <li><code>/logoff</code> beendet das Log wieder. Danach wird es per E-Mail an alle gesendet, die w&auml;hrenddessen im Raum waren.</li>
          <li>Beim Beenden erscheint kursiv die Systemmeldung <code>Log wurde beendet.</code></li>
          <li>Das Log wird zuerst mit PDF- und Word-Anhang verschickt. Wenn der Mailserver das nicht akzeptiert, gibt es automatisch einen Fallback auf nur PDF oder notfalls nur die E-Mail selbst.</li>
          <li>Formatierungen wie kursiv, fett, Emotes und farblich hervorgehobene Namen werden im Log &uuml;bernommen.</li>
          <li>Wenn alle den Raum verlassen, endet ein aktives Log automatisch und wird ebenfalls per E-Mail verschickt.</li>
        </ul>
      </section>
    <% } %>

    <% if (helpTopic.slug === "chat-formatierung") { %>
      <section class="panel help-section">
        <h2>Chat-Formatierung</h2>
        <p>Im Chat gibt es eine einfache Schnellformatierung direkt beim Schreiben.</p>
        <ul class="help-list">
          <li><code>*Text*</code> = kursiv</li>
          <li><code>"Text"</code> = fett</li>
          <li><code>""Text""</code> = ebenfalls fett, ohne dass die zus&auml;tzlichen Anf&uuml;hrungszeichen sichtbar bleiben</li>
          <li><code>/me betritt den Raum</code> = Emote, der Charaktername steht ohne Doppelpunkt davor und die ganze Aktion ist kursiv</li>
          <li><code>/me betritt den Raum "Hallo"</code> = Emote kursiv, <code>Hallo</code> darin fett</li>
          <li><code>*Kommt heute an "Hallo"*</code> = alles kursiv, <code>Hallo</code> darin fett</li>
        </ul>
      </section>
    <% } %>
  <% } %>
</section>

<%- include("partials/end") %>
