<%- include("../partials/start", { hideTopbar: true, pageClass: "page-roomlist" }) %>

<section class="rp-shell">
  <% const roomlistDisplayName = currentUserDisplayName || (currentUser ? currentUser.display_name || currentUser.username : character.name); %>
  <% const roomlistAccountDisplayName = currentUserAccountName || (currentUser ? currentUser.username : character.name); %>
  <% const roomlistIdentityRoleStyle = currentHeaderCharacter && currentUser && currentUser.is_admin && Number(currentUser.admin_character_id) === Number(currentHeaderCharacter.id)
    ? "admin"
    : currentHeaderCharacter && currentUser && currentUser.is_moderator && Number(currentUser.moderator_character_id) === Number(currentHeaderCharacter.id)
      ? "moderator"
      : (currentHeaderCharacter ? "" : (currentUserDisplayRoleStyle || "")); %>
  <% const roomlistIdentityName = currentHeaderCharacter?.name || roomlistDisplayName; %>
  <% const roomlistIdentityColor = currentHeaderCharacter?.chat_text_color || currentUser?.display_chat_text_color || ""; %>
  <% const roomlistLiveUpdatesInitialRevision = String(latestSiteUpdateRevisionToken || "").trim(); %>
  <% const roomlistLiveUpdatesInitialRevisions = Array.isArray(recentSiteUpdateRevisions)
    ? recentSiteUpdateRevisions
    : []; %>
  <% const showRoomlistHeaderIdentity = Boolean(currentUser && roomlistIdentityName); %>
  <% const roomlistHeaderIdentityHref = currentUser?.is_admin
    ? "/admin"
    : currentUser?.is_moderator
      ? "/staff"
      : ""; %>
  <% const roomlistHeaderIdentityTitle = currentUser?.is_admin
    ? "Adminbereich im neuen Tab öffnen"
    : currentUser?.is_moderator
      ? "Moderatorenbereich im neuen Tab öffnen"
      : roomlistIdentityName; %>
  <% const isLarpCharacterView = character.server_id === "larp"; %>
  <% const roomlistAreaHref =
    isLarpCharacterView
      ? "/dashboard/larp"
      : character.server_id === "free-rp" || character.server_id === "erp"
        ? "/dashboard"
        : "#roomlist"; %>
  <% const roomlistAreaLabel =
    isLarpCharacterView
      ? "LARP-Bereich"
      : character.server_id === "free-rp" || character.server_id === "erp"
        ? "Charakterliste"
        : "Raumliste"; %>
  <% const roomlistBoardServerId = currentHeaderCharacter?.server_id || character.server_id; %>
  <% const roomlistBoardCharacterId = isOwner ? character.id : (currentHeaderCharacter ? currentHeaderCharacter.id : 0); %>
  <% const roomlistBoardHref = `/rp-board?server_id=${roomlistBoardServerId}&character_id=${Number(roomlistBoardCharacterId)}`; %>
  <% const formatRoomlistRoleName = (value) => String(value || "").replace(/\s*\(M\)\s*$/i, "").trim(); %>
  <% const formatRoomlistBirthdayName = (entry) => {
    const label = formatRoomlistRoleName(entry?.name || "");
    if (!label) return "";
    return entry?.show_birthday_cake ? `${String.fromCodePoint(0x1F382)} ${label}` : label;
  }; %>
  <header class="rp-topline">
    <a class="rp-logo" href="/">Heldenhafte Reisen</a>
      <nav class="rp-menu" aria-label="Charakter Navigation">
        <a href="<%= roomlistAreaHref %>"><%= roomlistAreaLabel %></a>
        <a href="/members" target="_blank" rel="noopener noreferrer">Mitglieder</a>
        <% if (character.server_id === "free-rp" || character.server_id === "erp") { %>
          <a
            href="/characters/<%= character.id %>/festplays/public"
            target="_blank"
            rel="noopener noreferrer"
            data-live-character-href-template="/characters/__CHARACTER_ID__/festplays/public"
          >Festspiele</a>
        <% } %>
        <% if (!isLarpCharacterView) { %>
          <a
            class="rp-board-nav-link"
            href="<%= roomlistBoardHref %>"
            target="_blank"
            rel="noopener noreferrer"
            data-rp-board-link-root
            data-live-character-href-template="/rp-board?server_id=__SERVER_ID__&character_id=__CHARACTER_ID__"
            data-rp-board-server-id="<%= roomlistBoardServerId %>"
            data-rp-board-festplay-id="0"
            data-rp-board-character-id="<%= Number(roomlistBoardCharacterId) %>"
          >
            <span>RP-Aushang</span>
            <span class="rp-board-nav-badge" data-rp-board-badge hidden>1</span>
          </a>
        <% } %>
        <a
          class="live-updates-nav-link"
        href="/live-updates"
        target="site-live-updates"
        data-live-updates-link-root
        data-live-updates-target="site-live-updates"
        data-live-updates-initial-revision="<%= roomlistLiveUpdatesInitialRevision %>"
        data-live-updates-initial-revisions="<%= roomlistLiveUpdatesInitialRevisions.join('|') %>"
      >
        <span>Live Updates</span>
        <span class="live-updates-nav-badge" data-live-updates-badge hidden>1</span>
      </a>
    </nav>
    <div class="rp-topline-actions">
      <% if (showRoomlistHeaderIdentity) { %>
        <% if (roomlistHeaderIdentityHref) { %>
          <a
            class="rp-header-identity rp-header-identity-link"
            data-header-identity
            href="<%= roomlistHeaderIdentityHref %>"
            target="_blank"
            rel="noopener noreferrer"
            title="<%= roomlistHeaderIdentityTitle %>"
            style="<%= roomlistIdentityColor ? `color:${roomlistIdentityColor};` : '' %>"
          ><%= roomlistIdentityName %></a>
        <% } else { %>
          <span
            class="rp-header-identity"
            data-header-identity
            title="<%= roomlistIdentityName %>"
            style="<%= roomlistIdentityColor ? `color:${roomlistIdentityColor};` : '' %>"
          ><%= roomlistIdentityName %></span>
        <% } %>
      <% } %>
      <form method="POST" action="/settings/theme" class="inline-form theme-form">
        <label for="rp-theme-select-roomlist">Design</label>
        <input type="hidden" name="return_to" value="<%= currentPath || '/' %>" />
        <select
          id="rp-theme-select-roomlist"
          name="theme"
          class="theme-select"
        >
          <% availableThemes.forEach((theme) => { %>
            <option value="<%= theme.id %>" <%= activeTheme === theme.id ? "selected" : "" %>>
              <%= theme.label %>
            </option>
          <% }) %>
        </select>
      </form>
      <div class="rp-topline-quick-actions">
        <%- include("../partials/guestbook-notification-link") %>
        <details class="rp-user-menu">
          <summary
            class="rp-user-menu-toggle"
            aria-label="Benutzermen&uuml; &ouml;ffnen"
            title="Benutzermen&uuml;"
          >
            <span class="rp-user-menu-toggle-icon" aria-hidden="true">&#128100;</span>
          </summary>
          <div class="rp-user-menu-panel">
        <div class="rp-user-menu-meta">
          <strong class="<%= roomlistIdentityRoleStyle ? `role-name-${roomlistIdentityRoleStyle}` : "" %>"><%= roomlistIdentityName %></strong>
          <% if (roomlistAccountDisplayName && roomlistAccountDisplayName !== roomlistIdentityName) { %>
            <span>Konto: <%= roomlistAccountDisplayName %></span>
          <% } %>
          <% if (characterCreatedAtLabel) { %>
            <span>Charakter erstellt: <%= characterCreatedAtLabel %></span>
          <% } %>
          <% if (Array.isArray(publicBirthdayRows)) { %>
            <% publicBirthdayRows.forEach((entry) => { %>
              <span><%= entry.label %>: <%= entry.value %></span>
            <% }) %>
          <% } %>
          <span data-live-character-server-label>Server: <%= character.server_id === "larp" ? "LARP" : (character.server_id === "erp" ? "ERP" : "FREE-RP") %></span>
        </div>

        <nav class="rp-user-menu-links" aria-label="Benutzermen&uuml;">
          <a href="/account" target="_blank" rel="noopener noreferrer">Account</a>
          <a href="/dashboard" target="_blank" rel="noopener noreferrer">Serverliste</a>
          <% if (isOwner) { %>
            <a
              href="/characters/<%= character.id %>/edit"
              target="_blank"
              rel="noopener noreferrer"
              data-live-character-href-template="/characters/__CHARACTER_ID__/edit"
            >
              Charakter editieren
            </a>
          <% } %>
          <a
            href="/characters/<%= character.id %>/guestbook"
            target="_blank"
            rel="noopener noreferrer"
            data-live-character-href-template="/characters/__CHARACTER_ID__/guestbook"
          >G&auml;stebuch</a>
          <% if (isOwner && !isLarpCharacterView) { %>
            <a
              href="/characters/<%= character.id %>/rooms/new"
              target="_blank"
              rel="noopener noreferrer"
              data-live-character-href-template="/characters/__CHARACTER_ID__/rooms/new"
            >
              Raum erstellen/editieren
            </a>
          <% } %>
          <% if (character.server_id === "free-rp" || character.server_id === "erp") { %>
            <a
              href="/characters/<%= character.id %>/festplays"
              target="_blank"
              rel="noopener noreferrer"
              data-live-character-href-template="/characters/__CHARACTER_ID__/festplays"
            >Meine Festplays</a>
          <% } %>
          <a href="/help" target="_blank" rel="noopener noreferrer">Hilfe</a>
        </nav>

        <form method="POST" action="/logout" class="inline-form rp-user-menu-form">
          <button type="submit" class="rp-user-menu-logout">Logout</button>
        </form>
          </div>
        </details>
      </div>
    </div>
  </header>

  <section class="rp-room-panel" id="roomlist">
    <% if (isOwner && currentUser && (currentUser.is_admin || currentUser.is_moderator)) { %>
      <form method="POST" action="/characters/<%= character.id %>/role-character" class="rp-role-character-form">
        <fieldset class="gb-role-character-box">
          <legend>Rollenname</legend>
          <% if (currentUser.is_admin) { %>
            <label class="gb-role-character-option">
              <input
                type="checkbox"
                name="use_as_admin_character"
                value="1"
                <%= Number(currentUser.admin_character_id) === Number(character.id) ? "checked" : "" %>
              />
              Als Admin-Charakter verwenden
            </label>
          <% } %>
          <% if (currentUser.is_moderator) { %>
            <label class="gb-role-character-option">
              <input
                type="checkbox"
                name="use_as_moderator_character"
                value="1"
                <%= Number(currentUser.moderator_character_id) === Number(character.id) ? "checked" : "" %>
              />
              Als Moderator-Charakter verwenden
            </label>
          <% } %>
          <p class="gb-role-character-hint muted">
            Der markierte Charakter wird dann als sichtbarer Rollenname auf der Startseite, im Menü und im Chat verwendet.
          </p>
          <button class="btn btn-secondary rp-role-character-submit" type="submit">Rollenname speichern</button>
        </fieldset>
      </form>
    <% } %>

    <div class="rp-room-list-wrap">
      <% if (isLarpCharacterView) { %>
        <section class="rp-room-section rp-room-section-standard">
          <p class="muted">Dieser LARP-Charakter l&auml;uft getrennt vom RP- und ERP-Server. R&auml;ume, Festplays und RP-Aushang sind hier nicht verkn&uuml;pft.</p>
        </section>
      <% } %>

      <% if (isOwner && !isLarpCharacterView) { %>
        <details class="rp-room-section rp-room-section-standard rp-room-accordion" open>
          <summary class="rp-room-section-summary">
            <span>Meine R&auml;ume</span>
          </summary>
          <div class="rp-room-section-divider" aria-hidden="true"></div>
          <% if (!ownedRooms || !ownedRooms.length) { %>
            <p class="muted">Noch keine eigenen R&auml;ume vorhanden.</p>
          <% } else { %>
            <div class="rp-room-list rp-room-list-owned<%= Number(character.festplay_id) > 0 && String(character.festplay_dashboard_mode || '').trim().toLowerCase() === 'festplay' ? ' rp-room-list-owned-compact' : '' %>">
              <% ownedRooms.forEach((room) => { %>
                <% const activeUsers = Array.isArray(roomUsers?.[room.id]) ? roomUsers[room.id] : []; %>
                <div class="rp-room-standard-card rp-room-custom-card">
                  <div class="rp-room-custom-titleline">
                    <span
                      class="rp-room-lock-indicator<%= room.is_locked ? ' is-visible' : '' %>"
                      data-room-lock-target
                      data-room-lock-room="<%= room.id %>"
                      data-room-lock-server="<%= character.server_id %>"
                      aria-hidden="<%= room.is_locked ? 'false' : 'true' %>"
                      title="Raum ist abgeschlossen"
                    ><svg class="room-lock-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                      <path class="room-lock-fill" d="M12 3.7a4.45 4.45 0 0 0-4.45 4.45v1.92c0 .18-.06.35-.16.5l-1.31 2a1.08 1.08 0 0 0 .91 1.67h10.02a1.08 1.08 0 0 0 .91-1.67l-1.31-2c-.1-.15-.16-.32-.16-.5V8.15A4.45 4.45 0 0 0 12 3.7Z"/>
                      <path d="M8.1 10.02V8.35a3.9 3.9 0 1 1 7.8 0v1.67"/>
                      <rect x="6.35" y="10.02" width="11.3" height="9.28" rx="2.15" ry="2.15"/>
                      <path d="M12 13.15v2.8"/>
                    </svg></span>
                    <a
                      class="rp-room-custom-link<%= room.can_enter ? '' : ' is-disabled' %>"
                      href="<%= room.can_enter ? `/chat?room_id=${room.id}&character_id=${character.id}` : '#' %>"
                      title="<%= room.can_enter ? 'Raum betreten' : 'Raum ist abgeschlossen' %>"
                      data-room-link-target
                      data-room-link-room="<%= room.id %>"
                      data-room-link-server="<%= character.server_id %>"
                      data-room-link-url="/chat?room_id=<%= room.id %>&character_id=<%= character.id %>"
                      aria-disabled="<%= room.can_enter ? 'false' : 'true' %>"
                    ><%= room.name %></a>
                  </div>
                  <% if (room.description) { %>
                    <div class="rp-room-custom-description">
                      <%= room.description %>
                    </div>
                  <% } %>
                  <% if (!room.hide_owned_room_users) { %>
                    <div
                      class="rp-room-occupants"
                      data-room-watch-target
                      data-room-watch-room="<%= room.id %>"
                      data-room-watch-server="<%= character.server_id %>"
                    >
                      <% if (activeUsers.length) { %>
                        <% activeUsers.forEach((entry, index) => { %>
                          <% if (entry.character_id) { %>
                            <a
                              class="rp-room-occupant <%= entry.has_room_rights ? 'has-room-rights ' : '' %><%= entry.role_style ? `role-name-${entry.role_style}` : '' %><%= entry.is_afk ? ' is-afk' : '' %>"
                              href="/characters/<%= entry.character_id %>/guestbook"
                            ><% if (entry.is_afk) { %><span class="rp-room-afk-clock" aria-hidden="true">&#9687;</span><% } %><%= formatRoomlistBirthdayName(entry) %></a>
                          <% } else { %>
                            <span
                              class="rp-room-occupant <%= entry.has_room_rights ? 'has-room-rights ' : '' %><%= entry.role_style ? `role-name-${entry.role_style}` : '' %><%= entry.is_afk ? ' is-afk' : '' %>"
                            ><% if (entry.is_afk) { %><span class="rp-room-afk-clock" aria-hidden="true">&#9687;</span><% } %><%= formatRoomlistBirthdayName(entry) %></span>
                          <% } %>
                          <% if (index < activeUsers.length - 1) { %>
                            <span class="rp-room-occupant-separator">, </span>
                          <% } %>
                        <% }) %>
                      <% } else { %>
                        <span class="muted">Gerade niemand dort.</span>
                      <% } %>
                    </div>
                  <% } %>
                </div>
              <% }) %>
            </div>
          <% } %>
        </details>
      <% } %>

      <% if (isOwner && !isLarpCharacterView) { %>
        <section class="rp-room-section rp-room-section-standard">
          <h2 class="rp-room-form-title">Raum erstellen</h2>
          <form
            method="POST"
            action="/characters/<%= character.id %>/enter-room"
            class="rp-room-form rp-room-form-inline"
          >
            <input type="hidden" name="return_to" value="roomlist" />
            <div class="rp-room-input">
              <span class="rp-room-icon" aria-hidden="true">&#128172;</span>
              <input
                name="room_name"
                maxlength="80"
                placeholder="Raumname"
                required
              />
            </div>
            <input
              name="room_description"
              maxlength="160"
              placeholder="Raumbeschreibung"
            />
            <button type="submit" class="rp-enter-btn">Raum erstellen</button>
          </form>
        </section>
      <% } %>

      <% if (standardRooms && standardRooms.length) { %>
        <details class="rp-room-section rp-room-section-standard rp-room-accordion" open>
          <summary class="rp-room-section-summary">
            <span>Gemeinsamer Treffpunkt</span>
          </summary>
          <div class="rp-room-section-divider" aria-hidden="true"></div>
            <div class="rp-room-list rp-room-list-standard">
              <% standardRooms.forEach((standardRoom) => { %>
                <% const activeUsers = Array.isArray(standardRoomUsers?.[standardRoom.id]) ? standardRoomUsers[standardRoom.id] : []; %>
                <% const visibleUsers = activeUsers.filter((entry) => entry && entry.is_npc !== true); %>
                <div class="rp-room-standard-card">
                  <a
                    class="rp-room-link rp-room-link-standard"
                    href="/chat?server=<%= character.server_id %>&standard_room=<%= standardRoom.id %>&character_id=<%= character.id %>"
                    title="Treffpunkt betreten"
                >
                  <span class="rp-room-link-name"><%= standardRoom.name %></span>
                  <div class="rp-room-link-meta">
                    <small><%= standardRoom.category || "Offplay" %></small>
                    <small><%= standardRoom.teaser %></small>
                  </div>
                </a>
                <div
                  class="rp-room-occupants"
                  data-room-watch-target
                  data-room-watch-room=""
                  data-room-watch-server="<%= character.server_id %>"
                  data-room-watch-standard-room="<%= standardRoom.id %>"
                >
                  <% if (visibleUsers.length) { %>
                    <% visibleUsers.forEach((entry, index) => { %>
                      <% if (entry.character_id) { %>
                        <a
                          class="rp-room-occupant <%= entry.has_room_rights ? 'has-room-rights ' : '' %><%= entry.role_style ? `role-name-${entry.role_style}` : '' %><%= entry.is_afk ? ' is-afk' : '' %>"
                          href="/characters/<%= entry.character_id %>/guestbook"
                        ><% if (entry.is_afk) { %><span class="rp-room-afk-clock" aria-hidden="true">&#9687;</span><% } %><%= formatRoomlistBirthdayName(entry) %></a>
                      <% } else { %>
                        <span
                          class="rp-room-occupant <%= entry.has_room_rights ? 'has-room-rights ' : '' %><%= entry.role_style ? `role-name-${entry.role_style}` : '' %><%= entry.is_afk ? ' is-afk' : '' %>"
                        ><% if (entry.is_afk) { %><span class="rp-room-afk-clock" aria-hidden="true">&#9687;</span><% } %><%= formatRoomlistBirthdayName(entry) %></span>
                      <% } %>
                      <% if (index < visibleUsers.length - 1) { %>
                        <span class="rp-room-occupant-separator">, </span>
                      <% } %>
                    <% }) %>
                  <% } else { %>
                    <span class="muted">Gerade niemand dort.</span>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </details>
      <% } %>

      <% if (fantasyPublicRooms && fantasyPublicRooms.length) { %>
        <details class="rp-room-section rp-room-section-standard rp-room-accordion" open>
          <summary class="rp-room-section-summary">
            <span>Fantasy Räume</span>
          </summary>
          <div class="rp-room-section-divider" aria-hidden="true"></div>
          <div class="rp-room-list rp-room-list-stacked">
            <% fantasyPublicRooms.forEach((room) => { %>
              <% const activeUsers = Array.isArray(publicRoomUsers?.[room.id]) ? publicRoomUsers[room.id] : []; %>
              <% const visibleUsers = activeUsers.filter((entry) => entry && entry.is_npc !== true); %>
              <div class="rp-room-standard-card rp-room-custom-card">
                <div class="rp-room-custom-titleline">
                  <span
                    class="rp-room-lock-indicator<%= room.is_locked ? ' is-visible' : '' %>"
                    data-room-lock-target
                    data-room-lock-room="<%= room.id %>"
                    data-room-lock-server="<%= character.server_id %>"
                    aria-hidden="<%= room.is_locked ? 'false' : 'true' %>"
                    title="Raum ist abgeschlossen"
                  ><svg class="room-lock-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path class="room-lock-fill" d="M12 3.7a4.45 4.45 0 0 0-4.45 4.45v1.92c0 .18-.06.35-.16.5l-1.31 2a1.08 1.08 0 0 0 .91 1.67h10.02a1.08 1.08 0 0 0 .91-1.67l-1.31-2c-.1-.15-.16-.32-.16-.5V8.15A4.45 4.45 0 0 0 12 3.7Z"/>
                    <path d="M8.1 10.02V8.35a3.9 3.9 0 1 1 7.8 0v1.67"/>
                    <rect x="6.35" y="10.02" width="11.3" height="9.28" rx="2.15" ry="2.15"/>
                    <path d="M12 13.15v2.8"/>
                  </svg></span>
                  <a
                    class="rp-room-custom-link<%= room.can_enter ? '' : ' is-disabled' %>"
                    href="<%= room.can_enter ? `/chat?room_id=${room.id}&character_id=${character.id}` : '#' %>"
                    title="<%= room.can_enter ? 'Raum betreten' : 'Raum ist abgeschlossen' %>"
                    data-room-link-target
                    data-room-link-room="<%= room.id %>"
                    data-room-link-server="<%= character.server_id %>"
                    data-room-link-url="/chat?room_id=<%= room.id %>&character_id=<%= character.id %>"
                    aria-disabled="<%= room.can_enter ? 'false' : 'true' %>"
                  ><%= room.name %></a>
                </div>
                <% if (room.description) { %>
                  <div class="rp-room-custom-description">
                    <%= room.description %>
                  </div>
                <% } %>
                <div
                  class="rp-room-occupants"
                  data-room-watch-target
                  data-room-watch-room="<%= room.id %>"
                  data-room-watch-server="<%= character.server_id %>"
                >
                  <% if (visibleUsers.length) { %>
                    <% visibleUsers.forEach((entry, index) => { %>
                      <% if (entry.character_id) { %>
                        <a
                          class="rp-room-occupant <%= entry.has_room_rights ? 'has-room-rights ' : '' %><%= entry.role_style ? `role-name-${entry.role_style}` : '' %><%= entry.is_afk ? ' is-afk' : '' %>"
                          href="/characters/<%= entry.character_id %>/guestbook"
                        ><% if (entry.is_afk) { %><span class="rp-room-afk-clock" aria-hidden="true">&#9687;</span><% } %><%= formatRoomlistBirthdayName(entry) %></a>
                      <% } else { %>
                        <span
                          class="rp-room-occupant <%= entry.has_room_rights ? 'has-room-rights ' : '' %><%= entry.role_style ? `role-name-${entry.role_style}` : '' %><%= entry.is_afk ? ' is-afk' : '' %>"
                        ><% if (entry.is_afk) { %><span class="rp-room-afk-clock" aria-hidden="true">&#9687;</span><% } %><%= formatRoomlistBirthdayName(entry) %></span>
                      <% } %>
                      <% if (index < visibleUsers.length - 1) { %>
                        <span class="rp-room-occupant-separator">, </span>
                      <% } %>
                    <% }) %>
                  <% } else { %>
                    <span class="muted">Gerade niemand dort.</span>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </details>
      <% } %>

      <% if (publicRooms && publicRooms.length) { %>
        <details class="rp-room-section rp-room-section-standard rp-room-accordion" open>
          <summary class="rp-room-section-summary">
            <span><%= character.server_id === "erp" ? "ERP" : "Free RP" %></span>
          </summary>
          <div class="rp-room-section-divider" aria-hidden="true"></div>
          <div class="rp-room-list rp-room-list-stacked">
            <% publicRooms.forEach((room) => { %>
              <% const activeUsers = Array.isArray(publicRoomUsers?.[room.id]) ? publicRoomUsers[room.id] : []; %>
              <% const visibleUsers = activeUsers.filter((entry) => entry && entry.is_npc !== true); %>
              <div class="rp-room-standard-card rp-room-custom-card">
                <div class="rp-room-custom-titleline">
                  <span
                    class="rp-room-lock-indicator<%= room.is_locked ? ' is-visible' : '' %>"
                    data-room-lock-target
                    data-room-lock-room="<%= room.id %>"
                    data-room-lock-server="<%= character.server_id %>"
                    aria-hidden="<%= room.is_locked ? 'false' : 'true' %>"
                    title="Raum ist abgeschlossen"
                  ><svg class="room-lock-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path class="room-lock-fill" d="M12 3.7a4.45 4.45 0 0 0-4.45 4.45v1.92c0 .18-.06.35-.16.5l-1.31 2a1.08 1.08 0 0 0 .91 1.67h10.02a1.08 1.08 0 0 0 .91-1.67l-1.31-2c-.1-.15-.16-.32-.16-.5V8.15A4.45 4.45 0 0 0 12 3.7Z"/>
                    <path d="M8.1 10.02V8.35a3.9 3.9 0 1 1 7.8 0v1.67"/>
                    <rect x="6.35" y="10.02" width="11.3" height="9.28" rx="2.15" ry="2.15"/>
                    <path d="M12 13.15v2.8"/>
                  </svg></span>
                  <a
                    class="rp-room-custom-link<%= room.can_enter ? '' : ' is-disabled' %>"
                    href="<%= room.can_enter ? `/chat?room_id=${room.id}&character_id=${character.id}` : '#' %>"
                    title="<%= room.can_enter ? 'Raum betreten' : 'Raum ist abgeschlossen' %>"
                    data-room-link-target
                    data-room-link-room="<%= room.id %>"
                    data-room-link-server="<%= character.server_id %>"
                    data-room-link-url="/chat?room_id=<%= room.id %>&character_id=<%= character.id %>"
                    aria-disabled="<%= room.can_enter ? 'false' : 'true' %>"
                  ><%= room.name %></a>
                </div>
                <% if (room.description) { %>
                  <div class="rp-room-custom-description">
                    <%= room.description %>
                  </div>
                <% } %>
                <div
                  class="rp-room-occupants"
                  data-room-watch-target
                  data-room-watch-room="<%= room.id %>"
                  data-room-watch-server="<%= character.server_id %>"
                >
                  <% if (visibleUsers.length) { %>
                    <% visibleUsers.forEach((entry, index) => { %>
                      <% if (entry.character_id) { %>
                        <a
                          class="rp-room-occupant <%= entry.has_room_rights ? 'has-room-rights ' : '' %><%= entry.role_style ? `role-name-${entry.role_style}` : '' %><%= entry.is_afk ? ' is-afk' : '' %>"
                          href="/characters/<%= entry.character_id %>/guestbook"
                        ><% if (entry.is_afk) { %><span class="rp-room-afk-clock" aria-hidden="true">&#9687;</span><% } %><%= formatRoomlistBirthdayName(entry) %></a>
                      <% } else { %>
                        <span
                          class="rp-room-occupant <%= entry.has_room_rights ? 'has-room-rights ' : '' %><%= entry.role_style ? `role-name-${entry.role_style}` : '' %><%= entry.is_afk ? ' is-afk' : '' %>"
                        ><% if (entry.is_afk) { %><span class="rp-room-afk-clock" aria-hidden="true">&#9687;</span><% } %><%= formatRoomlistBirthdayName(entry) %></span>
                      <% } %>
                      <% if (index < visibleUsers.length - 1) { %>
                        <span class="rp-room-occupant-separator">, </span>
                      <% } %>
                    <% }) %>
                  <% } else { %>
                    <span class="muted">Gerade niemand dort.</span>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </details>
      <% } %>

      <% if (isOwner) { %>
        <% if (false && character.server_id === "erp" && ownedFestplays && ownedFestplays.length) { %>
          <details class="rp-room-section rp-room-section-standard rp-room-accordion">
            <summary class="rp-room-section-summary">
              <span>Meine Festspiele</span>
            </summary>
            <div class="rp-room-section-divider" aria-hidden="true"></div>
              <div class="rp-room-inline-list">
                <% ownedFestplays.forEach((festplay) => { %>
                  <a
                    class="rp-room-inline-item"
                    href="/characters/<%= character.id %>/festplays?selected_festplay=<%= festplay.id %>#festplay-selected-editor"
                    target="_blank"
                    rel="noopener noreferrer"
                    title="Festspiel im neuen Tab öffnen"
                  >
                    <span class="rp-room-inline-name"><%= festplay.name %></span>
                  </a>
                <% }) %>
              </div>
          </details>
        <% } %>
      <% } %>
    </div>
  </section>
</section>

<div
  data-server-presence="<%= character.server_id %>"
  data-active-character-id="<%= currentHeaderCharacter ? currentHeaderCharacter.id : '' %>"
  hidden
></div>
<script src="/server-presence.js?v=<%= staticAssetVersion %>"></script>

<%- include("../partials/end") %>
