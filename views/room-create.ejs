<%- include("partials/start", { hideTopbar: true, pageClass: "page-roomlist" }) %>

<section class="rp-shell">
  <% const roomcreateDisplayName = currentUserDisplayName || (currentUser ? currentUser.display_name || currentUser.username : character.name); %>
  <% const roomcreateAccountDisplayName = currentUserAccountName || (currentUser ? currentUser.username : character.name); %>
  <% const roomcreateIdentityRoleStyle = currentUser && currentUser.is_admin && Number(currentUser.admin_character_id) === Number(character.id)
    ? "admin"
    : currentUser && currentUser.is_moderator && Number(currentUser.moderator_character_id) === Number(character.id)
      ? "moderator"
      : (currentUserDisplayRoleStyle || ""); %>
  <% const roomcreateIdentityName = character.name || roomcreateDisplayName; %>
  <% const roomcreateIdentityColor = character.chat_text_color || currentUser?.display_chat_text_color || ""; %>
  <% const roomcreateLiveUpdatesInitialRevision = String(latestSiteUpdateRevisionToken || "").trim(); %>
  <% const roomcreateLiveUpdatesInitialRevisions = Array.isArray(recentSiteUpdateRevisions) ? recentSiteUpdateRevisions : []; %>
  <% const roomcreateHeaderIdentityHref = currentUser?.is_admin
    ? "/admin"
    : currentUser?.is_moderator
      ? "/staff"
      : ""; %>
  <% const roomcreateHeaderIdentityTitle = currentUser?.is_admin
    ? "Adminbereich im neuen Tab &ouml;ffnen"
    : currentUser?.is_moderator
      ? "Moderatorenbereich im neuen Tab &ouml;ffnen"
      : roomcreateIdentityName; %>

  <header class="rp-topline">
    <a class="rp-logo" href="/">Heldenhafte Reisen</a>
    <nav class="rp-menu" aria-label="Raum erstellen Navigation">
      <a href="<%= character.server_id === 'free-rp' || character.server_id === 'erp' ? `/dashboard/areas/${character.server_id}` : `/characters/${character.id}#roomlist` %>"><%= character.server_id === "free-rp" || character.server_id === "erp" ? "Serverliste" : "Raumliste" %></a>
      <a href="/members" target="_blank" rel="noopener noreferrer">Mitgliederliste</a>
      <a
        class="live-updates-nav-link"
        href="/live-updates"
        target="site-live-updates"
        data-live-updates-link-root
        data-live-updates-target="site-live-updates"
        data-live-updates-initial-revision="<%= roomcreateLiveUpdatesInitialRevision %>"
        data-live-updates-initial-revisions="<%= roomcreateLiveUpdatesInitialRevisions.join('|') %>"
      >
        <span>Live Updates</span>
        <span class="live-updates-nav-badge" data-live-updates-badge hidden>1</span>
      </a>
    </nav>
    <div class="rp-topline-actions">
      <% if (roomcreateHeaderIdentityHref) { %>
        <a
          class="rp-header-identity rp-header-identity-link"
          data-header-identity
          href="<%= roomcreateHeaderIdentityHref %>"
          target="_blank"
          rel="noopener noreferrer"
          title="<%- roomcreateHeaderIdentityTitle %>"
          style="<%= roomcreateIdentityColor ? `color:${roomcreateIdentityColor};` : '' %>"
        ><%= roomcreateIdentityName %></a>
      <% } else { %>
        <span
          class="rp-header-identity"
          data-header-identity
          title="<%= roomcreateIdentityName %>"
          style="<%= roomcreateIdentityColor ? `color:${roomcreateIdentityColor};` : '' %>"
        ><%= roomcreateIdentityName %></span>
      <% } %>
      <form method="POST" action="/settings/theme" class="inline-form theme-form">
        <label for="rp-theme-select-room-create">Design</label>
        <input type="hidden" name="return_to" value="<%= currentPath || '/' %>" />
        <select
          id="rp-theme-select-room-create"
          name="theme"
          class="theme-select"
        >
          <% availableThemes.forEach((theme) => { %>
            <option value="<%= theme.id %>" <%= activeTheme === theme.id ? "selected" : "" %>>
              <%= theme.label %>
            </option>
          <% }) %>
        </select>
      </form>
      <div class="rp-topline-quick-actions">
        <%- include("partials/guestbook-notification-link") %>
        <details class="rp-user-menu">
          <summary
            class="rp-user-menu-toggle"
            aria-label="Benutzermen&uuml; &ouml;ffnen"
            title="Benutzermen&uuml;"
          >
            <span class="rp-user-menu-toggle-icon" aria-hidden="true">&#128100;</span>
          </summary>
          <div class="rp-user-menu-panel">
        <div class="rp-user-menu-meta">
          <strong
            class="<%= roomcreateIdentityRoleStyle ? `role-name-${roomcreateIdentityRoleStyle}` : '' %>"
            style="<%= roomcreateIdentityColor ? `color:${roomcreateIdentityColor};` : '' %>"
          ><%= roomcreateIdentityName %></strong>
            <span>Charakter: <%= character.name %></span>
          <span>Server: <%= character.server_id === "erp" ? "ERP" : "FREE-RP" %></span>
        </div>

        <nav class="rp-user-menu-links" aria-label="Benutzermen&uuml;">
          <a href="/account">Account</a>
          <a href="/dashboard">Serverliste</a>
          <a href="/characters/<%= character.id %>/edit" target="_blank" rel="noopener noreferrer">Charakter editieren</a>
          <a href="/characters/<%= character.id %>/guestbook" target="_blank" rel="noopener noreferrer">G&auml;stebuch</a>
          <a href="/help" target="_blank" rel="noopener noreferrer">Hilfe</a>
        </nav>

        <form method="POST" action="/logout" class="inline-form rp-user-menu-form">
          <button type="submit" class="rp-user-menu-logout">Logout</button>
        </form>
          </div>
        </details>
      </div>
    </div>
  </header>

  <section class="rp-room-panel rp-room-panel-create" id="room-create">
    <div class="rp-room-create-header">
      <h1>Eigenen Raum erstellen</h1>
      <button
        class="btn rp-room-create-save"
        type="submit"
        form="<%= selectedRoom ? `room-editor-form-${selectedRoom.id}` : 'room-create-form' %>"
      >Speichern</button>
    </div>

    <section class="rp-room-create-list" aria-label="Eigene R&auml;ume">
      <% if (!ownedRooms || !ownedRooms.length) { %>
        <p class="muted">Noch keine eigenen R&auml;ume vorhanden.</p>
      <% } else { %>
        <div
          class="rp-room-manage-list rp-room-inline-list-sortable"
          data-owned-room-sort-list
          data-sort-endpoint="/characters/<%= character.id %>/rooms/reorder"
        >
          <% ownedRooms.forEach((room) => { %>
            <% const isSelectedRoom = selectedRoom && Number(selectedRoom.id) === Number(room.id); %>
            <div
              class="rp-room-manage-row rp-room-sort-card<%= isSelectedRoom ? ' is-active' : '' %>"
              data-room-sort-item
              data-room-id="<%= room.id %>"
              draggable="true"
              title="Mit der Maus verschieben"
            >
              <span class="rp-room-sort-handle" aria-hidden="true">&#8646;</span>
              <div class="rp-room-manage-main">
                <a
                  class="rp-room-inline-item rp-room-manage-link<%= isSelectedRoom ? ' is-active' : '' %>"
                  href="<%= isSelectedRoom ? `/characters/${character.id}/rooms/new#room-create` : `/characters/${character.id}/rooms/new?selected_room=${room.id}#room-selected-editor` %>"
                  title="<%= isSelectedRoom ? 'Raum schlie&szlig;en' : 'Raum ausw&auml;hlen' %>"
                  aria-current="<%= isSelectedRoom ? 'page' : 'false' %>"
                >
                  <span
                    class="rp-room-lock-indicator<%= room.is_locked ? ' is-visible' : '' %>"
                    aria-hidden="<%= room.is_locked ? 'false' : 'true' %>"
                    title="Raum ist abgeschlossen"
                  ><svg class="room-lock-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path class="room-lock-fill" d="M12 3.7a4.45 4.45 0 0 0-4.45 4.45v1.92c0 .18-.06.35-.16.5l-1.31 2a1.08 1.08 0 0 0 .91 1.67h10.02a1.08 1.08 0 0 0 .91-1.67l-1.31-2c-.1-.15-.16-.32-.16-.5V8.15A4.45 4.45 0 0 0 12 3.7Z"/>
                    <path d="M8.1 10.02V8.35a3.9 3.9 0 1 1 7.8 0v1.67"/>
                    <rect x="6.35" y="10.02" width="11.3" height="9.28" rx="2.15" ry="2.15"/>
                    <path d="M12 13.15v2.8"/>
                  </svg></span>
                  <span class="rp-room-inline-name"><%= room.name %></span>
                  <% if (room.description) { %>
                    <span class="rp-room-inline-teaser"> - [<%= room.description %>]</span>
                  <% } %>
                </a>
                <form
                  method="POST"
                  action="/characters/<%= character.id %>/rooms/<%= room.id %>/delete"
                  class="inline-form rp-room-delete-form"
                >
                  <button
                    class="rp-room-delete-btn"
                    type="submit"
                    aria-label="Raum <%= room.name %> l&ouml;schen"
                    title="Raum l&ouml;schen"
                  >X</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
        <p class="rp-room-editor-note rp-room-sort-status" data-room-sort-status <%= ownedRooms.length > 1 ? '' : 'hidden' %>>Mit der Maus ziehen, um die Reihenfolge zu ändern.</p>
      <% } %>
    </section>

    <% if (selectedRoom) { %>
      <section class="rp-room-editor" id="room-selected-editor" aria-label="Raumdetails">
        <div class="rp-room-editor-bar">
          <div class="rp-room-editor-title-wrap">
            <strong class="rp-room-editor-title"><%= selectedRoom.name %></strong>
            <% if (selectedRoom.description) { %>
              <span class="rp-room-inline-teaser"> - [<%= selectedRoom.description %>]</span>
            <% } %>
          </div>
          <a
            class="rp-room-editor-enter"
            href="/chat?room_id=<%= selectedRoom.id %>&character_id=<%= character.id %>"
          >Raum betreten</a>
        </div>

        <nav class="rp-room-editor-tabs" aria-label="Raum bearbeiten">
          <a
            class="rp-room-editor-tab is-active"
            href="/characters/<%= character.id %>/rooms/new?selected_room=<%= selectedRoom.id %>#room-selected-editor"
          >&Uuml;bersicht</a>
        </nav>

        <form
          id="room-editor-form-<%= selectedRoom.id %>"
          method="POST"
          action="/characters/<%= character.id %>/rooms/<%= selectedRoom.id %>/update"
          class="rp-room-editor-body"
        >
          <div class="rp-room-editor-checks">
            <label class="rp-room-editor-check">
              <input
                type="checkbox"
                name="is_locked"
                value="1"
                <%= selectedRoom.is_locked ? "checked" : "" %>
              />
              Raum abschlie&szlig;en
            </label>
            <label class="rp-room-editor-check">
              <input
                type="checkbox"
                name="email_log_enabled"
                value="1"
                <%= selectedRoom.email_log_enabled ? "checked" : "" %>
              />
              Log
            </label>
            <label class="rp-room-editor-check">
              <input
                type="checkbox"
                name="delete_room"
                value="1"
              />
              Raum l&ouml;schen
            </label>
          </div>

          <label class="rp-room-editor-field">
            <span class="rp-room-editor-field-label">Raumname</span>
            <input
              type="text"
              name="room_name"
              maxlength="80"
              placeholder="Raumname"
              value="<%= selectedRoom.name || '' %>"
              required
            />
          </label>

          <label class="rp-room-editor-field">
            <span class="rp-room-editor-field-label">Raumbeschreibung</span>
            <input
              type="text"
              name="room_description"
              maxlength="160"
              placeholder="Kurzer Text f&uuml;r die Raumliste"
              value="<%= selectedRoom.description || '' %>"
            />
          </label>

          <label class="rp-room-editor-field">
            <span class="rp-room-editor-field-label">
              Beschreibung im Raum
              <a
                class="rp-room-editor-help-link"
                href="/help/gaestebuch-design-bbcode"
                target="_blank"
                rel="noopener noreferrer"
              >BBCode-Hilfe</a>
            </span>
            <textarea
              name="room_teaser"
              rows="9"
              maxlength="160"
              placeholder="Dieser Text erscheint direkt im Raum"
            ><%= selectedRoom.teaser || '' %></textarea>
          </label>

          <div class="rp-room-editor-actions">
            <button type="submit" class="btn">Speichern</button>
          </div>
        </form>
      </section>
    <% } else if (ownedRooms && ownedRooms.length) { %>
      <section class="rp-room-editor rp-room-editor-placeholder" id="room-selected-editor" aria-label="Raumdetails">
        <div class="rp-room-editor-body">
          <p class="rp-room-editor-note">Klicke oben auf einen Raum, dann wird er hervorgehoben und hier ge&ouml;ffnet.</p>
        </div>
      </section>
    <% } %>

    <% if (!selectedRoom) { %>
      <form
        id="room-create-form"
        method="POST"
        action="/characters/<%= character.id %>/enter-room"
        class="rp-room-form"
      >
        <div class="rp-room-input">
          <span class="rp-room-icon" aria-hidden="true">&#128172;</span>
          <input
            id="room_name"
            name="room_name"
            maxlength="80"
            placeholder="Raumname (neu anlegen)"
            required
          />
        </div>
        <input
          name="room_description"
          maxlength="160"
          placeholder="Raumbeschreibung"
        />
      </form>
    <% } %>
  </section>
</section>

<script>
  (() => {
    const sortList = document.querySelector("[data-owned-room-sort-list]");
    if (!sortList) {
      return;
    }

    const statusNode = document.querySelector("[data-room-sort-status]");
    let draggedItem = null;
    let startOrder = "";

    const getItems = () => Array.from(sortList.querySelectorAll("[data-room-sort-item]"));
    const getOrder = () => getItems().map((item) => item.dataset.roomId || "").filter(Boolean).join(",");
    const clearDropMarkers = () => {
      getItems().forEach((item) => item.classList.remove("is-drop-target"));
    };

    const setStatus = (message, mode = "") => {
      if (!statusNode) {
        return;
      }
      statusNode.hidden = !message;
      statusNode.textContent = message;
      statusNode.classList.remove("is-success", "is-error");
      if (mode) {
        statusNode.classList.add(mode);
      }
    };

    const submitOrderFallback = (roomIds) => {
      const endpoint = sortList.dataset.sortEndpoint || "";
      if (!roomIds.length || !endpoint) {
        setStatus("Reihenfolge konnte nicht gespeichert werden.", "is-error");
        return;
      }

      const form = document.createElement("form");
      form.method = "POST";
      form.action = endpoint;
      form.hidden = true;

      const roomIdsInput = document.createElement("input");
      roomIdsInput.type = "hidden";
      roomIdsInput.name = "room_ids";
      roomIdsInput.value = JSON.stringify(roomIds);
      form.appendChild(roomIdsInput);

      document.body.appendChild(form);
      form.submit();
    };

    const saveOrder = async () => {
      const roomIds = getItems()
        .map((item) => item.dataset.roomId || "")
        .filter(Boolean);
      const endpoint = sortList.dataset.sortEndpoint || "";
      if (!roomIds.length || !endpoint) {
        return;
      }

      const body = new URLSearchParams();
      body.set("room_ids", JSON.stringify(roomIds));

      try {
        setStatus("Reihenfolge wird gespeichert...");
        const response = await fetch(endpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
            "X-Requested-With": "fetch"
          },
          credentials: "same-origin",
          body: body.toString()
        });

        if (!response.ok) {
          submitOrderFallback(roomIds);
          return;
        }

        setStatus("Reihenfolge gespeichert.", "is-success");
        window.setTimeout(() => {
          setStatus(getItems().length > 1 ? "Mit der Maus ziehen, um die Reihenfolge zu ändern." : "");
        }, 1600);
      } catch (error) {
        console.error("owned room order save failed", error);
        submitOrderFallback(roomIds);
      }
    };

    sortList.addEventListener("dragover", (event) => {
      if (!draggedItem) {
        return;
      }

      event.preventDefault();
      const targetItem = event.target.closest("[data-room-sort-item]");
      if (!targetItem || targetItem === draggedItem) {
        return;
      }

      clearDropMarkers();
      targetItem.classList.add("is-drop-target");
      const targetRect = targetItem.getBoundingClientRect();
      const insertBeforeTarget = event.clientX < targetRect.left + targetRect.width / 2;
      sortList.insertBefore(draggedItem, insertBeforeTarget ? targetItem : targetItem.nextSibling);
    });

    getItems().forEach((item) => {
      item.addEventListener("dragstart", (event) => {
        draggedItem = item;
        startOrder = getOrder();
        item.classList.add("is-dragging");
        if (event.dataTransfer) {
          event.dataTransfer.effectAllowed = "move";
          event.dataTransfer.setData("text/plain", item.dataset.roomId || "");
        }
      });

      item.addEventListener("drop", (event) => {
        if (!draggedItem) {
          return;
        }
        event.preventDefault();
      });

      item.addEventListener("dragend", () => {
        item.classList.remove("is-dragging");
        clearDropMarkers();
        const endOrder = getOrder();
        draggedItem = null;
        if (startOrder && endOrder && startOrder !== endOrder) {
          void saveOrder();
        }
      });
    });
  })();
</script>

<%- include("partials/end") %>
