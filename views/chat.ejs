<%- include("partials/start", { hideTopbar: true, activeCharacter, pageClass: "page-rp-screen page-chat" }) %>

<% const chatDisplayName = currentUserDisplayName || (currentUser ? currentUser.display_name || currentUser.username : "User"); %>
<% const chatAccountDisplayName = currentUserAccountName || (currentUser ? currentUser.username : "User"); %>
<% const chatIdentityRoleStyle = activeCharacter && currentUser && currentUser.is_admin && Number(currentUser.admin_character_id) === Number(activeCharacter.id)
  ? "admin"
  : activeCharacter && currentUser && currentUser.is_moderator && Number(currentUser.moderator_character_id) === Number(activeCharacter.id)
    ? "moderator"
    : (activeCharacter ? "" : (currentUserDisplayRoleStyle || "")); %>
<% const chatIdentityName = activeCharacter ? activeCharacter.name : chatDisplayName; %>
<% const chatIdentityColor = activeCharacter?.chat_text_color || currentUser?.display_chat_text_color || ""; %>
<% const chatLiveUpdatesInitialRevision = String(latestSiteUpdateRevisionToken || "").trim(); %>
<% const chatLiveUpdatesInitialRevisions = Array.isArray(recentSiteUpdateRevisions)
  ? recentSiteUpdateRevisions
  : []; %>
<% const showChatHeaderIdentity = Boolean(currentUser && chatIdentityName); %>
<% const chatHeaderIdentityHref = currentUser?.is_admin
  ? "/admin"
  : currentUser?.is_moderator
    ? "/staff"
    : ""; %>
<% const chatHeaderIdentityTitle = currentUser?.is_admin
  ? "Adminbereich im neuen Tab öffnen"
  : currentUser?.is_moderator
    ? "Moderatorenbereich im neuen Tab öffnen"
    : chatIdentityName; %>

<section class="rp-shell">
  <header class="rp-topline">
    <a class="rp-logo" href="/">Heldenhafte Reisen</a>
    <nav class="rp-menu" aria-label="Chat Navigation">
      <% if (activeCharacter) { %>
        <a href="/characters/<%= activeCharacter.id %>#roomlist">Raumliste</a>
      <% } else { %>
        <a href="/dashboard">Dashboard</a>
      <% } %>
      <a href="/members" target="_blank" rel="noopener noreferrer">Mitgliederliste</a>
      <a
        class="live-updates-nav-link"
        href="/live-updates"
        target="site-live-updates"
        data-live-updates-link-root
        data-live-updates-target="site-live-updates"
        data-live-updates-initial-revision="<%= chatLiveUpdatesInitialRevision %>"
        data-live-updates-initial-revisions="<%= chatLiveUpdatesInitialRevisions.join('|') %>"
      >
        <span>Live Updates</span>
        <span class="live-updates-nav-badge" data-live-updates-badge hidden>1</span>
      </a>
    </nav>
    <% if (showChatHeaderIdentity) { %>
      <% if (chatHeaderIdentityHref) { %>
        <a
          class="rp-header-identity rp-header-identity-link"
          data-header-identity
          href="<%= chatHeaderIdentityHref %>"
          target="_blank"
          rel="noopener noreferrer"
          title="<%= chatHeaderIdentityTitle %>"
          style="<%= chatIdentityColor ? `color:${chatIdentityColor};` : '' %>"
        ><%= chatIdentityName %></a>
      <% } else { %>
        <span
          class="rp-header-identity"
          data-header-identity
          title="<%= chatIdentityName %>"
          style="<%= chatIdentityColor ? `color:${chatIdentityColor};` : '' %>"
        ><%= chatIdentityName %></span>
      <% } %>
    <% } %>
    <form method="POST" action="/settings/theme" class="inline-form theme-form">
      <label for="rp-theme-select-chat">Design</label>
      <input type="hidden" name="return_to" value="<%= currentPath || '/' %>" />
      <select
        id="rp-theme-select-chat"
        name="theme"
        class="theme-select"
      >
        <% availableThemes.forEach((theme) => { %>
          <option value="<%= theme.id %>" <%= activeTheme === theme.id ? "selected" : "" %>>
            <%= theme.label %>
          </option>
        <% }) %>
      </select>
    </form>
    <%- include("partials/guestbook-notification-link") %>
    <button
      id="chat-sound-toggle"
      class="chat-sound-toggle"
      type="button"
      aria-pressed="true"
      aria-label="Raumton ausschalten"
      title="Raumton ausschalten"
    >
      <span id="chat-sound-toggle-icon" class="chat-sound-toggle-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path class="chat-bell-fill" d="M12 3.5a4.5 4.5 0 0 0-4.5 4.5v2.1c0 1.4-.42 2.76-1.22 3.91L4.9 16.1a1.1 1.1 0 0 0 .9 1.75h12.4a1.1 1.1 0 0 0 .9-1.75l-1.38-2.09a6.74 6.74 0 0 1-1.22-3.91V8A4.5 4.5 0 0 0 12 3.5Z"/>
          <path d="M12 3.5a4.5 4.5 0 0 0-4.5 4.5v2.1c0 1.4-.42 2.76-1.22 3.91L4.9 16.1a1.1 1.1 0 0 0 .9 1.75h12.4a1.1 1.1 0 0 0 .9-1.75l-1.38-2.09a6.74 6.74 0 0 1-1.22-3.91V8A4.5 4.5 0 0 0 12 3.5Z"/>
          <path d="M9.6 18.1a2.45 2.45 0 0 0 4.8 0"/>
        </svg>
      </span>
    </button>
    <details class="rp-user-menu">
      <summary
        class="rp-user-menu-toggle"
        aria-label="Benutzermen&uuml; &ouml;ffnen"
        title="Benutzermen&uuml;"
      >
        <span class="rp-user-menu-toggle-icon" aria-hidden="true">&#128100;</span>
      </summary>
      <div class="rp-user-menu-panel">
        <div class="rp-user-menu-meta">
          <strong
            class="<%= chatIdentityRoleStyle ? `role-name-${chatIdentityRoleStyle}` : "" %>"
            style="<%= chatIdentityColor ? `color:${chatIdentityColor};` : "" %>"
          ><%= chatIdentityName %></strong>
          <% if (chatAccountDisplayName && chatAccountDisplayName !== chatIdentityName) { %>
            <span>Konto: <%= chatAccountDisplayName %></span>
          <% } %>
          <% if (currentUser) { %>
            <span>Account Nr.: <%= currentUser.account_number %></span>
          <% } %>
          <% if (activeCharacter) { %>
            <span>Charakter: <%= activeCharacter.name %></span>
            <span>Server: <%= activeServerId === "erp" ? "ERP" : "FREE-RP" %></span>
          <% } %>
        </div>

        <nav class="rp-user-menu-links" aria-label="Benutzermen&uuml;">
          <a href="/account">Account</a>
          <a href="/dashboard">Dashboard</a>
          <% if (activeCharacter && !activeCharacter.is_owner) { %>
            <a href="/characters/<%= activeCharacter.id %>">Charakter</a>
          <% } %>
          <% if (activeCharacter && activeCharacter.is_owner) { %>
            <a href="/characters/<%= activeCharacter.id %>/edit" target="_blank" rel="noopener noreferrer">Charakter editieren</a>
            <a href="/characters/<%= activeCharacter.id %>/rooms/new" target="_blank" rel="noopener noreferrer">Raum editieren</a>
          <% } %>
          <% if (activeCharacter) { %>
            <a href="/characters/<%= activeCharacter.id %>/guestbook" target="_blank" rel="noopener noreferrer">G&auml;stebuch</a>
            <% if (activeCharacter.server_id === "free-rp" || activeCharacter.server_id === "erp") { %>
              <a href="/characters/<%= activeCharacter.id %>#roomlist">Festplays</a>
            <% } %>
          <% } %>
          <a href="/help" target="_blank" rel="noopener noreferrer">Hilfe</a>
        </nav>

        <form method="POST" action="/logout" class="inline-form rp-user-menu-form">
          <button type="submit" class="rp-user-menu-logout">Logout</button>
        </form>
      </div>
    </details>
  </header>

  <section class="rp-room-panel <%= activeRoom ? 'is-room-chat' : 'is-server-chat' %>">
    <div class="chat-layout">
      <div class="chat-sidebar">
        <div class="chat-room-heading">
          <h1 class="chat-room-title">
            <% if (activeRoom?.is_locked) { %>
              <span class="chat-room-lock" aria-hidden="true"><svg class="room-lock-icon" viewBox="0 0 24 24" focusable="false">
                <path class="room-lock-fill" d="M12 3.7a4.45 4.45 0 0 0-4.45 4.45v1.92c0 .18-.06.35-.16.5l-1.31 2a1.08 1.08 0 0 0 .91 1.67h10.02a1.08 1.08 0 0 0 .91-1.67l-1.31-2c-.1-.15-.16-.32-.16-.5V8.15A4.45 4.45 0 0 0 12 3.7Z"/>
                <path d="M8.1 10.02V8.35a3.9 3.9 0 1 1 7.8 0v1.67"/>
                <rect x="6.35" y="10.02" width="11.3" height="9.28" rx="2.15" ry="2.15"/>
                <path d="M12 13.15v2.8"/>
              </svg></span>
            <% } %>
            <%= activeRoom
              ? activeRoom.name
              : (standardRoom ? standardRoom.name : `${activeServerId === "erp" ? "ERP" : "FREE-RP"} Chat`) %>
          </h1>
          <% const chatRoomDescription = activeRoom?.teaser || ""; %>
          <% const chatSidebarDescription = activeRoom
            ? (activeRoom.description || "")
            : (standardRoom?.teaser || ""); %>
          <% if (chatSidebarDescription) { %>
            <p class="chat-room-description"><%= chatSidebarDescription %></p>
          <% } %>
          <div class="chat-room-divider" aria-hidden="true"></div>
        </div>

        <aside class="chat-online-panel">
          <h2>Online Charaktere:</h2>
          <div id="online-char-list" class="chat-online-list">
            <% if (onlineCharacters && onlineCharacters.length) { %>
              <% onlineCharacters.forEach((entry) => { %>
                <button
                  class="chat-online-item chat-online-trigger"
                  type="button"
                  data-user-id="<%= entry.user_id %>"
                  data-character-id="<%= entry.character_id || '' %>"
                  data-name="<%= entry.name %>"
                  data-role-style="<%= entry.role_style || '' %>"
                  data-chat-text-color="<%= entry.chat_text_color || '' %>"
                >
                  <span class="chat-online-content">
                    <span
                      class="chat-online-name <%= entry.role_style ? `role-name-${entry.role_style}` : "" %>"
                      style="<%= entry.chat_text_color ? `color:${entry.chat_text_color};` : "" %>"
                    ><%= entry.name %></span>
                  </span>
                </button>
              <% }) %>
            <% } else { %>
              <p class="muted">Niemand online.</p>
            <% } %>
          </div>
        </aside>
      </div>

      <div class="chat-main">
        <div
          id="chat-box"
          class="chat-box"
          data-room-id="<%= activeRoom ? activeRoom.id : '' %>"
          data-server-id="<%= activeServerId %>"
          data-current-character-name="<%= activeCharacter ? activeCharacter.name : '' %>"
          data-current-display-name="<%= chatIdentityName %>"
          data-current-user-id="<%= currentUser ? currentUser.id : '' %>"
          data-active-character-id="<%= activeCharacter ? activeCharacter.id : '' %>"
        >
          <% if (chatRoomDescription) { %>
            <section class="chat-room-scene" aria-label="Raumbeschreibung">
              <div class="guestbook-entry-body"><%- activeRoomDescriptionHtml %></div>
            </section>
          <% } %>
          <% messages.forEach((msg) => { %>
            <article class="chat-message<%= msg.type === 'system' ? ' chat-system' : '' %>">
              <% if (msg.type === "system") { %>
                <p><span><%= msg.content %></span></p>
              <% } else { %>
                <p>
                  <strong
                    class="<%= msg.role_style ? `role-name-${msg.role_style}` : "" %>"
                    style="<%= msg.chat_text_color ? `color:${msg.chat_text_color};` : "" %>"
                  ><%= msg.username %>:</strong>
                  <span style="<%= msg.chat_text_color ? `color:${msg.chat_text_color};` : "" %>"><%= msg.content %></span>
                </p>
              <% } %>
            </article>
          <% }) %>
        </div>

        <form id="chat-form" class="chat-form">
          <input id="chat-input" maxlength="500" placeholder="Nachricht eingeben..." required />
          <button class="btn" type="submit">Senden</button>
        </form>
      </div>
    </div>
  </section>
</section>

<div id="online-actions-menu" class="online-actions-menu" hidden>
  <a
    id="online-action-guestbook"
    class="online-actions-item"
    href="#"
    target="_blank"
    rel="noopener noreferrer"
  >
    G&auml;stebuch &ouml;ffnen
  </a>
  <button id="online-action-whisper" class="online-actions-item" type="button">
    Fl&uuml;stern
  </button>
</div>

<div id="whisper-modal" class="whisper-modal" hidden>
  <div class="whisper-modal-card">
    <header class="whisper-modal-head">
      <h3 id="whisper-modal-title">Fl&uuml;stern</h3>
      <button id="whisper-close-btn" type="button" class="whisper-close-btn" aria-label="Schlie&szlig;en">
        &times;
      </button>
    </header>
    <div class="whisper-thread-shell">
      <p id="whisper-thread-empty" class="muted whisper-thread-empty">Noch keine Fl&uuml;sternachrichten.</p>
      <div id="whisper-thread" class="whisper-thread" aria-live="polite"></div>
    </div>
    <form id="whisper-form" class="form">
      <input id="whisper-target-user-id" type="hidden" />
      <label>
        Nachricht
        <textarea id="whisper-input" rows="4" maxlength="500" required></textarea>
      </label>
      <div class="whisper-actions">
        <button class="btn" type="submit">Senden</button>
        <button id="whisper-cancel-btn" class="btn btn-secondary" type="button">Abbrechen</button>
      </div>
    </form>
  </div>
</div>

<div id="room-invite-modal" class="room-invite-modal" hidden>
  <div class="room-invite-card">
    <header class="room-invite-head">
      <h3>Raumeinladung</h3>
    </header>
    <p id="room-invite-message" class="room-invite-message"></p>
    <p id="room-invite-description" class="room-invite-description" hidden></p>
    <div class="room-invite-actions">
      <button id="room-invite-accept" class="btn" type="button">&#10003; Annehmen</button>
      <button id="room-invite-decline" class="btn btn-secondary room-invite-decline" type="button">&#10005; Ablehnen</button>
    </div>
  </div>
</div>

<script src="/chat.js?v=<%= staticAssetVersion %>"></script>
<script>
  (() => {
  })();
</script>

<%- include("partials/end") %>
