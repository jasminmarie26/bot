<%- include("partials/start", { hideTopbar: true, activeCharacter, pageClass: "page-rp-screen page-chat" }) %>

<% const chatDisplayName = currentUserDisplayName || (currentUser ? currentUser.display_name || currentUser.username : "User"); %>
<% const chatAccountDisplayName = currentUserAccountName || (currentUser ? currentUser.username : "User"); %>
<% const formatChatRoleName = (value, roleStyle = "") => {
  const label = String(value || "").trim();
  return label.replace(/\s*\(M\)\s*$/i, "").trim();
}; %>
<% const getChatSpecialNameClass = (value) => {
  const label = String(value || "").trim();
  if (/^noctra(?:\b|\s|\[|\()/i.test(label)) return "has-noctra-wings";
  if (/^(?:crescentia|cresentia)(?:\b|\s|\[|\()/i.test(label)) return "has-crescentia-moons";
  return "";
}; %>
<% const chatIdentityRoleStyle = activeCharacter && currentUser && currentUser.is_admin && Number(currentUser.admin_character_id) === Number(activeCharacter.id)
  ? "admin"
  : activeCharacter && currentUser && currentUser.is_moderator && Number(currentUser.moderator_character_id) === Number(activeCharacter.id)
    ? "moderator"
    : (activeCharacter ? "" : (currentUserDisplayRoleStyle || "")); %>
<% const chatIdentityName = activeCharacter ? activeCharacter.name : chatDisplayName; %>
<% const chatIdentityColor = activeCharacter?.chat_text_color || currentUser?.display_chat_text_color || ""; %>
<% const chatLiveUpdatesInitialRevision = String(latestSiteUpdateRevisionToken || "").trim(); %>
<% const chatLiveUpdatesInitialRevisions = Array.isArray(recentSiteUpdateRevisions)
  ? recentSiteUpdateRevisions
  : []; %>
<% const showChatHeaderIdentity = Boolean(currentUser && chatIdentityName); %>
<% const chatHeaderIdentityHref = currentUser?.is_admin
  ? "/admin"
  : currentUser?.is_moderator
    ? "/staff"
    : ""; %>
<% const chatHeaderIdentityTitle = currentUser?.is_admin
  ? "Adminbereich im neuen Tab öffnen"
  : currentUser?.is_moderator
    ? "Moderatorenbereich im neuen Tab öffnen"
    : chatIdentityName; %>
<% const isFestplayContext = Boolean(activeRoom && activeRoom.festplay_id); %>
<% const chatRoomListHref = activeCharacter
  ? `/characters/${activeCharacter.id}`
  : "/dashboard"; %>
<% const chatRoomListHrefTemplate = activeCharacter
  ? "/characters/__CHARACTER_ID__"
  : ""; %>
<% const chatBoardServerId = activeCharacter ? activeCharacter.server_id : activeServerId; %>
<% const chatBoardFestplayId = 0; %>
<% const chatBoardCharacterId = activeCharacter ? activeCharacter.id : 0; %>
<% const chatBoardHref = `/rp-board?server_id=${chatBoardServerId}&character_id=${Number(chatBoardCharacterId)}`; %>
<% const chatBoardHrefTemplate = activeCharacter
  ? "/rp-board?server_id=__SERVER_ID__&character_id=__CHARACTER_ID__"
  : ""; %>
<% const chatBackgroundColor = /^#[0-9a-f]{6}$/i.test(String(activeCharacter?.chat_background_color || "").trim())
  ? String(activeCharacter.chat_background_color).trim().toUpperCase()
  : "#EFEFEF"; %>
<% const chatBackgroundUrl = /^https?:\/\/.+/i.test(String(activeCharacter?.chat_background_url || "").trim())
  ? String(activeCharacter.chat_background_url).trim()
  : ""; %>
<% const chatBackgroundImageOpacity = Math.min(
  100,
  Math.max(0, Number.parseInt(String(activeCharacter?.chat_background_image_opacity ?? "100"), 10) || 100)
) / 100; %>
<% const chatBackgroundStyle = [
  `--character-chat-background-color: ${chatBackgroundColor};`,
  `--character-chat-background-image-opacity: ${chatBackgroundImageOpacity};`,
  chatBackgroundUrl ? `--character-chat-background-image: url(${JSON.stringify(chatBackgroundUrl)});` : ""
].filter(Boolean).join(" "); %>

<section class="rp-shell">
  <header class="rp-topline">
    <a class="rp-logo" href="/">Heldenhafte Reisen</a>
    <nav class="rp-menu" aria-label="Chat Navigation">
      <a
        href="<%= chatRoomListHref %>"
        target="_blank"
        rel="noopener noreferrer"
        <%= chatRoomListHrefTemplate ? `data-chat-character-href-template="${chatRoomListHrefTemplate}"` : "" %>
      >Raumliste</a>
      <a href="/members" target="_blank" rel="noopener noreferrer">Mitglieder</a>
      <% if (activeCharacter && (activeCharacter.server_id === "free-rp" || activeCharacter.server_id === "erp")) { %>
        <a
          href="/characters/<%= activeCharacter.id %>/festplays/public"
          target="_blank"
          rel="noopener noreferrer"
          data-chat-character-href-template="/characters/__CHARACTER_ID__/festplays/public"
        >Festspiele</a>
      <% } %>
      <a
        class="rp-board-nav-link"
        href="<%= chatBoardHref %>"
        target="_blank"
        rel="noopener noreferrer"
        data-rp-board-link-root
        <%= chatBoardHrefTemplate ? `data-chat-character-href-template="${chatBoardHrefTemplate}"` : "" %>
        data-rp-board-server-id="<%= chatBoardServerId %>"
        data-rp-board-festplay-id="0"
        data-rp-board-character-id="<%= Number(chatBoardCharacterId) %>"
      >
        <span>RP-Aushang</span>
        <span class="rp-board-nav-badge" data-rp-board-badge hidden>1</span>
      </a>
      <a
        class="live-updates-nav-link"
        href="/live-updates"
        target="site-live-updates"
        data-live-updates-link-root
        data-live-updates-target="site-live-updates"
        data-live-updates-initial-revision="<%= chatLiveUpdatesInitialRevision %>"
        data-live-updates-initial-revisions="<%= chatLiveUpdatesInitialRevisions.join('|') %>"
      >
        <span>Live Updates</span>
        <span class="live-updates-nav-badge" data-live-updates-badge hidden>1</span>
      </a>
    </nav>
    <div class="rp-topline-actions">
      <% if (showChatHeaderIdentity) { %>
        <% if (chatHeaderIdentityHref) { %>
          <a
            class="rp-header-identity rp-header-identity-link"
            data-header-identity
            href="<%= chatHeaderIdentityHref %>"
            target="_blank"
            rel="noopener noreferrer"
            title="<%= chatHeaderIdentityTitle %>"
            style="<%= chatIdentityColor ? `color:${chatIdentityColor};` : '' %>"
          ><%= chatIdentityName %></a>
        <% } else { %>
          <span
            class="rp-header-identity"
            data-header-identity
            title="<%= chatIdentityName %>"
            style="<%= chatIdentityColor ? `color:${chatIdentityColor};` : '' %>"
          ><%= chatIdentityName %></span>
        <% } %>
      <% } %>
      <form method="POST" action="/settings/theme" class="inline-form theme-form">
        <label for="rp-theme-select-chat">Design</label>
        <input type="hidden" name="return_to" value="<%= currentPath || '/' %>" />
        <select
          id="rp-theme-select-chat"
          name="theme"
          class="theme-select"
        >
          <% availableThemes.forEach((theme) => { %>
            <option value="<%= theme.id %>" <%= activeTheme === theme.id ? "selected" : "" %>>
              <%= theme.label %>
            </option>
          <% }) %>
        </select>
      </form>
      <div class="rp-topline-quick-actions">
        <%- include("partials/guestbook-notification-link") %>
        <button
          id="chat-whisper-toggle"
          class="chat-whisper-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="chat-whisper-panel"
          aria-label="Fl&uuml;sterverlauf &ouml;ffnen"
          title="Fl&uuml;sterverlauf"
        >
          <span class="chat-whisper-toggle-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path class="chat-whisper-fill" d="M4.8 5.1h14.4a2.2 2.2 0 0 1 2.2 2.2v8a2.2 2.2 0 0 1-2.2 2.2h-7.1l-3.8 3.1c-.4.3-.9 0-.9-.5v-2.6H4.8a2.2 2.2 0 0 1-2.2-2.2v-8a2.2 2.2 0 0 1 2.2-2.2Z"/>
              <path d="M4.8 5.1h14.4a2.2 2.2 0 0 1 2.2 2.2v8a2.2 2.2 0 0 1-2.2 2.2h-7.1l-3.8 3.1c-.4.3-.9 0-.9-.5v-2.6H4.8a2.2 2.2 0 0 1-2.2-2.2v-8a2.2 2.2 0 0 1 2.2-2.2Z"/>
              <path d="M8 10.2h8"/>
              <path d="M8 13.4h5.2"/>
            </svg>
          </span>
          <span id="chat-whisper-toggle-badge" class="chat-whisper-toggle-badge" hidden>0</span>
        </button>
        <div class="chat-sound-menu">
          <button
            id="chat-sound-toggle"
            class="chat-sound-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="chat-sound-panel"
            aria-label="Ton-Einstellungen öffnen"
            title="Ton-Einstellungen"
          >
            <span id="chat-sound-toggle-icon" class="chat-sound-toggle-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path class="chat-bell-fill" d="M12 3.5a4.5 4.5 0 0 0-4.5 4.5v2.1c0 1.4-.42 2.76-1.22 3.91L4.9 16.1a1.1 1.1 0 0 0 .9 1.75h12.4a1.1 1.1 0 0 0 .9-1.75l-1.38-2.09a6.74 6.74 0 0 1-1.22-3.91V8A4.5 4.5 0 0 0 12 3.5Z"/>
                <path d="M12 3.5a4.5 4.5 0 0 0-4.5 4.5v2.1c0 1.4-.42 2.76-1.22 3.91L4.9 16.1a1.1 1.1 0 0 0 .9 1.75h12.4a1.1 1.1 0 0 0 .9-1.75l-1.38-2.09a6.74 6.74 0 0 1-1.22-3.91V8A4.5 4.5 0 0 0 12 3.5Z"/>
                <path d="M9.6 18.1a2.45 2.45 0 0 0 4.8 0"/>
              </svg>
            </span>
          </button>
          <div id="chat-sound-panel" class="chat-sound-panel" hidden>
            <p class="chat-sound-panel-title">Ton-Einstellungen</p>
            <label class="chat-sound-option" for="chat-entry-sound-toggle">
              <input id="chat-entry-sound-toggle" type="checkbox" />
              <span class="chat-sound-option-copy">
                <strong>Beitrittssound aktivieren</strong>
                <small>Du hörst einen Ton, wenn jemand den Raum betritt.</small>
              </span>
            </label>
            <label class="chat-sound-option" for="chat-message-sound-toggle">
              <input id="chat-message-sound-toggle" type="checkbox" />
              <span class="chat-sound-option-copy">
                <strong>Chatsound</strong>
                <small>Du hörst einen anderen Ton, wenn jemand schreibt.</small>
              </span>
            </label>
          </div>
        </div>
        <details class="rp-user-menu">
          <summary
            class="rp-user-menu-toggle"
            aria-label="Benutzermen&uuml; &ouml;ffnen"
            title="Benutzermen&uuml;"
          >
            <span class="rp-user-menu-toggle-icon" aria-hidden="true">&#128100;</span>
          </summary>
          <div class="rp-user-menu-panel">
        <div class="rp-user-menu-meta">
          <strong
            data-chat-user-menu-identity
            class="<%= chatIdentityRoleStyle ? `role-name-${chatIdentityRoleStyle}` : "" %>"
            style="<%= chatIdentityColor ? `color:${chatIdentityColor};` : "" %>"
          ><%= chatIdentityName %></strong>
            <% if (currentUser) { %>
              <span>Account Nr.: <%= currentUser.account_number %></span>
            <% } %>
          <% if (activeCharacter) { %>
            <span>Server: <%= activeCharacter.server_id === "larp" ? "LARP" : (activeCharacter.server_id === "erp" ? "ERP" : "FREE-RP") %></span>
          <% } %>
        </div>

        <nav class="rp-user-menu-links" aria-label="Benutzermen&uuml;">
          <a href="/account" target="_blank" rel="noopener noreferrer">Account</a>
          <a href="/dashboard" target="_blank" rel="noopener noreferrer">Serverliste</a>
          <% if (activeCharacter && activeCharacter.is_owner) { %>
            <a
              href="/characters/<%= activeCharacter.id %>/edit"
              target="_blank"
              rel="noopener noreferrer"
              data-chat-character-href-template="/characters/__CHARACTER_ID__/edit"
            >Charakter editieren</a>
          <% } %>
          <% if (activeCharacter) { %>
            <a
              href="/characters/<%= activeCharacter.id %>/guestbook"
              target="_blank"
              rel="noopener noreferrer"
              data-chat-character-href-template="/characters/__CHARACTER_ID__/guestbook"
            >G&auml;stebuch</a>
            <% if (activeCharacter.is_owner && isFestplayContext) { %>
              <a
                href="/characters/<%= activeCharacter.id %>/festplays/<%= activeRoom.festplay_id %>/rooms"
                data-chat-character-href-template="/characters/__CHARACTER_ID__/festplays/<%= activeRoom.festplay_id %>/rooms"
              >Festspiel-R&auml;ume</a>
            <% } else if (activeCharacter.is_owner) { %>
              <a
                href="/characters/<%= activeCharacter.id %>/rooms/new"
                target="_blank"
                rel="noopener noreferrer"
                data-chat-character-href-template="/characters/__CHARACTER_ID__/rooms/new"
              >Raum erstellen/editieren</a>
            <% } %>
            <% if (activeCharacter.server_id === "free-rp" || activeCharacter.server_id === "erp") { %>
              <a
                href="/characters/<%= activeCharacter.id %>/festplays"
                target="_blank"
                rel="noopener noreferrer"
                data-chat-character-href-template="/characters/__CHARACTER_ID__/festplays"
              >Meine Festplays</a>
            <% } %>
          <% } %>
          <a href="/help" target="_blank" rel="noopener noreferrer">Hilfe</a>
        </nav>

        <form method="POST" action="/logout" class="inline-form rp-user-menu-form">
          <button type="submit" class="rp-user-menu-logout">Logout</button>
        </form>
          </div>
        </details>
      </div>
    </div>
  </header>

  <section class="rp-room-panel <%= activeRoom ? 'is-room-chat' : 'is-server-chat' %>">
    <div class="chat-layout">
      <div class="chat-sidebar">
        <div class="chat-room-heading">
          <h1 class="chat-room-title">
            <% if (activeRoom?.is_locked) { %>
              <span class="chat-room-lock" aria-hidden="true"><svg class="room-lock-icon" viewBox="0 0 24 24" focusable="false">
                <path class="room-lock-fill" d="M12 3.7a4.45 4.45 0 0 0-4.45 4.45v1.92c0 .18-.06.35-.16.5l-1.31 2a1.08 1.08 0 0 0 .91 1.67h10.02a1.08 1.08 0 0 0 .91-1.67l-1.31-2c-.1-.15-.16-.32-.16-.5V8.15A4.45 4.45 0 0 0 12 3.7Z"/>
                <path d="M8.1 10.02V8.35a3.9 3.9 0 1 1 7.8 0v1.67"/>
                <rect x="6.35" y="10.02" width="11.3" height="9.28" rx="2.15" ry="2.15"/>
                <path d="M12 13.15v2.8"/>
              </svg></span>
            <% } %>
            <span class="chat-room-title-text">
              <%= activeRoom
                ? activeRoom.name
                : (standardRoom ? standardRoom.name : `${activeServerId === "erp" ? "ERP" : "FREE-RP"} Chat`) %>
            </span>
          </h1>
          <% const chatRoomDescription = activeRoom?.teaser || ""; %>
          <% const chatSidebarDescription = activeRoom
            ? (activeRoom.description || "")
            : (standardRoom?.teaser || ""); %>
          <% if (chatSidebarDescription) { %>
            <p class="chat-room-description"><%= chatSidebarDescription %></p>
          <% } %>
          <div class="chat-room-divider" aria-hidden="true"></div>
        </div>

        <aside class="chat-online-panel">
          <h2>Online Charaktere:</h2>
          <% const includeTavernInnkeeper = Boolean(activeRoom && activeRoom.name === "Zum Silbermond-Krug"); %>
          <% const tavernInnkeeperAlreadyPresent = Array.isArray(onlineCharacters) && onlineCharacters.some((entry) => entry && entry.is_npc); %>
          <div
            id="online-char-list"
            class="chat-online-list"
            data-include-tavern-innkeeper="<%= includeTavernInnkeeper ? 'true' : 'false' %>"
          >
            <% if (onlineCharacters && onlineCharacters.length) { %>
              <% onlineCharacters.forEach((entry) => { %>
                <% const onlineEntryDisplayName = formatChatRoleName(entry.name, entry.role_style); %>
                <% const onlineEntrySpecialClass = getChatSpecialNameClass(onlineEntryDisplayName); %>
                <% if (entry.is_npc) { %>
                  <div
                    class="chat-online-item is-npc"
                    data-presence-key="<%= entry.presence_key || '' %>"
                    aria-label="<%= `${onlineEntryDisplayName} (Raumfigur)` %>"
                    title="Raumfigur"
                  >
                    <span class="chat-online-content">
                      <% if (entry.is_afk) { %>
                        <span class="chat-afk-clock" aria-hidden="true">&#9687;</span>
                      <% } %>
                      <span
                        class="chat-online-name <%= entry.role_style ? `role-name-${entry.role_style}` : "" %><%= onlineEntrySpecialClass ? ` ${onlineEntrySpecialClass}` : "" %><%= entry.is_afk ? ' is-afk' : '' %>"
                        style="<%= entry.chat_text_color ? `color:${entry.chat_text_color};` : "" %>"
                      ><%= onlineEntryDisplayName %></span>
                    </span>
                  </div>
                <% } else { %>
                  <button
                    class="chat-online-item chat-online-trigger"
                    type="button"
                    data-user-id="<%= entry.user_id %>"
                    data-character-id="<%= entry.character_id || '' %>"
                    data-presence-key="<%= entry.presence_key || '' %>"
                    data-name="<%= onlineEntryDisplayName %>"
                    data-role-style="<%= entry.role_style || '' %>"
                    data-chat-text-color="<%= entry.chat_text_color || '' %>"
                  >
                    <span class="chat-online-content">
                      <% if (entry.is_afk) { %>
                        <span class="chat-afk-clock" aria-hidden="true">&#9687;</span>
                      <% } %>
                      <span
                        class="chat-online-name <%= entry.role_style ? `role-name-${entry.role_style}` : "" %><%= onlineEntrySpecialClass ? ` ${onlineEntrySpecialClass}` : "" %><%= entry.is_afk ? ' is-afk' : '' %>"
                        style="<%= entry.chat_text_color ? `color:${entry.chat_text_color};` : "" %>"
                      ><%= onlineEntryDisplayName %></span>
                    </span>
                  </button>
                <% } %>
              <% }) %>
              <% if (includeTavernInnkeeper && !tavernInnkeeperAlreadyPresent) { %>
                <div
                  class="chat-online-item is-npc"
                  data-presence-key="npc:edric-muehlenbrand"
                  aria-label="Edric Mühlenbrand (Raumfigur)"
                  title="Raumfigur"
                >
                  <span class="chat-online-content">
                    <span
                      class="chat-online-name"
                      style="color:#c4863a;"
                    >Edric Mühlenbrand</span>
                  </span>
                </div>
              <% } %>
            <% } else if (includeTavernInnkeeper) { %>
              <div
                class="chat-online-item is-npc"
                data-presence-key="npc:edric-muehlenbrand"
                aria-label="Edric Mühlenbrand (Raumfigur)"
                title="Raumfigur"
              >
                <span class="chat-online-content">
                  <span
                    class="chat-online-name"
                    style="color:#c4863a;"
                  >Edric Mühlenbrand</span>
                </span>
              </div>
            <% } else { %>
              <p class="muted">Niemand online.</p>
            <% } %>
          </div>
        </aside>
      </div>

      <div class="chat-main">
        <div
          id="chat-box"
          class="chat-box"
          style="<%= chatBackgroundStyle %>"
          data-room-id="<%= activeRoom ? activeRoom.id : '' %>"
          data-server-id="<%= activeServerId %>"
          data-standard-room-id="<%= standardRoom ? standardRoom.id : '' %>"
          data-current-character-name="<%= activeCharacter ? activeCharacter.name : '' %>"
          data-current-display-name="<%= chatIdentityName %>"
          data-current-user-id="<%= currentUser ? currentUser.id : '' %>"
          data-active-character-id="<%= activeCharacter ? activeCharacter.id : '' %>"
          data-afk-timeout-minutes="<%= currentUser?.afk_timeout_minutes || 20 %>"
          data-auto-afk-enabled="<%= currentUser?.auto_afk_enabled === false ? '0' : '1' %>"
          data-show-chat-timestamps="<%= currentUser?.show_own_chat_time ? '1' : '0' %>"
        >
          <% if (chatRoomDescription) { %>
            <section class="chat-room-scene" aria-label="Raumbeschreibung">
              <div class="guestbook-entry-body"><%- activeRoomDescriptionHtml %></div>
            </section>
          <% } %>
          <% messages.forEach((msg) => { %>
            <article class="chat-message<%= msg.type === 'system' ? ' chat-system' : '' %>">
              <% if (msg.type === "system") { %>
                <% if (msg.system_kind === "dice-roll" && msg.presence_actor_name) { %>
                  <% const systemActorDisplayName = formatChatRoleName(msg.presence_actor_name, msg.presence_actor_role_style); %>
                  <% const systemActorSpecialClass = getChatSpecialNameClass(systemActorDisplayName); %>
                  <p>
                    <strong
                      class="<%= systemActorSpecialClass %>"
                      style="<%= msg.presence_actor_chat_text_color ? `color:${msg.presence_actor_chat_text_color};` : '' %>"
                    ><%= systemActorDisplayName %></strong>
                    <span> <%= msg.content %></span>
                  </p>
                <% } else { %>
                  <p><span><%= msg.content %></span></p>
                <% } %>
              <% } else { %>
                <% const chatMessageDisplayName = formatChatRoleName(msg.username, msg.role_style); %>
                <% const chatMessageSpecialClass = getChatSpecialNameClass(chatMessageDisplayName); %>
                <p>
                  <strong
                    class="<%= msg.role_style ? `role-name-${msg.role_style}` : "" %><%= chatMessageSpecialClass ? ` ${chatMessageSpecialClass}` : "" %>"
                    style="<%= msg.chat_text_color ? `color:${msg.chat_text_color};` : "" %>"
                  ><%= chatMessageDisplayName %>:</strong>
                  <span style="<%= msg.chat_text_color ? `color:${msg.chat_text_color};` : "" %>"><%= msg.content %></span>
                </p>
              <% } %>
            </article>
          <% }) %>
        </div>

        <form id="chat-form" class="chat-form" autocomplete="off">
          <textarea
            id="chat-input"
            rows="1"
            placeholder="Nachricht eingeben..."
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            aria-autocomplete="none"
            data-lpignore="true"
            required
          ></textarea>
          <button class="btn" type="submit">Senden</button>
        </form>
      </div>
    </div>
  </section>
</section>

<div id="online-actions-menu" class="online-actions-menu" hidden>
  <a
    id="online-action-guestbook"
    class="online-actions-item"
    href="#"
    target="_blank"
    rel="noopener noreferrer"
  >
    G&auml;stebuch &ouml;ffnen
  </a>
  <button id="online-action-whisper" class="online-actions-item" type="button">
    Fl&uuml;stern
  </button>
  <button id="online-action-friend" class="online-actions-item" type="button">
    Als Freund speichern
  </button>
  <button id="online-action-ignore-character" class="online-actions-item" type="button">
    Charakter ignorieren
  </button>
  <button id="online-action-ignore-account" class="online-actions-item" type="button">
    Account ignorieren
  </button>
</div>

<div id="chat-whisper-panel" class="chat-whisper-panel" hidden>
  <div class="chat-whisper-panel-card">
    <header class="chat-whisper-panel-head">
      <div class="chat-whisper-panel-copy">
        <h3>Fl&uuml;stern</h3>
        <p>Verl&auml;ufe in diesem Raum, bis du ihn verl&auml;sst.</p>
        <p class="muted chat-whisper-panel-tip">Shift + Enter macht eine neue Zeile.</p>
      </div>
      <button id="chat-whisper-close-btn" type="button" class="chat-whisper-close-btn" aria-label="Schlie&szlig;en">
        &times;
      </button>
    </header>
    <div class="chat-whisper-layout">
      <aside class="chat-whisper-list-wrap">
        <p id="chat-whisper-list-empty" class="muted chat-whisper-list-empty">Noch keine Fl&uuml;stergespr&auml;che in diesem Raum.</p>
        <div id="chat-whisper-list" class="chat-whisper-list" hidden></div>
      </aside>

      <section class="chat-whisper-thread-wrap">
        <p id="chat-whisper-placeholder" class="muted chat-whisper-placeholder">W&auml;hle links ein Gespr&auml;ch aus oder starte eines &uuml;ber einen Namen im Chat.</p>

        <div id="chat-whisper-thread-shell" class="whisper-thread-shell" hidden>
          <div class="chat-whisper-thread-head">
            <h4 id="chat-whisper-thread-title">Fl&uuml;stern</h4>
          </div>
          <p id="whisper-thread-empty" class="muted whisper-thread-empty">Noch keine Fl&uuml;sternachrichten.</p>
          <div id="whisper-thread" class="whisper-thread" aria-live="polite"></div>
        </div>

        <form id="whisper-form" class="chat-whisper-form" autocomplete="off" hidden>
          <input id="whisper-target-user-id" type="hidden" />
          <label>
            Nachricht
            <textarea
              id="whisper-input"
              rows="4"
              autocomplete="off"
              autocorrect="off"
              autocapitalize="off"
              spellcheck="false"
              aria-autocomplete="none"
              data-lpignore="true"
              required
            ></textarea>
          </label>
          <div class="whisper-actions">
            <button class="btn" type="submit">Senden</button>
          </div>
        </form>
      </section>
    </div>
  </div>
</div>

<div id="room-invite-modal" class="room-invite-modal" hidden>
  <div class="room-invite-card">
    <header class="room-invite-head">
      <h3>Raumeinladung</h3>
    </header>
    <p id="room-invite-message" class="room-invite-message"></p>
    <p id="room-invite-description" class="room-invite-description" hidden></p>
    <div class="room-invite-actions">
      <button id="room-invite-accept" class="btn" type="button">&#10003; Annehmen</button>
      <button id="room-invite-decline" class="btn btn-secondary room-invite-decline" type="button">&#10005; Ablehnen</button>
    </div>
  </div>
</div>

