<%- include("partials/start", { topbarCharacter }) %>

<% const hasPostingCharacters = Array.isArray(guestbookPostingCharacters) && guestbookPostingCharacters.length > 0; %>

<section class="panel guestbook-layout">
  <div class="guestbook-sticky-head">
    <% if (characterCreatedAtLabel) { %>
      <div class="guestbook-meta-row">
        <span class="guestbook-meta-created">Charakter erstellt am <%= characterCreatedAtLabel %></span>
      </div>
    <% } %>

    <div class="guestbook-entry-rail">
      <button type="button" class="guestbook-entry-launcher" data-guestbook-modal-open>
        Gästebuch-Einträge
      </button>
    </div>
  </div>

  <nav class="guestbook-page-tabs" aria-label="Gästebuch Seiten">
    <% (guestbookPages || []).forEach((page) => { %>
      <a
        class="guestbook-page-tab <%= activeGuestbookPage.id === page.id ? "is-active" : "" %>"
        href="/characters/<%= character.id %>/guestbook?page_id=<%= page.id %><%= guestbookContextQuery %>"
      >
        <%= page.page_number %>
      </a>
    <% }) %>
  </nav>

  <article
    class="guestbook-page-preview gb-font-<%= guestbookSettings?.font_style || 'default' %>"
    style="color:<%= guestbookSettings?.chat_text_color || '#AEE7B7' %>;"
  >
    <% if (guestbookSettings?.image_url) { %>
      <img class="guestbook-page-image" src="<%= guestbookSettings.image_url %>" alt="Gästebuch Bild" />
    <% } %>
    <% if (activeGuestbookPage?.content_html) { %>
      <p class="guestbook-entry-body"><%- activeGuestbookPage.content_html %></p>
    <% } else { %>
      <p class="muted">Diese Seite ist noch leer.</p>
    <% } %>
  </article>
</section>

<div
  class="guestbook-modal"
  data-guestbook-modal
  data-auto-open="<%= guestbookAccessState?.viaReplyAccess ? "true" : "false" %>"
  hidden
>
  <div class="guestbook-modal-backdrop" data-guestbook-modal-close></div>
  <section
    class="panel guestbook-modal-shell"
    role="dialog"
    aria-modal="true"
    aria-labelledby="guestbook-modal-title"
  >
    <header class="guestbook-modal-header">
      <div class="guestbook-modal-title">
        <strong id="guestbook-modal-title">Gästebuch-Einträge</strong>
        <span class="muted">für <%= character.name %></span>
      </div>
      <button type="button" class="guestbook-modal-close btn btn-secondary" data-guestbook-modal-close>
        Schließen
      </button>
    </header>

    <div class="guestbook-modal-body">
      <% if (guestbookAccessState?.viaReplyAccess) { %>
        <p class="muted guestbook-reply-hint">
          Du bist über einen Gästebuch-Link hier gelandet. Du kannst direkt mit deinem passenden Charakter antworten.
        </p>
      <% } %>

      <form method="POST" action="/characters/<%= character.id %>/guestbook" class="form guestbook-entry-form">
        <input type="hidden" name="page_id" value="<%= activeGuestbookPage.id %>" />
        <% if (guestbookAccessState?.viaReplyAccess) { %>
          <input type="hidden" name="reply_context_entry_id" value="<%= guestbookAccessState.replyContextEntryId %>" />
          <input type="hidden" name="reply_context_character_id" value="<%= guestbookAccessState.replyContextCharacterId %>" />
        <% } %>
        <a class="bbcode-help-link" href="#bbcode-hilfe-<%= activeGuestbookPage.id %>">BBCode Hilfe anzeigen</a>
        <details id="bbcode-hilfe-<%= activeGuestbookPage.id %>" class="bbcode-help">
          <summary>Welche Codes gehen?</summary>
          <div class="bbcode-help-content">
            <p><code>[b]fett[/b]</code> <code>[i]kursiv[/i]</code> <code>[u]unterstrichen[/u]</code></p>
            <p><code>[h1]Titel[/h1]</code> <code>[h2]Titel[/h2]</code> <code>[h3]Titel[/h3]</code></p>
            <p><code>[color=#610b0b]Text[/color]</code> <code>[gradient=0,0,#ff0000,#00aaff]Text[/gradient]</code></p>
            <p><code>[center]Text[/center]</code> <code>[right]Text[/right]</code> <code>[block]Text[/block]</code></p>
            <p><code>[table][tr][td]Links[/td][td]Rechts[/td][/tr][/table]</code></p>
            <p><code>[img]https://...[/img]</code> <code>[img float=left]https://...[/img]Text</code></p>
            <p><code>[img float=right]https://...[/img]Text</code></p>
            <p><code>[url]https://beispiel.de[/url]</code> <code>[url=/characters/1/guestbook]Gästebuch[/url]</code></p>
            <p><code>[spoiler=Buttonname]Inhalt[/spoiler]</code> <code>[ab18]Inhalt[/ab18]</code> <code>[hr]</code></p>
            <p><code>[quote]Zitat[/quote]</code> <code>[code]Code[/code]</code></p>
          </div>
        </details>

        <% if (hasPostingCharacters) { %>
          <label>
            Schreiben als
            <select name="author_character_id" required>
              <% guestbookPostingCharacters.forEach((entry) => { %>
                <option value="<%= entry.id %>" <%= Number(selectedGuestbookAuthorCharacterId) === Number(entry.id) ? "selected" : "" %>>
                  <%= entry.name %> (<%= entry.server_id === "erp" ? "ERP" : "FREE-RP" %>)
                </option>
              <% }) %>
            </select>
          </label>
        <% } else { %>
          <p class="muted">Du brauchst erst einen eigenen Charakter, um ins Gästebuch zu schreiben.</p>
        <% } %>

        <label>
          Eintrag
          <textarea name="content" rows="5" maxlength="4000" required <%= hasPostingCharacters ? "" : "disabled" %>></textarea>
        </label>

        <label class="guestbook-private-row">
          <input type="checkbox" name="is_private" value="1" />
          Privater Eintrag
        </label>

        <button type="submit" class="rp-enter-btn" <%= hasPostingCharacters ? "" : "disabled" %>>
          Eintragen (Seite <%= activeGuestbookPage.page_number %>)
        </button>
      </form>

      <h3>Einträge auf Seite <%= activeGuestbookPage.page_number %></h3>
      <% if (!guestbookEntries || !guestbookEntries.length) { %>
        <p class="muted">Noch keine sichtbaren Einträge.</p>
      <% } else { %>
        <div class="guestbook-list">
          <% guestbookEntries.forEach((entry) => { %>
            <article id="guestbook-entry-<%= entry.id %>" class="guestbook-item">
              <header class="guestbook-item-header">
                <div class="guestbook-item-authorline">
                  <% if (entry.author_guestbook_url) { %>
                    <a class="guestbook-author-link" href="<%= entry.author_guestbook_url %>"><strong><%= entry.author_name %></strong></a>
                  <% } else { %>
                    <strong><%= entry.author_name %></strong>
                  <% } %>
                  <div class="guestbook-entry-badges">
                    <% if (entry.private_label) { %>
                      <span class="guestbook-entry-badge is-private"><%= entry.private_label %></span>
                    <% } %>
                    <% if (entry.updated_label) { %>
                      <span class="guestbook-entry-badge"><%= entry.updated_label %></span>
                    <% } %>
                  </div>
                </div>
                <small><%= entry.created_at %></small>
              </header>
              <p class="guestbook-entry-body"><%- entry.content_html %></p>

              <% if (entry.can_edit || entry.can_delete) { %>
                <div class="guestbook-item-actions">
                  <% if (entry.can_edit) { %>
                    <details class="guestbook-edit-form">
                      <summary>Eintrag bearbeiten</summary>
                      <form method="POST" action="/characters/<%= character.id %>/guestbook/entries/<%= entry.id %>/update" class="form">
                        <input type="hidden" name="page_id" value="<%= activeGuestbookPage.id %>" />
                        <% if (guestbookAccessState?.viaReplyAccess) { %>
                          <input type="hidden" name="reply_context_entry_id" value="<%= guestbookAccessState.replyContextEntryId %>" />
                          <input type="hidden" name="reply_context_character_id" value="<%= guestbookAccessState.replyContextCharacterId %>" />
                        <% } %>
                        <label>
                          Inhalt
                          <textarea name="content" rows="4" maxlength="4000" required><%= entry.content %></textarea>
                        </label>
                        <label class="guestbook-private-row">
                          <input type="checkbox" name="is_private" value="1" <%= entry.is_private ? "checked" : "" %> />
                          Privater Eintrag
                        </label>
                        <button type="submit" class="btn">Speichern</button>
                      </form>
                    </details>
                  <% } %>

                  <% if (entry.can_delete) { %>
                    <form
                      method="POST"
                      action="/characters/<%= character.id %>/guestbook/entries/<%= entry.id %>/delete"
                      class="guestbook-delete-form"
                      onsubmit="return confirm('Diesen Eintrag wirklich löschen?');"
                    >
                      <input type="hidden" name="page_id" value="<%= activeGuestbookPage.id %>" />
                      <% if (guestbookAccessState?.viaReplyAccess) { %>
                        <input type="hidden" name="reply_context_entry_id" value="<%= guestbookAccessState.replyContextEntryId %>" />
                        <input type="hidden" name="reply_context_character_id" value="<%= guestbookAccessState.replyContextCharacterId %>" />
                      <% } %>
                      <button type="submit" class="btn btn-secondary">Löschen</button>
                    </form>
                  <% } %>
                </div>
              <% } %>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>
</div>

<div data-server-presence="<%= character.server_id %>" hidden></div>
<script src="/server-presence.js?v=<%= staticAssetVersion %>"></script>
<script src="/guestbook-modal.js?v=<%= staticAssetVersion %>"></script>

<%- include("partials/end") %>
