<%- include("partials/start") %>

<section class="panel narrow">
  <h1><%= title %></h1>
  <p>
    Du hast dich mit <strong><%= providerLabel %></strong> angemeldet.
    <% if (requireBirthDate && requirePassword) { %>
      Bevor es weitergeht, brauchen wir noch dein Geburtsdatum und ein Passwort für diese Seite.
    <% } else if (requirePassword) { %>
      Bevor es weitergeht, vergib bitte noch ein Passwort für diese Seite.
    <% } else { %>
      Bevor es weitergeht, musst du bitte noch dein Geburtsdatum eintragen.
    <% } %>
  </p>

  <% if (requireBirthDate) { %>
    <p class="field-hint">
      Ohne diese Angabe kommst du nicht weiter. Das Datum wird für Altersfreigaben benötigt
      und ist nicht öffentlich sichtbar.
    </p>
  <% } %>

  <% if (requirePassword) { %>
    <p class="field-hint">
      Das ist dein Passwort für Heldenhafte Reisen. Dein Google-Passwort wird dabei nicht übernommen
      und ist für diese Seite nicht sichtbar.
    </p>
  <% } %>

  <% if (error) { %>
    <div class="inline-error"><%= error %></div>
  <% } %>

  <form method="POST" action="/auth/complete-profile" class="form">
    <% if (requireBirthDate) { %>
      <label>
        Geburtsdatum
        <input
          type="date"
          name="birth_date"
          required
          max="<%= new Date().toISOString().slice(0, 10) %>"
          value="<%= values.birth_date || '' %>"
        />
      </label>
    <% } %>

    <% if (requirePassword) { %>
      <label>
        Passwort für diese Seite
        <input
          type="password"
          name="password"
          required
          minlength="6"
          autocomplete="new-password"
        />
      </label>
    <% } %>

    <div class="hero-actions">
      <button type="submit" class="btn">Speichern und weiter</button>
    </div>
  </form>
</section>

<%- include("partials/end") %>
