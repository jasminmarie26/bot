<%- include("partials/start") %>

<%
  const isLogin = mode === "login";
  const isRegister = mode === "register";
  const isForgotUsername = mode === "forgot-username";
  const isForgotPassword = mode === "forgot-password";
  const isResetPassword = mode === "reset-password";
  const googleOAuth = oauthProviders?.google || { enabled: oauthEnabled.google };
  const facebookOAuth = oauthProviders?.facebook || { enabled: oauthEnabled.facebook };

  const heading = isRegister
    ? "Registrieren"
    : isForgotUsername
      ? "Benutzernamen vergessen"
      : isForgotPassword
        ? "Passwort vergessen"
        : isResetPassword
          ? "Passwort zurücksetzen"
          : "Login";

  const formAction = isRegister
    ? "/register"
    : isForgotUsername
      ? "/forgot-username"
      : isForgotPassword
        ? "/forgot-password"
        : isResetPassword
          ? "/reset-password"
          : "/login";

  const submitLabel = isRegister
    ? "Account erstellen"
    : isForgotUsername
      ? "Benutzernamen senden"
      : isForgotPassword
        ? "Link senden"
        : isResetPassword
          ? "Neues Passwort speichern"
          : "Einloggen";
%>

<section class="panel narrow">
  <h1><%= heading %></h1>

  <% if (isLogin && currentUser) { %>
    <p>Du bist bereits eingeloggt als <strong><%= currentUser.username %></strong>.</p>
    <div class="hero-actions">
      <a class="btn" href="/dashboard">Zur Serverliste</a>
      <a class="btn btn-secondary" href="/">Zur Startseite</a>
    </div>
  <% } else { %>
    <% if (error) { %>
      <div class="inline-error"><%= error %></div>
    <% } %>
    <% if (success || recoveredUsername || resetUrl) { %>
      <div class="inline-success auth-result">
        <% if (success) { %>
          <p><%= success %></p>
        <% } %>
        <% if (recoveredUsername) { %>
          <p>Benutzername: <strong><%= recoveredUsername %></strong></p>
        <% } %>
        <% if (resetUrl) { %>
          <a class="btn btn-secondary auth-result-link" href="<%= resetUrl %>">
            Neues Passwort festlegen
          </a>
          <p class="field-hint">Der Link ist 2 Stunden gültig.</p>
        <% } %>
      </div>
    <% } %>

    <form method="POST" action="<%= formAction %>" class="form">
      <% if (isRegister) { %>
        <input type="hidden" name="form_token" value="<%= registrationGuardToken || "" %>" />
        <div class="bot-trap" aria-hidden="true">
          <label>
            Webseite
            <input
              name="website"
              tabindex="-1"
              autocomplete="off"
              data-lpignore="true"
            />
          </label>
        </div>
      <% } %>

      <% if (isResetPassword) { %>
        <input type="hidden" name="token" value="<%= resetToken || "" %>" />
      <% } %>

      <% if (isLogin || isRegister) { %>
        <label>
          Username
          <input name="username" required minlength="3" maxlength="24" value="<%= values.username %>" />
        </label>
      <% } %>

      <% if (isRegister || isForgotUsername || isForgotPassword) { %>
        <label>
          E-Mail
          <input
            type="email"
            name="email"
            required
            maxlength="255"
            value="<%= values.email || "" %>"
          />
        </label>
      <% } %>

      <% if (isRegister) { %>
        <label>
          Geburtsdatum
          <input
            type="date"
            name="birth_date"
            required
            max="<%= new Date().toISOString().slice(0, 10) %>"
            value="<%= values.birth_date || "" %>"
          />
        </label>
        <p class="field-hint">Dieses Datum ist nicht öffentlich sichtbar und wird nur für Admins angezeigt.</p>
      <% } %>

      <% if (isLogin || isRegister || isResetPassword) { %>
        <label>
          Passwort
          <input type="password" name="password" required minlength="6" />
        </label>
      <% } %>

      <% if (isResetPassword) { %>
        <label>
          Passwort wiederholen
          <input type="password" name="password_confirm" required minlength="6" />
        </label>
      <% } %>

      <button type="submit" class="btn"><%= submitLabel %></button>
    </form>

    <% if (isLogin) { %>
      <div class="auth-helper-links">
        <a href="/forgot-username">Benutzernamen vergessen?</a>
        <a href="/forgot-password">Passwort vergessen?</a>
      </div>
    <% } %>

    <% if (isLogin || isRegister) { %>
      <div class="oauth-section">
        <p class="muted">Oder mit Social Login:</p>
        <div class="oauth-buttons">
          <% if (googleOAuth.enabled) { %>
            <a class="btn btn-secondary oauth-btn" href="/auth/google">Mit Google einloggen</a>
          <% } else { %>
            <span class="oauth-disabled">Google Login noch nicht eingerichtet</span>
            <p class="field-hint oauth-hint">
              Wird aktiv, sobald Google Client ID und Client Secret eingetragen sind.
            </p>
          <% } %>

          <% if (facebookOAuth.enabled) { %>
            <a class="btn btn-secondary oauth-btn" href="/auth/facebook">Mit Facebook einloggen</a>
          <% } else { %>
            <span class="oauth-disabled">Facebook Login noch nicht eingerichtet</span>
            <p class="field-hint oauth-hint">
              Wird aktiv, sobald Facebook App ID und App Secret eingetragen sind.
            </p>
          <% } %>
        </div>
      </div>
    <% } %>

    <p class="muted auth-secondary-links">
      <% if (isRegister) { %>
        Schon registriert? <a href="/login">Zum Login</a>
      <% } else if (isForgotUsername) { %>
        Zurück zum <a href="/login">Login</a> oder direkt <a href="/forgot-password">Passwort zurücksetzen</a>
      <% } else if (isForgotPassword) { %>
        Zurück zum <a href="/login">Login</a> oder zuerst <a href="/forgot-username">Username anfordern</a>
      <% } else if (isResetPassword) { %>
        Zurück zum <a href="/login">Login</a>
      <% } else { %>
        Noch keinen Account? <a href="/register">Jetzt registrieren</a>
      <% } %>
    </p>
  <% } %>
</section>

<%- include("partials/end") %>
