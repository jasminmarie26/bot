<%- include("partials/start", { hideTopbar: true, enableRealtime: false }) %>

<section class="gb-editor-shell">
  <header class="gb-editor-topbar">
    <a class="rp-logo" href="/">Heldenhafte Reisen</a>

    <div class="gb-editor-actions">
      <button class="btn" type="submit" form="guestbook-editor-form">Speichern</button>
      <button
        class="btn btn-secondary"
        type="submit"
        form="guestbook-editor-form"
        formaction="/characters/<%= character.id %>/guestbook/edit/preview?page_id=<%= activePage.id %>"
        formmethod="POST"
        formtarget="guestbook-preview-<%= character.id %>"
      >
        Vorschau
      </button>

      <form method="POST" action="/characters/<%= character.id %>/guestbook/edit/add-page" class="inline-form">
        <button class="btn btn-secondary" type="submit">Seite hinzuf&uuml;gen</button>
      </form>

      <form method="POST" action="/characters/<%= character.id %>/guestbook/edit/delete-page" class="inline-form">
        <input type="hidden" name="page_id" value="<%= activePage.id %>" />
        <button
          class="btn btn-danger"
          type="submit"
          onclick="return confirm('Aktuelle Seite wirklich l&ouml;schen?')"
        >
          Aktuelle Seite l&ouml;schen
        </button>
      </form>
    </div>

    <form method="POST" action="/settings/theme" class="inline-form theme-form">
      <label for="gb-theme-select">Design</label>
      <input type="hidden" name="return_to" value="<%= currentPath || '/' %>" />
      <select
        id="gb-theme-select"
        name="theme"
        class="theme-select"
      >
        <% availableThemes.forEach((theme) => { %>
          <option value="<%= theme.id %>" <%= activeTheme === theme.id ? "selected" : "" %>>
            <%= theme.label %>
          </option>
        <% }) %>
      </select>
    </form>

    <form method="POST" action="/logout" class="inline-form">
      <button type="submit" class="ghost-btn">Logout</button>
    </form>
  </header>

  <% if ((pages || []).length > 1) { %>
    <nav class="gb-editor-tabs" aria-label="G&auml;stebuch Seiten">
      <% pages.forEach((page) => { %>
        <a
          class="gb-editor-tab <%= page.id === activePage.id ? "is-active" : "" %>"
          href="/characters/<%= character.id %>/guestbook/edit?page_id=<%= page.id %>"
        >
          <%= page.page_number %>
        </a>
      <% }) %>
    </nav>
  <% } %>

  <form
    id="guestbook-editor-form"
    method="POST"
    action="/characters/<%= character.id %>/guestbook/edit/save"
    class="panel form gb-editor-form"
  >
    <input type="hidden" name="page_id" value="<%= activePage.id %>" />

    <h2>Einstellungen</h2>

    <div class="gb-editor-section">
      <span class="gb-editor-subheading">Zensur</span>
      <div class="gb-radio-list">
        <label><input type="radio" name="censor_level" value="ab18" <%= settings.censor_level === "ab18" ? "checked" : "" %> /> ab 18 schalten</label>
        <label><input type="radio" name="censor_level" value="sexual" <%= settings.censor_level === "sexual" ? "checked" : "" %> /> sexuelle Darstellung</label>
        <label><input type="radio" name="censor_level" value="none" <%= settings.censor_level !== "ab18" && settings.censor_level !== "sexual" ? "checked" : "" %> /> keine Altersbeschr&auml;nkung</label>
      </div>
    </div>

    <label>
      Style
      <select name="theme_style">
        <option value="blumen" <%= settings.theme_style === "blumen" ? "selected" : "" %>>Blumen</option>
        <option value="nacht" <%= settings.theme_style === "nacht" ? "selected" : "" %>>Nacht</option>
        <option value="minimal" <%= settings.theme_style === "minimal" ? "selected" : "" %>>Minimal</option>
        <option value="tiefschwarz" <%= settings.theme_style === "tiefschwarz" ? "selected" : "" %>>Schwarz mit wei&szlig;em Rahmen</option>
        <option value="neutral-weiss" <%= settings.theme_style === "neutral-weiss" ? "selected" : "" %>>Neutral Wei&szlig;</option>
      </select>
    </label>

    <div class="gb-color-row">
      <div>
        <span class="gb-editor-subheading">Rahmenfarbe</span>
        <span class="gb-editor-helptext">Leer = Standard vom gew&auml;hlten Style.</span>
      </div>

      <div class="gb-color-input-wrap">
        <input
          id="guestbook-frame-color-text"
          name="frame_color"
          value="<%= settings.frame_color || '' %>"
          maxlength="7"
          placeholder="#7A6855"
          spellcheck="false"
          autocomplete="off"
        />
        <input
          id="guestbook-frame-color-picker"
          class="gb-color-picker"
          type="color"
          value="<%= settings.frame_color || '#7A6855' %>"
          aria-label="Rahmenfarbe ausw&auml;hlen"
        />
        <span id="guestbook-frame-color-preview" class="gb-color-preview gb-color-preview-swatch" aria-hidden="true"></span>
        <button type="button" class="btn btn-secondary gb-color-reset" data-color-reset="guestbook-frame-color">
          Standard
        </button>
      </div>
    </div>

    <div class="gb-color-row">
      <div>
        <span class="gb-editor-subheading">Hintergrundfarbe</span>
        <span class="gb-editor-helptext">Leer = Standard vom gew&auml;hlten Style.</span>
      </div>

      <div class="gb-color-input-wrap">
        <input
          id="guestbook-background-color-text"
          name="background_color"
          value="<%= settings.background_color || '' %>"
          maxlength="7"
          placeholder="#3E3935"
          spellcheck="false"
          autocomplete="off"
        />
        <input
          id="guestbook-background-color-picker"
          class="gb-color-picker"
          type="color"
          value="<%= settings.background_color || '#3E3935' %>"
          aria-label="Hintergrundfarbe ausw&auml;hlen"
        />
        <span
          id="guestbook-background-color-preview"
          class="gb-color-preview gb-color-preview-swatch"
          aria-hidden="true"
        ></span>
        <button type="button" class="btn btn-secondary gb-color-reset" data-color-reset="guestbook-background-color">
          Standard
        </button>
      </div>
    </div>

    <div class="gb-color-row">
      <div>
        <span class="gb-editor-subheading">Fl&auml;che hinter dem Rahmen</span>
        <span class="gb-editor-helptext">F&auml;rbt den gro&szlig;en Bereich um das G&auml;stebuch, aber nicht den Header oben.</span>
      </div>

      <div class="gb-color-input-wrap">
        <input
          id="guestbook-surround-color-text"
          name="surround_color"
          value="<%= settings.surround_color || '' %>"
          maxlength="7"
          placeholder="#2C2118"
          spellcheck="false"
          autocomplete="off"
        />
        <input
          id="guestbook-surround-color-picker"
          class="gb-color-picker"
          type="color"
          value="<%= settings.surround_color || '#2C2118' %>"
          aria-label="Fl&auml;chenfarbe ausw&auml;hlen"
        />
        <span
          id="guestbook-surround-color-preview"
          class="gb-color-preview gb-color-preview-swatch"
          aria-hidden="true"
        ></span>
        <button type="button" class="btn btn-secondary gb-color-reset" data-color-reset="guestbook-surround-color">
          Standard
        </button>
      </div>
    </div>

    <label>
      Font
      <select name="font_style">
        <% (guestbookFontOptions || []).forEach((fontOption) => { %>
          <option value="<%= fontOption.id %>" <%= settings.font_style === fontOption.id ? "selected" : "" %>>
            <%= fontOption.label %>
          </option>
        <% }) %>
      </select>
    </label>

    <label>
      Tags
      <input name="tags" maxlength="500" value="<%= settings.tags %>" />
    </label>

    <p class="gb-editor-link-row">
      <a
        class="gb-editor-text-link"
        href="https://heldenhaftereisen.net/help/gaestebuch-design-bbcode"
        target="_blank"
        rel="noopener noreferrer"
      >
        BBCode Hilfe
      </a>
    </p>

    <label>
      Seiteninhalt (BBCode)
      <textarea name="page_content" rows="12" maxlength="12000"><%= activePage.content %></textarea>
    </label>
  </form>
</section>

<script>
  (() => {
    const censorRadios = Array.from(document.querySelectorAll('input[name="censor_level"]'));

    censorRadios.forEach((radio) => {
      radio.addEventListener("pointerdown", () => {
        radio.dataset.wasChecked = radio.checked ? "1" : "";
      });

      radio.addEventListener("keydown", (event) => {
        if (event.key === " " || event.key === "Spacebar" || event.key === "Enter") {
          radio.dataset.wasChecked = radio.checked ? "1" : "";
        }
      });

      radio.addEventListener("click", () => {
        if (radio.dataset.wasChecked === "1") {
          window.requestAnimationFrame(() => {
            radio.checked = true;
          });
        }
        delete radio.dataset.wasChecked;
      });
    });

    const normalizeHexColor = (value) => {
      const normalized = String(value || "").trim().toUpperCase();
      return /^#[0-9A-F]{6}$/.test(normalized) ? normalized : "";
    };

    const bindColorField = (key, defaultColor) => {
      const textInput = document.getElementById(`${key}-text`);
      const pickerInput = document.getElementById(`${key}-picker`);
      const preview = document.getElementById(`${key}-preview`);
      const resetButton = document.querySelector(`[data-color-reset="${key}"]`);

      if (!textInput || !pickerInput || !preview || !resetButton) {
        return;
      }

      const renderColor = (value, force = false) => {
        const normalized = normalizeHexColor(value);
        if (force) {
          textInput.value = normalized || "";
        }
        if (normalized) {
          pickerInput.value = normalized.toLowerCase();
        } else {
          pickerInput.value = defaultColor.toLowerCase();
        }
        preview.style.backgroundColor = normalized || defaultColor;
        preview.style.opacity = normalized ? "1" : "0.42";
      };

      renderColor(textInput.value, true);

      textInput.addEventListener("input", () => {
        renderColor(textInput.value, false);
      });

      textInput.addEventListener("blur", () => {
        renderColor(textInput.value, true);
      });

      pickerInput.addEventListener("input", () => {
        textInput.value = pickerInput.value.toUpperCase();
        renderColor(textInput.value, true);
      });

      resetButton.addEventListener("click", () => {
        renderColor("", true);
      });
    };

    bindColorField("guestbook-frame-color", "#7A6855");
    bindColorField("guestbook-background-color", "#3E3935");
    bindColorField("guestbook-surround-color", "#2C2118");
  })();
</script>

<%- include("partials/end") %>
