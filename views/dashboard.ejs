<%- include("partials/start") %>

<section class="header-line dashboard-page-header">
  <div>
    <h1>DASHBOARD - SERVER&Uuml;BERSICHT</h1>
    <p class="muted">Deine Charaktere, Bereiche und n&auml;chsten Welten auf einen Blick.</p>
  </div>
  <div class="dashboard-server-actions">
    <% if (currentUser && currentUser.is_admin) { %>
      <a class="btn btn-secondary dashboard-admin-btn" href="/admin">Admin Panel</a>
    <% } %>
    <a class="btn btn-secondary" href="/help" target="_blank" rel="noopener noreferrer">Hilfe</a>
    <button
      type="button"
      class="btn btn-secondary dashboard-delete-btn"
      id="account-delete-open"
      aria-haspopup="dialog"
      aria-controls="account-delete-modal"
    >
      Account l&ouml;schen
    </button>
  </div>
</section>

<section class="dashboard-block dashboard-accordion-stack">
  <details class="dashboard-accordion">
    <summary class="dashboard-accordion-summary">
      <div class="dashboard-accordion-copy">
        <h2>Rollenspiel</h2>
        <p class="muted">Hier liegen deine laufenden Charaktere f&uuml;r beide RP-Bereiche.</p>
      </div>
      <span class="dashboard-accordion-icon" aria-hidden="true"></span>
    </summary>

    <div class="dashboard-accordion-body">
      <div class="dashboard-server-list">
        <% serverSections.forEach((section) => { %>
          <section class="panel dashboard-server-panel dashboard-subpanel">
            <div class="header-line">
              <div>
                <h3><%= section.dashboard_label || section.label %></h3>
                <p class="muted dashboard-section-copy"><%= section.dashboard_caption %></p>
              </div>
              <div class="dashboard-server-actions">
                <a class="btn" href="/characters/new?server=<%= section.id %>">+ Charakter</a>
              </div>
            </div>

            <% if (!section.characters.length) { %>
              <p class="muted">Noch keine Charaktere im Bereich <%= section.dashboard_label || section.label %>.</p>
            <% } else { %>
              <div class="character-mini-grid">
                <% section.characters.forEach((char) => { %>
                  <article class="character-mini-card">
                    <a class="character-mini-item" href="/characters/<%= char.id %>" title="<%= char.name %>">
                      <span class="character-mini-name"><%= char.name %></span>
                    </a>
                    <div class="character-mini-actions">
                      <form
                        method="POST"
                        action="/characters/<%= char.id %>/move"
                        class="character-mini-move-form"
                        onsubmit="return confirm('Charakter auf <%= char.server_id === \"free-rp\" ? \"ERP\" : \"FREE-RP\" %> verschieben?')"
                      >
                        <button
                          type="submit"
                          class="character-mini-move-btn"
                          aria-label="Charakter verschieben"
                          title="<%= char.server_id === 'free-rp' ? 'Nach ERP verschieben' : 'Nach FREE-RP verschieben' %>"
                        >
                          <%= char.server_id === "free-rp" ? "\u2192" : "\u2190" %>
                        </button>
                      </form>
                      <form
                        method="POST"
                        action="/characters/<%= char.id %>/delete"
                        class="character-mini-delete-form"
                        onsubmit="return confirm('Charakter wirklich l&ouml;schen?')"
                      >
                        <button
                          type="submit"
                          class="character-mini-delete-btn"
                          aria-label="Charakter l&ouml;schen"
                          title="Charakter l&ouml;schen"
                        >
                          X
                        </button>
                      </form>
                    </div>
                  </article>
                <% }) %>
              </div>
            <% } %>
          </section>
        <% }) %>
      </div>
    </div>
  </details>

  <details class="dashboard-accordion dashboard-larp-accordion">
    <summary class="dashboard-accordion-summary">
      <div class="dashboard-accordion-copy">
        <h2>LARP BEREICH</h2>
        <p class="muted"><%= larpSection.description %></p>
      </div>
      <span class="dashboard-accordion-icon" aria-hidden="true"></span>
    </summary>

    <div class="dashboard-accordion-body">
      <section class="panel dashboard-larp-panel dashboard-subpanel">
        <div class="dashboard-larp-orb" aria-hidden="true"></div>
        <div class="dashboard-larp-copy">
          <span class="dashboard-status-pill">In Planung</span>
          <h3>Wegmarken f&uuml;r deine n&auml;chste Reise</h3>
          <p class="muted"><%= larpSection.note %></p>
        </div>
      </section>
    </div>
  </details>
</section>

<%- include("partials/end") %>
