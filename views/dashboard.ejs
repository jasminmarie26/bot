<%- include("partials/start") %>

<section class="header-line dashboard-page-header">
  <div>
    <h1>Dashboard</h1>
    <p class="muted">Deine Charaktere, Bereiche und nächsten Welten auf einen Blick.</p>
  </div>
  <div class="dashboard-server-actions">
    <% if (currentUser && currentUser.is_admin) { %>
      <a class="btn btn-secondary dashboard-admin-btn" href="/admin">Admin Panel</a>
    <% } %>
    <button
      type="button"
      class="btn btn-secondary dashboard-delete-btn"
      id="account-delete-open"
      aria-haspopup="dialog"
      aria-controls="account-delete-modal"
    >
      Account löschen
    </button>
  </div>
</section>

<section class="dashboard-block">
  <div class="dashboard-block-head">
    <span class="dashboard-kicker">RP-Server</span>
    <h2>Free - RP & ERP</h2>
    <p class="muted">Hier liegen deine laufenden Charaktere für beide RP-Bereiche.</p>
  </div>

  <div class="dashboard-server-list">
    <% serverSections.forEach((section) => { %>
      <section class="panel dashboard-server-panel">
        <div class="header-line">
          <div>
            <h3><%= section.dashboard_label || section.label %></h3>
            <p class="muted dashboard-section-copy"><%= section.dashboard_caption %></p>
          </div>
          <div class="dashboard-server-actions">
            <a class="btn" href="/characters/new?server=<%= section.id %>">+ Charakter</a>
          </div>
        </div>

        <% if (!section.characters.length) { %>
          <p class="muted">Noch keine Charaktere im Bereich <%= section.dashboard_label || section.label %>.</p>
        <% } else { %>
          <div class="character-mini-grid">
            <% section.characters.forEach((char) => { %>
              <a class="character-mini-item" href="/characters/<%= char.id %>" title="<%= char.name %>">
                <span class="character-mini-name"><%= char.name %></span>
                <% if (char.festplay_name) { %>
                  <span class="character-mini-meta"><%= char.festplay_name %></span>
                <% } %>
              </a>
            <% }) %>
          </div>
        <% } %>
      </section>
    <% }) %>
  </div>
</section>

<section class="dashboard-block dashboard-larp-block">
  <div class="dashboard-block-head">
    <span class="dashboard-kicker">LARP-Bereich</span>
    <h2><%= larpSection.title %></h2>
    <p class="muted"><%= larpSection.description %></p>
  </div>

  <section class="panel dashboard-larp-panel">
    <div class="dashboard-larp-orb" aria-hidden="true"></div>
    <div class="dashboard-larp-copy">
      <span class="dashboard-status-pill">In Planung</span>
      <h3>Wegmarken für deine nächste Reise</h3>
      <p class="muted"><%= larpSection.note %></p>
    </div>
  </section>
</section>

<%- include("partials/end") %>
