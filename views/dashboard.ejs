<section class="header-line dashboard-page-header">
  <div>
    <h1>W&auml;hle einen Bereich</h1>
    <p class="muted">Von hier aus &ouml;ffnest du Free RP, Erotik oder sp&auml;ter den LARP-Bereich.</p>
  </div>
  <div class="dashboard-server-actions">
    <a class="btn btn-secondary" href="/help" target="_blank" rel="noopener noreferrer">Hilfe</a>
    <button
      type="button"
      class="btn btn-secondary dashboard-delete-btn"
      id="account-delete-open"
      aria-haspopup="dialog"
      aria-controls="account-delete-modal"
    >
      Account l&ouml;schen
    </button>
  </div>
</section>

<section class="dashboard-block dashboard-area-grid" aria-label="Bereichsauswahl">
  <% serverSections.forEach((section) => { %>
    <a
      class="panel dashboard-area-card"
      href="/dashboard/areas/<%= section.id %>"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span class="dashboard-area-kicker"><%= section.id === "free-rp" ? "Free RP" : "Erotik" %></span>
      <h2><%= section.dashboard_area_title %></h2>
      <p class="muted"><%= section.dashboard_card_caption %></p>
      <div class="dashboard-area-meta">
        <span class="dashboard-area-pill"><%= section.characters.length %> Charaktere</span>
        <span class="dashboard-area-pill"><%= section.festplays.length %> Festspiele</span>
      </div>
      <span class="dashboard-area-arrow" aria-hidden="true">&rarr;</span>
    </a>
  <% }) %>

  <section class="panel dashboard-area-card dashboard-area-card-disabled" aria-label="LARP Bereich">
    <span class="dashboard-area-kicker">In Planung</span>
    <h2><%= larpSection.title %></h2>
    <p class="muted"><%= larpSection.description %></p>
    <div class="dashboard-area-meta">
      <span class="dashboard-area-pill">Noch nicht offen</span>
    </div>
  </section>
</section>
