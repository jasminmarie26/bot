<%- include("partials/start") %>

<section class="header-line">
  <div>
    <h1>Dashboard</h1>
  </div>
</section>

<div class="dashboard-server-list">
  <% serverSections.forEach((section) => { %>
    <section class="panel">
      <div class="header-line">
        <div>
          <h2><%= section.label %></h2>
        </div>
        <div class="dashboard-server-actions">
          <a class="btn" href="/characters/new?server=<%= section.id %>">+ Charakter</a>
        </div>
      </div>

      <% if (!section.characters.length) { %>
        <p class="muted">Noch keine Charaktere im <%= section.label %>-Server.</p>
      <% } else { %>
        <div class="character-mini-grid">
          <% section.characters.forEach((char) => { %>
            <a class="character-mini-item" href="/characters/<%= char.id %>" title="<%= char.name %>">
              <span class="character-mini-name"><%= char.name %></span>
            </a>
          <% }) %>
        </div>
      <% } %>
    </section>
  <% }) %>

  <section class="panel">
    <h2>Account loeschen</h2>
    <p class="muted">
      Dieser Schritt ist dauerhaft. Dein Account und alle dazugehoerigen Daten
      (Charaktere, Rooms, Eintraege) werden unwiderruflich entfernt.
    </p>

    <form method="POST" action="/account/delete" class="form">
      <label>
        Username zur Bestaetigung
        <input
          name="confirm_username"
          required
          maxlength="24"
          autocomplete="off"
          placeholder="<%= currentUser.username %>"
        />
      </label>
      <label>
        Passwort
        <input type="password" name="password" required minlength="6" autocomplete="current-password" />
      </label>
      <button type="submit" class="btn btn-danger">Account endgueltig loeschen</button>
    </form>
  </section>
</div>

<%- include("partials/end") %>

