<%- include("partials/start") %>

<section class="header-line dashboard-page-header">
  <div>
    <h1>Serverliste</h1>
    <p class="muted">Hier &ouml;ffnest du Free RP oder Erotik direkt im selben Fenster.</p>
  </div>
</section>

<section class="dashboard-block dashboard-accordion-stack">
  <details class="dashboard-accordion" open>
    <summary class="dashboard-accordion-summary">
      <div class="dashboard-accordion-copy">
        <h2>Rollenspiel</h2>
        <p class="muted">W&auml;hle Free RP oder Erotik. Die jeweilige &Uuml;bersicht &ouml;ffnet sich direkt im selben Fenster.</p>
      </div>
      <span class="dashboard-accordion-icon" aria-hidden="true"></span>
    </summary>

    <div class="dashboard-accordion-body">
      <div class="dashboard-role-switch" aria-label="Rollenspiel-Bereiche">
        <% serverSections.forEach((section) => { %>
          <a
            class="dashboard-role-link"
            href="/dashboard/areas/<%= section.id %>"
          >
            <span class="dashboard-role-tab-title"><%= section.dashboard_area_title %></span>
          </a>
        <% }) %>
      </div>
    </div>
  </details>

  <details class="dashboard-accordion dashboard-larp-accordion">
    <summary class="dashboard-accordion-summary">
      <div class="dashboard-accordion-copy">
        <h2>LARP BEREICH</h2>
        <p class="muted"><%= larpSection.description %></p>
      </div>
      <span class="dashboard-accordion-icon" aria-hidden="true"></span>
    </summary>

    <div class="dashboard-accordion-body">
      <div class="dashboard-larp-preview">
        <section class="panel dashboard-larp-hero dashboard-subpanel">
          <div class="dashboard-larp-hero-copy">
            <span class="dashboard-status-pill"><%= larpSection.intro_badge %></span>
            <h3><%= larpSection.hero_title %></h3>
            <p class="muted"><%= larpSection.hero_text %></p>
          </div>

          <div class="dashboard-larp-hero-actions">
            <a class="btn" href="<%= larpSection.cta_href %>"><%= larpSection.cta_label %></a>
            <span class="dashboard-status-pill is-soft">Eigener Zugang</span>
          </div>

          <div class="dashboard-larp-stat-grid">
            <% (Array.isArray(larpSection.stats) ? larpSection.stats : []).forEach((stat) => { %>
              <article class="dashboard-larp-stat-card">
                <strong><%= stat.value %></strong>
                <span><%= stat.label %></span>
                <p><%= stat.note %></p>
              </article>
            <% }) %>
          </div>
        </section>

        <%- include("partials/larp-forum-categories", { larpSection, compactView: true }) %>
      </div>
    </div>
  </details>
</section>

<%- include("partials/end") %>
