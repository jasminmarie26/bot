<%- include("../partials/start") %>

<% const dashboardAreaReturnTarget = `/dashboard/areas/${serverSection.id}`; %>

<section class="header-line serverlist-page-header">
  <div>
    <span class="serverlist-kicker">Rollenspiel</span>
    <h1><%= serverSection.dashboard_area_title %></h1>
    <p class="muted"><%= serverSection.dashboard_area_description %></p>
  </div>
  <div class="serverlist-actions">
    <a
      class="btn serverlist-add-character-btn"
      href="/characters/new?server=<%= serverSection.id %>&return_to=<%= encodeURIComponent(dashboardAreaReturnTarget) %>"
      aria-label="Charakter hinzufügen"
      title="Charakter hinzufügen"
    >
      +
    </a>
    <form
      method="POST"
      action="/dashboard/areas/<%= serverSection.id %>/guestbook-code-email"
      class="serverlist-export-all-form"
    >
      <input type="hidden" name="return_to" value="/dashboard/areas/<%= serverSection.id %>">
      <button
        type="submit"
        class="btn serverlist-add-character-btn serverlist-export-all-btn"
        aria-label="Gästebücher per E-Mail senden"
        title="Gästebücher per E-Mail senden"
      >
        &#10003;
      </button>
    </form>
  </div>
</section>

<section class="serverlist-block">
  <details class="serverlist-festplay-overview serverlist-character-overview" open>
    <summary class="serverlist-festplay-overview-header">
      <div class="serverlist-festplay-overview-title">
        <h3>Meine Charaktere</h3>
        <span class="serverlist-festplay-count">(<%= serverSection.characters.length %>)</span>
      </div>
      <span class="serverlist-festplay-toggle-icon" aria-hidden="true"></span>
    </summary>

    <div class="serverlist-panel serverlist-character-overview-body">
      <% if (!serverSection.characters.length) { %>
        <p class="muted">
          <%= serverSection.festplays && serverSection.festplays.length
            ? `Keine freien Charaktere direkt im Bereich ${serverSection.dashboard_label || serverSection.label}. Festspiel-Charaktere sind darunter untergliedert.`
            : `Noch keine Charaktere im Bereich ${serverSection.dashboard_label || serverSection.label}.` %>
        </p>
      <% } else { %>
        <div class="character-mini-grid">
          <% serverSection.characters.forEach((char) => { %>
            <article class="character-mini-card">
              <a class="character-mini-item" href="/characters/<%= char.id %>" title="<%= char.name %>">
                <span class="character-mini-name"><%= char.name %></span>
              </a>
              <div class="character-mini-actions">
                <a
                  class="character-mini-guestbook-open-link"
                  href="/characters/<%= char.id %>/guestbook"
                  aria-label="G&auml;stebuch &ouml;ffnen"
                  title="G&auml;stebuch &ouml;ffnen"
                >
                  <span class="character-mini-guestbook-open-icon" aria-hidden="true"></span>
                </a>
                <a
                  class="character-mini-guestbook-edit-link"
                  href="/characters/<%= char.id %>/guestbook/edit"
                  aria-label="G&auml;stebuch bearbeiten"
                  title="G&auml;stebuch bearbeiten"
                >
                  <span class="character-mini-guestbook-edit-icon" aria-hidden="true"></span>
                </a>
                <% if (char.can_dashboard_move) { %>
                  <form
                    method="POST"
                    action="/characters/<%= char.id %>/move"
                    class="character-mini-move-form"
                    data-serverlist-area-move-confirm
                    data-serverlist-character-name="<%= char.name %>"
                    data-serverlist-current-server="<%= char.server_id %>"
                    data-serverlist-home-server="<%= char.festplay_home_server_id || "" %>"
                    data-serverlist-position="<%= char.dashboard_position || "main" %>"
                  >
                    <input type="hidden" name="return_to" value="/dashboard/areas/<%= serverSection.id %>">
                    <input type="hidden" name="target_server_id" value="">
                    <input type="hidden" name="target_dashboard_mode" value="">
                    <button
                      type="submit"
                      class="character-mini-move-btn"
                      aria-label="Charakter verschieben"
                      title="Zielserver auswählen"
                    >
                      &harr;
                    </button>
                  </form>
                <% } %>
                <form
                  method="POST"
                  action="/characters/<%= char.id %>/guestbook-code-email"
                  class="character-mini-export-form"
                >
                  <input type="hidden" name="return_to" value="/dashboard/areas/<%= serverSection.id %>">
                  <button
                    type="submit"
                    class="character-mini-export-btn"
                    aria-label="Gästebuch-Code per E-Mail senden"
                    title="Gästebuch-Code per E-Mail senden"
                  >
                    <span class="character-mini-export-icon" aria-hidden="true"></span>
                  </button>
                </form>
                <form
                  method="POST"
                  action="/characters/<%= char.id %>/delete"
                  class="character-mini-delete-form"
                  onsubmit="return confirm('Charakter wirklich löschen?')"
                >
                  <input type="hidden" name="return_to" value="<%= dashboardAreaReturnTarget %>">
                  <button
                    type="submit"
                    class="character-mini-delete-btn"
                    aria-label="Charakter löschen"
                    title="Charakter löschen"
                  >
                    X
                  </button>
                </form>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  </details>

  <% if (serverSection.festplays && serverSection.festplays.length) { %>
    <details class="serverlist-festplay-overview" open>
      <summary class="serverlist-festplay-overview-header">
        <div class="serverlist-festplay-overview-title">
          <h3>Meine Festspiele</h3>
          <span class="serverlist-festplay-count">(<%= serverSection.festplays.length %>)</span>
        </div>
        <span class="serverlist-festplay-toggle-icon" aria-hidden="true"></span>
      </summary>

      <div class="serverlist-festplay-stack">
        <% serverSection.festplays.forEach((festplay) => { %>
          <section class="panel serverlist-panel serverlist-festplay-panel serverlist-subpanel">
            <div class="header-line">
              <div>
                <h3><%= festplay.name %></h3>
                <p class="muted serverlist-section-copy">
                  <%= festplay.caption || "Festspiel auf diesem Bereich." %>
                </p>
              </div>
            </div>

            <div class="character-mini-grid">
              <% festplay.characters.forEach((char) => { %>
                <% const currentServerId = char.current_server_id || serverSection.id; %>
                <% const isInFestplayArea = Boolean(char.is_in_festplay_area); %>
                <% const isOnCurrentServer = currentServerId === serverSection.id; %>
                <% const currentLocationLabel = isOnCurrentServer
                  ? (serverSection.dashboard_label || serverSection.label)
                  : (char.current_server_label || serverSection.dashboard_label || serverSection.label); %>
                <article class="character-mini-card<%= isInFestplayArea ? "" : " is-festplay-ghost" %>">
                  <% if (isInFestplayArea) { %>
                    <a
                      class="character-mini-item"
                      href="/characters/<%= char.id %>/festplays/<%= festplay.id %>/rooms"
                      title="Festspiel-Räume mit <%= char.name %> öffnen"
                    >
                      <span class="character-mini-name"><%= char.name %></span>
                    </a>
                  <% } else { %>
                    <span
                      class="character-mini-placeholder"
                      title="<%= isOnCurrentServer
                        ? `${char.name} liegt aktuell oben in ${currentLocationLabel}.`
                        : `${char.name} ist aktuell auf ${currentLocationLabel}.` %>"
                    >
                      <span class="character-mini-name"><%= char.name %></span>
                    </span>
                  <% } %>
                  <div class="character-mini-actions">
                    <a
                      class="character-mini-guestbook-open-link"
                      href="/characters/<%= char.id %>/guestbook"
                      aria-label="G&auml;stebuch &ouml;ffnen"
                      title="G&auml;stebuch &ouml;ffnen"
                    >
                      <span class="character-mini-guestbook-open-icon" aria-hidden="true"></span>
                    </a>
                    <a
                      class="character-mini-guestbook-edit-link"
                      href="/characters/<%= char.id %>/guestbook/edit"
                      aria-label="G&auml;stebuch bearbeiten"
                      title="G&auml;stebuch bearbeiten"
                    >
                      <span class="character-mini-guestbook-edit-icon" aria-hidden="true"></span>
                    </a>
                    <form
                      method="POST"
                      action="/characters/<%= char.id %>/move"
                      class="character-mini-move-form"
                      data-serverlist-area-move-confirm
                      data-serverlist-character-name="<%= char.name %>"
                      data-serverlist-current-server="<%= currentServerId %>"
                      data-serverlist-home-server="<%= serverSection.id %>"
                      data-serverlist-position="<%= char.dashboard_position || "main" %>"
                    >
                      <input type="hidden" name="return_to" value="/dashboard/areas/<%= serverSection.id %>">
                      <input type="hidden" name="target_server_id" value="">
                      <input type="hidden" name="target_dashboard_mode" value="">
                      <button
                        type="submit"
                        class="character-mini-move-btn"
                        aria-label="Charakter verschieben"
                        title="Zielserver auswählen"
                      >
                        &harr;
                      </button>
                    </form>
                    <form
                      method="POST"
                      action="/characters/<%= char.id %>/guestbook-code-email"
                      class="character-mini-export-form"
                    >
                      <input type="hidden" name="return_to" value="/dashboard/areas/<%= serverSection.id %>">
                      <button
                        type="submit"
                        class="character-mini-export-btn"
                        aria-label="Gästebuch-Code per E-Mail senden"
                        title="Gästebuch-Code per E-Mail senden"
                      >
                        <span class="character-mini-export-icon" aria-hidden="true"></span>
                      </button>
                    </form>
                    <% if (isInFestplayArea) { %>
                      <form
                        method="POST"
                        action="/characters/<%= char.id %>/delete"
                        class="character-mini-delete-form"
                        onsubmit="return confirm('Charakter wirklich löschen?')"
                      >
                        <input type="hidden" name="return_to" value="<%= dashboardAreaReturnTarget %>">
                        <button
                          type="submit"
                          class="character-mini-delete-btn"
                          aria-label="Charakter löschen"
                          title="Charakter löschen"
                        >
                          X
                        </button>
                      </form>
                    <% } %>
                  </div>
                </article>
              <% }) %>
            </div>
          </section>
        <% }) %>
      </div>
    </details>
  <% } %>
</section>

<div
  id="serverlist-area-move-modal"
  class="serverlist-confirm-modal"
  data-erp-move-allowed="<%= erpMoveAllowed ? "true" : "false" %>"
  hidden
>
  <div class="serverlist-confirm-backdrop" data-serverlist-area-close></div>
  <section
    class="serverlist-confirm-card panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="serverlist-area-move-title"
  >
    <h2 id="serverlist-area-move-title">Charakter verschieben</h2>
    <p class="muted serverlist-confirm-note">
      Freischaltungen an Festspielen bleiben dabei erhalten.
    </p>
    <div class="serverlist-confirm-actions">
      <button type="button" class="btn btn-secondary" data-serverlist-area-close>
        Abbrechen
      </button>
      <button type="button" class="btn btn-secondary" id="serverlist-area-move-free">
        Free RP
      </button>
      <button type="button" class="btn" id="serverlist-area-move-erp">
        ERP
      </button>
    </div>
  </section>
</div>

<%- include("../partials/end") %>
