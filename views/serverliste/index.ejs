<%- include("../partials/start") %>

<% const larpStatusLabel = "Verfuegbar fuer alle"; %>
<% const larpActionLabel = "LARP-Bereich oeffnen"; %>
<% const larpAccessNote = "Im LARP-Bereich nutzt jeder Account nur einen Zugangsname, nicht wie im RP Bereich mehrere Charaktere. Das LARP-Forum ist fuer alle verfuegbar."; %>

<section class="header-line serverlist-page-header">
  <div>
    <h1>Serverliste</h1>
    <p class="muted">Hier oeffnest du Free RP oder Erotik direkt im selben Fenster.</p>
  </div>
</section>

<section class="serverlist-block serverlist-accordion-stack">
  <details class="serverlist-accordion" <%= openLarpSection ? "" : "open" %>>
    <summary class="serverlist-accordion-summary">
      <div class="serverlist-accordion-copy">
        <h2>Rollenspiel</h2>
        <p class="muted">Waehle Free RP oder Erotik. Die jeweilige Uebersicht oeffnet sich direkt im selben Fenster.</p>
      </div>
      <span class="serverlist-accordion-icon" aria-hidden="true"></span>
    </summary>

    <div class="serverlist-accordion-body">
      <div class="serverlist-role-switch" aria-label="Rollenspiel-Bereiche">
        <% serverSections.forEach((section) => { %>
          <a
            class="serverlist-role-link"
            href="/dashboard/areas/<%= section.id %>"
          >
            <span class="serverlist-role-tab-title"><%= section.dashboard_area_title %></span>
          </a>
        <% }) %>
      </div>
    </div>
  </details>

  <details class="serverlist-accordion" <%= openLarpSection ? "open" : "" %>>
    <summary class="serverlist-accordion-summary">
      <div class="serverlist-accordion-copy">
        <h2>LARP BEREICH</h2>
        <p class="muted"><%= larpSection.description %></p>
      </div>
      <span class="serverlist-accordion-icon" aria-hidden="true"></span>
    </summary>

    <div class="serverlist-accordion-body">
      <section class="panel serverlist-larp-panel serverlist-subpanel">
        <div class="serverlist-larp-orb" aria-hidden="true"></div>
        <div class="serverlist-larp-copy">
          <span class="serverlist-status-pill"><%= larpStatusLabel %></span>
          <p class="muted"><%= larpAccessNote %></p>

          <div class="serverlist-larp-actions">
            <a class="btn btn-secondary" href="/dashboard/larp">
              <%= larpActionLabel %>
            </a>
          </div>
        </div>
      </section>
    </div>
  </details>
</section>

<%- include("../partials/end") %>
