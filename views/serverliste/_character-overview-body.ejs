<section class="serverlist-block">
  <div class="serverlist-overview-grid" data-erp-move-allowed="<%= erpMoveAllowed ? "true" : "false" %>">
    <% overviewSections.forEach((section) => { %>
      <% const isFestplaySection = section.id === "festspiele"; %>
      <% const canCreateInOverviewSection = !isFestplaySection && (section.id !== "erp" || erpMoveAllowed); %>
      <details
        class="serverlist-festplay-overview serverlist-overview-column<%= isFestplaySection ? " serverlist-overview-column-wide" : "" %>"
        <%= isFestplaySection ? "" : `data-serverlist-drop-zone data-serverlist-server-id="${section.id}" data-serverlist-server-label="${section.overview_title}"` %>
        data-serverlist-exclusive-section="serverlist-overview"
        name="serverlist-overview"
        <%= section.id === "free-rp" ? "open" : "" %>
      >
        <summary class="serverlist-festplay-overview-header serverlist-overview-column-header">
          <div class="serverlist-festplay-overview-title">
            <h3><%= section.overview_title %></h3>
            <span class="serverlist-festplay-count">(<%= section.characters.length %>)</span>
          </div>
          <div class="serverlist-overview-header-actions">
            <% if (canCreateInOverviewSection) { %>
              <a
                class="btn serverlist-add-character-btn"
                href="/characters/new?server=<%= section.id %>&return_to=<%= encodeURIComponent(dashboardOverviewReturnTarget) %>"
                aria-label="Charakter in <%= section.overview_title %> hinzuf&uuml;gen"
                title="Charakter in <%= section.overview_title %> hinzuf&uuml;gen"
              >
                +
              </a>
            <% } else { %>
              <button
                type="button"
                class="btn serverlist-add-character-btn"
                aria-label="ERP erst ab 18 Jahren verf&uuml;gbar"
                title="ERP ist erst ab 18 Jahren verf&uuml;gbar"
                disabled
              >
                +
              </button>
            <% } %>
            <span class="serverlist-festplay-toggle-icon" aria-hidden="true"></span>
          </div>
        </summary>

        <div class="serverlist-panel serverlist-character-overview-body serverlist-overview-column-body">
          <p class="muted serverlist-section-copy"><%= section.overview_description %></p>

          <% if (isFestplaySection) { %>
            <div class="serverlist-overview-grid serverlist-overview-nested-grid">
              <% (section.festplay_groups || []).forEach((group) => { %>
                <section class="serverlist-overview-subcolumn">
                  <section class="panel serverlist-panel serverlist-festplay-panel serverlist-subpanel serverlist-overview-subcolumn-box">
                    <div class="serverlist-overview-subcolumn-header">
                      <h4><%= group.overview_short_title %></h4>
                      <span class="serverlist-festplay-count">(<%= group.characters.length %>)</span>
                    </div>
                    <p class="muted serverlist-section-copy"><%= group.overview_description %></p>

                    <% if (!group.characters.length) { %>
                      <p class="muted">Noch keine Festspiel-Charaktere in <%= group.overview_short_title %>.</p>
                    <% } else { %>
                      <div class="character-mini-grid serverlist-overview-character-grid">
                      <% group.characters.forEach((char) => { %>
                        <% const isInFestplayArea = Boolean(char.is_in_festplay_area); %>
                        <article
                          class="character-mini-card serverlist-overview-character-card<%= isInFestplayArea ? "" : " is-festplay-ghost" %>"
                          data-serverlist-draggable-character
                          data-serverlist-character-id="<%= char.id %>"
                        >
                          <span
                            class="serverlist-drag-handle"
                            draggable="true"
                            data-serverlist-drag-handle
                            aria-label="Charakter per Drag &amp; Drop zuordnen"
                            title="Charakter per Drag &amp; Drop zuordnen"
                          ></span>
                          <% if (isInFestplayArea) { %>
                            <a
                              class="character-mini-item"
                              href="/chat/rooms?c=<%= encodeURIComponent(String(char.chat_character_url_number || char.id)) %>"
                              title="Mit <%= char.name %> zur Raum&uuml;bersicht"
                              draggable="false"
                            >
                              <span class="character-mini-name"><%= char.name %></span>
                              <span class="serverlist-character-state"><%= group.overview_short_title %></span>
                            </a>
                          <% } else { %>
                            <span
                              class="character-mini-placeholder"
                              title="<%= `${char.name} liegt aktuell oben auf ${char.server_id === "erp" ? "ERP" : "Free RP"}.` %>"
                            >
                              <span class="character-mini-name"><%= char.name %></span>
                              <span class="serverlist-character-state"><%= char.server_id === "erp" ? "ERP" : "Free RP" %></span>
                            </span>
                          <% } %>
                          <div class="character-mini-actions">
                            <a
                              class="character-mini-guestbook-open-link"
                              href="/characters/<%= char.id %>/guestbook"
                              aria-label="G&auml;stebuch &ouml;ffnen"
                              title="G&auml;stebuch &ouml;ffnen"
                            >
                              <span class="character-mini-guestbook-open-icon" aria-hidden="true"></span>
                            </a>
                            <a
                              class="character-mini-guestbook-edit-link"
                              href="/characters/<%= char.id %>/guestbook/edit"
                              aria-label="G&auml;stebuch bearbeiten"
                              title="G&auml;stebuch bearbeiten"
                            >
                              <span class="character-mini-guestbook-edit-icon" aria-hidden="true"></span>
                            </a>
                            <form
                              method="POST"
                              action="/characters/<%= char.id %>/move"
                              class="character-mini-move-form serverlist-overview-move-form"
                              data-serverlist-area-move-confirm
                              data-serverlist-character-name="<%= char.name %>"
                              data-serverlist-current-server="<%= char.server_id %>"
                              data-serverlist-home-server="<%= char.festplay_home_server_id || "" %>"
                              data-serverlist-position="<%= char.dashboard_position || "main" %>"
                              hidden
                            >
                              <input type="hidden" name="return_to" value="<%= dashboardOverviewReturnTarget %>">
                              <input type="hidden" name="target_server_id" value="">
                              <input type="hidden" name="target_dashboard_mode" value="">
                            </form>
                            <button
                              type="button"
                              class="character-mini-move-btn serverlist-overview-move-trigger"
                              data-serverlist-overview-move-trigger
                              aria-label="Charakter verschieben"
                              title="Ziel ausw&auml;hlen"
                            >
                              &harr;
                            </button>
                            <form
                              method="POST"
                              action="/characters/<%= char.id %>/guestbook-code-email"
                              class="character-mini-export-form"
                            >
                              <input type="hidden" name="return_to" value="<%= dashboardOverviewReturnTarget %>">
                              <button
                                type="submit"
                                class="character-mini-export-btn"
                                aria-label="G&auml;stebuch-Code per E-Mail senden"
                                title="G&auml;stebuch-Code per E-Mail senden"
                              >
                                <span class="character-mini-export-icon" aria-hidden="true"></span>
                              </button>
                            </form>
                            <form
                              method="POST"
                              action="/characters/<%= char.id %>/delete"
                              class="character-mini-delete-form"
                              onsubmit="return confirm('Charakter wirklich l&ouml;schen?')"
                            >
                              <input type="hidden" name="return_to" value="<%= dashboardOverviewReturnTarget %>">
                              <button
                                type="submit"
                                class="character-mini-delete-btn"
                                aria-label="Charakter l&ouml;schen"
                                title="Charakter l&ouml;schen"
                              >
                                X
                              </button>
                            </form>
                          </div>
                        </article>
                      <% }) %>
                      </div>
                    <% } %>
                  </section>
                </section>
              <% }) %>
            </div>
          <% } else if (!section.characters.length) { %>
            <p class="muted">Noch keine Charaktere in <%= section.overview_title %>.</p>
          <% } else { %>
            <div class="character-mini-grid serverlist-overview-character-grid">
              <% section.characters.forEach((char) => { %>
                <% const isFestplayCharacter = char.dashboard_position === "festplay"; %>
                <article
                  class="character-mini-card serverlist-overview-character-card"
                  data-serverlist-draggable-character
                  data-serverlist-character-id="<%= char.id %>"
                >
                  <span
                    class="serverlist-drag-handle"
                    draggable="true"
                    data-serverlist-drag-handle
                    aria-label="Charakter per Drag &amp; Drop zuordnen"
                    title="Charakter per Drag &amp; Drop zuordnen"
                  ></span>
                  <a
                    class="character-mini-item"
                    href="/chat/rooms?c=<%= encodeURIComponent(String(char.chat_character_url_number || char.id)) %>"
                    title="Mit <%= char.name %> zur Raum&uuml;bersicht"
                    draggable="false"
                  >
                    <span class="character-mini-name"><%= char.name %></span>
                    <% if (isFestplayCharacter && !isFestplaySection) { %>
                      <span class="serverlist-character-state">Festspiel</span>
                    <% } else if (isFestplaySection) { %>
                      <span class="serverlist-character-state">
                        <%= char.festplay_home_server_label || (char.server_id === "erp" ? "ERP" : "Free RP") %>
                      </span>
                    <% } %>
                  </a>
                  <div class="character-mini-actions">
                    <a
                      class="character-mini-guestbook-open-link"
                      href="/characters/<%= char.id %>/guestbook"
                      aria-label="G&auml;stebuch &ouml;ffnen"
                      title="G&auml;stebuch &ouml;ffnen"
                    >
                      <span class="character-mini-guestbook-open-icon" aria-hidden="true"></span>
                    </a>
                    <a
                      class="character-mini-guestbook-edit-link"
                      href="/characters/<%= char.id %>/guestbook/edit"
                      aria-label="G&auml;stebuch bearbeiten"
                      title="G&auml;stebuch bearbeiten"
                    >
                      <span class="character-mini-guestbook-edit-icon" aria-hidden="true"></span>
                    </a>
                    <form
                      method="POST"
                      action="/characters/<%= char.id %>/move"
                      class="character-mini-move-form serverlist-overview-move-form"
                      data-serverlist-area-move-confirm
                      data-serverlist-character-name="<%= char.name %>"
                      data-serverlist-current-server="<%= char.server_id %>"
                      data-serverlist-home-server="<%= char.festplay_home_server_id || "" %>"
                      data-serverlist-position="<%= char.dashboard_position || "main" %>"
                      hidden
                    >
                      <input type="hidden" name="return_to" value="<%= dashboardOverviewReturnTarget %>">
                      <input type="hidden" name="target_server_id" value="">
                      <input type="hidden" name="target_dashboard_mode" value="">
                    </form>
                    <button
                      type="button"
                      class="character-mini-move-btn serverlist-overview-move-trigger"
                      data-serverlist-overview-move-trigger
                      aria-label="Charakter verschieben"
                      title="Ziel ausw&auml;hlen"
                    >
                      &harr;
                    </button>
                    <form
                      method="POST"
                      action="/characters/<%= char.id %>/guestbook-code-email"
                      class="character-mini-export-form"
                    >
                      <input type="hidden" name="return_to" value="<%= dashboardOverviewReturnTarget %>">
                      <button
                        type="submit"
                        class="character-mini-export-btn"
                        aria-label="G&auml;stebuch-Code per E-Mail senden"
                        title="G&auml;stebuch-Code per E-Mail senden"
                      >
                        <span class="character-mini-export-icon" aria-hidden="true"></span>
                      </button>
                    </form>
                    <form
                      method="POST"
                      action="/characters/<%= char.id %>/delete"
                      class="character-mini-delete-form"
                      onsubmit="return confirm('Charakter wirklich l&ouml;schen?')"
                    >
                      <input type="hidden" name="return_to" value="<%= dashboardOverviewReturnTarget %>">
                      <button
                        type="submit"
                        class="character-mini-delete-btn"
                        aria-label="Charakter l&ouml;schen"
                        title="Charakter l&ouml;schen"
                      >
                        X
                      </button>
                    </form>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } %>
        </div>
      </details>
    <% }) %>
  </div>
</section>
