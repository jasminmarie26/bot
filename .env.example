PORT=3000
SESSION_SECRET=bitte-langes-zufaelliges-geheimnis-eintragen
APP_BASE_URL=https://heldenhaftereisen.net

# SMTP fuer Verifizierungs-Mails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Google OAuth (Gmail Login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional. Leer lassen, dann wird APP_BASE_URL + /auth/google/callback verwendet.
GOOGLE_CALLBACK_URL=

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Optional. Leer lassen, dann wird APP_BASE_URL + /auth/facebook/callback verwendet.
FACEBOOK_CALLBACK_URL=

